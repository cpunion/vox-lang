import "std/testing" as t
import "std/fs" as fs
import "std/time" as tm

fn lock_test_tmp_file(prefix: String) -> String {
  let dir: String = "target/tmp/main_lock_test";
  fs.mkdir_p(dir);
  return dir.concat("/").concat(prefix).concat("_").concat(tm.now_ns().to_string()).concat(".txt");
}

fn test_write_string_if_changed_smoke() -> () {
  let path: String = lock_test_tmp_file("write_if_changed");
  fs.write_string(path, "abc\n");
  t.assert(!write_string_if_changed(path, "abc\n"));
  t.assert_eq(fs.read_to_string(path), "abc\n");

  t.assert(write_string_if_changed(path, "xyz\n"));
  t.assert_eq(fs.read_to_string(path), "xyz\n");
}

fn test_write_string_if_changed_creates_missing_file_smoke() -> () {
  let path: String = lock_test_tmp_file("write_if_changed_create");
  t.assert(!fs.exists(path));
  t.assert(write_string_if_changed(path, "hello\n"));
  t.assert(fs.exists(path));
  t.assert_eq(fs.read_to_string(path), "hello\n");
}

fn test_replace_file_host_from_tmp_smoke() -> () {
  let dst: String = lock_test_tmp_file("replace_tmp_dst");
  let tmp: String = tmp_artifact_path(dst);
  fs.write_string(dst, "old\n");
  fs.write_string(tmp, "new\n");
  t.assert(replace_file_host_from_tmp(tmp, dst, false));
  t.assert_eq(fs.read_to_string(dst), "new\n");
  t.assert(!fs.exists(tmp));
}

fn test_replace_file_host_from_tmp_exe_fallback_smoke() -> () {
  let dst: String = lock_test_tmp_file("replace_tmp_exe_dst");
  let tmp_base: String = tmp_artifact_path(dst);
  let tmp_exe: String = tmp_base.concat(".exe");
  let dst_exe: String = dst.concat(".exe");
  fs.write_string(tmp_exe, "new-exe\n");
  t.assert(replace_file_host_from_tmp(tmp_base, dst, false));
  t.assert_eq(fs.read_to_string(dst_exe), "new-exe\n");
  t.assert(!fs.exists(tmp_exe));
}

fn test_tmp_artifact_path_preserves_extension_smoke() -> () {
  let wasm_tmp: String = tmp_artifact_path("target/debug/demo.wasm");
  let bin_tmp: String = tmp_artifact_path("target/debug/demo.bin");
  t.assert(has_suffix(wasm_tmp, ".wasm"));
  t.assert(has_suffix(bin_tmp, ".bin"));
  t.assert(text_contains(wasm_tmp, ".tmp."));
}

fn test_write_lockfile_from_lock_deps_smoke() -> () {
  let lock_path: String = "vox.lock";
  let original: String = fs.read_to_string(lock_path);
  let mut deps: Vec[LockDep] = Vec();
  deps.push(LockDep {
    name: "demo",
    source: "path",
    path: "/tmp/demo",
    resolved_path: "/tmp/demo",
    git: "",
    rev: "",
    registry: "",
    version: "",
    digest: "123",
  });
  write_lockfile_from_lock_deps(deps);
  let out: String = fs.read_to_string(lock_path);
  t.assert(text_contains(out, "[[dependency]]"));
  t.assert(text_contains(out, "name = \"demo\""));
  t.assert(text_contains(out, "source = \"path\""));
  t.assert(text_contains(out, "resolved_path = \"/tmp/demo\""));
  t.assert(text_contains(out, "digest = \"123\""));
  fs.write_string(lock_path, original);
}
