}

fn dur_nonneg_ns(start: i64, end: i64) -> i64 {
  if end <= start { return 0; }
  return end - start;
}

fn two_digits(v0: i64) -> String {
  let mut v: i64 = v0;
  if v < 0 { v = 0; }
  if v > 99 { v = v % 100; }
  if v < 10 { return "0".concat(v.to_string()); }
  return v.to_string();
}

fn format_duration_ns(ns0: i64) -> String {
  let mut ns: i64 = ns0;
  if ns < 0 { ns = 0; }
  if ns < 1000 { return ns.to_string().concat("ns"); }
  if ns < 1000000 {
    let whole: i64 = ns / 1000;
    let frac: i64 = (ns % 1000) / 10;
    return whole.to_string().concat(".").concat(two_digits(frac)).concat("us");
  }
  if ns < 1000000000 {
    let whole: i64 = ns / 1000000;
    let frac: i64 = (ns % 1000000) / 10000;
    return whole.to_string().concat(".").concat(two_digits(frac)).concat("ms");
  }
  let whole: i64 = ns / 1000000000;
  let frac: i64 = (ns % 1000000000) / 10000000;
  return whole.to_string().concat(".").concat(two_digits(frac)).concat("s");
}

fn env_truthy(raw0: String) -> bool {
  return text_truthy(raw0);
}

fn build_cache_enabled_from_env(raw: String) -> bool {
  return !env_truthy(raw);
}

fn incremental_enabled_from_env(raw0: String) -> bool {
  let raw: String = txt.trim_space(raw0);
  if raw == "" { return true; }
  let s: String = tc_ascii_lower(raw);
  return !(s == "0" || s == "false" || s == "no" || s == "off");
}

fn effective_incremental_cache_enabled(cache_enabled: bool, incremental_enabled: bool) -> bool {
  return cache_enabled && incremental_enabled;
}

fn effective_incremental_query_shadow_enabled(query_shadow_enabled: bool, incremental_enabled: bool) -> bool {
  return query_shadow_enabled && incremental_enabled;
}

fn query_shadow_force_prepare_from_env(raw: String) -> bool {
  return env_truthy(raw);
}

fn effective_query_shadow_force_prepare(query_shadow_on: bool, query_shadow_trace: bool, force_prepare_raw: bool) -> bool {
  return query_shadow_on && query_shadow_trace && force_prepare_raw;
}

struct CacheRuntimeFlags {
  build_cache_enabled: bool,
  incremental_enabled: bool,
  cache_enabled: bool,
  query_shadow_on: bool,
  query_shadow_trace: bool,
  query_shadow_force_prepare: bool,
  cache_trace: bool,
}

fn cache_runtime_flags(trace_exec: bool) -> CacheRuntimeFlags {
  let build_cache_enabled: bool = build_cache_enabled_from_env(osys.getenv("VOX_BUILD_CACHE_DISABLE"));
  let incremental_enabled: bool = incremental_enabled_from_env(osys.getenv("VOX_INCREMENTAL"));
  let cache_enabled: bool = effective_incremental_cache_enabled(build_cache_enabled, incremental_enabled);
  let query_shadow_env_on: bool = env_truthy(osys.getenv("VOX_QUERY_SHADOW"));
  let query_shadow_on: bool = effective_incremental_query_shadow_enabled(query_shadow_env_on, incremental_enabled);
  let query_shadow_trace: bool = query_shadow_on && (trace_exec || env_truthy(osys.getenv("VOX_QUERY_SHADOW_TRACE")));
  let query_shadow_force_prepare_raw: bool = query_shadow_force_prepare_from_env(osys.getenv("VOX_QUERY_SHADOW_FORCE_PREPARE"));
  let query_shadow_force_prepare: bool = effective_query_shadow_force_prepare(query_shadow_on, query_shadow_trace, query_shadow_force_prepare_raw);
  let cache_trace: bool = env_truthy(osys.getenv("VOX_CACHE_TRACE"));
  if cache_trace && query_shadow_on && query_shadow_force_prepare_raw && !query_shadow_trace {
    print("[query-shadow] force-prepare ignored (trace disabled)\n");
  }
  return CacheRuntimeFlags {
    build_cache_enabled: build_cache_enabled,
    incremental_enabled: incremental_enabled,
    cache_enabled: cache_enabled,
    query_shadow_on: query_shadow_on,
    query_shadow_trace: query_shadow_trace,
    query_shadow_force_prepare: query_shadow_force_prepare,
    cache_trace: cache_trace,
  };
}

struct CSourceLoadResult {
  c_sources: Vec[String],
  c_sources_sig: String,
}

fn load_pkg_c_sources_with_optional_sig(need_sig: bool) -> CSourceLoadResult {
  let c_all: Vec[String] = filter_pkg_c_sources(srcw.walk_c_files("."));
  let c_user: Vec[ld.SourceFile] = load_files(c_all);
  let mut c_sources: Vec[String] = Vec();
  let mut i: i32 = 0;
  while i < c_user.len() {
    c_sources.push(c_user.get(i).text);
    i = i + 1;
  }
  if !need_sig {
    return CSourceLoadResult {
      c_sources: c_sources,
      c_sources_sig: "",
    };
  }
  let kept: BuildCacheCSourcesSigKeep = build_cache_c_sources_sig_from_texts_keep(c_sources);
  return CSourceLoadResult {
    c_sources: kept.c_sources,
    c_sources_sig: kept.c_sources_sig,
  };
}

fn build_mode_with_c_sources_sig(mode: String, c_sources_sig: String) -> String {
  return append_build_mode_line(mode, "c_sources_sig=", c_sources_sig);
}

fn should_use_sem_cache(cache_enabled: bool, query_shadow_on: bool) -> bool {
  let _: bool = query_shadow_on;
  return cache_enabled;
}

fn should_skip_query_shadow_prepare(cache_enabled: bool, sem_cache_hit: bool, query_shadow_force_prepare: bool) -> bool {
  if !cache_enabled { return false; }
  if !sem_cache_hit { return false; }
  if query_shadow_force_prepare { return false; }
  return true;
}

fn should_refresh_sem_key_from_pkg_keys(sem_key: String, sem_cache_hit: bool, sem_key_from_obj_ref: bool) -> bool {
  if sem_key == "" { return true; }
  return sem_key_from_obj_ref && !sem_cache_hit;
}

struct SemKeyDepHashesKeepOrderResult {
  files: Vec[ld.SourceFile],
  pkgs: Vec[String],
  order: Vec[i32],
  sem_pkg_keys: Vec[BuildCachePkgKey],
  sem_key: String,
  sem_key_from_obj_ref: bool,
  sem_dep_hashes: Vec[q.ParseLoadDepHash],
}

fn ensure_sem_key_dep_hashes_with_keep_order(
  files0: Vec[ld.SourceFile],
  pkgs0: Vec[String],
  order0: Vec[i32],
  sem_pkg_keys0: Vec[BuildCachePkgKey],
  sem_mode: String,
  sem_key0: String,
  sem_cache_hit: bool,
  sem_key_from_obj_ref0: bool,
  sem_dep_hashes0: Vec[q.ParseLoadDepHash],
) -> SemKeyDepHashesKeepOrderResult {
  let mut files: Vec[ld.SourceFile] = files0;
  let mut pkgs: Vec[String] = pkgs0;
  let mut order: Vec[i32] = order0;
  let mut sem_pkg_keys: Vec[BuildCachePkgKey] = sem_pkg_keys0;
  let mut sem_key: String = sem_key0;
  let mut sem_key_from_obj_ref: bool = sem_key_from_obj_ref0;
  let mut sem_dep_hashes: Vec[q.ParseLoadDepHash] = sem_dep_hashes0;
  if sem_dep_hashes.len() != 0 {
    return SemKeyDepHashesKeepOrderResult {
      files: files,
      pkgs: pkgs,
      order: order,
      sem_pkg_keys: sem_pkg_keys,
      sem_key: sem_key,
      sem_key_from_obj_ref: sem_key_from_obj_ref,
      sem_dep_hashes: sem_dep_hashes,
    };
  }
  if sem_pkg_keys.len() == 0 {
    let sem_keys_keep: BuildCachePkgSemOnlySourceKeysKeepOrderResult =
      build_cache_pkg_sem_source_keys_only_keep_order_with_files(
        files,
        pkgs,
        order,
      );
    files = sem_keys_keep.files;
    pkgs = sem_keys_keep.pkgs;
    order = sem_keys_keep.order;
    sem_pkg_keys = sem_keys_keep.sem_keys;
  }
  let sem_dep_keep: BuildCacheSemDepHashesKeep =
    build_cache_sem_dep_hashes_from_pkg_source_keys_keep(sem_pkg_keys, sem_mode);
  sem_pkg_keys = sem_dep_keep.keys;
  sem_dep_hashes = sem_dep_keep.dep_hashes;
  if should_refresh_sem_key_from_pkg_keys(sem_key, sem_cache_hit, sem_key_from_obj_ref) {
    let sem_key_keep: BuildCacheSemKeyKeep = build_cache_sem_key_from_pkg_source_keys_keep(sem_pkg_keys, sem_mode);
    sem_pkg_keys = sem_key_keep.keys;
    sem_key = sem_key_keep.sem_key;
    sem_key_from_obj_ref = false;
  }
  return SemKeyDepHashesKeepOrderResult {
    files: files,
    pkgs: pkgs,
    order: order,
    sem_pkg_keys: sem_pkg_keys,
    sem_key: sem_key,
    sem_key_from_obj_ref: sem_key_from_obj_ref,
    sem_dep_hashes: sem_dep_hashes,
  };
}

fn query_shadow_state_from_sem_key(
  phase: String,
  sem_key: String,
  switches0: Vec[String],
  trace_predicted_hit: bool,
) -> q.ParseLoadShadowState {
  let switches: Vec[String] = switches0;
  if sem_key == "" {
    return q.ParseLoadShadowState { key: "", predicted_hit: false };
  }
  let mut h: u64 = 1469598103934665603 as u64;
  h = lock_hash_text(h, "query-shadow-sem-v1\n");
  h = lock_hash_text(h, phase);
  h = lock_hash_text(h, "\n");
  h = lock_hash_text(h, sem_key);
  h = lock_hash_text(h, "\n");
  let mut i: i32 = 0;
  while i < switches.len() {
    h = lock_hash_text(h, "X\n");
    h = lock_hash_text(h, switches.get(i));
    h = lock_hash_text(h, "\n");
    i = i + 1;
  }
  let key: String = h.to_string();
  let predicted_hit: bool = if trace_predicted_hit { q.parse_load_shadow_predict_hit(key) } else { false };
  return q.ParseLoadShadowState { key: key, predicted_hit: predicted_hit };
}

fn cache_on_off(v: bool) -> String {
  return if v { "on" } else { "off" };
}

fn cache_hit_miss(v: bool) -> String {
  return if v { "hit" } else { "miss" };
}

fn cache_hit_miss_skip(hit: bool, checked: bool) -> String {
  if !checked { return "skip"; }
  return cache_hit_miss(hit);
}

fn print_profile_cache_summary(
  mode: String,
  cache_enabled: bool,
  incremental_enabled: bool,
  sem_checked: bool,
  sem_hit: bool,
  c_hit: bool,
  obj_label: String,
  obj_hit: bool,
  final_label: String,
  final_hit: bool,
  sem_c_reuse: bool,
  qshadow_skip: bool,
) -> () {
  print(
    "[profile] cache "
      .concat(mode)
      .concat(": cache=").concat(cache_on_off(cache_enabled))
      .concat(" incremental=").concat(cache_on_off(incremental_enabled))
      .concat(" sem=").concat(cache_hit_miss_skip(sem_hit, sem_checked))
      .concat(" c=").concat(cache_hit_miss(c_hit))
      .concat(" ").concat(obj_label).concat("=").concat(cache_hit_miss(obj_hit))
      .concat(" ").concat(final_label).concat("=").concat(cache_hit_miss(final_hit))
      .concat(" sem_c_reuse=").concat(cache_hit_miss(sem_c_reuse))
      .concat(" qshadow_skip=").concat(cache_hit_miss(qshadow_skip))
      .concat("\n"),
  );
}

fn print_profile_list_cache_summary(
  cache_enabled: bool,
  incremental_enabled: bool,
  sem_checked: bool,
  sem_hit: bool,
  output_hit: bool,
) -> () {
  print(
    "[profile] cache list: cache="
      .concat(cache_on_off(cache_enabled))
      .concat(" incremental=").concat(cache_on_off(incremental_enabled))
      .concat(" sem=").concat(cache_hit_miss_skip(sem_hit, sem_checked))
      .concat(" output=").concat(cache_hit_miss(output_hit))
      .concat("\n"),
  );
}

fn print_profile_test_list_cache_summary(
  cache_enabled: bool,
  incremental_enabled: bool,
  output_hit: bool,
) -> () {
  print(
    "[profile] cache test-list: cache="
      .concat(cache_on_off(cache_enabled))
      .concat(" incremental=").concat(cache_on_off(incremental_enabled))
      .concat(" output=").concat(cache_hit_miss(output_hit))
      .concat("\n"),
  );
}

fn print_profile_cache_prep_summary(mode: String, keys_ns: i64, probe_ns: i64, qshadow_ns: i64) -> () {
  print(
    "[profile] cache-prep "
      .concat(mode)
      .concat(": keys=").concat(format_duration_ns(keys_ns))
      .concat(" probe=").concat(format_duration_ns(probe_ns))
      .concat(" qshadow=").concat(format_duration_ns(qshadow_ns))
      .concat("\n"),
  );
}

fn duration_us(ns0: i64) -> i64 {
  let mut ns: i64 = ns0;
  if ns < 0 { ns = 0; }
  return (ns + 500) / 1000;
}

fn test_module_name(name: String) -> String {
  let mut i: i32 = 0;
  while i + 1 < name.len() {
    if name.byte_at(i) == 58 && name.byte_at(i + 1) == 58 {
      return name.slice(0, i);
    }
    i = i + 1;
  }
  return "(root)";
}

fn update_module_summary_idx(mods0: Vec[ModuleSummary], idx: i32, ok: bool, dur_ns: i64) -> Vec[ModuleSummary] {
  let mut mods: Vec[ModuleSummary] = mods0;
  let mut s0: ModuleSummary = mods.get(idx);
  if ok { s0.passed = s0.passed + 1; } else { s0.failed = s0.failed + 1; }
  s0.dur_ns = s0.dur_ns + dur_ns;
  mods.set(idx, s0);
  return mods;
}

fn update_module_detail_idx(ds0: Vec[ModuleDetail], idx: i32, name: String, ok: bool, dur_ns: i64) -> Vec[ModuleDetail] {
  let mut ds: Vec[ModuleDetail] = ds0;
  let d0: ModuleDetail = ds.get(idx);
  let mut tests1: Vec[String] = d0.tests;
  tests1.push(name);
  let mut failed_tests1: Vec[String] = d0.failed_tests;
  if !ok { failed_tests1.push(name); }
  let d1: ModuleDetail = ModuleDetail {
    module: d0.module,
    tests: tests1,
    failed_tests: failed_tests1,
    passed: d0.passed + if ok { 1 } else { 0 },
    failed: d0.failed + if ok { 0 } else { 1 },
    dur_ns: d0.dur_ns + dur_ns,
  };
  ds.set(idx, d1);
  return ds;
}

fn sort_module_details(xs0: Vec[ModuleDetail]) -> Vec[ModuleDetail] {
  let mut out: Vec[ModuleDetail] = Vec();
  let mut i: i32 = 0;
  while i < xs0.len() {
    let d0: ModuleDetail = xs0.get(i);
    out.push(ModuleDetail {
      module: d0.module,
      tests: sort_strings_if_needed(d0.tests),
      failed_tests: sort_strings_if_needed(d0.failed_tests),
      passed: d0.passed,
      failed: d0.failed,
      dur_ns: d0.dur_ns,
    });
    i = i + 1;
  }
  if out.len() <= 1 { return out; }
  let mut sorted: bool = true;
  i = 1;
  while i < out.len() {
    if out.get(i - 1).module > out.get(i).module {
      sorted = false;
      break;
    }
    i = i + 1;
  }
  if sorted { return out; }
  let mut gap: i32 = out.len() / 2;
  while gap > 0 {
    let mut oi: i32 = gap;
    while oi < out.len() {
      let keep: ModuleDetail = out.get(oi);
      let keep_module: String = keep.module;
      let mut j: i32 = oi;
      while j >= gap {
        let prev: ModuleDetail = out.get(j - gap);
        if prev.module <= keep_module { break; }
        out.set(j, prev);
        j = j - gap;
      }
      out.set(j, keep);
      oi = oi + 1;
    }
    gap = gap / 2;
  }
  return out;
}

fn sort_module_summaries_if_needed(xs0: Vec[ModuleSummary]) -> Vec[ModuleSummary] {
  let mut xs: Vec[ModuleSummary] = xs0;
  if xs.len() <= 1 { return xs; }
  let mut i: i32 = 1;
  while i < xs.len() {
    if xs.get(i - 1).module > xs.get(i).module {
      let mut gap: i32 = xs.len() / 2;
      while gap > 0 {
        let mut oi: i32 = gap;
        while oi < xs.len() {
          let keep: ModuleSummary = xs.get(oi);
          let keep_module: String = keep.module;
          let mut j: i32 = oi;
          while j >= gap {
            let prev: ModuleSummary = xs.get(j - gap);
            if prev.module <= keep_module { break; }
            xs.set(j, prev);
            j = j - gap;
          }
          xs.set(j, keep);
          oi = oi + 1;
        }
        gap = gap / 2;
      }
      return xs;
    }
    i = i + 1;
  }
  return xs;
}

fn sort_test_results(xs0: Vec[TestRunResult]) -> Vec[TestRunResult] {
  if xs0.len() <= 1 { return xs0; }
  let mid: i32 = xs0.len() / 2;
  let mut left: Vec[TestRunResult] = Vec();
  let mut right: Vec[TestRunResult] = Vec();
  let mut i: i32 = 0;
  while i < xs0.len() {
    if i < mid {
      left.push(xs0.get(i));
    } else {
      right.push(xs0.get(i));
    }
    i = i + 1;
  }
  let left_sorted: Vec[TestRunResult] = sort_test_results(left);
  let right_sorted: Vec[TestRunResult] = sort_test_results(right);
  let mut out: Vec[TestRunResult] = Vec();
  let mut li: i32 = 0;
  let mut ri: i32 = 0;
  while li < left_sorted.len() && ri < right_sorted.len() {
    let l: TestRunResult = left_sorted.get(li);
    let r: TestRunResult = right_sorted.get(ri);
    if l.name <= r.name {
      out.push(l);
      li = li + 1;
    } else {
      out.push(r);
      ri = ri + 1;
    }
  }
  while li < left_sorted.len() {
    out.push(left_sorted.get(li));
    li = li + 1;
  }
  while ri < right_sorted.len() {
    out.push(right_sorted.get(ri));
    ri = ri + 1;
  }
  return out;
}

fn slowest_insert(xs0: Vec[NamedDuration], x: NamedDuration) -> Vec[NamedDuration] {
  let mut out: Vec[NamedDuration] = Vec();
  let mut inserted: bool = false;
  let mut i: i32 = 0;
  while i < xs0.len() {
    let cur: NamedDuration = xs0.get(i);
    if !inserted && (x.dur_ns > cur.dur_ns || (x.dur_ns == cur.dur_ns && x.name < cur.name)) {
      out.push(x);
      inserted = true;
    }
    out.push(cur);
    i = i + 1;
  }
  if !inserted { out.push(x); }
  if out.len() <= 5 { return out; }
  let mut top: Vec[NamedDuration] = Vec();
  let mut ti: i32 = 0;
  while ti < 5 {
    top.push(out.get(ti));
    ti = ti + 1;
  }
  return top;
}

struct ModuleQueue {
  module: String,
  tests: Vec[String],
  next: i32,
}

struct ModuleQueueIndexEntry {
  module: String,
  queue_idx: i32,
}

struct ModuleQueueLookupKeepResult {
  entries: Vec[ModuleQueueIndexEntry],
  found: bool,
  queue_idx: i32,
  insert_at: i32,
}

struct RunningJob {
  module_idx: i32,
  name: String,
  rc_file: String,
  log_file: String,
  start_ns: i64,
}

fn module_queue_lookup_keep(entries0: Vec[ModuleQueueIndexEntry], module: String) -> ModuleQueueLookupKeepResult {
  let entries: Vec[ModuleQueueIndexEntry] = entries0;
  let mut lo: i32 = 0;
  let mut hi: i32 = entries.len();
  while lo < hi {
    let mid: i32 = lo + (hi - lo) / 2;
    let cur: ModuleQueueIndexEntry = entries.get(mid);
    if cur.module == module {
      return ModuleQueueLookupKeepResult {
        entries: entries,
        found: true,
        queue_idx: cur.queue_idx,
        insert_at: mid,
      };
    }
    if cur.module < module {
      lo = mid + 1;
    } else {
      hi = mid;
    }
  }
  return ModuleQueueLookupKeepResult {
    entries: entries,
    found: false,
    queue_idx: -1,
    insert_at: lo,
  };
}

fn build_module_queues(tests: Vec[String]) -> Vec[ModuleQueue] {
  let mut out: Vec[ModuleQueue] = Vec();
  let mut module_index: Vec[ModuleQueueIndexEntry] = Vec();
  let mut last_module: String = "";
  let mut last_qi: i32 = -1;
  let mut i: i32 = 0;
  while i < tests.len() {
    let name: String = tests.get(i);
    let module: String = test_module_name(name);
    let mut qi: i32 = last_qi;
    if qi < 0 || last_module != module {
      let lookup_keep: ModuleQueueLookupKeepResult = module_queue_lookup_keep(module_index, module.slice(0, module.len()));
      module_index = lookup_keep.entries;
      if lookup_keep.found {
        qi = lookup_keep.queue_idx;
      } else {
        qi = out.len();
        let mut next_index: Vec[ModuleQueueIndexEntry] = Vec();
        let mut mii: i32 = 0;
        while mii < lookup_keep.insert_at {
          next_index.push(module_index.get(mii));
          mii = mii + 1;
        }
        next_index.push(ModuleQueueIndexEntry { module: module.slice(0, module.len()), queue_idx: qi });
        while mii < module_index.len() {
          next_index.push(module_index.get(mii));
          mii = mii + 1;
        }
        module_index = next_index;
      }
    }
    if qi == out.len() {
      let mut ts: Vec[String] = Vec();
      ts.push(name);
      out.push(ModuleQueue { module: module.slice(0, module.len()), tests: ts, next: 0 });
    } else {
      let q0: ModuleQueue = out.get(qi);
      let mut ts1: Vec[String] = q0.tests;
      ts1.push(name);
      let q1: ModuleQueue = ModuleQueue { module: q0.module, tests: ts1, next: q0.next };
      out.set(qi, q1);
    }
    last_module = module;
    last_qi = qi;
    i = i + 1;
  }
  return out;
}

fn json_quote(s: String) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push("\"");
  let mut i: i32 = 0;
  while i < s.len() {
    let ch: i32 = s.byte_at(i);
    if ch == 34 { parts.push("\\\""); i = i + 1; continue; } // "
    if ch == 92 { parts.push("\\\\"); i = i + 1; continue; } // \
    if ch == 10 { parts.push("\\n"); i = i + 1; continue; } // \n
    if ch == 13 { parts.push("\\r"); i = i + 1; continue; } // \r
    if ch == 9 { parts.push("\\t"); i = i + 1; continue; } // \t
    parts.push(s.slice(i, i + 1));
    i = i + 1;
  }
  parts.push("\"");
  return parts.join("");
}

fn json_bool(v: bool) -> String { return if v { "true" } else { "false" }; }

fn json_of_tests(tests: Vec[String]) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push("[");
  let mut i: i32 = 0;
  while i < tests.len() {
    if i > 0 { parts.push(","); }
    parts.push(json_quote(tests.get(i)));
    i = i + 1;
  }
  parts.push("]");
  return parts.join("");
}

fn json_report_text(
  discovered: i32,
  selected: i32,
  module_pat: String,
  run_pat: String,
  filter: String,
  jobs: i32,
  fail_fast: bool,
  rerun_failed: bool,
  rerun_failed_count: i32,
  list_only: bool,
  selected_tests: Vec[String],
  results: Vec[TestRunResult],
  modules: Vec[ModuleSummary],
  module_details: Vec[ModuleDetail],
  slowest: Vec[NamedDuration],
  failed_tests: Vec[String],
  hint: String,
  message: String,
  rerun_cache_path: String,
  passed: i32,
  failed: i32,
  skipped: i32,
  total_ns: i64,
) -> String {
  let list_module_details: Vec[ModuleDetail] =
    if list_only {
      let mut selected_tests_for_modules: Vec[String] = Vec();
      let mut stmi: i32 = 0;
      while stmi < selected_tests.len() {
        selected_tests_for_modules.push(selected_tests.get(stmi));
        stmi = stmi + 1;
      }
      let tests_sorted: Vec[String] = sort_strings(selected_tests_for_modules);
      let queues: Vec[ModuleQueue] = build_module_queues(tests_sorted);
      let mut out: Vec[ModuleDetail] = Vec();
      let mut qi: i32 = 0;
      while qi < queues.len() {
        let q: ModuleQueue = queues.get(qi);
        out.push(ModuleDetail {
          module: q.module,
          tests: q.tests,
          failed_tests: Vec(),
          passed: q.tests.len(),
          failed: 0,
          dur_ns: 0,
        });
        qi = qi + 1;
      }
      sort_module_details(out)
    } else {
      module_details
    };
  let mut out: String = "{";
  out = out.concat("\"report_version\":1");
  out = out.concat(",\"rerun_cache_path\":").concat(json_quote(rerun_cache_path));
  out = out.concat(",\"rerun_cache_version\":1");
  out = out.concat(",\"selection\":{");
  out = out.concat("\"discovered\":").concat(discovered.to_string());
  out = out.concat(",\"selected\":").concat(selected.to_string());
  if jobs > 0 { out = out.concat(",\"jobs\":").concat(jobs.to_string()); }
  if fail_fast { out = out.concat(",\"fail_fast\":").concat(json_bool(true)); }
  if module_pat != "" {
    out = out.concat(",\"module\":").concat(json_quote(module_pat));
    out = out.concat(",\"module_pattern\":").concat(json_quote(module_pat));
  }
  if run_pat != "" {
    out = out.concat(",\"run\":").concat(json_quote(run_pat));
    out = out.concat(",\"run_pattern\":").concat(json_quote(run_pat));
  }
  if filter != "" { out = out.concat(",\"filter\":").concat(json_quote(filter)); }
  if rerun_failed {
    out = out.concat(",\"rerun_failed\":").concat(json_bool(true));
    out = out.concat(",\"prev_failed_count\":").concat(rerun_failed_count.to_string());
    out = out.concat(",\"rerun_cache_path\":").concat(json_quote(rerun_cache_path));
  }
  out = out.concat("}");
  out = out.concat(",\"list_only\":").concat(json_bool(list_only));
  out = out.concat(",\"selected_tests\":").concat(json_of_tests(selected_tests));
  let mut module_details_parts: Vec[String] = Vec();
  module_details_parts.push("[");
  let mut mdi: i32 = 0;
  while mdi < list_module_details.len() {
    if mdi > 0 { module_details_parts.push(","); }
    let d: ModuleDetail = list_module_details.get(mdi);
    module_details_parts.push("{\"module\":");
    module_details_parts.push(json_quote(d.module));
    module_details_parts.push(",\"tests\":");
    module_details_parts.push(json_of_tests(d.tests));
    module_details_parts.push(",\"failed_tests\":");
    module_details_parts.push(json_of_tests(d.failed_tests));
    module_details_parts.push(",\"passed\":");
    module_details_parts.push(d.passed.to_string());
    module_details_parts.push(",\"failed\":");
    module_details_parts.push(d.failed.to_string());
    module_details_parts.push(",\"duration_us\":");
    module_details_parts.push(duration_us(d.dur_ns).to_string());
    module_details_parts.push("}");
    mdi = mdi + 1;
  }
  module_details_parts.push("]");
  let module_details_json: String = module_details_parts.join("");
  out = out.concat(",\"module_details\":").concat(module_details_json);
  if message != "" { out = out.concat(",\"message\":").concat(json_quote(message)); }
  if !list_only {
    let mut results_parts: Vec[String] = Vec();
    results_parts.push("[");
    let mut ri: i32 = 0;
    while ri < results.len() {
      if ri > 0 { results_parts.push(","); }
      let r: TestRunResult = results.get(ri);
      results_parts.push("{\"name\":");
      results_parts.push(json_quote(r.name));
      results_parts.push(",\"module\":");
      results_parts.push(json_quote(r.module));
      results_parts.push(",\"status\":");
      results_parts.push(json_quote(if r.ok { "ok" } else { "fail" }));
      results_parts.push(",\"duration_us\":");
      results_parts.push(duration_us(r.dur_ns).to_string());
      if r.err != "" {
        results_parts.push(",\"error\":");
        results_parts.push(json_quote(r.err));
      }
      if r.log_file != "" {
        results_parts.push(",\"log_file\":");
        results_parts.push(json_quote(r.log_file));
      }
      results_parts.push("}");
      ri = ri + 1;
    }
    results_parts.push("]");
    let results_json: String = results_parts.join("");
    out = out.concat(",\"results\":").concat(results_json);
    let mut modules_parts: Vec[String] = Vec();
    modules_parts.push("[");
    let mut mi: i32 = 0;
    while mi < modules.len() {
      if mi > 0 { modules_parts.push(","); }
      let m: ModuleSummary = modules.get(mi);
      modules_parts.push("{\"module\":");
      modules_parts.push(json_quote(m.module));
      modules_parts.push(",\"passed\":");
      modules_parts.push(m.passed.to_string());
      modules_parts.push(",\"failed\":");
      modules_parts.push(m.failed.to_string());
      modules_parts.push(",\"duration_us\":");
      modules_parts.push(duration_us(m.dur_ns).to_string());
      modules_parts.push("}");
      mi = mi + 1;
    }
    modules_parts.push("]");
    let modules_json: String = modules_parts.join("");
    out = out.concat(",\"modules\":").concat(modules_json);
    let mut slowest_parts: Vec[String] = Vec();
    slowest_parts.push("[");
    let mut si: i32 = 0;
    while si < slowest.len() {
      if si > 0 { slowest_parts.push(","); }
      let x: NamedDuration = slowest.get(si);
      slowest_parts.push("{\"name\":");
      slowest_parts.push(json_quote(x.name));
      slowest_parts.push(",\"module\":");
      slowest_parts.push(json_quote(x.module));
      slowest_parts.push(",\"duration_us\":");
      slowest_parts.push(duration_us(x.dur_ns).to_string());
      slowest_parts.push("}");
      si = si + 1;
    }
    slowest_parts.push("]");
    let slowest_json: String = slowest_parts.join("");
    out = out.concat(",\"slowest\":").concat(slowest_json);
    out = out.concat(",\"failed_tests\":").concat(json_of_tests(failed_tests));
    if hint != "" { out = out.concat(",\"hint\":").concat(json_quote(hint)); }
    out = out.concat(",\"summary\":{");
    out = out.concat("\"passed\":").concat(passed.to_string());
    out = out.concat(",\"failed\":").concat(failed.to_string());
    out = out.concat(",\"skipped\":").concat(skipped.to_string());
    out = out.concat(",\"duration_us\":").concat(duration_us(total_ns).to_string());
    out = out.concat("}");
  }
  out = out.concat("}");
  return out;
}

fn print_json_report(
  discovered: i32,
  selected: i32,
  module_pat: String,
  run_pat: String,
  filter: String,
  jobs: i32,
  fail_fast: bool,
  rerun_failed: bool,
  rerun_failed_count: i32,
  list_only: bool,
  selected_tests: Vec[String],
  results: Vec[TestRunResult],
  modules: Vec[ModuleSummary],
  module_details: Vec[ModuleDetail],
  slowest: Vec[NamedDuration],
  failed_tests: Vec[String],
  hint: String,
  message: String,
  rerun_cache_path: String,
  passed: i32,
  failed: i32,
  skipped: i32,
  total_ns: i64,
) -> () {
  print(
    json_report_text(
      discovered,
      selected,
      module_pat,
      run_pat,
      filter,
      jobs,
      fail_fast,
      rerun_failed,
      rerun_failed_count,
      list_only,
      selected_tests,
      results,
      modules,
      module_details,
      slowest,
      failed_tests,
      hint,
      message,
      rerun_cache_path,
      passed,
      failed,
      skipped,
      total_ns,
    ).concat("\n"),
  );
}

fn failed_tests_path(out: String) -> String {
  let base0: String = sanitize_path_part(pth.base_name(out));
  let base: String = if base0 != "" { base0 } else { "out" };
  let mut h: u64 = 1469598103934665603 as u64;
  h = lock_hash_text(h, "failed-tests-cache-v1\n");
  h = lock_hash_text(h, out);
  h = lock_hash_text(h, "\n");
  return path_join("target/debug", ".vox_last_failed_tests.".concat(base).concat(".").concat(h.to_string()).concat(".json"));
}

fn normalize_failed_tests(names: Vec[String]) -> Vec[String] {
  let sorted: Vec[String] = sort_strings(names);
  let mut out: Vec[String] = Vec();
  let mut i: i32 = 0;
  while i < sorted.len() {
    let name: String = txt.trim_space(sorted.get(i));
    if name != "" {
      if out.len() == 0 || out.get(out.len() - 1) != name {
        out.push(name);
      }
    }
    i = i + 1;
  }
  return out;
}

fn split_lines(s: String) -> Vec[String] {
  let mut out: Vec[String] = Vec();
  let mut cur: String = "";
  let mut i: i32 = 0;
  while i < s.len() {
    let ch: i32 = s.byte_at(i);
    if ch == 13 { i = i + 1; continue; } // '\r'
    if ch == 10 { // '\n'
      if cur.len() > 0 { out.push(cur); }
      cur = "";
      i = i + 1;
      continue;
    }
    cur = cur.concat(s.slice(i, i + 1));
    i = i + 1;
  }
  if cur.len() > 0 { out.push(cur); }
  return out;
}

fn index_of_from(s: String, needle: String, start: i32) -> i32 {
  if needle.len() == 0 { return start; }
  let mut i: i32 = if start < 0 { 0 } else { start };
  while i + needle.len() <= s.len() {
    if s.slice(i, i + needle.len()) == needle { return i; }
    i = i + 1;
  }
  return -1;
}

fn write_failed_tests(out_path: String, names: Vec[String]) -> Vec[String] {
  fs.mkdir_p("target/debug");
  let canon: Vec[String] = normalize_failed_tests(names);
  let mut tests_json: String = "[";
  let mut cfi: i32 = 0;
  while cfi < canon.len() {
    if cfi > 0 { tests_json = tests_json.concat(","); }
    tests_json = tests_json.concat(json_quote(canon.get(cfi)));
    cfi = cfi + 1;
  }
  tests_json = tests_json.concat("]");
  let updated_us: i64 = tm.now_ns() / 1000;
  let mut meta: String = "{";
  meta = meta.concat("\"version\":1");
  meta = meta.concat(",\"updated_unix_us\":").concat(updated_us.to_string());
  meta = meta.concat(",\"tests\":").concat(tests_json.slice(0, tests_json.len()));
  meta = meta.concat(",\"failed_tests\":").concat(tests_json);
  meta = meta.concat("}\n");
  fs.write_string(failed_tests_path(out_path), meta);
  return canon;
}

fn load_deps_from_manifest() -> DepsResult {
  return load_deps_from_manifest_at(".", Vec(), Vec(), Vec(), true);
}

fn load_deps_from_manifest_with_c_text(load_c_text: bool) -> DepsResult {
  return load_deps_from_manifest_at(".", Vec(), Vec(), Vec(), load_c_text);
}

struct DepsResult { ok: bool, err: String, files: Vec[ld.SourceFile], seen: Vec[String], resolved: Vec[mf.Dependency] }

struct SeedProjectFilesResult {
  ok: bool,
  err: String,
  files: Vec[ld.SourceFile],
  resolved: Vec[mf.Dependency],
}

fn seed_project_files(has_std: bool, has_vox: bool, load_std_c_text: bool, load_dep_c_text: bool) -> SeedProjectFilesResult {
  let mut files: Vec[ld.SourceFile] = if has_std { Vec() } else { load_stage1_std_with_c_text(load_std_c_text) };
  if !has_vox {
    let preload_vox: Vec[ld.SourceFile] = load_stage1_vox();
    let mut pvi: i32 = 0;
    while pvi < preload_vox.len() {
      files.push(preload_vox.get(pvi));
      pvi = pvi + 1;
    }
  }
  let dr: DepsResult = load_deps_from_manifest_with_c_text(load_dep_c_text);
  if !dr.ok {
    return SeedProjectFilesResult { ok: false, err: dr.err, files: Vec(), resolved: Vec() };
  }
  let mut di: i32 = 0;
  while di < dr.files.len() {
    files.push(dr.files.get(di));
    di = di + 1;
  }
  return SeedProjectFilesResult { ok: true, err: "", files: files, resolved: dr.resolved };
}

struct LockVerifyWriteResult {
  ok: bool,
  err: String,
}

fn verify_and_write_lockfile_or_err(resolved: Vec[mf.Dependency]) -> LockVerifyWriteResult {
  let vr: LockVerifyResult = verify_lockfile_or_ok(resolved);
  if !vr.ok {
    return LockVerifyWriteResult { ok: false, err: vr.err };
  }
  write_lockfile_from_lock_deps(vr.lock_deps);
  return LockVerifyWriteResult { ok: true, err: "" };
}

fn deps_err(msg: String) -> DepsResult {
  return DepsResult { ok: false, err: msg, files: Vec(), seen: Vec(), resolved: Vec() };
}

fn resolve_dep_root(base: String, p: String) -> String {
  if pth.is_abs_path(p) { return p; }
  return path_join(base, p);
}

fn sanitize_path_part(s: String) -> String {
  let mut out: String = "";
  let mut i: i32 = 0;
  while i < s.len() {
    let ch: i32 = s.byte_at(i);
    if
      (ch >= 48 && ch <= 57) // 0..9
      || (ch >= 65 && ch <= 90) // A..Z
      || (ch >= 97 && ch <= 122) // a..z
      || ch == 45 // -
      || ch == 95 // _
      || ch == 46 // .
    {
      out = out.concat(s.slice(i, i + 1));
    } else {
      out = out.concat("_");
    }
    i = i + 1;
  }
  if out == "" { return "_"; }
  return out;
}

fn shell_quote(s: String) -> String {
  if host_is_windows() { return "\"".concat(s).concat("\""); }
  let mut out: String = "'";
  let mut i: i32 = 0;
  while i < s.len() {
    let ch: i32 = s.byte_at(i);
    if ch == 39 { // '\''
      out = out.concat("'\"'\"'");
    } else {
      out = out.concat(s.slice(i, i + 1));
    }
    i = i + 1;
  }
  return out.concat("'");
}

fn dep_cache_root(base: String) -> String {
  return path_join(base, ".vox/deps");
}

fn load_deps_from_manifest_at(
  base: String,
  files0: Vec[ld.SourceFile],
  seen0: Vec[String],
  resolved0: Vec[mf.Dependency],
  load_c_text: bool,
) -> DepsResult {
  let mani_path: String = path_join(base, "vox.toml");
  let mt: String = fs.read_to_string(mani_path);
  let mr: mf.ParseResult = mf.parse(mt);
  if !mr.ok { return deps_err(mr.err); }

  let mut files: Vec[ld.SourceFile] = files0;
  let mut seen: Vec[String] = seen0;
  let mut resolved: Vec[mf.Dependency] = resolved0;
  let mut local_seen: Vec[String] = Vec();
  let include_legacy_runtime_c: bool = include_legacy_runtime_c_from_env();

  let mut i: i32 = 0;
  while i < mr.m.deps.len() {
    let d: mf.Dependency = mr.m.deps.get(i);
    if txt.contains_str(local_seen, d.name) {
      return deps_err("duplicate dependency: ".concat(d.name));
    }
    local_seen.push(d.name);
    if txt.contains_str(seen, d.name) { i = i + 1; continue; }
    seen.push(d.name);

    let dep_name: String = d.name.slice(0, d.name.len());
    let mut dep_root: String = "";
    if d.has_path {
      dep_root = resolve_dep_root(base, d.path);
      if !fs.exists(path_join(dep_root, "vox.toml")) {
        return deps_err("dependency missing vox.toml: ".concat(d.name));
      }
      resolved.push(mf.Dependency {
        name: d.name,
        path: dep_root,
        has_path: true,
        git: d.git,
        has_git: d.has_git,
        rev: d.rev,
        has_rev: d.has_rev,
        registry: d.registry,
        has_registry: d.has_registry,
        version: d.version,
        has_version: d.has_version,
      });
    } else if d.has_git {
      let mut git_src: String = d.git;
      if !pth.is_abs_path(git_src) && !txt.has_prefix(git_src, "http://") && !txt.has_prefix(git_src, "https://") && !txt.has_prefix(git_src, "ssh://") && !txt.has_prefix(git_src, "git@") {
        git_src = resolve_dep_root(base, git_src);
      }
      let cache_base: String = path_join(path_join(dep_cache_root(base), "git"), sanitize_path_part(d.name).concat("-").concat(sanitize_path_part(git_src)));
      fs.mkdir_p(path_join(dep_cache_root(base), "git"));
      if !fs.exists(path_join(cache_base, ".git")) {
        let clone_cmd: String = "git clone ".concat(shell_quote(git_src)).concat(" ").concat(shell_quote(cache_base));
        if osys.exec(clone_cmd) != 0 {
          return deps_err("git clone failed: ".concat(d.name));
        }
      } else {
        let fetch_cmd: String = "git -C ".concat(shell_quote(cache_base)).concat(" fetch --all --tags --prune");
        osys.exec(fetch_cmd);
      }
      let mut target: String = "";
      if d.has_rev { target = d.rev; } else if d.has_version { target = d.version; }
      if target != "" {
        let checkout_cmd: String = "git -C ".concat(shell_quote(cache_base)).concat(" checkout ").concat(shell_quote(target));
        if osys.exec(checkout_cmd) != 0 {
          return deps_err("git checkout failed: ".concat(d.name));
        }
      }
      let rev_file: String = path_join(cache_base, ".vox_resolved_rev");
      let rev_cmd: String = "git -C ".concat(shell_quote(cache_base)).concat(" rev-parse HEAD > ").concat(shell_quote(rev_file));
      let mut resolved_rev: String = d.rev;
      let mut has_resolved_rev: bool = d.has_rev;
      if osys.exec(rev_cmd) == 0 {
        resolved_rev = txt.trim_space(fs.read_to_string(rev_file));
        has_resolved_rev = resolved_rev != "";
      }
      if !fs.exists(path_join(cache_base, "vox.toml")) {
        return deps_err("dependency missing vox.toml: ".concat(d.name));
      }
      dep_root = cache_base;
      resolved.push(mf.Dependency {
        name: d.name,
        path: dep_root,
        has_path: true,
        git: git_src,
        has_git: true,
        rev: resolved_rev,
        has_rev: has_resolved_rev,
        registry: d.registry,
        has_registry: d.has_registry,
        version: d.version,
        has_version: d.has_version,
      });
    } else {
      if !d.has_version {
        return deps_err("dependency requires path/git/version: ".concat(d.name));
      }
      let mut reg_ok: bool = true;
      let mut reg_err: String = "";
      let mut reg_root: String = "";
      if !d.has_registry {
        reg_root = path_join(dep_cache_root(base), "registry");
      } else {
        let raw: String = d.registry;
        let mut git_src: String = raw;
        if txt.has_prefix(raw, "git+") && raw.len() > 4 {
          git_src = raw.slice(4, raw.len());
        }
        let git_src_is_remote: bool =
          txt.has_prefix(git_src, "http://") ||
          txt.has_prefix(git_src, "https://") ||
          txt.has_prefix(git_src, "ssh://") ||
          txt.has_prefix(git_src, "git@") ||
          txt.has_prefix(git_src, "file://") ||
          has_suffix(git_src, ".git");
        let as_git: bool = txt.has_prefix(raw, "git+") || git_src_is_remote;
        if !as_git {
          reg_root = resolve_dep_root(base, raw);
        } else {
          if !pth.is_abs_path(git_src) && !git_src_is_remote {
            git_src = resolve_dep_root(base, git_src);
          }
          let cache_base: String = path_join(path_join(dep_cache_root(base), "registry_remote"), sanitize_path_part(git_src));
          fs.mkdir_p(path_join(dep_cache_root(base), "registry_remote"));
          if !fs.exists(path_join(cache_base, ".git")) {
            let clone_cmd: String = "git clone ".concat(shell_quote(git_src)).concat(" ").concat(shell_quote(cache_base));
            if osys.exec(clone_cmd) != 0 {
              reg_ok = false;
              reg_err = "registry git clone failed: ".concat(raw);
            }
          } else {
            let fetch_cmd: String = "git -C ".concat(shell_quote(cache_base)).concat(" fetch --all --tags --prune");
            osys.exec(fetch_cmd);
          }
          if reg_ok {
            reg_root = cache_base;
          }
        }
      }
      if !reg_ok {
        return deps_err(reg_err);
      }
      dep_root = path_join(path_join(reg_root, d.name), d.version);
      if !fs.exists(path_join(dep_root, "vox.toml")) {
        return deps_err("registry dependency not found: ".concat(d.name).concat("@").concat(d.version));
      }
      resolved.push(mf.Dependency {
        name: d.name,
        path: dep_root,
        has_path: true,
        git: d.git,
        has_git: d.has_git,
        rev: d.rev,
        has_rev: d.has_rev,
        registry: d.registry,
        has_registry: d.has_registry,
        version: d.version,
        has_version: d.has_version,
      });
    }
    let rels: Vec[String] = srcw.walk_src_non_test_vox_files(dep_root);
    let mut dep_files: Vec[ld.SourceFile] = Vec();
    let mut j: i32 = 0;
    while j < rels.len() {
      let rel: String = rels.get(j);
      let full: String = path_join(dep_root, rel);
      let virt: String = dep_name.concat("/").concat(rel);
      dep_files.push(ld.SourceFile { path: virt, text: fs.read_to_string(full) });
      j = j + 1;
    }
    if load_c_text {
      let c_rels: Vec[String] = filter_pkg_c_sources_with_legacy(srcw.walk_c_files(dep_root), include_legacy_runtime_c);
      let mut ci: i32 = 0;
      while ci < c_rels.len() {
        let c_rel: String = c_rels.get(ci);
        let c_full: String = path_join(dep_root, c_rel);
        let c_virt: String = dep_name.concat("/").concat(c_rel);
        dep_files.push(ld.SourceFile { path: c_virt, text: fs.read_to_string(c_full) });
        ci = ci + 1;
      }
    }
    let mut di: i32 = 0;
    while di < dep_files.len() { files.push(dep_files.get(di)); di = di + 1; }

    let rr: DepsResult = load_deps_from_manifest_at(dep_root, files, seen, resolved, load_c_text);
    if !rr.ok { return rr; }
    files = rr.files;
    seen = rr.seen;
    resolved = rr.resolved;

    i = i + 1;
  }

  return DepsResult { ok: true, err: "", files: files, seen: seen, resolved: resolved };
}

fn toml_quote(s: String) -> String {
  return "\"".concat(s.escape_c()).concat("\"");
}

fn write_string_if_changed(path: String, text: String) -> bool {
  if fs.exists(path) && fs.read_to_string(path) == text {
    return false;
  }
  fs.write_string(path, text);
  return true;
}

fn write_lockfile_from_lock_deps(deps: Vec[LockDep]) -> () {
  let mut out: String = "# generated by vox stage1\nversion = 1\n";
  let mut i: i32 = 0;
  while i < deps.len() {
    let d: LockDep = deps.get(i);
    out = out.concat("\n[[dependency]]\n");
    out = out.concat("name = ").concat(toml_quote(d.name)).concat("\n");
    out = out.concat("source = ").concat(toml_quote(d.source)).concat("\n");
    if d.path != "" {
      out = out.concat("path = ").concat(toml_quote(d.path)).concat("\n");
    }
    if d.resolved_path != "" {
      out = out.concat("resolved_path = ").concat(toml_quote(d.resolved_path)).concat("\n");
    }
    if d.git != "" {
      out = out.concat("git = ").concat(toml_quote(d.git)).concat("\n");
    }
    if d.rev != "" {
      out = out.concat("rev = ").concat(toml_quote(d.rev)).concat("\n");
    }
    if d.registry != "" {
      out = out.concat("registry = ").concat(toml_quote(d.registry)).concat("\n");
    }
    if d.version != "" {
      out = out.concat("version = ").concat(toml_quote(d.version)).concat("\n");
    }
    out = out.concat("digest = ").concat(toml_quote(d.digest)).concat("\n");
    i = i + 1;
  }
  let _: bool = write_string_if_changed("vox.lock", out);
}

fn load_files(paths: Vec[String]) -> Vec[ld.SourceFile] {
  let mut out: Vec[ld.SourceFile] = Vec();
  let mut i: i32 = 0;
  while i < paths.len() {
    let p: String = paths.get(i);
    out.push(ld.SourceFile { path: p, text: fs.read_to_string(p) });
    i = i + 1;
  }
  return out;
}

struct KeepVoxSourceFilesResult {
  files: Vec[ld.SourceFile],
  vox_files: Vec[ld.SourceFile],
}

fn keep_vox_source_files_with_input(files0: Vec[ld.SourceFile]) -> KeepVoxSourceFilesResult {
  let files: Vec[ld.SourceFile] = files0;
  let mut out: Vec[ld.SourceFile] = Vec();
  let mut i: i32 = 0;
  while i < files.len() {
    let f: ld.SourceFile = files.get(i);
    if txt.has_suffix(f.path, ".vox") {
      out.push(f);
    }
    i = i + 1;
  }
  return KeepVoxSourceFilesResult { files: files, vox_files: out };
}

fn load_files_with_cached(paths: Vec[String], cached0: Vec[ld.SourceFile]) -> Vec[ld.SourceFile] {
  if cached0.len() == 0 {
    return load_files(paths);
  }
  let paths: Vec[String] = paths;
  let cached: Vec[ld.SourceFile] = cached0;
  let mut order: Vec[i32] = Vec();
  let mut cached_sorted: bool = true;
  let mut ci0: i32 = 0;
  while ci0 < cached.len() {
    if ci0 > 0 && cached.get(ci0 - 1).path > cached.get(ci0).path {
      cached_sorted = false;
    }
    order.push(ci0);
    ci0 = ci0 + 1;
  }
  if !cached_sorted {
    let mut gap: i32 = order.len() / 2;
    while gap > 0 {
      let mut oi: i32 = gap;
      while oi < order.len() {
        let keep: i32 = order.get(oi);
        let keep_path: String = cached.get(keep).path;
        let mut j: i32 = oi;
        while j >= gap {
          let prev: i32 = order.get(j - gap);
          if cached.get(prev).path <= keep_path { break; }
          order.set(j, prev);
          j = j - gap;
        }
        order.set(j, keep);
        oi = oi + 1;
      }
      gap = gap / 2;
    }
  }
  let mut paths_sorted: bool = true;
  if paths.len() > 1 {
    let mut pi: i32 = 1;
    while pi < paths.len() {
      if paths.get(pi - 1) > paths.get(pi) {
        paths_sorted = false;
        pi = paths.len();
      } else {
        pi = pi + 1;
      }
    }
  }
  let mut out: Vec[ld.SourceFile] = Vec();
  if cached_sorted && paths_sorted {
    let mut ci: i32 = 0;
    let mut i: i32 = 0;
    while i < paths.len() {
      let p: String = paths.get(i);
      while ci < cached.len() && cached.get(ci).path < p {
        ci = ci + 1;
      }
      if ci < cached.len() && cached.get(ci).path == p {
        out.push(ld.SourceFile { path: p, text: cached.get(ci).text });
      } else {
        out.push(ld.SourceFile { path: p, text: fs.read_to_string(p) });
      }
      i = i + 1;
    }
  } else {
    let mut i: i32 = 0;
    while i < paths.len() {
      let p: String = paths.get(i);
      let mut lo: i32 = 0;
      let mut hi: i32 = order.len();
      while lo < hi {
        let mid: i32 = lo + (hi - lo) / 2;
        let sf: ld.SourceFile = cached.get(order.get(mid));
        if sf.path < p {
          lo = mid + 1;
        } else {
          hi = mid;
        }
      }
      if lo < order.len() {
        let sf: ld.SourceFile = cached.get(order.get(lo));
        if sf.path == p {
          out.push(ld.SourceFile { path: p, text: sf.text });
        } else {
          out.push(ld.SourceFile { path: p, text: fs.read_to_string(p) });
        }
      } else {
        out.push(ld.SourceFile { path: p, text: fs.read_to_string(p) });
      }
      i = i + 1;
    }
  }
  return out;
}

fn normalize_std_search_root(root0: String) -> String {
  let root: String = pth.to_forward_slashes(root0);
  if has_suffix(root, "/src/std") {
    return dir_name(dir_name(root));
  }
  if has_suffix(root, "/src") {
    return dir_name(root);
  }
  return root;
}

fn load_stage1_std_from_root_with_c_text(root0: String, load_c_text: bool) -> Vec[ld.SourceFile] {
  let root: String = normalize_std_search_root(root0);
  let rels: Vec[String] = srcw.walk_src_non_test_vox_files(root);
  let mut out: Vec[ld.SourceFile] = Vec();
  let mut i: i32 = 0;
  while i < rels.len() {
    let rel: String = rels.get(i);
    if txt.has_prefix(rel, "src/std/") {
      let full: String = path_join(root, rel);
      out.push(ld.SourceFile { path: rel, text: fs.read_to_string(full) });
    }
    i = i + 1;
  }
  if load_c_text {
    let c_rels: Vec[String] = srcw.walk_c_files(root);
    let mut ci: i32 = 0;
    while ci < c_rels.len() {
      let c_rel: String = c_rels.get(ci);
      if txt.has_prefix(c_rel, "src/std/") && !is_hidden_source_path(c_rel) {
        let c_full: String = path_join(root, c_rel);
        out.push(ld.SourceFile { path: c_rel, text: fs.read_to_string(c_full) });
      }
      ci = ci + 1;
    }
  }
  return out;
}

fn load_stage1_std_with_c_text(load_c_text: bool) -> Vec[ld.SourceFile] {
  let env_vox_root: String = txt.trim_space(osys.getenv("VOX_ROOT"));
  if env_vox_root != "" {
    let from_root_env: Vec[ld.SourceFile] = load_stage1_std_from_root_with_c_text(env_vox_root, load_c_text);
    if from_root_env.len() > 0 { return from_root_env; }
  }

  let env_root: String = txt.trim_space(osys.getenv("VOX_STDLIB"));
  if env_root != "" {
    let from_env: Vec[ld.SourceFile] = load_stage1_std_from_root_with_c_text(env_root, load_c_text);
    if from_env.len() > 0 { return from_env; }
  }

  // Prefer bundled std layout next to installed binary: <bin>/../src/std.
  let exe: String = normalize_host_fs_path(osys.exe_path());
  let bin_dir: String = dir_name(exe);
  let from_bin_near: Vec[ld.SourceFile] = load_stage1_std_from_root_with_c_text(path_join(bin_dir, "../src/std"), load_c_text);
  if from_bin_near.len() > 0 { return from_bin_near; }

  // Then fallback to build-time embedded source root.
  let embed_root: String = txt.trim_space(pth.to_forward_slashes(bi.build_source_root()));
  if embed_root != "" {
    let from_embed: Vec[ld.SourceFile] = load_stage1_std_from_root_with_c_text(embed_root, load_c_text);
    if from_embed.len() > 0 { return from_embed; }
  }

  // Finally use runtime-derived repo roots for local developer builds.
  let root: String = stage1_root();
  let from_root: Vec[ld.SourceFile] = load_stage1_std_from_root_with_c_text(root, load_c_text);
  if from_root.len() > 0 { return from_root; }
  let from_src: Vec[ld.SourceFile] = load_stage1_std_from_root_with_c_text(path_join(root, "src"), load_c_text);
  if from_src.len() > 0 { return from_src; }
  let from_lib: Vec[ld.SourceFile] = load_stage1_std_from_root_with_c_text(path_join(root, "lib"), load_c_text);
  if from_lib.len() > 0 { return from_lib; }
  return Vec();
}

fn load_stage1_std() -> Vec[ld.SourceFile] {
  return load_stage1_std_with_c_text(true);
}

fn load_stage1_vox() -> Vec[ld.SourceFile] {
  let env_vox_root: String = txt.trim_space(osys.getenv("VOX_ROOT"));
  if env_vox_root != "" {
    let root: String = normalize_std_search_root(env_vox_root);
    let rels: Vec[String] = srcw.walk_src_non_test_vox_files(root);
    let mut from_env_root: Vec[ld.SourceFile] = Vec();
    let mut i: i32 = 0;
    while i < rels.len() {
      let rel: String = rels.get(i);
      if txt.has_prefix(rel, "src/vox/") {
        let full: String = path_join(root, rel);
        from_env_root.push(ld.SourceFile { path: rel, text: fs.read_to_string(full) });
      }
      i = i + 1;
    }
    if from_env_root.len() > 0 { return from_env_root; }
  }
  return Vec();
}

fn run_git_capture(root: String, suffix: String, subcmd: String) -> String {
  if !fs.exists(path_join(root, ".git")) { return ""; }
  fs.mkdir_p("target/debug");
  let out: String = path_join("target/debug", ".vox_git_".concat(suffix));
  let cmd: String = "git -C ".concat(shell_quote(root)).concat(" ").concat(subcmd).concat(" > ").concat(shell_quote(out)).concat(" 2>&1");
  if osys.exec(cmd) != 0 { return ""; }
  return txt.trim_space(fs.read_to_string(out));
}

fn local_dev_repo_has_selfhost() -> bool {
  if !fs.exists("vox.toml") { return false; }
  if !fs.exists("src/main.vox") { return false; }
  if !fs.exists("scripts/ci/rolling-selfhost.sh") { return false; }
  if !fs.exists("scripts/ci/resolve-selfhost-bin.sh") { return false; }
  return true;
}

fn maybe_handle_local_dev_selfhost_with_args(args0: Vec[String], trace_exec: bool) -> ToolchainRouteWithArgsResult {
  let args: Vec[String] = args0;
  if args.len() == 0 { return tc_route_no_with_args(args); }
  if txt.trim_space(osys.getenv("VOX_DEV_SELFHOST_DISABLE")) == "1" {
    return tc_route_no_with_args(args);
  }
  let cmd: String = args.get(0);
  if cmd != "fmt" && cmd != "install" { return tc_route_no_with_args(args); }
  if !local_dev_repo_has_selfhost() { return tc_route_no_with_args(args); }
  let exe: String = pth.to_forward_slashes(normalize_host_fs_path(osys.exe_path()));
  if
    has_suffix(exe, "/target/debug/vox_rolling")
    || has_suffix(exe, "/target/debug/vox_rolling.exe")
    || has_suffix(exe, "target/debug/vox_rolling")
    || has_suffix(exe, "target/debug/vox_rolling.exe")
  {
    return tc_route_no_with_args(args);
  }

  let mut pr_ok: bool = false;
  let mut pr_err: String = "";
  let mut pr_bin: String = "";
  if !local_dev_repo_has_selfhost() {
    pr_err = "not in vox-lang repo root";
  } else {
    fs.mkdir_p("target/debug");
    let out: String = "target/debug/.vox_local_selfhost_resolve_bin.log";
    let script: String = shell_exec_path("scripts/ci/resolve-selfhost-bin.sh");
    let resolve_bin_cmd: String =
      "bash "
        .concat(shell_quote(script))
        .concat(" > ")
        .concat(shell_quote(shell_exec_path(out)))
        .concat(" 2>&1");
    let resolve_bin_rc: i32 = exec_cmd(resolve_bin_cmd, trace_exec);
    let resolve_bin_txt: String = if fs.exists(out) { fs.read_to_string(out) } else { "" };
    if resolve_bin_rc != 0 {
      if resolve_bin_txt != "" {
        pr_err = resolve_bin_txt;
      } else {
        pr_err = "rolling selfhost resolve helper failed";
      }
    } else {
      let lines: Vec[String] = split_lines(resolve_bin_txt);
      let mut bin: String = "";
      if lines.len() > 0 {
        let mut lni: i32 = lines.len() - 1;
        while lni >= 0 {
          let s: String = txt.trim_space(lines.get(lni));
          if s != "" {
            bin = s;
            break;
          }
          lni = lni - 1;
        }
      }
      if bin == "" {
        pr_err = "rolling selfhost resolve helper did not print compiler path";
      } else {
        if !fs.exists(bin) {
          pr_err = "rolling selfhost binary missing: ".concat(bin);
        } else {
          pr_bin = bin;
          pr_ok = true;
        }
      }
    }
  }
  if !pr_ok {
    print("local selfhost failed\n");
    if pr_err != "" { print(pr_err.concat("\n")); }
    return tc_route_yes_with_args(1);
  }
  let mut cmdline: String = tc_build_exec_cmd(pr_bin, args);
  if trace_exec { cmdline = cmdline.concat(" ").concat(shell_quote("-x")); }
  let mut rc: i32 = 0;
  if host_is_windows() {
    let wrapped: String = "set VOX_DEV_SELFHOST_DISABLE=1&& ".concat(cmdline);
    rc = exec_cmd("cmd /C ".concat(shell_quote(wrapped)), trace_exec);
  } else {
    let wrapped: String = "VOX_DEV_SELFHOST_DISABLE=".concat(shell_quote("1")).concat(" ").concat(cmdline);
    rc = exec_cmd(wrapped, trace_exec);
  }
  return tc_route_yes_with_args(rc);
}

fn copy_file_host(src: String, dst: String, trace: bool) -> bool {
  let mut cmd: String = "";
  if host_is_windows() {
    cmd =
      "copy /Y "
        .concat(shell_quote(shell_exec_path(src)))
        .concat(" ")
        .concat(shell_quote(shell_exec_path(dst)));
  } else {
    cmd =
      "cp "
        .concat(shell_quote(shell_exec_path(src)))
        .concat(" ")
        .concat(shell_quote(shell_exec_path(dst)));
  }
  return exec_cmd(cmd, trace) == 0;
}

fn move_file_host(src: String, dst: String, trace: bool) -> bool {
  let mut cmd: String = "";
  if host_is_windows() {
    cmd =
      "move /Y "
        .concat(shell_quote(shell_exec_path(src)))
        .concat(" ")
        .concat(shell_quote(shell_exec_path(dst)));
  } else {
    cmd =
      "mv -f "
        .concat(shell_quote(shell_exec_path(src)))
        .concat(" ")
        .concat(shell_quote(shell_exec_path(dst)));
  }
  return exec_cmd(cmd, trace) == 0;
}

fn tmp_artifact_path(dst: String) -> String {
  let stamp: String = tm.now_ns().to_string();
  let mut last_sep: i32 = -1;
  let mut i: i32 = 0;
  while i < dst.len() {
    let ch: i32 = dst.byte_at(i);
    if ch == 47 || ch == 92 {
      last_sep = i;
    }
    i = i + 1;
  }
  let mut last_dot: i32 = -1;
  i = last_sep + 1;
  while i < dst.len() {
    if dst.byte_at(i) == 46 { last_dot = i; }
    i = i + 1;
  }
  if last_dot > last_sep + 1 {
    return dst.slice(0, last_dot).concat(".tmp.").concat(stamp).concat(dst.slice(last_dot, dst.len()));
  }
  return dst.concat("_tmp_").concat(stamp);
}

fn replace_file_host_from_tmp(tmp_out: String, dst: String, trace: bool) -> bool {
  let mut src: String = tmp_out;
  if !fs.exists(src) && fs.exists(tmp_out.concat(".exe")) {
    src = tmp_out.concat(".exe");
  }
  if !fs.exists(src) { return false; }
  let mut dst_out: String = dst;
  if has_suffix(src, ".exe") && !has_suffix(dst_out, ".exe") {
    dst_out = dst_out.concat(".exe");
  }
  return move_file_host(src, dst_out, trace);
}

fn publish_staged_artifact(stage_out: String, dst: String, trace: bool) -> bool {
  if stage_out == dst { return true; }
  if replace_file_host_from_tmp(stage_out, dst, trace) { return true; }
  let mut src: String = stage_out;
  if !fs.exists(src) && fs.exists(stage_out.concat(".exe")) {
    src = stage_out.concat(".exe");
  }
  if !fs.exists(src) { return false; }
  return copy_file_host(src, dst, trace);
}

fn publish_staged_artifact_keep_source(stage_out: String, dst: String, trace: bool) -> bool {
  if stage_out == dst { return true; }
  let mut src: String = stage_out;
  if !fs.exists(src) && fs.exists(stage_out.concat(".exe")) {
    src = stage_out.concat(".exe");
  }
  if !fs.exists(src) { return false; }
  return copy_file_host(src, dst, trace);
}

fn cmd_lsp(trace: bool) -> i32 {
  let root: String = stage1_root();
  let p0: String = path_join(path_join(root, "tools"), "lsp/server.mjs");
  let mut script: String = "";
  if fs.exists(p0) {
    script = p0;
  } else {
    let p1: String = path_join(path_join(path_join(path_join(root, "tools"), "vscode"), "vox-lang"), "server/server.mjs");
    if fs.exists(p1) { script = p1; }
  }
  if script == "" {
    print("lsp server script not found under tools/lsp or tools/vscode/vox-lang/server\n");
    return 1;
  }
  let mut node: String = txt.trim_space(osys.getenv("VOX_NODE"));
  if node == "" { node = "node"; }
  let cmd: String =
    shell_quote(node)
      .concat(" ")
      .concat(shell_quote(shell_exec_path(script)));
  let rc: i32 = exec_cmd(cmd, trace);
  if rc != 0 {
    print("lsp server exited with code ".concat(rc.to_string()).concat("\n"));
  }
  return rc;
}

fn main() -> i32 {
  let raw_args: Vec[String] = osys.args();
  let mut trace_exec: bool = false;
  let mut args: Vec[String] = raw_args;
  if args.len() > 0 && args.get(0) == "-x" {
    trace_exec = true;
    let mut tail_args: Vec[String] = Vec();
    let mut tail_i: i32 = 1;
    while tail_i < args.len() {
      tail_args.push(args.get(tail_i));
      tail_i = tail_i + 1;
    }
    args = tail_args;
  }
  if args.len() >= 2 && local_dev_repo_has_selfhost() && args.get(0) == "run" && args.get(1) == "fmt" {
    let mut alias_out: Vec[String] = Vec();
    alias_out.push("fmt");
    let mut alias_i: i32 = 2;
    while alias_i < args.len() {
      alias_out.push(args.get(alias_i));
      alias_i = alias_i + 1;
    }
    args = alias_out;
  }
  let routed: ToolchainRouteWithArgsResult = maybe_handle_toolchain_or_reroute_with_args(args, trace_exec);
  args = routed.args;
  if routed.handled { return routed.code; }
  let local_routed: ToolchainRouteWithArgsResult = maybe_handle_local_dev_selfhost_with_args(args, trace_exec);
  args = local_routed.args;
  if local_routed.handled { return local_routed.code; }
  if args.len() < 1 {
    usage();
    print("invalid args\n");
    return 1;
  }
  let cmd_in: String = args.get(0);
  if cmd_in == "version" || cmd_in == "--version" || cmd_in == "-V" {
    let override_raw: String = txt.trim_space(osys.getenv("VOX_BUILD_VERSION"));
    let override: String =
      if override_raw != "" && override_raw.len() > 1 && override_raw.byte_at(0) == 118 {
        override_raw.slice(1, override_raw.len())
      } else {
        override_raw
      };
    let mut cli_version: String = "";
    if override != "" {
      cli_version = override;
    } else {
      let base_raw: String = txt.trim_space(bi.version());
      let base0: String =
        if base_raw != "" && base_raw.len() > 1 && base_raw.byte_at(0) == 118 {
          base_raw.slice(1, base_raw.len())
        } else {
          base_raw
        };
      let base: String = if base0 != "" { base0 } else { "0.0.0" };
      let root: String = stage1_root();
      let sha: String = run_git_capture(root, "head_short", "rev-parse --short=12 HEAD");
      if sha != "" {
        let dirty: bool = run_git_capture(root, "status_porcelain", "status --porcelain") != "";
        let mut exact_base_tag: bool = false;
        if base != "" {
          let tag: String = "v".concat(base);
          let got: String = run_git_capture(root, "exact_tag", "describe --tags --exact-match --match ".concat(shell_quote(tag)));
          exact_base_tag = got == tag;
        }
        if !dirty && exact_base_tag {
          cli_version = base;
        } else {
          let mut n: String = "";
          if base != "" {
            let tag: String = "v".concat(base);
            n = run_git_capture(root, "count_since_tag", "rev-list --count ".concat(shell_quote(tag).concat("..HEAD")));
          }
          if n == "" { n = run_git_capture(root, "count_total", "rev-list --count HEAD"); }
          if n == "" { n = "0"; }
          if dirty {
            cli_version = base.concat("-dirty-").concat(n).concat("+g").concat(sha);
          } else {
            cli_version = base.concat("-").concat(n).concat("+g").concat(sha);
          }
        }
      } else {
        if txt.trim_space(bi.channel()) == "release" {
          cli_version = base;
        } else if base != "" {
          cli_version = base.concat("+src");
        } else {
          cli_version = "unknown";
        }
      }
    }
    print("vox ".concat(cli_version).concat("\n"));
    return 0;
  }
  let mut cmd: String = cmd_in;
  if cmd == "fmt" {
    let mut fmt_args: Vec[String] = Vec();
    let mut i_fmt: i32 = 1;
    while i_fmt < args.len() {
      if args.get(i_fmt) == "-x" {
        trace_exec = true;
      } else {
        fmt_args.push(args.get(i_fmt));
      }
      i_fmt = i_fmt + 1;
    }
    let mut check_only: bool = false;
    let mut raw_paths: Vec[String] = Vec();
    let mut fi0: i32 = 0;
    while fi0 < fmt_args.len() {
      let a: String = fmt_args.get(fi0);
      if a == "--check" {
        check_only = true;
        fi0 = fi0 + 1;
        continue;
      }
      if txt.has_prefix(a, "-") {
        usage();
        print("unknown fmt flag: ".concat(a).concat("\n"));
        return 1;
      }
      raw_paths.push(a);
      fi0 = fi0 + 1;
    }

    let mut paths: Vec[String] = Vec();
    fi0 = 0;
    while fi0 < raw_paths.len() {
      if raw_paths.get(fi0) != "" {
        paths.push(raw_paths.get(fi0));
      }
      fi0 = fi0 + 1;
    }
    if paths.len() == 0 {
      paths.push("src");
      if fs.exists("tests") { paths.push("tests"); }
      if fs.exists("examples") { paths.push("examples"); }
    }

    let files: Vec[String] = vf.discover_files(paths);
    if files.len() == 0 {
      print("[fmt] no .vox files found\n");
      return 1;
    }

    let mut checked: i32 = 0;
    let mut changed: i32 = 0;
    let mut fi: i32 = 0;
    while fi < files.len() {
      let path: String = files.get(fi);
      let src: String = fs.read_to_string(path);
      let got: String = vf.format_text(src);
      checked = checked + 1;
      if got != src {
        changed = changed + 1;
        if check_only {
          print("[fmt] would format ".concat(path).concat("\n"));
        } else {
          fs.write_string(path, got);
          print("[fmt] formatted ".concat(path).concat("\n"));
        }
      }
      fi = fi + 1;
    }
    if check_only {
      if changed == 0 {
        print("[fmt] ok: ".concat(checked.to_string()).concat(" file(s) clean\n"));
        return 0;
      }
      print("[fmt] failed: ".concat(changed.to_string()).concat(" file(s) need formatting\n"));
      return 1;
    }
    print("[fmt] done: ".concat(checked.to_string()).concat(" file(s), ").concat(changed.to_string()).concat(" changed\n"));
    return 0;
  }
  if cmd == "lsp" {
    if args.len() == 2 && args.get(1) == "-x" {
      trace_exec = true;
      return cmd_lsp(trace_exec);
    }
    if args.len() != 1 {
      usage();
      print("unexpected args for lsp\n");
      return 1;
    }
    return cmd_lsp(trace_exec);
  }
  if cmd != "build" && cmd != "test" && cmd != "run" && cmd != "install" && cmd != "list" {
    usage();
    print("unknown command\n");
    return 1;
  }

  let mut driver: cg.DriverMainKind = cg.DriverMainKind.User;
  let mut test_module_pat: String = "";
  let mut test_run_pat: String = "";
  let mut test_filter: String = "";
  let mut test_jobs: i32 = 1;
  let mut test_fail_fast: bool = false;
  let mut test_list_only: bool = false;
  let mut test_rerun_failed: bool = false;
  let mut list_include_tests: bool = false;
  let mut test_json: bool = false;
  let mut target_flag: String = "";
  let mut artifact_flag: String = "";
  let mut emit_c_enabled: bool = false;
  let mut emit_c_path: String = "";
  let mut out: String = "";
  let mut i: i32 = 1;
  while i < args.len() {
    let a: String = args.get(i);
    if a == "-x" {
      trace_exec = true;
      i = i + 1;
      continue;
    }
    if txt.has_prefix(a, "--driver=") {
      let v: String = a.slice(9, a.len());
      if v == "user" { driver = cg.DriverMainKind.User; i = i + 1; continue; }
      if v == "tool" { driver = cg.DriverMainKind.Tool; i = i + 1; continue; }
      usage();
      print("unknown driver: ".concat(v).concat("\n"));
      return 1;
    }
    if txt.has_prefix(a, "--run=") {
      if cmd != "test" {
        usage();
        print("unknown flag: ".concat(a).concat("\n"));
        return 1;
      }
      test_run_pat = a.slice(6, a.len());
      i = i + 1;
      continue;
    }
    if a == "--run" {
      if cmd != "test" {
        usage();
        print("unknown flag: ".concat(a).concat("\n"));
        return 1;
      }
      if i + 1 >= args.len() {
        usage();
        print("missing value for --run\n");
        return 1;
      }
      test_run_pat = args.get(i + 1);
      i = i + 2;
      continue;
    }
    if txt.has_prefix(a, "--module=") {
      if cmd != "test" {
        usage();
        print("unknown flag: ".concat(a).concat("\n"));
        return 1;
      }
      test_module_pat = a.slice(9, a.len());
      i = i + 1;
      continue;
    }
    if a == "--module" {
      if cmd != "test" {
        usage();
        print("unknown flag: ".concat(a).concat("\n"));
        return 1;
      }
      if i + 1 >= args.len() {
        usage();
        print("missing value for --module\n");
        return 1;
      }
      test_module_pat = args.get(i + 1);
      i = i + 2;
      continue;
    }
    if a == "-j" || a == "--jobs" {
      if cmd != "test" {
        usage();
        print("unknown flag: ".concat(a).concat("\n"));
        return 1;
      }
      if i + 1 >= args.len() {
        usage();
        print("missing value for --jobs\n");
        return 1;
      }
      let pj: ParseI32Result = parse_i32_decimal(args.get(i + 1));
      if !pj.ok || pj.v <= 0 {
        usage();
        print("invalid --jobs value: ".concat(args.get(i + 1)).concat("\n"));
        return 1;
      }
      test_jobs = pj.v;
      i = i + 2;
      continue;
    }
    if txt.has_prefix(a, "--jobs=") {
      if cmd != "test" {
        usage();
        print("unknown flag: ".concat(a).concat("\n"));
        return 1;
      }
      let pj: ParseI32Result = parse_i32_decimal(a.slice(7, a.len()));
      if !pj.ok || pj.v <= 0 {
        usage();
        print("invalid --jobs value: ".concat(a.slice(7, a.len())).concat("\n"));
        return 1;
      }
      test_jobs = pj.v;
      i = i + 1;
      continue;
    }
    if txt.has_prefix(a, "--filter=") {
      if cmd != "test" {
        usage();
        print("unknown flag: ".concat(a).concat("\n"));
        return 1;
      }
      test_filter = a.slice(9, a.len());
      i = i + 1;
      continue;
    }
    if a == "--filter" {
      if cmd != "test" {
        usage();
        print("unknown flag: ".concat(a).concat("\n"));
        return 1;
      }
      if i + 1 >= args.len() {
        usage();
        print("missing value for --filter\n");
        return 1;
      }
      test_filter = args.get(i + 1);
      i = i + 2;
      continue;
    }
    if a == "--fail-fast" {
      if cmd != "test" {
        usage();
        print("unknown flag: ".concat(a).concat("\n"));
        return 1;
      }
      test_fail_fast = true;
      i = i + 1;
      continue;
    }
    if a == "--list" {
      if cmd != "test" {
        usage();
        print("unknown flag: ".concat(a).concat("\n"));
        return 1;
      }
      test_list_only = true;
      i = i + 1;
      continue;
    }
    if a == "--rerun-failed" {
      if cmd != "test" {
        usage();
        print("unknown flag: ".concat(a).concat("\n"));
        return 1;
      }
      test_rerun_failed = true;
      i = i + 1;
      continue;
    }
    if a == "--json" {
      if cmd != "test" && cmd != "list" {
        usage();
        print("unknown flag: ".concat(a).concat("\n"));
        return 1;
      }
      test_json = true;
      i = i + 1;
      continue;
    }
    if a == "--tests" {
      if cmd != "list" {
        usage();
        print("unknown flag: ".concat(a).concat("\n"));
        return 1;
      }
      list_include_tests = true;
      i = i + 1;
      continue;
    }
    if a == "--no-tests" {
      if cmd != "list" {
        usage();
        print("unknown flag: ".concat(a).concat("\n"));
        return 1;
      }
      list_include_tests = false;
      i = i + 1;
      continue;
    }
    if txt.has_prefix(a, "--target=") {
      if !(cmd.slice(0, cmd.len()) == "build" || cmd.slice(0, cmd.len()) == "test" || cmd.slice(0, cmd.len()) == "run" || cmd.slice(0, cmd.len()) == "install" || cmd.slice(0, cmd.len()) == "list") {
        usage();
        print("unknown flag: ".concat(a).concat("\n"));
        return 1;
      }
      target_flag = a.slice(9, a.len());
      i = i + 1;
      continue;
    }
    if a == "--target" {
      if !(cmd.slice(0, cmd.len()) == "build" || cmd.slice(0, cmd.len()) == "test" || cmd.slice(0, cmd.len()) == "run" || cmd.slice(0, cmd.len()) == "install" || cmd.slice(0, cmd.len()) == "list") {
        usage();
        print("unknown flag: ".concat(a).concat("\n"));
        return 1;
      }
      if i + 1 >= args.len() {
        usage();
        print("missing value for --target\n");
        return 1;
      }
      target_flag = args.get(i + 1);
      i = i + 2;
      continue;
    }
    if txt.has_prefix(a, "--artifact=") {
      if !(cmd.slice(0, cmd.len()) == "build" || cmd.slice(0, cmd.len()) == "run" || cmd.slice(0, cmd.len()) == "install") {
        usage();
        print("unknown flag: ".concat(a).concat("\n"));
        return 1;
      }
      artifact_flag = a.slice(11, a.len());
      i = i + 1;
      continue;
    }
    if a == "--artifact" {
      if !(cmd.slice(0, cmd.len()) == "build" || cmd.slice(0, cmd.len()) == "run" || cmd.slice(0, cmd.len()) == "install") {
        usage();
        print("unknown flag: ".concat(a).concat("\n"));
        return 1;
      }
      if i + 1 >= args.len() {
        usage();
        print("missing value for --artifact\n");
        return 1;
      }
      artifact_flag = args.get(i + 1);
      i = i + 2;
      continue;
    }
    if txt.has_prefix(a, "--emit-c=") {
      if !(cmd.slice(0, cmd.len()) == "build" || cmd.slice(0, cmd.len()) == "test" || cmd.slice(0, cmd.len()) == "run") {
        usage();
        print("unknown flag: ".concat(a).concat("\n"));
        return 1;
      }
      emit_c_enabled = true;
      emit_c_path = a.slice(9, a.len());
      i = i + 1;
      continue;
    }
    if a == "--emit-c" {
      if !(cmd.slice(0, cmd.len()) == "build" || cmd.slice(0, cmd.len()) == "test" || cmd.slice(0, cmd.len()) == "run") {
        usage();
        print("unknown flag: ".concat(a).concat("\n"));
        return 1;
      }
      emit_c_enabled = true;
      i = i + 1;
      continue;
    }
    if txt.has_prefix(a, "-") {
      usage();
      print("unknown flag: ".concat(a).concat("\n"));
      return 1;
    }
    if cmd == "list" {
      usage();
      print("unexpected positional arg for list: ".concat(a).concat("\n"));
      return 1;
    }
    if out != "" {
      usage();
      print("unexpected positional arg for ".concat(cmd).concat(": ").concat(a).concat("\n"));
      return 1;
    }
    out = a;
    i = i + 1;
  }
  if out == "" {
    if cmd == "build" || cmd == "test" || cmd == "run" || cmd == "install" {
      let mut pkg_name: String = "app";
      if fs.exists("vox.toml") {
        let mr: mf.ParseResult = mf.parse(fs.read_to_string("vox.toml"));
        if mr.ok && mr.m.pkg_name != "" {
          pkg_name = sanitize_path_part(mr.m.pkg_name);
        }
      }
      out = path_join("target/debug", pkg_name);
    } else if cmd != "list" {
      usage();
      print("missing out path\n");
      return 1;
    }
  }

  let host_platform: String = tc_detect_platform();
  let mut host_os: String = "linux";
  let mut host_arch: String = "amd64";
  let mut host_sep: i32 = -1;
  let mut hi: i32 = 0;
  while hi < host_platform.len() {
    if host_platform.byte_at(hi) == 45 {
      host_sep = hi;
      hi = host_platform.len();
    } else {
      hi = hi + 1;
    }
  }
  if host_sep >= 0 {
    host_os = host_platform.slice(0, host_sep);
    if host_sep + 1 < host_platform.len() {
      host_arch = host_platform.slice(host_sep + 1, host_platform.len());
    }
  } else if host_platform != "" {
    host_os = host_platform;
  }
  let tr: CliTargetSpec = parse_cli_target_spec(target_flag, host_os, host_arch);
  if !tr.ok {
    usage();
    print(tr.err.concat("\n"));
    return 1;
  }
  let target_os: String = tr.os;
  let target_arch: String = tr.arch;
  let target_ptr: i32 = if target_arch == "x86" || target_arch == "wasm32" { 32 } else { 64 };
  let target_triple: String = tr.triple;
  let target_abi: String = tr.abi;

  let ar: CliArtifactSpec = parse_cli_artifact(artifact_flag);
  if !ar.ok {
    usage();
    print(ar.err.concat("\n"));
    return 1;
  }
  let artifact: String = ar.kind;
  let profile_on: bool = env_truthy(osys.getenv("VOX_PROFILE"));

  if target_os == "wasm" {
    if cmd == "test" && target_abi != "wasi" {
      usage();
      print("invalid --target for test: wasm target requires wasm32-wasi runner mode\n");
      return 1;
    }
    if cmd == "run" && target_abi != "wasi" {
      usage();
      print("invalid --target for run: wasm run requires wasm32-wasi\n");
      return 1;
    }
    if (cmd == "build" || cmd == "run" || cmd == "install") && artifact != "exe" {
      usage();
      print("invalid --artifact for wasm target: expected exe\n");
      return 1;
    }
  }
  if cmd == "run" && target_os != "wasm" && (target_os != host_os || target_arch != host_arch) {
    usage();
    print("invalid --target for run: only host target is supported\n");
    return 1;
  }

  if cmd == "list" {
    let list_paths: Vec[String] = if list_include_tests {
      let list_all_paths: Vec[String] = srcw.walk_vox_files(".");
      let mut filtered_paths: Vec[String] = Vec();
      let mut fpi: i32 = 0;
      while fpi < list_all_paths.len() {
        let p: String = list_all_paths.get(fpi);
        if txt.has_prefix(p, "src/") || txt.has_prefix(p, "tests/") {
          filtered_paths.push(p);
        }
        fpi = fpi + 1;
      }
      filtered_paths
    } else {
      srcw.walk_src_non_test_vox_files(".")
    };
    let src_presence: SrcPresenceResult = detect_src_presence(list_paths);
    let paths: Vec[String] = src_presence.paths;
    let seeded: SeedProjectFilesResult = seed_project_files(src_presence.has_std, src_presence.has_vox, false, false);
    if !seeded.ok {
      print("invalid vox.toml: ".concat(seeded.err).concat("\n"));
      return 1;
    }
    let mut files: Vec[ld.SourceFile] = seeded.files;
    let user: Vec[ld.SourceFile] = load_files(paths);
    let mut ui: i32 = 0;
    while ui < user.len() { files.push(user.get(ui)); ui = ui + 1; }
    let c_paths_kept: BuildCachePathListSigKeep = build_cache_path_list_sig_keep(filter_pkg_c_sources(srcw.walk_c_files(".")), "list-c-files");
    let c_all: Vec[String] = c_paths_kept.paths;
    let c_files_sig: String = c_paths_kept.sig;
    let mut c_user: Vec[ld.SourceFile] = Vec();
    let mut cui_load: i32 = 0;
    while cui_load < c_all.len() {
      let c_path: String = c_all.get(cui_load);
      c_user.push(ld.SourceFile { path: c_path, text: "" });
      cui_load = cui_load + 1;
    }
    let mut cui: i32 = 0;
    while cui < c_user.len() { files.push(c_user.get(cui)); cui = cui + 1; }

    let build_cache_enabled: bool = build_cache_enabled_from_env(osys.getenv("VOX_BUILD_CACHE_DISABLE"));
    let incremental_enabled: bool = incremental_enabled_from_env(osys.getenv("VOX_INCREMENTAL"));
    let cache_enabled: bool = effective_incremental_cache_enabled(build_cache_enabled, incremental_enabled);
    let cache_trace: bool = env_truthy(osys.getenv("VOX_CACHE_TRACE"));
    let use_sem_cache: bool = should_use_sem_cache(cache_enabled, false);
    let compiler_rev: String = bi.version().concat("@").concat(bi.channel());
    let mut sem_key: String = "";
    let mut sem_pkg_keys: Vec[BuildCachePkgKey] = Vec();
    let mut sem_dep_hashes: Vec[q.ParseLoadDepHash] = Vec();
    let mut sem_mode: String = "";
    let mut list_cache_out: String = "";
    let mut sem_cache_hit: bool = false;
    let mut sem_checked: bool = false;
    let list_keys_t0: i64 = tm.now_ns();
    if use_sem_cache {
      sem_checked = true;
      let pkg_keys_result: BuildCachePkgSemSourceKeysResult = build_cache_pkg_sem_source_keys_with_files(files);
      files = pkg_keys_result.files;
      let mut list_mode: String = "";
      list_mode = append_build_mode_line(list_mode, "cmd=", "list");
      list_mode = append_build_mode_line(list_mode, "include_tests=", if list_include_tests { "1" } else { "0" });
      list_mode = append_build_mode_line(list_mode, "target=", target_os.concat("-").concat(target_arch));
      list_mode = append_build_mode_line(list_mode, "target_ptr_bits=", target_ptr.to_string());
      list_mode = append_build_mode_line(list_mode, "format=", if test_json { "json" } else { "text" });
      list_mode = append_build_mode_line(list_mode, "c_files_sig=", c_files_sig);
      list_mode = append_build_mode_line(list_mode, "compiler=", compiler_rev);
      sem_pkg_keys = pkg_keys_result.sem_keys;
      sem_mode = "sem\n".concat(list_mode);
      let sem_keep: BuildCacheSemKeyDepsKeep =
        build_cache_sem_key_dep_hashes_from_pkg_source_keys_keep(
          sem_pkg_keys,
          sem_mode,
        );
      sem_pkg_keys = sem_keep.keys;
      sem_key = sem_keep.sem_key;
      sem_dep_hashes = sem_keep.dep_hashes;
      list_cache_out = path_join(path_join(path_join("target", "cache"), "pkg-sem-v1"), sem_key).concat(if test_json { ".list.json" } else { ".list.txt" });
      sem_cache_hit = build_sem_cache_hit(sem_key);
      if sem_cache_hit && fs.exists(list_cache_out) {
        if profile_on {
          print_profile_list_cache_summary(cache_enabled, incremental_enabled, sem_checked, sem_cache_hit, true);
          print_profile_cache_prep_summary("list", dur_nonneg_ns(list_keys_t0, tm.now_ns()), 0, 0);
        }
        if cache_trace {
          print(
            "[cache] mode=list cache="
              .concat(cache_on_off(cache_enabled))
              .concat(" incremental=").concat(cache_on_off(incremental_enabled))
              .concat(" sem=").concat(cache_hit_miss_skip(sem_cache_hit, sem_checked))
              .concat(" output=").concat(cache_hit_miss(true))
              .concat(" key=").concat(sem_key)
              .concat("\n"),
          );
        }
        print(fs.read_to_string(list_cache_out));
        return 0;
      }
    }
    if profile_on {
      print_profile_list_cache_summary(cache_enabled, incremental_enabled, sem_checked, sem_cache_hit, false);
      print_profile_cache_prep_summary("list", dur_nonneg_ns(list_keys_t0, tm.now_ns()), 0, 0);
    }
    if cache_trace {
      print(
        "[cache] mode=list cache="
          .concat(cache_on_off(cache_enabled))
          .concat(" incremental=").concat(cache_on_off(incremental_enabled))
          .concat(" sem=").concat(cache_hit_miss_skip(sem_cache_hit, sem_checked))
          .concat(" output=").concat(cache_hit_miss(false))
          .concat(" key=").concat(sem_key)
          .concat("\n"),
      );
    }

    let opts: lst.GraphOptions = lst.GraphOptions {
      include_tests: list_include_tests,
      target_os: target_os,
      target_arch: target_arch,
      target_ptr_bits: target_ptr,
    };
    let lr: lst.BuildResult = lst.graph_from_files_with_options(files, opts);
    if !lr.ok {
      print("list failed: ".concat(lr.err).concat("\n"));
      return 1;
    }
    let rendered: String = if test_json {
      lst.graph_to_json(lr.graph).concat("\n")
    } else {
      lst.graph_to_text(lr.graph)
    };
    if use_sem_cache && sem_key != "" {
      if !sem_cache_hit {
        write_build_sem_cache_with_deps(sem_key, sem_dep_hashes);
      }
      fs.mkdir_p(dir_name(list_cache_out));
      let _: bool = write_string_if_changed(list_cache_out, rendered);
    }
    print(rendered);
    return 0;
  }

  if cmd == "build" {
    let src_presence: SrcPresenceResult = detect_src_presence(srcw.walk_src_non_test_vox_files("."));
    let paths: Vec[String] = src_presence.paths;
    let is_self_std: bool = src_presence.has_std;
    let seeded: SeedProjectFilesResult = seed_project_files(src_presence.has_std, src_presence.has_vox, false, false);
    if !seeded.ok {
      print("invalid vox.toml: ".concat(seeded.err).concat("\n"));
      return 1;
    }
    let lock_check: LockVerifyWriteResult = verify_and_write_lockfile_or_err(seeded.resolved);
    if !lock_check.ok {
      print("invalid vox.lock: ".concat(lock_check.err).concat("\n"));
      print("hint: refresh lockfile after dependency changes: remove vox.lock then rerun build/test.\n");
      return 1;
    }
    let mut files: Vec[ld.SourceFile] = seeded.files;
    let user: Vec[ld.SourceFile] = load_files(paths);
    let mut ui: i32 = 0;
    while ui < user.len() { files.push(user.get(ui)); ui = ui + 1; }
    let cache_flags: CacheRuntimeFlags = cache_runtime_flags(trace_exec);
    let build_cache_enabled: bool = cache_flags.build_cache_enabled;
    let incremental_enabled: bool = cache_flags.incremental_enabled;
    let cache_enabled: bool = cache_flags.cache_enabled;
    let query_shadow_on: bool = cache_flags.query_shadow_on;
    let query_shadow_trace: bool = cache_flags.query_shadow_trace;
    let query_shadow_force_prepare: bool = cache_flags.query_shadow_force_prepare;
    let cache_trace: bool = cache_flags.cache_trace;
    let use_sem_cache: bool = should_use_sem_cache(cache_enabled, query_shadow_on);
    let need_c_sources_sig: bool = cache_enabled || query_shadow_on;
    let c_sources_build_loaded: CSourceLoadResult = load_pkg_c_sources_with_optional_sig(need_c_sources_sig);
    let c_sources_build: Vec[String] = c_sources_build_loaded.c_sources;
    let c_sources_sig: String = c_sources_build_loaded.c_sources_sig;
    let out_cpath: String = out.concat(".c");
    let driver_key: String = if driver == cg.DriverMainKind.Tool { "tool" } else { "user" };
    let emit_driver_key: String = if artifact == "exe" { "1" } else { "0" };
    let compiler_rev: String = bi.version().concat("@").concat(bi.channel());
    let mut compile_mode: String =
      build_sem_mode_text(
        "build",
        driver_key,
        emit_driver_key,
        host_os,
        host_arch,
        target_os,
        target_arch,
        target_triple,
        target_abi,
        compiler_rev,
      );
    let mut link_mode: String =
      build_mode_text_without_toolchain(
        "build",
        driver_key,
        emit_driver_key,
        host_os,
        host_arch,
        target_os,
        target_arch,
        target_triple,
        target_abi,
        artifact,
        compiler_rev,
      );
    if cache_enabled {
      let compile_cc: String = cc_cmd_for_target(host_os, host_arch, target_os, target_arch, target_triple, target_abi);
      let compile_use_msvc: bool = cc_is_msvc_cmd(compile_cc);
      let compile_tflags: String = cc_target_flags_for_target(compile_cc, host_os, host_arch, target_os, target_arch, target_triple);
      let compile_cflags: String = cc_common_flags_for_target(target_os, compile_use_msvc);
      let compile_dflags: String = cc_debug_flags(compile_use_msvc);
      let compile_lflags: String = cc_link_flags_for_target(target_os, target_abi, compile_use_msvc, artifact);
      let compile_cc_ver: String = tool_version_fingerprint_line(compile_cc, "cc");
      let mut compile_toolchain: String = "";
      compile_toolchain = append_build_mode_line(compile_toolchain, "cc=", compile_cc);
      compile_toolchain = append_build_mode_line(compile_toolchain, "cc_version=", compile_cc_ver);
      compile_toolchain = append_build_mode_line(compile_toolchain, "cc_target_flags=", compile_tflags);
      compile_toolchain = append_build_mode_line(compile_toolchain, "cc_common_flags=", compile_cflags);
      compile_toolchain = append_build_mode_line(compile_toolchain, "cc_debug_flags=", compile_dflags);
      compile_mode = append_build_mode_line(
        compile_mode,
        "toolchain=",
        compile_toolchain,
      );
      let mut link_toolchain: String = "";
      link_toolchain = append_build_mode_line(link_toolchain, "cc=", compile_cc);
      link_toolchain = append_build_mode_line(link_toolchain, "cc_version=", compile_cc_ver);
      link_toolchain = append_build_mode_line(link_toolchain, "cc_target_flags=", compile_tflags);
      link_toolchain = append_build_mode_line(link_toolchain, "cc_common_flags=", compile_cflags);
      link_toolchain = append_build_mode_line(link_toolchain, "cc_debug_flags=", compile_dflags);
      link_toolchain = append_build_mode_line(link_toolchain, "cc_link_flags=", compile_lflags);
      if artifact == "static" {
        let link_ar: String = ar_cmd_for_target(host_os, target_os, target_arch, target_triple, target_abi);
        let link_ar_ver: String = tool_version_fingerprint_line(link_ar, "ar");
        link_toolchain = append_build_mode_line(link_toolchain, "ar=", link_ar);
        link_toolchain = append_build_mode_line(link_toolchain, "ar_version=", link_ar_ver);
      }
      link_mode =
        build_mode_text_with_toolchain(
          "build",
          driver_key,
          emit_driver_key,
          host_os,
          host_arch,
          target_os,
          target_arch,
          target_triple,
          target_abi,
          artifact,
          compiler_rev,
          link_toolchain,
        );
    }
    if need_c_sources_sig {
      compile_mode = build_mode_with_c_sources_sig(compile_mode, c_sources_sig);
      link_mode = build_mode_with_c_sources_sig(link_mode, c_sources_sig);
    }
    let sem_mode: String =
      "sem\n".concat(
        build_sem_mode_text(
          "build",
          driver_key,
          emit_driver_key,
          host_os,
          host_arch,
          target_os,
          target_arch,
          target_triple,
          target_abi,
          compiler_rev,
        ),
      );
    let emit_opts: cg.EmitOptions = cg.EmitOptions {
      emit_driver_main: artifact == "exe",
      driver_main_kind: driver,
      emit_test_main: false,
      test_funcs: Vec(),
      c_sources: Vec(),
    };
    let cc_target_cmd: String = cc_cmd_for_target(host_os, host_arch, target_os, target_arch, target_triple, target_abi);
    let obj_ext: String = if cc_is_msvc_cmd(cc_target_cmd) { ".obj" } else { ".o" };
    let mut query_shadow_state: q.ParseLoadShadowState = q.ParseLoadShadowState { key: "", predicted_hit: false };
    let mut pkg_keys: Vec[BuildCachePkgKey] = Vec();
    let mut pkg_key_pkgs: Vec[String] = Vec();
    let mut pkg_key_order: Vec[i32] = Vec();
    let mut sem_pkg_keys: Vec[BuildCachePkgKey] = Vec();
    let mut source_sig: String = "";
    let build_keys_t0: i64 = tm.now_ns();
    if query_shadow_on || cache_enabled {
      let pkg_keys_result: BuildCachePkgSourceKeysKeepOrderResult = build_cache_pkg_source_keys_keep_order_with_files(files);
      files = pkg_keys_result.files;
      pkg_keys = pkg_keys_result.keys;
      pkg_key_pkgs = pkg_keys_result.pkgs;
      pkg_key_order = pkg_keys_result.order;
    }
    let mut compile_key: String = "";
    let mut link_key: String = "";
    let mut sem_key: String = "";
    let mut cache_cpath: String = out_cpath;
    let mut cache_obj: String = out.concat(obj_ext);
    let mut cache_bin: String = out;
    let mut compile_c_cache_hit: bool = false;
    let mut compile_reused_sem_c: bool = false;
    let mut compile_cache_hit: bool = false;
    let mut link_cache_hit: bool = false;
    let mut sem_cache_hit: bool = false;
    let mut sem_checked: bool = false;
    let mut sem_key_from_obj_ref: bool = false;
    let mut sem_dep_hashes: Vec[q.ParseLoadDepHash] = Vec();
    if cache_enabled {
      let cache_keys_kept: BuildCacheKeyPairSourceSigKeep =
        build_cache_key_pair_source_sig_from_pkg_source_keys_keep(
          pkg_keys,
          compile_mode,
          link_mode,
        );
      pkg_keys = cache_keys_kept.keys;
      let cache_keys: BuildCacheKeyPair = cache_keys_kept.pair;
      compile_key = cache_keys.compile_key;
      link_key = cache_keys.link_key;
      source_sig = build_cache_source_sig_with_c_sources_sig(cache_keys_kept.source_sig, c_sources_sig);
      cache_cpath = build_cache_obj_path_for_key(compile_key, ".c");
      cache_obj = build_cache_obj_path_for_key(compile_key, obj_ext);
      cache_bin = build_cache_bin_for_key(link_key, target_os);
      compile_c_cache_hit = build_cache_c_hit(compile_key, cache_cpath);
      compile_cache_hit = compile_c_cache_hit && fs.exists(cache_obj);
      link_cache_hit = build_link_cache_hit(link_key, cache_bin);
    }
    let should_lookup_sem_from_obj_ref_build: bool = !compile_c_cache_hit || query_shadow_on;
    if cache_enabled && use_sem_cache && sem_key == "" && compile_key != "" && source_sig != "" && should_lookup_sem_from_obj_ref_build {
      sem_checked = true;
      sem_key = build_cache_lookup_sem_key_from_obj_cache_ref("pkg-obj-v1", compile_key, source_sig);
      if sem_key != "" {
        sem_key_from_obj_ref = true;
        sem_cache_hit = build_sem_cache_hit(sem_key);
      }
    }
    if cache_enabled && use_sem_cache && sem_key == "" && (!compile_c_cache_hit || query_shadow_on) {
      sem_checked = true;
      let sem_keys_keep: BuildCachePkgSemOnlySourceKeysKeepOrderResult =
        build_cache_pkg_sem_source_keys_only_keep_order_with_files(
          files,
          pkg_key_pkgs,
          pkg_key_order,
        );
      files = sem_keys_keep.files;
      pkg_key_pkgs = sem_keys_keep.pkgs;
      pkg_key_order = sem_keys_keep.order;
      sem_pkg_keys = sem_keys_keep.sem_keys;
      let sem_key_keep: BuildCacheSemKeyKeep = build_cache_sem_key_from_pkg_source_keys_keep(sem_pkg_keys, sem_mode);
      sem_pkg_keys = sem_key_keep.keys;
      sem_key = sem_key_keep.sem_key;
      sem_key_from_obj_ref = false;
      sem_cache_hit = build_sem_cache_hit(sem_key);
    }
    let build_keys_ns: i64 = dur_nonneg_ns(build_keys_t0, tm.now_ns());
    let build_probe_t0: i64 = tm.now_ns();
    if cache_enabled && use_sem_cache && sem_cache_hit && !compile_c_cache_hit && sem_key != "" && compile_key != "" && source_sig != "" {
      let sem_c_key_hit: String = build_cache_lookup_c_key_from_sem_cache_ref_with_source_sig(sem_key, source_sig);
      if sem_c_key_hit == compile_key && fs.exists(cache_cpath) {
        compile_c_cache_hit = true;
        let cache_obj_meta: String = path_join(path_join(path_join("target", "cache"), "pkg-obj-v1"), compile_key).concat(".build.cache.key");
        fs.mkdir_p(dir_name(cache_obj_meta));
        let _: bool = write_string_if_changed(cache_obj_meta, compile_key.concat("\n"));
      } else if build_cache_try_reuse_sem_cached_c_with_source_sig(sem_key, compile_key, source_sig, cache_cpath, trace_exec) {
        compile_c_cache_hit = true;
        compile_reused_sem_c = true;
      }
      compile_cache_hit = compile_c_cache_hit && fs.exists(cache_obj);
    }
    let skip_query_shadow_prepare: bool = should_skip_query_shadow_prepare(cache_enabled, compile_c_cache_hit || sem_cache_hit, query_shadow_force_prepare);
    if cache_trace {
      print(
        "[cache] mode=build cache="
          .concat(cache_on_off(cache_enabled))
          .concat(" incremental=").concat(cache_on_off(incremental_enabled))
          .concat(" sem=").concat(cache_hit_miss_skip(sem_cache_hit, sem_checked))
          .concat(" c=").concat(cache_hit_miss(compile_c_cache_hit))
          .concat(" obj=").concat(cache_hit_miss(compile_cache_hit))
          .concat(" link=").concat(cache_hit_miss(link_cache_hit))
          .concat(" sem_c_reuse=").concat(cache_hit_miss(compile_reused_sem_c))
          .concat(" qshadow_skip=").concat(cache_hit_miss(skip_query_shadow_prepare))
          .concat("\n"),
      );
    }
    if query_shadow_on && skip_query_shadow_prepare && query_shadow_trace {
      print("[query-shadow] phase=build skipped prepare (sem-cache hit; set VOX_QUERY_SHADOW_FORCE_PREPARE=1 to force)\n");
    }
    let mut build_qshadow_ns: i64 = 0;
    if query_shadow_on && !skip_query_shadow_prepare {
      let build_qshadow_t0: i64 = tm.now_ns();
      if use_sem_cache && sem_key != "" && !query_shadow_force_prepare {
        let mut qswitches: Vec[String] = Vec();
        qswitches.push("compile_mode=".concat(compile_mode));
        qswitches.push("link_mode=".concat(link_mode));
        qswitches.push("target_triple=".concat(target_triple));
        qswitches.push("target_abi=".concat(target_abi));
        qswitches.push("artifact=".concat(artifact));
        query_shadow_state =
          query_shadow_state_from_sem_key(
            "build",
            sem_key,
            qswitches,
            query_shadow_trace,
          );
      } else {
        let mut qswitches: Vec[String] = Vec();
        qswitches.push("compile_mode=".concat(compile_mode));
        qswitches.push("link_mode=".concat(link_mode));
        qswitches.push("target_triple=".concat(target_triple));
        qswitches.push("target_abi=".concat(target_abi));
        qswitches.push("artifact=".concat(artifact));
        let mut dep_hashes: Vec[q.ParseLoadDepHash] = Vec();
        if use_sem_cache {
          let sem_keep: SemKeyDepHashesKeepOrderResult =
            ensure_sem_key_dep_hashes_with_keep_order(
              files,
              pkg_key_pkgs,
              pkg_key_order,
              sem_pkg_keys,
              sem_mode,
              sem_key,
              sem_cache_hit,
              sem_key_from_obj_ref,
              sem_dep_hashes,
            );
          files = sem_keep.files;
          pkg_key_pkgs = sem_keep.pkgs;
          pkg_key_order = sem_keep.order;
          sem_pkg_keys = sem_keep.sem_pkg_keys;
          sem_key = sem_keep.sem_key;
          sem_key_from_obj_ref = sem_keep.sem_key_from_obj_ref;
          sem_dep_hashes = sem_keep.sem_dep_hashes;
          let mut sdi: i32 = 0;
          while sdi < sem_dep_hashes.len() {
            dep_hashes.push(sem_dep_hashes.get(sdi));
            sdi = sdi + 1;
          }
        } else {
          let mut dhi: i32 = 0;
          while dhi < pkg_keys.len() {
            let pk: BuildCachePkgKey = pkg_keys.get(dhi);
            dep_hashes.push(q.ParseLoadDepHash {
              pkg: pk.pkg,
              export_sig_hash: pk.key,
              type_sig_hash: pk.key,
              impl_sig_hash: pk.key,
            });
            dhi = dhi + 1;
          }
        }
        let qprep: c.CompileQueryShadowPrepareResult =
          c.compile_query_shadow_prepare_for_target_with_files(
            files,
            emit_opts,
            target_ptr,
            target_os,
            target_arch,
            c.CompileQueryShadowOptions {
            enabled: true,
            trace_predicted_hit: query_shadow_trace,
            mode: "build",
            diagnostics_mode: "diag-v0",
            compiler_version: bi.version(),
            compiler_channel: bi.channel(),
            feature_switches: qswitches,
            dep_hashes: dep_hashes,
          },
          );
        files = qprep.files;
        query_shadow_state = qprep.state;
      }
      if query_shadow_trace {
        print(q.parse_load_shadow_trace_line("build", query_shadow_state).concat("\n"));
      }
      build_qshadow_ns = dur_nonneg_ns(build_qshadow_t0, tm.now_ns());
    }
    let build_probe_total_ns: i64 = dur_nonneg_ns(build_probe_t0, tm.now_ns());
    let build_probe_ns: i64 = if build_probe_total_ns >= build_qshadow_ns { build_probe_total_ns - build_qshadow_ns } else { 0 };
    if profile_on {
      print_profile_cache_summary(
        "build",
        cache_enabled,
        incremental_enabled,
        sem_checked,
        sem_cache_hit,
        compile_c_cache_hit,
        "obj",
        compile_cache_hit,
        "link",
        link_cache_hit,
        compile_reused_sem_c,
        skip_query_shadow_prepare,
      );
      print_profile_cache_prep_summary("build", build_keys_ns, build_probe_ns, build_qshadow_ns);
    }
    if !compile_cache_hit {
      if !compile_c_cache_hit {
        let vox_files_keep: KeepVoxSourceFilesResult = keep_vox_source_files_with_input(files);
        files = vox_files_keep.files;
        let cp: c.CompileProfileResult =
          c.compile_files_to_c_profile_for_target_with_extra_c_sources(
            vox_files_keep.vox_files,
            emit_opts,
            c_sources_build,
            target_ptr,
            target_os,
            target_arch,
          );
        let r: c.CompileResult = cp.r;
        if !r.ok {
          print("compile failed: ".concat(r.err).concat("\n"));
          return 1;
        }
        let mut wi: i32 = 0;
        while wi < r.warnings.len() {
          print("[warn] ".concat(r.warnings.get(wi)).concat("\n"));
          wi = wi + 1;
        }
        if profile_on {
          let load_ns: i64 = cp.p.load_ns;
          let macroexpand_ns: i64 = cp.p.macroexpand_ns;
          let rewrite_async_ns: i64 = cp.p.rewrite_async_ns;
          let typecheck_ns: i64 = cp.p.typecheck_ns;
          let typecheck_build_ctx_ns: i64 = cp.p.typecheck_build_ctx_ns;
          let typecheck_build_ctx_validate_imports_ns: i64 = cp.p.typecheck_build_ctx_validate_imports_ns;
          let typecheck_build_ctx_collect_type_aliases_ns: i64 = cp.p.typecheck_build_ctx_collect_type_aliases_ns;
          let typecheck_build_ctx_collect_structs_ns: i64 = cp.p.typecheck_build_ctx_collect_structs_ns;
          let typecheck_build_ctx_collect_enums_ns: i64 = cp.p.typecheck_build_ctx_collect_enums_ns;
          let typecheck_build_ctx_collect_traits_ns: i64 = cp.p.typecheck_build_ctx_collect_traits_ns;
          let typecheck_build_ctx_collect_funcs_ns: i64 = cp.p.typecheck_build_ctx_collect_funcs_ns;
          let typecheck_build_ctx_collect_impls_ns: i64 = cp.p.typecheck_build_ctx_collect_impls_ns;
          let typecheck_build_ctx_collect_async_fns_ns: i64 = cp.p.typecheck_build_ctx_collect_async_fns_ns;
          let typecheck_build_ctx_collect_consts_ns: i64 = cp.p.typecheck_build_ctx_collect_consts_ns;
          let typecheck_build_ctx_collect_statics_ns: i64 = cp.p.typecheck_build_ctx_collect_statics_ns;
          let typecheck_build_ctx_collect_body_type_names_ns: i64 = cp.p.typecheck_build_ctx_collect_body_type_names_ns;
          let typecheck_build_ctx_rebuild_lookup_indexes_ns: i64 = cp.p.typecheck_build_ctx_rebuild_lookup_indexes_ns;
          let typecheck_filter_world_ns: i64 = cp.p.typecheck_filter_world_ns;
          let typecheck_core_ns: i64 = cp.p.typecheck_core_ns;
          let typecheck_core_funcs_ns: i64 = cp.p.typecheck_core_funcs_ns;
          let typecheck_core_impl_methods_ns: i64 = cp.p.typecheck_core_impl_methods_ns;
          let typecheck_core_default_methods_ns: i64 = cp.p.typecheck_core_default_methods_ns;
          let irgen_ns: i64 = cp.p.irgen_ns;
          let ir_verify_ns: i64 = cp.p.ir_verify_ns;
          let codegen_ns: i64 = cp.p.codegen_ns;
          let total_ns: i64 = load_ns + macroexpand_ns + rewrite_async_ns + typecheck_ns + irgen_ns + ir_verify_ns + codegen_ns;
          print("[profile] compile total: ".concat(format_duration_ns(total_ns)).concat("\n"));
          print("[profile] compile load: ".concat(format_duration_ns(load_ns)).concat("\n"));
          print("[profile] compile macroexpand: ".concat(format_duration_ns(macroexpand_ns)).concat("\n"));
          print("[profile] compile rewrite-async: ".concat(format_duration_ns(rewrite_async_ns)).concat("\n"));
          print("[profile] compile typecheck: ".concat(format_duration_ns(typecheck_ns)).concat("\n"));
          print("[profile] compile typecheck/build-ctx: ".concat(format_duration_ns(typecheck_build_ctx_ns)).concat("\n"));
          print("[profile] compile typecheck/build-ctx/validate-imports: ".concat(format_duration_ns(typecheck_build_ctx_validate_imports_ns)).concat("\n"));
          print("[profile] compile typecheck/build-ctx/collect-type-aliases: ".concat(format_duration_ns(typecheck_build_ctx_collect_type_aliases_ns)).concat("\n"));
          print("[profile] compile typecheck/build-ctx/collect-structs: ".concat(format_duration_ns(typecheck_build_ctx_collect_structs_ns)).concat("\n"));
          print("[profile] compile typecheck/build-ctx/collect-enums: ".concat(format_duration_ns(typecheck_build_ctx_collect_enums_ns)).concat("\n"));
          print("[profile] compile typecheck/build-ctx/collect-traits: ".concat(format_duration_ns(typecheck_build_ctx_collect_traits_ns)).concat("\n"));
          print("[profile] compile typecheck/build-ctx/collect-funcs: ".concat(format_duration_ns(typecheck_build_ctx_collect_funcs_ns)).concat("\n"));
          print("[profile] compile typecheck/build-ctx/collect-impls: ".concat(format_duration_ns(typecheck_build_ctx_collect_impls_ns)).concat("\n"));
          print("[profile] compile typecheck/build-ctx/collect-async-fns: ".concat(format_duration_ns(typecheck_build_ctx_collect_async_fns_ns)).concat("\n"));
          print("[profile] compile typecheck/build-ctx/collect-consts: ".concat(format_duration_ns(typecheck_build_ctx_collect_consts_ns)).concat("\n"));
          print("[profile] compile typecheck/build-ctx/collect-statics: ".concat(format_duration_ns(typecheck_build_ctx_collect_statics_ns)).concat("\n"));
          print("[profile] compile typecheck/build-ctx/collect-body-type-names: ".concat(format_duration_ns(typecheck_build_ctx_collect_body_type_names_ns)).concat("\n"));
          print("[profile] compile typecheck/build-ctx/rebuild-lookup-indexes: ".concat(format_duration_ns(typecheck_build_ctx_rebuild_lookup_indexes_ns)).concat("\n"));
          print("[profile] compile typecheck/filter-world: ".concat(format_duration_ns(typecheck_filter_world_ns)).concat("\n"));
          print("[profile] compile typecheck/core: ".concat(format_duration_ns(typecheck_core_ns)).concat("\n"));
          print("[profile] compile typecheck/core/funcs: ".concat(format_duration_ns(typecheck_core_funcs_ns)).concat("\n"));
          print("[profile] compile typecheck/core/impl-methods: ".concat(format_duration_ns(typecheck_core_impl_methods_ns)).concat("\n"));
          print("[profile] compile typecheck/core/default-methods: ".concat(format_duration_ns(typecheck_core_default_methods_ns)).concat("\n"));
          print("[profile] compile irgen: ".concat(format_duration_ns(irgen_ns)).concat("\n"));
          print("[profile] compile ir-verify: ".concat(format_duration_ns(ir_verify_ns)).concat("\n"));
          print("[profile] compile codegen: ".concat(format_duration_ns(codegen_ns)).concat("\n"));
        }
        fs.mkdir_p(dir_name(cache_cpath));
        fs.write_string(cache_cpath, r.c);
        if emit_c_enabled && emit_c_path != "" && emit_c_path != out_cpath {
          fs.mkdir_p(dir_name(emit_c_path));
          fs.write_string(emit_c_path, r.c);
        }
        compile_c_cache_hit = true;
      } else {
        // cache_cpath already has the C source; rebuild object only.
      }
      fs.mkdir_p(dir_name(cache_obj));
      let cc_obj_cmd: String =
        cc_cmd_for_target(
          host_os.slice(0, host_os.len()),
          host_arch.slice(0, host_arch.len()),
          target_os.slice(0, target_os.len()),
          target_arch.slice(0, target_arch.len()),
          target_triple.slice(0, target_triple.len()),
          target_abi.slice(0, target_abi.len()),
        );
      let cc_obj_use_msvc: bool = cc_is_msvc_cmd(cc_obj_cmd);
      let cc_obj_tflags: String =
        cc_target_flags_for_target(
          cc_obj_cmd,
          host_os.slice(0, host_os.len()),
          host_arch.slice(0, host_arch.len()),
          target_os.slice(0, target_os.len()),
          target_arch.slice(0, target_arch.len()),
          target_triple.slice(0, target_triple.len()),
        );
      let cache_obj_tmp: String = tmp_artifact_path(cache_obj);
      let cc_obj_cmdline: String =
        if cc_obj_use_msvc {
          let mut cmd: String = cc_obj_cmd;
          cmd = cmd.concat(" /nologo /TC /std:c11 /Od");
          cmd = cmd.concat(cc_debug_flags(true));
          cmd = cmd.concat(" /c ");
          cmd = cmd.concat(cache_cpath);
          cmd = cmd.concat(" /Fo:");
          cmd = cmd.concat(cache_obj_tmp);
          cmd
        } else {
          let mut cmd: String = cc_obj_cmd;
          cmd = cmd.concat(cc_obj_tflags);
          cmd = cmd.concat(" -std=c11 -O0");
          cmd = cmd.concat(cc_debug_flags(false));
          cmd = cmd.concat(cc_common_flags_for_target(target_os.slice(0, target_os.len()), false));
          cmd = cmd.concat(" -c ");
          cmd = cmd.concat(cache_cpath);
          cmd = cmd.concat(" -o ");
          cmd = cmd.concat(cache_obj_tmp);
          cmd
        };
      let cc_obj_t0: i64 = tm.now_ns();
      let code: i32 = exec_cmd(cc_obj_cmdline, trace_exec);
      let cc_obj_ns: i64 = dur_nonneg_ns(cc_obj_t0, tm.now_ns());
      if profile_on { print("[profile] cc-obj: ".concat(format_duration_ns(cc_obj_ns)).concat("\n")); }
      if code != 0 {
        print("cc failed: ".concat(cc_obj_cmdline).concat("\n"));
        print("cc exit: ".concat(code.to_string()).concat("\n"));
        return 1;
      }
      if !replace_file_host_from_tmp(cache_obj_tmp, cache_obj, trace_exec) {
        print("cc artifact replace failed: ".concat(cache_obj_tmp).concat(" -> ").concat(cache_obj).concat("\n"));
        return 1;
      }
      if cache_enabled {
        let cache_obj_meta: String = path_join(path_join(path_join("target", "cache"), "pkg-obj-v1"), compile_key).concat(".build.cache.key");
        fs.mkdir_p(dir_name(cache_obj_meta));
        let _: bool = write_string_if_changed(cache_obj_meta, compile_key.concat("\n"));
      }
    }
    if !link_cache_hit {
      fs.mkdir_p(dir_name(cache_bin));
      let link_cc: String =
        cc_cmd_for_target(
          host_os.slice(0, host_os.len()),
          host_arch.slice(0, host_arch.len()),
          target_os.slice(0, target_os.len()),
          target_arch.slice(0, target_arch.len()),
          target_triple.slice(0, target_triple.len()),
          target_abi.slice(0, target_abi.len()),
        );
      let link_use_msvc: bool = cc_is_msvc_cmd(link_cc);
      let link_tflags: String =
        cc_target_flags_for_target(
          link_cc,
          host_os.slice(0, host_os.len()),
          host_arch.slice(0, host_arch.len()),
          target_os.slice(0, target_os.len()),
          target_arch.slice(0, target_arch.len()),
          target_triple.slice(0, target_triple.len()),
        );
      let cache_bin_tmp: String = tmp_artifact_path(cache_bin);
      let link_cmdline: String =
        if artifact == "static" {
          let ar: String =
          ar_cmd_for_target(
            host_os.slice(0, host_os.len()),
            target_os.slice(0, target_os.len()),
            target_arch.slice(0, target_arch.len()),
            target_triple.slice(0, target_triple.len()),
            target_abi.slice(0, target_abi.len()),
          );
          if link_use_msvc {
            ar.concat(" /nologo /OUT:").concat(cache_bin_tmp).concat(" ").concat(cache_obj)
          } else {
            ar.concat(" rcs ").concat(cache_bin_tmp).concat(" ").concat(cache_obj)
          }
        } else if link_use_msvc {
          let shared_flag: String = if artifact == "shared" { cc_shared_flag_for_target(target_os.slice(0, target_os.len()), true) } else { "" };
          let mut cmd: String = link_cc;
          cmd = cmd.concat(" /nologo");
          cmd = cmd.concat(shared_flag);
          cmd = cmd.concat(" ");
          cmd = cmd.concat(cache_obj);
          cmd = cmd.concat(" /Fe:");
          cmd = cmd.concat(cache_bin_tmp);
          cmd = cmd.concat(cc_link_flags_for_target(target_os.slice(0, target_os.len()), target_abi.slice(0, target_abi.len()), true, artifact));
          cmd
        } else {
          let shared_flag: String = if artifact == "shared" { cc_shared_flag_for_target(target_os.slice(0, target_os.len()), false) } else { "" };
          let mut cmd: String = link_cc;
          cmd = cmd.concat(link_tflags);
          cmd = cmd.concat(shared_flag);
          cmd = cmd.concat(" ");
          cmd = cmd.concat(cache_obj);
          cmd = cmd.concat(" -o ");
          cmd = cmd.concat(cache_bin_tmp);
          cmd = cmd.concat(cc_link_flags_for_target(target_os.slice(0, target_os.len()), target_abi.slice(0, target_abi.len()), false, artifact));
          cmd
        };
      let link_t0: i64 = tm.now_ns();
      let link_code: i32 = exec_cmd(link_cmdline, trace_exec);
      let link_ns: i64 = dur_nonneg_ns(link_t0, tm.now_ns());
      if profile_on { print("[profile] link: ".concat(format_duration_ns(link_ns)).concat("\n")); }
      if link_code != 0 {
        print("link failed: ".concat(link_cmdline).concat("\n"));
        print("link exit: ".concat(link_code.to_string()).concat("\n"));
        return 1;
      }
      if !replace_file_host_from_tmp(cache_bin_tmp, cache_bin, trace_exec) {
        print("link artifact replace failed: ".concat(cache_bin_tmp).concat(" -> ").concat(cache_bin).concat("\n"));
        return 1;
      }
      if cache_enabled {
        let cache_link_meta: String = path_join(path_join(path_join("target", "cache"), "link-v1"), link_key).concat(".build.cache.key");
        fs.mkdir_p(dir_name(cache_link_meta));
        let _: bool = write_string_if_changed(cache_link_meta, link_key.concat("\n"));
      }
    }
    if cache_enabled {
      let mut cache_bin_src: String = cache_bin;
      if !fs.exists(cache_bin_src) && fs.exists(cache_bin.concat(".exe")) {
        cache_bin_src = cache_bin.concat(".exe");
      }
      let mut out_bin_dst: String = out;
      if !fs.exists(out_bin_dst) && fs.exists(out.concat(".exe")) {
        out_bin_dst = out.concat(".exe");
      }
      if !build_cache_output_copy_hit(out_bin_dst, link_key) {
        if !copy_file_host(cache_bin_src, out, trace_exec) {
          print("build cache copy failed: ".concat(cache_bin_src).concat(" -> ").concat(out).concat("\n"));
          return 1;
        }
        out_bin_dst = out;
        if !fs.exists(out_bin_dst) && fs.exists(out.concat(".exe")) {
          out_bin_dst = out.concat(".exe");
        }
        if link_key != "" {
          let out_bin_meta: String = out_bin_dst.concat(".build.copy.key");
          fs.mkdir_p(dir_name(out_bin_meta));
          let _: bool = write_string_if_changed(out_bin_meta, link_key.concat("\n"));
        }
      }
      if out_cpath != cache_cpath && !build_cache_output_copy_hit(out_cpath, compile_key) {
        fs.mkdir_p(dir_name(out_cpath));
        if !copy_file_host(cache_cpath, out_cpath, trace_exec) {
          fs.write_string(out_cpath, fs.read_to_string(cache_cpath));
        }
        if compile_key != "" {
          let out_c_meta: String = out_cpath.concat(".build.copy.key");
          fs.mkdir_p(dir_name(out_c_meta));
          let _: bool = write_string_if_changed(out_c_meta, compile_key.concat("\n"));
        }
      }
    }
    if compile_c_cache_hit {
      if emit_c_enabled && emit_c_path != "" && emit_c_path != out_cpath && fs.exists(out_cpath) {
        fs.mkdir_p(dir_name(emit_c_path));
        if !copy_file_host(out_cpath, emit_c_path, false) {
          fs.write_string(emit_c_path, fs.read_to_string(out_cpath));
        }
      }
    }
    if use_sem_cache && !sem_cache_hit && sem_key != "" {
      let sem_keep: SemKeyDepHashesKeepOrderResult =
        ensure_sem_key_dep_hashes_with_keep_order(
          files,
          pkg_key_pkgs,
          pkg_key_order,
          sem_pkg_keys,
          sem_mode,
          sem_key,
          sem_cache_hit,
          sem_key_from_obj_ref,
          sem_dep_hashes,
        );
      files = sem_keep.files;
      pkg_key_pkgs = sem_keep.pkgs;
      pkg_key_order = sem_keep.order;
      sem_pkg_keys = sem_keep.sem_pkg_keys;
      sem_key = sem_keep.sem_key;
      sem_key_from_obj_ref = sem_keep.sem_key_from_obj_ref;
      sem_dep_hashes = sem_keep.sem_dep_hashes;
      write_build_sem_cache_with_deps(sem_key, sem_dep_hashes);
    }
    if cache_enabled && use_sem_cache && sem_key != "" && compile_key != "" && source_sig != "" && compile_c_cache_hit {
      write_build_sem_cache_c_ref(sem_key, compile_key, source_sig);
      write_build_cache_sem_ref_for_obj_cache_key("pkg-obj-v1", compile_key, sem_key, source_sig);
    }
    if query_shadow_on && query_shadow_state.key != "" {
      q.parse_load_shadow_write(query_shadow_state.key);
    }
    return 0;
  }
  if cmd == "run" {
    if artifact != "exe" {
      usage();
      print("invalid --artifact for run: expected exe\n");
      return 1;
    }

    let self_bin: String = normalize_host_fs_path(osys.exe_path());
    let mut cmdline: String =
      shell_quote(shell_exec_path(self_bin))
        .concat(" build ")
        .concat(shell_quote(out));
    if driver == cg.DriverMainKind.Tool {
      cmdline = cmdline.concat(" --driver=tool");
    }
    if target_flag != "" {
      cmdline = cmdline.concat(" --target=").concat(shell_quote(target_flag));
    }
    if artifact_flag != "" {
      cmdline = cmdline.concat(" --artifact=").concat(shell_quote(artifact_flag));
    }
    if emit_c_enabled {
      if emit_c_path != "" {
        cmdline = cmdline.concat(" --emit-c=").concat(shell_quote(emit_c_path));
      } else {
        cmdline = cmdline.concat(" --emit-c");
      }
    }
    if trace_exec {
      cmdline = cmdline.concat(" -x");
    }
    let rc_build: i32 = exec_cmd(cmdline, trace_exec);
    if rc_build != 0 {
      print("run build failed\n");
      return rc_build;
    }

    let mut built: String = out;
    if !fs.exists(built) {
      let out_exe: String = out.concat(".exe");
      if fs.exists(out_exe) { built = out_exe; }
    }
    if !fs.exists(built) {
      print("run failed: built binary not found: ".concat(built).concat("\n"));
      return 1;
    }

    let mut run_cmd: String = shell_quote(shell_exec_path(built));
    if target_os == "wasm" && target_abi == "wasi" {
      let mut runner: String = txt.trim_space(osys.getenv("WASM_RUNNER"));
      if runner == "" { runner = "wasmtime"; }
      run_cmd = shell_quote(shell_exec_path(runner)).concat(" ").concat(shell_quote(shell_exec_path(built)));
    }
    return exec_cmd(run_cmd, trace_exec);
  }
  if cmd == "install" {
    if artifact != "exe" {
      usage();
      print("invalid --artifact for install: expected exe\n");
      return 1;
    }
    if target_os != host_os || target_arch != host_arch {
      usage();
      print("invalid --target for install: only host target is supported\n");
      return 1;
    }

    let self_bin: String = normalize_host_fs_path(osys.exe_path());
    let mut cmdline: String =
      shell_quote(shell_exec_path(self_bin))
        .concat(" build ")
        .concat(shell_quote(out));
    if driver == cg.DriverMainKind.Tool {
      cmdline = cmdline.concat(" --driver=tool");
    }
    if target_flag != "" {
      cmdline = cmdline.concat(" --target=").concat(shell_quote(target_flag));
    }
    if trace_exec {
      cmdline = cmdline.concat(" -x");
    }
    let rc_build: i32 = exec_cmd(cmdline, trace_exec);
    if rc_build != 0 {
      print("install build failed\n");
      return rc_build;
    }

    let mut built: String = out;
    if !fs.exists(built) {
      let out_exe: String = out.concat(".exe");
      if fs.exists(out_exe) { built = out_exe; }
    }
    if !fs.exists(built) {
      print("install failed: built binary not found: ".concat(built).concat("\n"));
      return 1;
    }

    let home_h: String = osys.getenv("HOME");
    let home_up: String = osys.getenv("USERPROFILE");
    let home_d: String = osys.getenv("HOMEDRIVE");
    let home_p: String = osys.getenv("HOMEPATH");
    let home_dir: String =
      if home_h != "" {
        home_h
      } else if home_up != "" {
        home_up
      } else if home_d != "" && home_p != "" {
        home_d.concat(home_p)
      } else {
        "."
      };
    let install_dir: String = path_join(path_join(home_dir, ".vox"), "bin");
    fs.mkdir_p(install_dir);
    let mut dst_name: String = "app";
    if fs.exists("vox.toml") {
      let mr: mf.ParseResult = mf.parse(fs.read_to_string("vox.toml"));
      if mr.ok && mr.m.pkg_name != "" {
        dst_name = sanitize_path_part(mr.m.pkg_name);
      }
    }
    if dst_name == "" || dst_name == "_" { dst_name = "app"; }
    if host_is_windows() && !has_suffix(dst_name, ".exe") {
      dst_name = dst_name.concat(".exe");
    }
    let dst: String = path_join(install_dir, dst_name);
    if !copy_file_host(built, dst, trace_exec) {
      print("install failed: copy error\n");
      return 1;
    }
    print("[install] ".concat(dst).concat("\n"));
    return 0;
  }
  if cmd == "test" {
    let incremental_enabled_test: bool = incremental_enabled_from_env(osys.getenv("VOX_INCREMENTAL"));
    let mut src_presence_test: SrcPresenceResult = SrcPresenceResult { has_std: false, has_vox: false, paths: Vec() };
    let mut paths: Vec[String] = Vec();
    let all: Vec[String] = srcw.walk_vox_files(".");
    let mut filtered_test_paths: Vec[String] = Vec();
    let mut fti: i32 = 0;
    while fti < all.len() {
      let p: String = all.get(fti);
      if txt.has_prefix(p, "src/") || txt.has_prefix(p, "tests/") {
        filtered_test_paths.push(p);
      }
      fti = fti + 1;
    }
    src_presence_test = detect_src_presence(filtered_test_paths);
    paths = src_presence_test.paths;

    let rerun_cache_path: String = failed_tests_path(out);
    let prev_failed: Vec[String] = if test_rerun_failed {
      let p: String = rerun_cache_path;
      if !fs.exists(p) {
        Vec()
      } else {
        let file_text: String = fs.read_to_string(p);
        let t: String = txt.trim_space(file_text);
        if t.len() > 0 && t.byte_at(0) == 123 { // '{'
          let mut parsed: Vec[String] = Vec();
          let mut key: String = "tests";
          let mut k: i32 = index_of_from(t, "\"".concat(key).concat("\""), 0);
          if k >= 0 {
            let lb: i32 = index_of_from(t, "[", k);
            let rb: i32 = if lb >= 0 { index_of_from(t, "]", lb + 1) } else { -1 };
            if lb >= 0 && rb >= 0 {
              let arr: String = t.slice(lb + 1, rb);
              let mut i: i32 = 0;
              while i < arr.len() {
                let q0: i32 = index_of_from(arr, "\"", i);
                if q0 < 0 { break; }
                let q1: i32 = index_of_from(arr, "\"", q0 + 1);
                if q1 < 0 { break; }
                parsed.push(arr.slice(q0 + 1, q1));
                i = q1 + 1;
              }
            }
          }
          if parsed.len() == 0 {
            key = "failed_tests";
            k = index_of_from(t, "\"".concat(key).concat("\""), 0);
            if k >= 0 {
              let lb: i32 = index_of_from(t, "[", k);
              let rb: i32 = if lb >= 0 { index_of_from(t, "]", lb + 1) } else { -1 };
              if lb >= 0 && rb >= 0 {
                let arr: String = t.slice(lb + 1, rb);
                let mut i: i32 = 0;
                while i < arr.len() {
                  let q0: i32 = index_of_from(arr, "\"", i);
                  if q0 < 0 { break; }
                  let q1: i32 = index_of_from(arr, "\"", q0 + 1);
                  if q1 < 0 { break; }
                  parsed.push(arr.slice(q0 + 1, q1));
                  i = q1 + 1;
                }
              }
            }
          }
          normalize_failed_tests(parsed)
        } else {
          normalize_failed_tests(split_lines(file_text))
        }
      }
    } else { Vec() };
    if test_rerun_failed && prev_failed.len() == 0 {
      if test_json {
        print_json_report(0, 0, test_module_pat, test_run_pat, test_filter, test_jobs, test_fail_fast, true, 0, false, Vec(), Vec(), Vec(), Vec(), Vec(), Vec(), "", "no previous failed tests", rerun_cache_path, 0, 0, 0, 0);
      } else {
        print("[test] no previous failed tests\n");
      }
      return 0;
    }
    let discovered_result: DiscoverTestsResult = discover_tests_with_paths(paths, incremental_enabled_test);
    let discovered: Vec[String] = discovered_result.tests;
    let cached_discovery_files: Vec[ld.SourceFile] = discovered_result.cached_files;
    paths = discovered_result.paths;
    let discovered_count: i32 = discovered.len();
    let prev_failed_count: i32 = prev_failed.len();
    let mut base: Vec[String] = discovered;
    if test_rerun_failed {
      let mut intersected: Vec[String] = Vec();
      let mut i: i32 = 0;
      while i < base.len() {
        let n: String = base.get(i);
        if txt.contains_str(prev_failed, n) { intersected.push(n); }
        i = i + 1;
      }
      base = intersected;
    }
    let mut by_module: Vec[String] = base;
    if test_module_pat != "" {
      let mut filtered: Vec[String] = Vec();
      let mut i: i32 = 0;
      while i < by_module.len() {
        let name: String = by_module.get(i);
        let module: String = test_module_name(name);
        if glob_match(module, test_module_pat) {
          filtered.push(name);
        }
        i = i + 1;
      }
      by_module = filtered;
    }
    let mut by_run: Vec[String] = by_module;
    if test_run_pat != "" {
      let mut filtered: Vec[String] = Vec();
      let mut i: i32 = 0;
      while i < by_run.len() {
        let name: String = by_run.get(i);
        let mut short: String = name;
        let mut short_i: i32 = name.len() - 1;
        while short_i >= 1 {
          if name.byte_at(short_i - 1) == 58 && name.byte_at(short_i) == 58 {
            short = name.slice(short_i + 1, name.len());
            break;
          }
          short_i = short_i - 1;
        }
        if glob_match(name, test_run_pat) || glob_match(short, test_run_pat) {
          filtered.push(name);
        }
        i = i + 1;
      }
      by_run = filtered;
    }
    let mut tests: Vec[String] = by_run;
    if test_filter != "" {
      let mut filtered: Vec[String] = Vec();
      let mut i: i32 = 0;
      while i < tests.len() {
        let name: String = tests.get(i);
        if text_contains(name, test_filter) { filtered.push(name); }
        i = i + 1;
      }
      tests = filtered;
    }
    if !test_json {
      print("[select] discovered: ".concat(discovered_count.to_string()).concat(", selected: ").concat(tests.len().to_string()).concat("\n"));
      if test_jobs > 0 {
        print("[select] --jobs: ".concat(test_jobs.to_string()).concat("\n"));
      }
      if test_fail_fast {
        print("[select] --fail-fast: true\n");
      }
      if test_module_pat != "" {
        print("[select] --module: \"".concat(test_module_pat).concat("\"\n"));
      }
      if test_run_pat != "" {
        print("[select] --run: \"".concat(test_run_pat).concat("\"\n"));
      }
      if test_filter != "" {
        print("[select] --filter: \"".concat(test_filter).concat("\"\n"));
      }
      if test_rerun_failed {
        print("[select] --rerun-failed: ".concat(prev_failed_count.to_string()).concat(" cached\n"));
      }
    }
    if test_list_only {
      let build_cache_enabled_list: bool = build_cache_enabled_from_env(osys.getenv("VOX_BUILD_CACHE_DISABLE"));
      let incremental_enabled_list: bool = incremental_enabled_from_env(osys.getenv("VOX_INCREMENTAL"));
      let cache_enabled_list: bool = effective_incremental_cache_enabled(build_cache_enabled_list, incremental_enabled_list);
      let mut list_cache_key: String = "";
      if cache_enabled_list {
        let mut tests_for_cache: Vec[String] = Vec();
        let mut tci: i32 = 0;
        while tci < tests.len() {
          tests_for_cache.push(tests.get(tci));
          tci = tci + 1;
        }
        list_cache_key =
          test_list_output_cache_key(
            discovered_result.key,
            tests_for_cache,
            test_module_pat,
            test_run_pat,
            test_filter,
            test_jobs,
            test_fail_fast,
            test_rerun_failed,
            if test_rerun_failed { prev_failed_count } else { 0 },
            test_json,
          );
        if list_cache_key != "" {
          let cached_list_output: TestListOutputCacheReadResult = test_list_output_cache_read(list_cache_key);
          if cached_list_output.hit {
            if profile_on {
              print_profile_test_list_cache_summary(cache_enabled_list, incremental_enabled_list, true);
            }
            print(cached_list_output.text);
            return 0;
          }
        }
      }
      let mut rendered: String = "";
      if test_json {
        let mut tests_for_report: Vec[String] = Vec();
        let mut ti: i32 = 0;
        while ti < tests.len() {
          tests_for_report.push(tests.get(ti));
          ti = ti + 1;
        }
        rendered =
          json_report_text(
            discovered_count,
            tests.len(),
            test_module_pat,
            test_run_pat,
            test_filter,
            test_jobs,
            test_fail_fast,
            test_rerun_failed,
            if test_rerun_failed { prev_failed_count } else { 0 },
            true,
            tests_for_report,
            Vec(),
            Vec(),
            Vec(),
            Vec(),
            Vec(),
            "",
            "",
            rerun_cache_path,
            0,
            0,
            0,
            0,
          ).concat("\n");
      } else {
        let mut names_unsorted: Vec[String] = Vec();
        let mut ti: i32 = 0;
        while ti < tests.len() {
          names_unsorted.push(tests.get(ti));
          ti = ti + 1;
        }
        let names: Vec[String] = sort_strings(names_unsorted);
        let mut rendered_parts: Vec[String] = Vec();
        let mut i: i32 = 0;
        while i < names.len() {
          let module: String = test_module_name(names.get(i));
          let mut j: i32 = i;
          while j < names.len() && test_module_name(names.get(j)) == module {
            j = j + 1;
          }
          rendered_parts.push("[list] ".concat(module).concat(" (").concat((j - i).to_string()).concat(")\n"));
          let mut k: i32 = i;
          while k < j {
            rendered_parts.push("[test] ".concat(names.get(k)).concat("\n"));
            k = k + 1;
          }
          i = j;
        }
        rendered_parts.push("[list] total: ".concat(names.len().to_string()).concat("\n"));
        rendered = rendered_parts.join("");
      }
      if cache_enabled_list && list_cache_key != "" {
        write_test_list_output_cache(list_cache_key, rendered);
      }
      if profile_on {
        print_profile_test_list_cache_summary(cache_enabled_list, incremental_enabled_list, false);
      }
      print(rendered);
      return 0;
    }
    if tests.len() == 0 {
      if test_json {
        print_json_report(discovered_count, 0, test_module_pat, test_run_pat, test_filter, test_jobs, test_fail_fast, test_rerun_failed, if test_rerun_failed { prev_failed_count } else { 0 }, false, Vec(), Vec(), Vec(), Vec(), Vec(), Vec(), "", "no tests found", rerun_cache_path, 0, 0, 0, 0);
      } else {
        print("[test] no tests found\n");
      }
      write_failed_tests(out, Vec());
      return 0;
    }

    let seeded: SeedProjectFilesResult = seed_project_files(src_presence_test.has_std, src_presence_test.has_vox, false, false);
    if !seeded.ok {
      print("invalid vox.toml: ".concat(seeded.err).concat("\n"));
      return 1;
    }
    let lock_check: LockVerifyWriteResult = verify_and_write_lockfile_or_err(seeded.resolved);
    if !lock_check.ok {
      print("invalid vox.lock: ".concat(lock_check.err).concat("\n"));
      print("hint: refresh lockfile after dependency changes: remove vox.lock then rerun build/test.\n");
      return 1;
    }
    let mut files: Vec[ld.SourceFile] = seeded.files;
    let user: Vec[ld.SourceFile] = load_files_with_cached(paths, cached_discovery_files);
    let mut ui: i32 = 0;
    while ui < user.len() { files.push(user.get(ui)); ui = ui + 1; }
    let cache_flags: CacheRuntimeFlags = cache_runtime_flags(trace_exec);
    let build_cache_enabled: bool = cache_flags.build_cache_enabled;
    let incremental_enabled: bool = cache_flags.incremental_enabled;
    let cache_enabled: bool = cache_flags.cache_enabled;
    let query_shadow_on: bool = cache_flags.query_shadow_on;
    let query_shadow_trace: bool = cache_flags.query_shadow_trace;
    let query_shadow_force_prepare: bool = cache_flags.query_shadow_force_prepare;
    let cache_trace: bool = cache_flags.cache_trace;
    let use_sem_cache: bool = should_use_sem_cache(cache_enabled, query_shadow_on);
    let need_c_sources_sig: bool = cache_enabled || query_shadow_on;
    let c_sources_test_loaded: CSourceLoadResult = load_pkg_c_sources_with_optional_sig(need_c_sources_sig);
    let c_sources_test: Vec[String] = c_sources_test_loaded.c_sources;
    let c_sources_sig: String = c_sources_test_loaded.c_sources_sig;

    let compiler_rev: String = bi.version().concat("@").concat(bi.channel());
    let mut test_mode: String =
      if cache_enabled {
        build_mode_text("test", "user", "0", host_os, host_arch, target_os, target_arch, target_triple, target_abi, "exe", compiler_rev)
      } else {
        build_mode_text_without_toolchain("test", "user", "0", host_os, host_arch, target_os, target_arch, target_triple, target_abi, "exe", compiler_rev)
      };
    if need_c_sources_sig {
      test_mode = build_mode_with_c_sources_sig(test_mode, c_sources_sig);
    }
    let sem_mode: String =
      "sem\n".concat(
        build_sem_mode_text(
          "test",
          "user",
          "0",
          host_os,
          host_arch,
          target_os,
          target_arch,
          target_triple,
          target_abi,
          compiler_rev,
        ),
      );
    let mut tests_for_compile: Vec[String] = Vec();
    let emit_test_opts: cg.EmitOptions = cg.EmitOptions {
      emit_driver_main: false,
      driver_main_kind: cg.DriverMainKind.User,
      emit_test_main: true,
      test_funcs: tests_for_compile,
      c_sources: Vec(),
    };
    let mut query_shadow_state: q.ParseLoadShadowState = q.ParseLoadShadowState { key: "", predicted_hit: false };
    let cc_test_cmd: String = cc_cmd_for_target(host_os, host_arch, target_os, target_arch, target_triple, target_abi);
    let cc_test_use_msvc: bool = cc_is_msvc_cmd(cc_test_cmd);
    let test_obj_ext: String = if cc_test_use_msvc { ".obj" } else { ".o" };
    let mut pkg_keys: Vec[BuildCachePkgKey] = Vec();
    let mut pkg_key_pkgs: Vec[String] = Vec();
    let mut pkg_key_order: Vec[i32] = Vec();
    let mut sem_pkg_keys: Vec[BuildCachePkgKey] = Vec();
    let mut source_sig: String = "";
    let test_keys_t0: i64 = tm.now_ns();
    if query_shadow_on || cache_enabled {
      let pkg_keys_result: BuildCachePkgSourceKeysKeepOrderResult = build_cache_pkg_source_keys_keep_order_with_files(files);
      files = pkg_keys_result.files;
      pkg_keys = pkg_keys_result.keys;
      pkg_key_pkgs = pkg_keys_result.pkgs;
      pkg_key_order = pkg_keys_result.order;
    }
    let mut test_build_key: String = "";
    let mut sem_key: String = "";
    let mut test_cache_out: String = "";
    let mut cpath: String = "";
    let mut obj: String = "";
    let mut bin: String = "";
    let mut build_out: String = "";
    let mut build_cpath: String = "";
    let mut build_obj: String = "";
    let mut build_bin: String = "";
    let mut tests_for_nocache: Vec[String] = Vec();
    let mut sem_cache_hit: bool = false;
    let mut sem_key_from_obj_ref: bool = false;
    let mut sem_dep_hashes: Vec[q.ParseLoadDepHash] = Vec();
    if cache_enabled {
      let keys_kept: TestBuildKeySourceSigKeep = test_build_key_source_sig_from_pkg_source_keys_keep(pkg_keys, test_mode);
      pkg_keys = keys_kept.keys;
      test_build_key = keys_kept.test_key;
      source_sig = build_cache_source_sig_with_c_sources_sig(keys_kept.source_sig, c_sources_sig);
      test_cache_out = path_join(path_join(path_join("target", "cache"), "test-link-v1"), test_build_key);
      cpath = path_join(path_join(path_join("target", "cache"), "test-pkg-obj-v1"), test_build_key).concat(".c");
      obj = path_join(path_join(path_join("target", "cache"), "test-pkg-obj-v1"), test_build_key).concat(test_obj_ext);
      bin = test_cache_out;
      build_out = test_cache_out;
      build_cpath = cpath;
      build_obj = obj;
      build_bin = bin;
    } else {
      let mut tni: i32 = 0;
      while tni < tests.len() {
        tests_for_nocache.push(tests.get(tni));
        tni = tni + 1;
      }
      test_cache_out =
        test_nocache_out_path(
          out,
          tests_for_nocache,
          test_module_pat,
          test_run_pat,
          test_filter,
          test_rerun_failed,
          if test_rerun_failed { prev_failed_count } else { 0 },
        );
      cpath = test_cache_out.concat(".c");
      obj = test_cache_out.concat(test_obj_ext);
      bin = test_cache_out;
      build_out = test_cache_out;
      build_cpath = cpath;
      build_obj = obj;
      build_bin = bin;
    }
    let total_tests: i32 = tests.len();
    let mut tests_for_json_report: Vec[String] = Vec();
    if test_json {
      let mut tjr: i32 = 0;
      while tjr < tests.len() {
        tests_for_json_report.push(tests.get(tjr));
        tjr = tjr + 1;
      }
    }
    let mut cache_c_hit: bool = false;
    let mut cache_obj_hit: bool = false;
    let mut cache_hit: bool = false;
    let mut cache_reused_sem_c: bool = false;
    let mut sem_checked: bool = false;
    if cache_enabled {
      let cache_state_result: TestBuildCacheStateResult = test_build_cache_state_with_tests(test_cache_out, test_build_key, cpath, obj, bin, tests);
      tests = cache_state_result.selected;
      cache_c_hit = cache_state_result.c_hit;
      cache_obj_hit = cache_state_result.obj_hit;
      cache_hit = cache_state_result.hit;
      let should_lookup_sem_from_obj_ref_test: bool = !cache_c_hit || query_shadow_on;
      if use_sem_cache && sem_key == "" && test_build_key != "" && source_sig != "" && should_lookup_sem_from_obj_ref_test {
        sem_checked = true;
        sem_key = build_cache_lookup_sem_key_from_obj_cache_ref("test-pkg-obj-v1", test_build_key, source_sig);
        if sem_key != "" {
          sem_key_from_obj_ref = true;
          sem_cache_hit = build_sem_cache_hit(sem_key);
        }
      }
      if use_sem_cache && sem_key == "" && (!cache_c_hit || query_shadow_on) {
        sem_checked = true;
        let sem_keys_keep: BuildCachePkgSemOnlySourceKeysKeepOrderResult =
          build_cache_pkg_sem_source_keys_only_keep_order_with_files(
            files,
            pkg_key_pkgs,
            pkg_key_order,
          );
        files = sem_keys_keep.files;
        pkg_key_pkgs = sem_keys_keep.pkgs;
        pkg_key_order = sem_keys_keep.order;
        sem_pkg_keys = sem_keys_keep.sem_keys;
        let sem_key_keep: BuildCacheSemKeyKeep = build_cache_sem_key_from_pkg_source_keys_keep(sem_pkg_keys, sem_mode);
        sem_pkg_keys = sem_key_keep.keys;
        sem_key = sem_key_keep.sem_key;
        sem_key_from_obj_ref = false;
        sem_cache_hit = build_sem_cache_hit(sem_key);
        if sem_cache_hit && !cache_c_hit && sem_key != "" && test_build_key != "" && source_sig != "" {
          let sem_c_key_hit: String = build_cache_lookup_c_key_from_sem_cache_ref_with_source_sig(sem_key, source_sig);
          if sem_c_key_hit == test_build_key && fs.exists(cpath) {
            cache_c_hit = true;
            cache_obj_hit = fs.exists(obj);
            cache_hit = cache_obj_hit && (fs.exists(bin) || fs.exists(bin.concat(".exe")));
            tests = write_test_build_cache_with_tests(test_cache_out, test_build_key, tests);
            cache_reused_sem_c = true;
          } else if test_build_cache_try_reuse_sem_cached_c_with_source_sig(
            sem_key,
            test_build_key,
            source_sig,
            cpath,
            test_obj_ext,
            tests,
            trace_exec,
          ) {
            cache_c_hit = true;
            cache_reused_sem_c = true;
          }
        }
      }
    }
    let test_keys_ns: i64 = dur_nonneg_ns(test_keys_t0, tm.now_ns());
    let test_probe_t0: i64 = tm.now_ns();
    let skip_query_shadow_prepare: bool = should_skip_query_shadow_prepare(cache_enabled, cache_c_hit || sem_cache_hit, query_shadow_force_prepare);
    if cache_trace {
      print(
        "[cache] mode=test cache="
          .concat(cache_on_off(cache_enabled))
          .concat(" incremental=").concat(cache_on_off(incremental_enabled))
          .concat(" sem=").concat(cache_hit_miss_skip(sem_cache_hit, sem_checked))
          .concat(" c=").concat(cache_hit_miss(cache_c_hit))
          .concat(" obj=").concat(cache_hit_miss(cache_obj_hit))
          .concat(" bin=").concat(cache_hit_miss(cache_hit))
          .concat(" sem_c_reuse=").concat(cache_hit_miss(cache_reused_sem_c))
          .concat(" qshadow_skip=").concat(cache_hit_miss(skip_query_shadow_prepare))
          .concat("\n"),
      );
    }
    if query_shadow_on && skip_query_shadow_prepare && query_shadow_trace {
      print("[query-shadow] phase=test skipped prepare (sem-cache hit; set VOX_QUERY_SHADOW_FORCE_PREPARE=1 to force)\n");
    }
    let mut test_qshadow_ns: i64 = 0;
    if query_shadow_on && !skip_query_shadow_prepare {
      let test_qshadow_t0: i64 = tm.now_ns();
      if use_sem_cache && sem_key != "" && !query_shadow_force_prepare {
        let mut qswitches: Vec[String] = Vec();
        qswitches.push("test_mode=".concat(test_mode));
        qswitches.push("target_triple=".concat(target_triple));
        qswitches.push("target_abi=".concat(target_abi));
        qswitches.push("test_module=".concat(test_module_pat));
        qswitches.push("test_run=".concat(test_run_pat));
        qswitches.push("test_filter=".concat(test_filter));
        qswitches.push("test_rerun_failed=".concat(if test_rerun_failed { "1" } else { "0" }));
        query_shadow_state =
          query_shadow_state_from_sem_key(
            "test",
            sem_key,
            qswitches,
            query_shadow_trace,
          );
      } else {
        let mut qswitches: Vec[String] = Vec();
        qswitches.push("test_mode=".concat(test_mode));
        qswitches.push("target_triple=".concat(target_triple));
        qswitches.push("target_abi=".concat(target_abi));
        qswitches.push("test_module=".concat(test_module_pat));
        qswitches.push("test_run=".concat(test_run_pat));
        qswitches.push("test_filter=".concat(test_filter));
        qswitches.push("test_rerun_failed=".concat(if test_rerun_failed { "1" } else { "0" }));
        let mut dep_hashes: Vec[q.ParseLoadDepHash] = Vec();
        if use_sem_cache {
          let sem_keep: SemKeyDepHashesKeepOrderResult =
            ensure_sem_key_dep_hashes_with_keep_order(
              files,
              pkg_key_pkgs,
              pkg_key_order,
              sem_pkg_keys,
              sem_mode,
              sem_key,
              sem_cache_hit,
              sem_key_from_obj_ref,
              sem_dep_hashes,
            );
          files = sem_keep.files;
          pkg_key_pkgs = sem_keep.pkgs;
          pkg_key_order = sem_keep.order;
          sem_pkg_keys = sem_keep.sem_pkg_keys;
          sem_key = sem_keep.sem_key;
          sem_key_from_obj_ref = sem_keep.sem_key_from_obj_ref;
          sem_dep_hashes = sem_keep.sem_dep_hashes;
          let mut sdi: i32 = 0;
          while sdi < sem_dep_hashes.len() {
            dep_hashes.push(sem_dep_hashes.get(sdi));
            sdi = sdi + 1;
          }
        } else {
          let mut dhi: i32 = 0;
          while dhi < pkg_keys.len() {
            let pk: BuildCachePkgKey = pkg_keys.get(dhi);
            dep_hashes.push(q.ParseLoadDepHash {
              pkg: pk.pkg,
              export_sig_hash: pk.key,
              type_sig_hash: pk.key,
              impl_sig_hash: pk.key,
            });
            dhi = dhi + 1;
          }
        }
        let qprep: c.CompileQueryShadowPrepareResult =
          c.compile_query_shadow_prepare_for_target_with_files(
            files,
            emit_test_opts,
            target_ptr,
            target_os,
            target_arch,
            c.CompileQueryShadowOptions {
            enabled: true,
            trace_predicted_hit: query_shadow_trace,
            mode: "test",
            diagnostics_mode: "diag-v0",
            compiler_version: bi.version(),
            compiler_channel: bi.channel(),
            feature_switches: qswitches,
            dep_hashes: dep_hashes,
          },
          );
        files = qprep.files;
        query_shadow_state = qprep.state;
      }
      if query_shadow_trace {
        print(q.parse_load_shadow_trace_line("test", query_shadow_state).concat("\n"));
      }
      test_qshadow_ns = dur_nonneg_ns(test_qshadow_t0, tm.now_ns());
    }
    let test_probe_total_ns: i64 = dur_nonneg_ns(test_probe_t0, tm.now_ns());
    let test_probe_ns: i64 = if test_probe_total_ns >= test_qshadow_ns { test_probe_total_ns - test_qshadow_ns } else { 0 };
    if profile_on {
      print_profile_cache_summary(
        "test",
        cache_enabled,
        incremental_enabled,
        sem_checked,
        sem_cache_hit,
        cache_c_hit,
        "obj",
        cache_obj_hit,
        "bin",
        cache_hit,
        cache_reused_sem_c,
        skip_query_shadow_prepare,
      );
      print_profile_cache_prep_summary("test", test_keys_ns, test_probe_ns, test_qshadow_ns);
    }
    if !cache_hit {
      if cache_enabled {
        let mut tests_for_stage: Vec[String] = Vec();
        let mut tsi: i32 = 0;
        while tsi < tests.len() {
          tests_for_stage.push(tests.get(tsi));
          tsi = tsi + 1;
        }
        let staged_out: String =
          test_cache_stage_out_path(
            test_cache_out,
            tests_for_stage,
            test_module_pat,
            test_run_pat,
            test_filter,
            test_rerun_failed,
            if test_rerun_failed { prev_failed_count } else { 0 },
          );
        build_out = staged_out;
        build_bin = staged_out;
        build_cpath = if cache_c_hit { cpath } else { staged_out.concat(".c") };
        build_obj = if cache_obj_hit { obj } else { staged_out.concat(test_obj_ext) };
      }
      if !cache_obj_hit {
        if !cache_c_hit {
          tests_for_compile = Vec();
          let mut tco: i32 = 0;
          while tco < tests.len() {
            tests_for_compile.push(tests.get(tco));
            tco = tco + 1;
          }
          let vox_files_keep: KeepVoxSourceFilesResult = keep_vox_source_files_with_input(files);
          files = vox_files_keep.files;
          let cp: c.CompileProfileResult =
            c.compile_files_to_c_profile_for_target_with_extra_c_sources(
              vox_files_keep.vox_files,
              cg.EmitOptions { emit_driver_main: false, driver_main_kind: cg.DriverMainKind.User, emit_test_main: true, test_funcs: tests_for_compile, c_sources: Vec() },
              c_sources_test,
              target_ptr,
              target_os,
              target_arch,
            );
          let r: c.CompileResult = cp.r;
          if !r.ok {
            print("compile failed: ".concat(r.err).concat("\n"));
            return 1;
          }
          let mut wi: i32 = 0;
          while wi < r.warnings.len() {
            print("[warn] ".concat(r.warnings.get(wi)).concat("\n"));
            wi = wi + 1;
          }
          if profile_on {
            let load_ns: i64 = cp.p.load_ns;
            let macroexpand_ns: i64 = cp.p.macroexpand_ns;
            let rewrite_async_ns: i64 = cp.p.rewrite_async_ns;
            let typecheck_ns: i64 = cp.p.typecheck_ns;
            let typecheck_build_ctx_ns: i64 = cp.p.typecheck_build_ctx_ns;
            let typecheck_build_ctx_validate_imports_ns: i64 = cp.p.typecheck_build_ctx_validate_imports_ns;
            let typecheck_build_ctx_collect_type_aliases_ns: i64 = cp.p.typecheck_build_ctx_collect_type_aliases_ns;
            let typecheck_build_ctx_collect_structs_ns: i64 = cp.p.typecheck_build_ctx_collect_structs_ns;
            let typecheck_build_ctx_collect_enums_ns: i64 = cp.p.typecheck_build_ctx_collect_enums_ns;
            let typecheck_build_ctx_collect_traits_ns: i64 = cp.p.typecheck_build_ctx_collect_traits_ns;
            let typecheck_build_ctx_collect_funcs_ns: i64 = cp.p.typecheck_build_ctx_collect_funcs_ns;
            let typecheck_build_ctx_collect_impls_ns: i64 = cp.p.typecheck_build_ctx_collect_impls_ns;
            let typecheck_build_ctx_collect_async_fns_ns: i64 = cp.p.typecheck_build_ctx_collect_async_fns_ns;
            let typecheck_build_ctx_collect_consts_ns: i64 = cp.p.typecheck_build_ctx_collect_consts_ns;
            let typecheck_build_ctx_collect_statics_ns: i64 = cp.p.typecheck_build_ctx_collect_statics_ns;
            let typecheck_build_ctx_collect_body_type_names_ns: i64 = cp.p.typecheck_build_ctx_collect_body_type_names_ns;
            let typecheck_build_ctx_rebuild_lookup_indexes_ns: i64 = cp.p.typecheck_build_ctx_rebuild_lookup_indexes_ns;
            let typecheck_filter_world_ns: i64 = cp.p.typecheck_filter_world_ns;
            let typecheck_core_ns: i64 = cp.p.typecheck_core_ns;
            let typecheck_core_funcs_ns: i64 = cp.p.typecheck_core_funcs_ns;
            let typecheck_core_impl_methods_ns: i64 = cp.p.typecheck_core_impl_methods_ns;
            let typecheck_core_default_methods_ns: i64 = cp.p.typecheck_core_default_methods_ns;
            let irgen_ns: i64 = cp.p.irgen_ns;
            let ir_verify_ns: i64 = cp.p.ir_verify_ns;
            let codegen_ns: i64 = cp.p.codegen_ns;
            let total_ns: i64 = load_ns + macroexpand_ns + rewrite_async_ns + typecheck_ns + irgen_ns + ir_verify_ns + codegen_ns;
            print("[profile] test-compile total: ".concat(format_duration_ns(total_ns)).concat("\n"));
            print("[profile] test-compile load: ".concat(format_duration_ns(load_ns)).concat("\n"));
            print("[profile] test-compile macroexpand: ".concat(format_duration_ns(macroexpand_ns)).concat("\n"));
            print("[profile] test-compile rewrite-async: ".concat(format_duration_ns(rewrite_async_ns)).concat("\n"));
            print("[profile] test-compile typecheck: ".concat(format_duration_ns(typecheck_ns)).concat("\n"));
            print("[profile] test-compile typecheck/build-ctx: ".concat(format_duration_ns(typecheck_build_ctx_ns)).concat("\n"));
            print("[profile] test-compile typecheck/build-ctx/validate-imports: ".concat(format_duration_ns(typecheck_build_ctx_validate_imports_ns)).concat("\n"));
            print("[profile] test-compile typecheck/build-ctx/collect-type-aliases: ".concat(format_duration_ns(typecheck_build_ctx_collect_type_aliases_ns)).concat("\n"));
            print("[profile] test-compile typecheck/build-ctx/collect-structs: ".concat(format_duration_ns(typecheck_build_ctx_collect_structs_ns)).concat("\n"));
            print("[profile] test-compile typecheck/build-ctx/collect-enums: ".concat(format_duration_ns(typecheck_build_ctx_collect_enums_ns)).concat("\n"));
            print("[profile] test-compile typecheck/build-ctx/collect-traits: ".concat(format_duration_ns(typecheck_build_ctx_collect_traits_ns)).concat("\n"));
            print("[profile] test-compile typecheck/build-ctx/collect-funcs: ".concat(format_duration_ns(typecheck_build_ctx_collect_funcs_ns)).concat("\n"));
            print("[profile] test-compile typecheck/build-ctx/collect-impls: ".concat(format_duration_ns(typecheck_build_ctx_collect_impls_ns)).concat("\n"));
            print("[profile] test-compile typecheck/build-ctx/collect-async-fns: ".concat(format_duration_ns(typecheck_build_ctx_collect_async_fns_ns)).concat("\n"));
            print("[profile] test-compile typecheck/build-ctx/collect-consts: ".concat(format_duration_ns(typecheck_build_ctx_collect_consts_ns)).concat("\n"));
            print("[profile] test-compile typecheck/build-ctx/collect-statics: ".concat(format_duration_ns(typecheck_build_ctx_collect_statics_ns)).concat("\n"));
            print("[profile] test-compile typecheck/build-ctx/collect-body-type-names: ".concat(format_duration_ns(typecheck_build_ctx_collect_body_type_names_ns)).concat("\n"));
            print("[profile] test-compile typecheck/build-ctx/rebuild-lookup-indexes: ".concat(format_duration_ns(typecheck_build_ctx_rebuild_lookup_indexes_ns)).concat("\n"));
            print("[profile] test-compile typecheck/filter-world: ".concat(format_duration_ns(typecheck_filter_world_ns)).concat("\n"));
            print("[profile] test-compile typecheck/core: ".concat(format_duration_ns(typecheck_core_ns)).concat("\n"));
            print("[profile] test-compile typecheck/core/funcs: ".concat(format_duration_ns(typecheck_core_funcs_ns)).concat("\n"));
            print("[profile] test-compile typecheck/core/impl-methods: ".concat(format_duration_ns(typecheck_core_impl_methods_ns)).concat("\n"));
            print("[profile] test-compile typecheck/core/default-methods: ".concat(format_duration_ns(typecheck_core_default_methods_ns)).concat("\n"));
            print("[profile] test-compile irgen: ".concat(format_duration_ns(irgen_ns)).concat("\n"));
            print("[profile] test-compile ir-verify: ".concat(format_duration_ns(ir_verify_ns)).concat("\n"));
            print("[profile] test-compile codegen: ".concat(format_duration_ns(codegen_ns)).concat("\n"));
          }

          fs.mkdir_p(dir_name(build_cpath));
          fs.write_string(build_cpath, r.c);
          if emit_c_enabled && emit_c_path != "" && emit_c_path != build_cpath {
            fs.mkdir_p(dir_name(emit_c_path));
            fs.write_string(emit_c_path, r.c);
          }
        }

        fs.mkdir_p(dir_name(build_obj));
        let cc_obj_tflags: String =
          cc_target_flags_for_target(
            cc_test_cmd,
            host_os.slice(0, host_os.len()),
            host_arch.slice(0, host_arch.len()),
            target_os.slice(0, target_os.len()),
            target_arch.slice(0, target_arch.len()),
            target_triple.slice(0, target_triple.len()),
          );
        let obj_tmp: String = tmp_artifact_path(build_obj);
        let cc_obj_cmdline: String =
          if cc_test_use_msvc {
            let mut cmd: String = cc_test_cmd;
            cmd = cmd.concat(" /nologo /TC /std:c11 /Od");
            cmd = cmd.concat(cc_debug_flags(true));
            cmd = cmd.concat(" /c ");
            cmd = cmd.concat(build_cpath);
            cmd = cmd.concat(" /Fo:");
            cmd = cmd.concat(obj_tmp);
            cmd
          } else {
            let mut cmd: String = cc_test_cmd;
            cmd = cmd.concat(cc_obj_tflags);
            cmd = cmd.concat(" -std=c11 -O0");
            cmd = cmd.concat(cc_debug_flags(false));
            cmd = cmd.concat(cc_common_flags_for_target(target_os.slice(0, target_os.len()), false));
            cmd = cmd.concat(" -c ");
            cmd = cmd.concat(build_cpath);
            cmd = cmd.concat(" -o ");
            cmd = cmd.concat(obj_tmp);
            cmd
          };
        let cc_obj_t0: i64 = tm.now_ns();
        let cc_obj_code: i32 = exec_cmd(cc_obj_cmdline, trace_exec);
        let cc_obj_ns: i64 = dur_nonneg_ns(cc_obj_t0, tm.now_ns());
        if profile_on { print("[profile] test-cc-obj: ".concat(format_duration_ns(cc_obj_ns)).concat("\n")); }
        if cc_obj_code != 0 {
          print("cc failed: ".concat(cc_obj_cmdline).concat("\n"));
          print("cc exit: ".concat(cc_obj_code.to_string()).concat("\n"));
          return 1;
        }
        if !replace_file_host_from_tmp(obj_tmp, build_obj, trace_exec) {
          print("test cc artifact replace failed: ".concat(obj_tmp).concat(" -> ").concat(build_obj).concat("\n"));
          return 1;
        }
      }

      fs.mkdir_p(dir_name(build_bin));
      let link_tflags: String =
        cc_target_flags_for_target(
          cc_test_cmd,
          host_os.slice(0, host_os.len()),
          host_arch.slice(0, host_arch.len()),
          target_os.slice(0, target_os.len()),
          target_arch.slice(0, target_arch.len()),
          target_triple.slice(0, target_triple.len()),
        );
      let bin_tmp: String = tmp_artifact_path(build_bin);
      let link_cmdline: String =
        if cc_test_use_msvc {
          let mut cmd: String = cc_test_cmd;
          cmd = cmd.concat(" /nologo ");
          cmd = cmd.concat(build_obj);
          cmd = cmd.concat(" /Fe:");
          cmd = cmd.concat(bin_tmp);
          cmd = cmd.concat(cc_link_flags_for_target(target_os.slice(0, target_os.len()), target_abi.slice(0, target_abi.len()), true, "exe"));
          cmd
        } else {
          let mut cmd: String = cc_test_cmd;
          cmd = cmd.concat(link_tflags);
          cmd = cmd.concat(" ");
          cmd = cmd.concat(build_obj);
          cmd = cmd.concat(" -o ");
          cmd = cmd.concat(bin_tmp);
          cmd = cmd.concat(cc_link_flags_for_target(target_os.slice(0, target_os.len()), target_abi.slice(0, target_abi.len()), false, "exe"));
          cmd
        };
      let link_t0: i64 = tm.now_ns();
      let link_code: i32 = exec_cmd(link_cmdline, trace_exec);
      let link_ns: i64 = dur_nonneg_ns(link_t0, tm.now_ns());
      if profile_on { print("[profile] test-link: ".concat(format_duration_ns(link_ns)).concat("\n")); }
      if link_code != 0 {
        print("link failed: ".concat(link_cmdline).concat("\n"));
        print("link exit: ".concat(link_code.to_string()).concat("\n"));
        return 1;
      }
      if !replace_file_host_from_tmp(bin_tmp, build_bin, trace_exec) {
        print("test link artifact replace failed: ".concat(bin_tmp).concat(" -> ").concat(build_bin).concat("\n"));
        return 1;
      }
      if cache_enabled {
        if !publish_staged_artifact(build_cpath, cpath, trace_exec) {
          print("test staged C publish failed: ".concat(build_cpath).concat(" -> ").concat(cpath).concat("\n"));
          return 1;
        }
        if !publish_staged_artifact(build_obj, obj, trace_exec) {
          print("test staged obj publish failed: ".concat(build_obj).concat(" -> ").concat(obj).concat("\n"));
          return 1;
        }
        if !publish_staged_artifact_keep_source(build_bin, bin, trace_exec) {
          print("test staged bin publish failed: ".concat(build_bin).concat(" -> ").concat(bin).concat("\n"));
          return 1;
        }
      }
      if cache_enabled && (!cache_c_hit || cache_reused_sem_c) {
        tests = write_test_build_cache_with_tests(test_cache_out, test_build_key, tests);
      }
    }
    if cache_hit || cache_c_hit {
      if emit_c_enabled && emit_c_path != "" && emit_c_path != cpath && fs.exists(cpath) {
        fs.mkdir_p(dir_name(emit_c_path));
        if !copy_file_host(cpath, emit_c_path, false) {
          fs.write_string(emit_c_path, fs.read_to_string(cpath));
        }
      }
    }
    if use_sem_cache && !sem_cache_hit && sem_key != "" {
      let sem_keep: SemKeyDepHashesKeepOrderResult =
        ensure_sem_key_dep_hashes_with_keep_order(
          files,
          pkg_key_pkgs,
          pkg_key_order,
          sem_pkg_keys,
          sem_mode,
          sem_key,
          sem_cache_hit,
          sem_key_from_obj_ref,
          sem_dep_hashes,
        );
      files = sem_keep.files;
      pkg_key_pkgs = sem_keep.pkgs;
      pkg_key_order = sem_keep.order;
      sem_pkg_keys = sem_keep.sem_pkg_keys;
      sem_key = sem_keep.sem_key;
      sem_key_from_obj_ref = sem_keep.sem_key_from_obj_ref;
      sem_dep_hashes = sem_keep.sem_dep_hashes;
      write_build_sem_cache_with_deps(sem_key, sem_dep_hashes);
    }
    if cache_enabled && use_sem_cache && sem_key != "" && test_build_key != "" && source_sig != "" && cache_c_hit {
      write_build_sem_cache_c_ref(sem_key, test_build_key, source_sig);
      write_build_cache_sem_ref_for_obj_cache_key("test-pkg-obj-v1", test_build_key, sem_key, source_sig);
    }
    if query_shadow_on && query_shadow_state.key != "" {
      q.parse_load_shadow_write(query_shadow_state.key);
    }

    // Run tests by module-level parallel queues, keeping module-internal order.
    let mut test_runner_cmd: String = "";
    if target_os == "wasm" && target_abi == "wasi" {
      test_runner_cmd = txt.trim_space(osys.getenv("WASM_RUNNER"));
      if test_runner_cmd == "" { test_runner_cmd = "wasmtime"; }
    }
    let run_start_ns: i64 = tm.now_ns();
    let mut passed: i32 = 0;
    let mut failed: i32 = 0;
    let mut failed_names: Vec[String] = Vec();
    let mut results: Vec[TestRunResult] = Vec();
    let mut queues: Vec[ModuleQueue] = build_module_queues(tests);
    let mut module_summaries: Vec[ModuleSummary] = Vec();
    let mut module_details: Vec[ModuleDetail] = Vec();
    let mut module_busy: Vec[bool] = Vec();
    let mut slowest: Vec[NamedDuration] = Vec();
    let mut qsi: i32 = 0;
    while qsi < queues.len() {
      let q: ModuleQueue = queues.get(qsi);
      module_summaries.push(ModuleSummary { module: q.module.slice(0, q.module.len()), passed: 0, failed: 0, dur_ns: 0 });
      module_details.push(ModuleDetail {
        module: q.module,
        tests: Vec(),
        failed_tests: Vec(),
        passed: 0,
        failed: 0,
        dur_ns: 0,
      });
      module_busy.push(false);
      qsi = qsi + 1;
    }
    let mut running: Vec[RunningJob] = Vec();
    let mut launch_seq: i32 = 0;
    let mut stop_launch: bool = false;
    let mut fail_fast_announced: bool = false;
    let run_dir: String = path_join("target/debug", ".vox_test_jobs_".concat(run_start_ns.to_string()));
    fs.mkdir_p(run_dir);
    while passed + failed < total_tests {
      while !stop_launch && running.len() < test_jobs {
        let mut qi: i32 = -1;
        let mut qpi: i32 = 0;
        while qpi < queues.len() {
          let q: ModuleQueue = queues.get(qpi);
          if q.next < q.tests.len() {
            if !module_busy.get(qpi) {
              qi = qpi;
              qpi = queues.len();
            } else {
              qpi = qpi + 1;
            }
          } else {
            qpi = qpi + 1;
          }
        }
        if qi < 0 { break; }
        let q: ModuleQueue = queues.get(qi);
        let name: String = q.tests.get(q.next);
        queues.set(qi, ModuleQueue { module: q.module, tests: q.tests, next: q.next + 1 });
        let tag: String = qi.to_string().concat("_").concat(launch_seq.to_string());
        let rc_file: String = path_join(run_dir, "job_".concat(tag).concat(".rc"));
        let log_file: String = path_join(run_dir, "job_".concat(tag).concat(".log"));
        let bin_exec: String = shell_exec_path(build_bin);
        let mut cmd_head: String = shell_quote(bin_exec).concat(" ").concat(shell_quote(name));
        let mut cmd_head_win: String = bin_exec.concat(" ").concat(name);
        let trimmed_runner_cmd: String = txt.trim_space(test_runner_cmd);
        if trimmed_runner_cmd != "" {
          let re: String = shell_exec_path(trimmed_runner_cmd);
          cmd_head = shell_quote(re).concat(" ").concat(shell_quote(bin_exec)).concat(" ").concat(shell_quote(name));
          cmd_head_win = re.concat(" ").concat(bin_exec).concat(" ").concat(name);
        }
        let log_redir: String = " > ".concat(shell_quote(shell_exec_path(log_file))).concat(" 2>&1");
        if host_is_windows() {
          let run_cmd_win: String = cmd_head_win.concat(" > ").concat(shell_exec_path(log_file)).concat(" 2>&1");
          let rc: i32 = exec_cmd(run_cmd_win, trace_exec);
          fs.write_string(rc_file, if rc == 0 { "0" } else { "1" });
        } else {
          let run_cmd: String =
            cmd_head.concat(log_redir)
              .concat(" && echo 0 > ").concat(shell_quote(shell_exec_path(rc_file)))
              .concat(" || echo 1 > ").concat(shell_quote(shell_exec_path(rc_file)));
          let bg_cmd: String = "( ".concat(run_cmd).concat(" ) &");
          let _rc: i32 = exec_cmd(bg_cmd, trace_exec);
        }
        let job: RunningJob = RunningJob {
          module_idx: qi,
          name: name,
          rc_file: rc_file,
          log_file: log_file,
          start_ns: tm.now_ns(),
        };
        module_busy.set(qi, true);
        running.push(job);
        launch_seq = launch_seq + 1;
      }

      let mut has_pending: bool = false;
      let mut qpn: i32 = 0;
      while qpn < queues.len() {
        let q: ModuleQueue = queues.get(qpn);
        if q.next < q.tests.len() {
          has_pending = true;
          qpn = queues.len();
        } else {
          qpn = qpn + 1;
        }
      }
      if running.len() == 0 && (!has_pending || stop_launch) { break; }

      let mut next_running: Vec[RunningJob] = Vec();
      let mut completed: bool = false;
      let mut i: i32 = 0;
      while i < running.len() {
        let job: RunningJob = running.get(i);
        if fs.exists(job.rc_file) {
          let rc_text: String = fs.read_to_string(job.rc_file);
          let prc: ParseI32Result = parse_i32_decimal(rc_text);
          if !prc.ok {
            // File may exist before shell write is fully visible; poll again.
            next_running.push(job);
            i = i + 1;
            continue;
          }
          completed = true;
          module_busy.set(job.module_idx, false);
          let rc: i32 = prc.v;
          let dur_ns: i64 = dur_nonneg_ns(job.start_ns, tm.now_ns());
          if rc != 0 {
            failed = failed + 1;
            failed_names.push(job.name);
            if test_fail_fast && !stop_launch {
              stop_launch = true;
            }
            module_summaries = update_module_summary_idx(module_summaries, job.module_idx, false, dur_ns);
            module_details = update_module_detail_idx(module_details, job.module_idx, job.name, false, dur_ns);
            let module_name: String = test_module_name(job.name);
            slowest = slowest_insert(slowest, NamedDuration { name: job.name, module: module_name.slice(0, module_name.len()), dur_ns: dur_ns });
            results.push(TestRunResult { name: job.name, module: module_name, ok: false, dur_ns: dur_ns, err: "test failed", log_file: job.log_file });
            if !test_json {
              print("[FAIL] ".concat(job.name).concat(" (").concat(format_duration_ns(dur_ns)).concat(")\n"));
              if fs.exists(job.log_file) {
                let log_text: String = fs.read_to_string(job.log_file);
                if txt.trim_space(log_text) != "" {
                  print("[log] ".concat(job.name).concat(":\n"));
                  print(log_text);
                  if !has_suffix(log_text, "\n") {
                    print("\n");
                  }
                }
              }
              if test_fail_fast && !fail_fast_announced {
                print("[test] fail-fast: stop scheduling remaining tests\n");
                fail_fast_announced = true;
              }
            }
          } else {
            passed = passed + 1;
            module_summaries = update_module_summary_idx(module_summaries, job.module_idx, true, dur_ns);
            module_details = update_module_detail_idx(module_details, job.module_idx, job.name, true, dur_ns);
            let module_name: String = test_module_name(job.name);
            slowest = slowest_insert(slowest, NamedDuration { name: job.name, module: module_name.slice(0, module_name.len()), dur_ns: dur_ns });
            results.push(TestRunResult { name: job.name, module: module_name, ok: true, dur_ns: dur_ns, err: "", log_file: "" });
            if !test_json { print("[OK] ".concat(job.name).concat(" (").concat(format_duration_ns(dur_ns)).concat(")\n")); }
          }
        } else {
          next_running.push(job);
        }
        i = i + 1;
      }
      running = next_running;

      if !completed {
        // Yield the current timeslice to avoid busy-spin when no job completed.
        tm.yield_now();
      }
    }
    let total_ns: i64 = dur_nonneg_ns(run_start_ns, tm.now_ns());
    let skipped: i32 = total_tests - (passed + failed);
    let results_sorted: Vec[TestRunResult] = sort_test_results(results);
    let module_summaries_sorted: Vec[ModuleSummary] = sort_module_summaries_if_needed(module_summaries);
    let module_details_sorted: Vec[ModuleDetail] = sort_module_details(module_details);
    let failed_names_sorted: Vec[String] = write_failed_tests(out, failed_names);
    let hint: String = if failed != 0 {
      let exe_name: String = pth.base_name(osys.exe_path());
      let mut cmd: String = exe_name.concat(" test --rerun-failed");
      if test_jobs > 1 {
        cmd = cmd.concat(" --jobs=").concat(test_jobs.to_string());
      }
      if test_fail_fast {
        cmd = cmd.concat(" --fail-fast");
      }
      cmd.concat(" ").concat(out)
    } else {
      ""
    };
    if test_json {
      print_json_report(discovered_count, total_tests, test_module_pat, test_run_pat, test_filter, test_jobs, test_fail_fast, test_rerun_failed, if test_rerun_failed { prev_failed_count } else { 0 }, false, tests_for_json_report, results_sorted, module_summaries_sorted, module_details_sorted, slowest, failed_names_sorted, hint, "", rerun_cache_path, passed, failed, skipped, total_ns);
    } else {
      let mut msi: i32 = 0;
      while msi < module_summaries_sorted.len() {
        let s: ModuleSummary = module_summaries_sorted.get(msi);
        print("[module] ".concat(s.module).concat(": ").concat(s.passed.to_string()).concat(" passed, ").concat(s.failed.to_string()).concat(" failed (").concat(format_duration_ns(s.dur_ns)).concat(")\n"));
        msi = msi + 1;
      }
      let mut si: i32 = 0;
      while si < slowest.len() {
        let x: NamedDuration = slowest.get(si);
        print("[slowest] ".concat(x.name).concat(" (").concat(format_duration_ns(x.dur_ns)).concat(")\n"));
        si = si + 1;
      }
      let mut summary: String = "[test] ".concat(passed.to_string()).concat(" passed, ").concat(failed.to_string()).concat(" failed");
      if skipped > 0 {
        summary = summary.concat(", ").concat(skipped.to_string()).concat(" skipped");
        if test_fail_fast {
          summary = summary.concat(" (fail-fast)");
        }
      }
      print(summary.concat("\n"));
      print("[time] total: ".concat(format_duration_ns(total_ns)).concat("\n"));
      if failed != 0 {
        print("[hint] rerun failed: ".concat(hint).concat("\n"));
      }
    }
    if failed != 0 { return 1; }
    return 0;
  }

  usage();
  print("unknown command\n");
  return 1;
}
