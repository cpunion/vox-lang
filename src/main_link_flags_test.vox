import "std/testing" as t

fn test_cc_link_flags_for_target_darwin_exe_sets_stack_size() -> () {
  let flags: String = cc_link_flags_for_target("darwin", "", false, "exe");
  t.assert(text_contains(flags, "-Wl,-stack_size,0x4000000"));
}

fn test_cc_link_flags_for_target_darwin_non_exe_empty() -> () {
  let flags_static: String = cc_link_flags_for_target("darwin", "", false, "static");
  let flags_shared: String = cc_link_flags_for_target("darwin", "", false, "shared");
  t.assert_eq(flags_static, "");
  t.assert_eq(flags_shared, "");
}
