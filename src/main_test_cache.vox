fn build_cache_output_copy_hit(out_path: String, key: String) -> bool {
  if key == "" { return false; }
  if !fs.exists(out_path) { return false; }
  let meta: String = build_cache_output_copy_meta_path(out_path);
  if !fs.exists(meta) { return false; }
  let cur: String = txt.trim_space(fs.read_to_string(meta));
  return cur == key;
}

