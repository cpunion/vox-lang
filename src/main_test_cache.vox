struct DiscoverTestsCacheKeyFromTestPathsKeep {
  key: String,
  test_files: Vec[ld.SourceFile],
}

fn discover_tests_cache_key_from_test_paths_keep(paths0: Vec[String]) -> DiscoverTestsCacheKeyFromTestPathsKeep {
  let mut h: u64 = 1469598103934665603 as u64;
  h = lock_hash_text(h, "discover-tests-cache-v1\n");
  let paths: Vec[String] = sort_strings_if_needed(paths0);
  let mut test_files: Vec[ld.SourceFile] = Vec();
  let mut j: i32 = 0;
  while j < paths.len() {
    let pth: String = paths.get(j);
    let text: String = fs.read_to_string(pth);
    test_files.push(ld.SourceFile { path: pth, text: text });
    h = lock_hash_text(h, "P\n");
    h = lock_hash_text(h, pth);
    h = lock_hash_text(h, "\n");
    h = lock_hash_text(h, text);
    h = lock_hash_text(h, "\n");
    j = j + 1;
  }
  return DiscoverTestsCacheKeyFromTestPathsKeep { key: h.to_string(), test_files: test_files };
}

fn parse_discover_tests_cache_list(text: String) -> Vec[String] {
  let lines: Vec[String] = txt.split_lines(text);
  let mut out: Vec[String] = Vec();
  let mut i: i32 = 0;
  while i < lines.len() {
    let s: String = txt.trim_space(lines.get(i));
    if s != "" { out.push(s); }
    i = i + 1;
  }
  return out;
}

struct FormatDiscoverTestsCacheListResult {
  tests: Vec[String],
  text: String,
}

fn format_discover_tests_cache_list_with_tests(tests0: Vec[String]) -> FormatDiscoverTestsCacheListResult {
  let tests: Vec[String] = tests0;
  let mut tests_copy: Vec[String] = Vec();
  let mut ci: i32 = 0;
  while ci < tests.len() {
    tests_copy.push(tests.get(ci));
    ci = ci + 1;
  }
  let tests_sorted: Vec[String] = sort_strings_if_needed(tests_copy);
  let mut out: String = "";
  let mut i: i32 = 0;
  while i < tests_sorted.len() {
    out = out.concat(tests_sorted.get(i)).concat("\n");
    i = i + 1;
  }
  return FormatDiscoverTestsCacheListResult { tests: tests, text: out };
}

fn discover_tests_cached_with_paths(paths0: Vec[String]) -> DiscoverTestsResult {
  let paths: Vec[String] = paths0;
  let mut test_paths: Vec[String] = Vec();
  let mut pi: i32 = 0;
  while pi < paths.len() {
    let p: String = paths.get(pi);
    if is_test_file_for_discovery(p) { test_paths.push(p); }
    pi = pi + 1;
  }
  let key_result: DiscoverTestsCacheKeyFromTestPathsKeep = discover_tests_cache_key_from_test_paths_keep(test_paths);
  let key: String = key_result.key;
  let key_path: String = discover_tests_cache_key_path();
  let list_path: String = discover_tests_cache_list_path();
  if fs.exists(key_path) && fs.exists(list_path) {
    let cached_key: String = txt.trim_space(fs.read_to_string(key_path));
    if cached_key == key {
      return DiscoverTestsResult { paths: paths, tests: parse_discover_tests_cache_list(fs.read_to_string(list_path)), cached_files: key_result.test_files };
    }
  }
  let discovered: DiscoverTestsResult = discover_tests_from_cached_test_files(paths, key_result.test_files);
  let paths_out: Vec[String] = discovered.paths;
  let tests: Vec[String] = discovered.tests;
  fs.mkdir_p("target/debug");
  let formatted: FormatDiscoverTestsCacheListResult = format_discover_tests_cache_list_with_tests(tests);
  let _: bool = write_string_if_changed(key_path, key.concat("\n"));
  let _: bool = write_string_if_changed(list_path, formatted.text);
  let tests_out: Vec[String] = formatted.tests;
  return DiscoverTestsResult { paths: paths_out, tests: tests_out, cached_files: discovered.cached_files };
}

fn discover_tests_cached_fast_with_paths(paths0: Vec[String]) -> DiscoverTestsResult {
  let paths: Vec[String] = paths0;
  let key_path: String = discover_tests_cache_key_path();
  let list_path: String = discover_tests_cache_list_path();
  if fs.exists(key_path) && fs.exists(list_path) {
    return DiscoverTestsResult { paths: paths, tests: parse_discover_tests_cache_list(fs.read_to_string(list_path)), cached_files: Vec() };
  }
  return discover_tests_cached_with_paths(paths);
}
