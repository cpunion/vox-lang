  if target_os == "wasm" { return out.concat(".wasm"); }
  return out.concat(".bin");
}

struct BuildCachePkgKey {
  pkg: String,
  key: String,
}

struct BuildCacheKeyPair {
  compile_key: String,
  link_key: String,
}

struct BuildCacheKeyPairKeep {
  keys: Vec[BuildCachePkgKey],
  pair: BuildCacheKeyPair,
}

struct BuildCachePkgSourceKeysResult {
  files: Vec[ld.SourceFile],
  keys: Vec[BuildCachePkgKey],
}

struct BuildCachePkgSemSourceKeysResult {
  files: Vec[ld.SourceFile],
  keys: Vec[BuildCachePkgKey],
  sem_keys: Vec[BuildCachePkgKey],
}

fn build_cache_pkg_from_source_path(path: String) -> String {
  if txt.has_prefix(path, "src/") || txt.has_prefix(path, "tests/") || txt.has_prefix(path, "std/") || txt.has_prefix(path, "examples/") || txt.has_prefix(path, "target/") {
    return "main";
  }
  let mut slash: i32 = 0;
  while slash < path.len() {
    if path.byte_at(slash) == 47 { // '/'
      break;
    }
    slash = slash + 1;
  }
  if slash > 0 && slash + 5 <= path.len() && path.slice(slash + 1, slash + 5) == "src/" {
    return "pkg/".concat(path.slice(0, slash));
  }
  let mp: String = ld.mod_path_from_file_path(path);
  if !txt.has_prefix(mp, "pkg/") { return "main"; }
  let mut i: i32 = 4; // after "pkg/"
  while i < mp.len() {
    if mp.byte_at(i) == 47 { // '/'
      return mp.slice(0, i);
    }
    i = i + 1;
  }
  return mp;
}

fn source_file_order_by_pkg_path_with_files(files0: Vec[ld.SourceFile]) -> SourceFilePkgOrderResult {
  let files: Vec[ld.SourceFile] = files0;
  let mut pkgs: Vec[String] = Vec();
  let mut order: Vec[i32] = Vec();
  let mut i: i32 = 0;
  while i < files.len() {
    pkgs.push(build_cache_pkg_from_source_path(files.get(i).path));
    order.push(i);
    i = i + 1;
  }

  let mut sorted: bool = true;
  i = 1;
  while i < order.len() {
    let prev_idx: i32 = order.get(i - 1);
    let cur_idx: i32 = order.get(i);
    let prev_pkg: String = pkgs.get(prev_idx);
    let cur_pkg: String = pkgs.get(cur_idx);
    let prev_path: String = files.get(prev_idx).path;
    let cur_path: String = files.get(cur_idx).path;
    if prev_pkg > cur_pkg || (prev_pkg == cur_pkg && prev_path > cur_path) {
      sorted = false;
      break;
    }
    i = i + 1;
  }
  if sorted {
    return SourceFilePkgOrderResult { files: files, pkgs: pkgs, order: order };
  }

  let mut gap: i32 = order.len() / 2;
  while gap > 0 {
    let mut oi: i32 = gap;
    while oi < order.len() {
      let keep: i32 = order.get(oi);
      let keep_pkg: String = pkgs.get(keep);
      let keep_path: String = files.get(keep).path;
      let mut j: i32 = oi;
      while j >= gap {
        let prev: i32 = order.get(j - gap);
        let prev_pkg: String = pkgs.get(prev);
        let prev_path: String = files.get(prev).path;
        if prev_pkg < keep_pkg || (prev_pkg == keep_pkg && prev_path <= keep_path) { break; }
        order.set(j, prev);
        j = j - gap;
      }
      order.set(j, keep);
      oi = oi + 1;
    }
    gap = gap / 2;
  }

  return SourceFilePkgOrderResult { files: files, pkgs: pkgs, order: order };
}

fn build_cache_pkg_sem_source_keys_with_files(files0: Vec[ld.SourceFile]) -> BuildCachePkgSemSourceKeysResult {
  let ordered: SourceFilePkgOrderResult = source_file_order_by_pkg_path_with_files(files0);
  let files: Vec[ld.SourceFile] = ordered.files;
  let pkgs: Vec[String] = ordered.pkgs;
  let order: Vec[i32] = ordered.order;

  let mut out: Vec[BuildCachePkgKey] = Vec();
  let mut sem_out: Vec[BuildCachePkgKey] = Vec();
  let mut has_cur: bool = false;
  let mut cur_pkg: String = "";
  let mut cur_h: u64 = 0 as u64;
  let mut cur_sem_h: u64 = 0 as u64;
  let mut oi: i32 = 0;
  while oi < order.len() {
    let idx: i32 = order.get(oi);
    let f: ld.SourceFile = files.get(idx);
    let pkg: String = pkgs.get(idx);
    if !has_cur || pkg != cur_pkg {
      if has_cur {
        out.push(BuildCachePkgKey { pkg: cur_pkg, key: cur_h.to_string() });
        sem_out.push(BuildCachePkgKey { pkg: cur_pkg, key: cur_sem_h.to_string() });
      }
      cur_pkg = pkg;
      cur_h = 1469598103934665603 as u64;
      cur_h = lock_hash_text(cur_h, "build-cache-pkg-src-v1\n");
      cur_h = lock_hash_text(cur_h, cur_pkg);
      cur_h = lock_hash_text(cur_h, "\n");
      cur_sem_h = cur_h;
      has_cur = true;
    }
    cur_h = lock_hash_text(cur_h, "F\n");
    cur_h = lock_hash_text(cur_h, f.path);
    cur_h = lock_hash_text(cur_h, "\n");
    cur_h = lock_hash_text(cur_h, f.text);
    cur_h = lock_hash_text(cur_h, "\n");
    if txt.has_suffix(f.path, ".vox") {
      cur_sem_h = lock_hash_text(cur_sem_h, "F\n");
      cur_sem_h = lock_hash_text(cur_sem_h, f.path);
      cur_sem_h = lock_hash_text(cur_sem_h, "\n");
      cur_sem_h = lock_hash_text(cur_sem_h, f.text);
      cur_sem_h = lock_hash_text(cur_sem_h, "\n");
    }
    oi = oi + 1;
  }
  if has_cur {
    out.push(BuildCachePkgKey { pkg: cur_pkg, key: cur_h.to_string() });
    sem_out.push(BuildCachePkgKey { pkg: cur_pkg, key: cur_sem_h.to_string() });
  }
  return BuildCachePkgSemSourceKeysResult { files: files, keys: out, sem_keys: sem_out };
}

fn build_cache_pkg_source_keys_with_files(files0: Vec[ld.SourceFile]) -> BuildCachePkgSourceKeysResult {
  let ordered: SourceFilePkgOrderResult = source_file_order_by_pkg_path_with_files(files0);
  let files: Vec[ld.SourceFile] = ordered.files;
  let pkgs: Vec[String] = ordered.pkgs;
  let order: Vec[i32] = ordered.order;

  let mut out: Vec[BuildCachePkgKey] = Vec();
  let mut has_cur: bool = false;
  let mut cur_pkg: String = "";
  let mut cur_h: u64 = 0 as u64;
  let mut oi: i32 = 0;
  while oi < order.len() {
    let idx: i32 = order.get(oi);
    let f: ld.SourceFile = files.get(idx);
    let pkg: String = pkgs.get(idx);
    if !has_cur || pkg != cur_pkg {
      if has_cur {
        out.push(BuildCachePkgKey { pkg: cur_pkg, key: cur_h.to_string() });
      }
      cur_pkg = pkg;
      cur_h = 1469598103934665603 as u64;
      cur_h = lock_hash_text(cur_h, "build-cache-pkg-src-v1\n");
      cur_h = lock_hash_text(cur_h, cur_pkg);
      cur_h = lock_hash_text(cur_h, "\n");
      has_cur = true;
    }
    cur_h = lock_hash_text(cur_h, "F\n");
    cur_h = lock_hash_text(cur_h, f.path);
    cur_h = lock_hash_text(cur_h, "\n");
    cur_h = lock_hash_text(cur_h, f.text);
    cur_h = lock_hash_text(cur_h, "\n");
    oi = oi + 1;
  }
  if has_cur {
    out.push(BuildCachePkgKey { pkg: cur_pkg, key: cur_h.to_string() });
  }
  return BuildCachePkgSourceKeysResult { files: files, keys: out };
}

fn build_cache_hash_for_mode_prefix(mode: String) -> u64 {
  let mut h: u64 = 1469598103934665603 as u64;
  h = lock_hash_text(h, "build-cache-v3\n");
  h = lock_hash_text(h, if host_is_windows() { "windows\n" } else { "posix\n" });
  h = lock_hash_text(h, mode);
  h = lock_hash_text(h, "\n");
  return h;
}

fn build_cache_pkg_hash_for_mode_prefix(mode: String) -> u64 {
  let mut h: u64 = 1469598103934665603 as u64;
  h = lock_hash_text(h, "build-cache-pkg-v2\n");
  h = lock_hash_text(h, if host_is_windows() { "windows\n" } else { "posix\n" });
  h = lock_hash_text(h, mode);
  h = lock_hash_text(h, "\n");
  return h;
}

fn build_cache_pkg_key_from_source_hash_prefix(sk: BuildCachePkgKey, h0: u64) -> BuildCachePkgKey {
  let mut h: u64 = h0;
  h = lock_hash_text(h, sk.pkg);
  h = lock_hash_text(h, "\n");
  h = lock_hash_text(h, sk.key);
  h = lock_hash_text(h, "\n");
  return BuildCachePkgKey { pkg: sk.pkg, key: h.to_string() };
}

fn build_cache_sem_key_from_pkg_source_keys(pkg_source_keys0: Vec[BuildCachePkgKey], sem_mode: String) -> String {
  let mut sem_h: u64 = build_cache_hash_for_mode_prefix(sem_mode);
  let sem_h0: u64 = build_cache_pkg_hash_for_mode_prefix(sem_mode);
  let mut i: i32 = 0;
  while i < pkg_source_keys0.len() {
    let spk: BuildCachePkgKey = build_cache_pkg_key_from_source_hash_prefix(pkg_source_keys0.get(i), sem_h0);
    sem_h = lock_hash_text(sem_h, "P\n");
    sem_h = lock_hash_text(sem_h, spk.pkg);
    sem_h = lock_hash_text(sem_h, "\n");
    sem_h = lock_hash_text(sem_h, spk.key);
    sem_h = lock_hash_text(sem_h, "\n");
    i = i + 1;
  }
  return sem_h.to_string();
}

fn build_cache_key_pair_from_pkg_source_keys_keep(
  pkg_source_keys0: Vec[BuildCachePkgKey],
  compile_mode: String,
  link_mode: String,
) -> BuildCacheKeyPairKeep {
  let pkg_source_keys: Vec[BuildCachePkgKey] = pkg_source_keys0;
  let mut compile_h: u64 = build_cache_hash_for_mode_prefix(compile_mode);
  let mut link_h: u64 = build_cache_hash_for_mode_prefix(link_mode);
  let compile_h0: u64 = build_cache_pkg_hash_for_mode_prefix(compile_mode);
  let link_h0: u64 = build_cache_pkg_hash_for_mode_prefix(link_mode);

  let mut i: i32 = 0;
  while i < pkg_source_keys.len() {
    let cpk: BuildCachePkgKey = build_cache_pkg_key_from_source_hash_prefix(pkg_source_keys.get(i), compile_h0);
    compile_h = lock_hash_text(compile_h, "P\n");
    compile_h = lock_hash_text(compile_h, cpk.pkg);
    compile_h = lock_hash_text(compile_h, "\n");
    compile_h = lock_hash_text(compile_h, cpk.key);
    compile_h = lock_hash_text(compile_h, "\n");

    let lpk: BuildCachePkgKey = build_cache_pkg_key_from_source_hash_prefix(pkg_source_keys.get(i), link_h0);
    link_h = lock_hash_text(link_h, "P\n");
    link_h = lock_hash_text(link_h, lpk.pkg);
    link_h = lock_hash_text(link_h, "\n");
    link_h = lock_hash_text(link_h, lpk.key);
    link_h = lock_hash_text(link_h, "\n");
    i = i + 1;
  }

  return BuildCacheKeyPairKeep {
    keys: pkg_source_keys,
    pair: BuildCacheKeyPair {
      compile_key: compile_h.to_string(),
      link_key: link_h.to_string(),
    },
  };
}

fn build_link_cache_hit(key: String, bin: String) -> bool {
  let meta: String = build_cache_meta_path_for_key(key);
  if !fs.exists(meta) { return false; }
  let has_bin: bool = fs.exists(bin) || fs.exists(bin.concat(".exe"));
  if !has_bin { return false; }
  let cur: String = txt.trim_space(fs.read_to_string(meta));
  return cur == key;
}

fn build_cache_c_hit(key: String, cpath: String) -> bool {
  let meta: String = build_cache_obj_meta_path_for_key(key);
  if !fs.exists(meta) { return false; }
  if !fs.exists(cpath) { return false; }
  let cur: String = txt.trim_space(fs.read_to_string(meta));
  return cur == key;
}

