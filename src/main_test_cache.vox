struct SourceFilePkgOrderResult {
  files: Vec[ld.SourceFile],
  pkgs: Vec[String],
  order: Vec[i32],
}

fn sort_strings_if_needed(xs0: Vec[String]) -> Vec[String] {
  let xs: Vec[String] = xs0;
  if xs.len() <= 1 { return xs; }
  let mut i: i32 = 1;
  while i < xs.len() {
    if xs.get(i - 1) > xs.get(i) {
      return sort_strings(xs);
    }
    i = i + 1;
  }
  return xs;
}

struct TestBuildKeyKeep {
  keys: Vec[BuildCachePkgKey],
  test_key: String,
}

struct TestBuildKeySourceSigKeep {
  keys: Vec[BuildCachePkgKey],
  test_key: String,
  source_sig: String,
}

fn test_build_key_from_pkg_source_keys_keep(pkg_source_keys0: Vec[BuildCachePkgKey], mode: String) -> TestBuildKeyKeep {
  let pkg_source_keys: Vec[BuildCachePkgKey] = pkg_source_keys0;
  let mut test_h: u64 = 1469598103934665603 as u64;
  test_h = lock_hash_text(test_h, "test-build-cache-v5\n");
  test_h = lock_hash_text(test_h, if host_is_windows() { "windows\n" } else { "posix\n" });
  test_h = lock_hash_text(test_h, mode);
  test_h = lock_hash_text(test_h, "\n");
  let test_h0: u64 = build_cache_pkg_hash_for_mode_prefix("test-build\n".concat(mode));

  let mut i: i32 = 0;
  while i < pkg_source_keys.len() {
    let tpk: BuildCachePkgKey = build_cache_pkg_key_from_source_hash_prefix(pkg_source_keys.get(i), test_h0);
    test_h = lock_hash_text(test_h, "P\n");
    test_h = lock_hash_text(test_h, tpk.pkg);
    test_h = lock_hash_text(test_h, "\n");
    test_h = lock_hash_text(test_h, tpk.key);
    test_h = lock_hash_text(test_h, "\n");
    i = i + 1;
  }

  return TestBuildKeyKeep {
    keys: pkg_source_keys,
    test_key: test_h.to_string(),
  };
}

fn test_build_key_source_sig_from_pkg_source_keys_keep(pkg_source_keys0: Vec[BuildCachePkgKey], mode: String) -> TestBuildKeySourceSigKeep {
  let pkg_source_keys: Vec[BuildCachePkgKey] = pkg_source_keys0;
  let mut test_h: u64 = 1469598103934665603 as u64;
  test_h = lock_hash_text(test_h, "test-build-cache-v5\n");
  test_h = lock_hash_text(test_h, if host_is_windows() { "windows\n" } else { "posix\n" });
  test_h = lock_hash_text(test_h, mode);
  test_h = lock_hash_text(test_h, "\n");
  let test_h0: u64 = build_cache_pkg_hash_for_mode_prefix("test-build\n".concat(mode));
  let mut source_sig_h: u64 = 1469598103934665603 as u64;
  source_sig_h = lock_hash_text(source_sig_h, "build-cache-source-sig-v1\n");

  let mut i: i32 = 0;
  while i < pkg_source_keys.len() {
    let tpk: BuildCachePkgKey = build_cache_pkg_key_from_source_hash_prefix(pkg_source_keys.get(i), test_h0);
    let pk: BuildCachePkgKey = pkg_source_keys.get(i);
    test_h = lock_hash_text(test_h, "P\n");
    test_h = lock_hash_text(test_h, tpk.pkg);
    test_h = lock_hash_text(test_h, "\n");
    test_h = lock_hash_text(test_h, tpk.key);
    test_h = lock_hash_text(test_h, "\n");
    source_sig_h = lock_hash_text(source_sig_h, "P\n");
    source_sig_h = lock_hash_text(source_sig_h, pk.pkg);
    source_sig_h = lock_hash_text(source_sig_h, "\n");
    source_sig_h = lock_hash_text(source_sig_h, pk.key);
    source_sig_h = lock_hash_text(source_sig_h, "\n");
    i = i + 1;
  }

  return TestBuildKeySourceSigKeep {
    keys: pkg_source_keys,
    test_key: test_h.to_string(),
    source_sig: source_sig_h.to_string(),
  };
}

fn parse_test_build_cache_tests(text: String) -> Vec[String] {
  let lines: Vec[String] = txt.split_lines(text);
  let mut out: Vec[String] = Vec();
  let mut i: i32 = 0;
  while i < lines.len() {
    let s: String = txt.trim_space(lines.get(i));
    if s != "" { out.push(s); }
    i = i + 1;
  }
  return out;
}

struct FormatTestsResult {
  tests: Vec[String],
  text: String,
}

fn format_test_build_cache_tests_with_tests(tests0: Vec[String]) -> FormatTestsResult {
  let tests: Vec[String] = tests0;
  let mut tests_copy: Vec[String] = Vec();
  let mut ci: i32 = 0;
  while ci < tests.len() {
    tests_copy.push(tests.get(ci));
    ci = ci + 1;
  }
  let tests_sorted: Vec[String] = sort_strings_if_needed(tests_copy);
  let mut out: String = "";
  let mut i: i32 = 0;
  while i < tests_sorted.len() {
    out = out.concat(tests_sorted.get(i)).concat("\n");
    i = i + 1;
  }
  return FormatTestsResult { tests: tests, text: out };
}

struct TestBuildCacheStateResult {
  selected: Vec[String],
  c_hit: bool,
  obj_hit: bool,
  hit: bool,
}

fn test_build_cache_state_with_tests(out: String, key: String, cpath: String, obj: String, bin: String, selected0: Vec[String]) -> TestBuildCacheStateResult {
  let selected: Vec[String] = selected0;
  let mut compiled: Vec[String] = Vec();
  let meta: String = out.concat(".test.cache.key");
  if fs.exists(meta) && fs.exists(cpath) {
    let cur: String = txt.trim_space(fs.read_to_string(meta));
    if cur == key {
      let tests_path: String = out.concat(".test.cache.tests");
      if fs.exists(tests_path) {
        compiled = parse_test_build_cache_tests(fs.read_to_string(tests_path));
      }
    }
  }
  if compiled.len() == 0 {
    return TestBuildCacheStateResult { selected: selected, c_hit: false, obj_hit: false, hit: false };
  }
  let mut selected_copy: Vec[String] = Vec();
  let mut sci: i32 = 0;
  while sci < selected.len() {
    selected_copy.push(selected.get(sci));
    sci = sci + 1;
  }
  let selected_sorted: Vec[String] = sort_strings_if_needed(selected_copy);
  let mut si: i32 = 0; // sorted-selected idx
  let mut cj: i32 = 0; // compiled idx
  while si < selected_sorted.len() {
    let want: String = selected_sorted.get(si);
    while cj < compiled.len() && compiled.get(cj) < want {
      cj = cj + 1;
    }
    if cj >= compiled.len() || compiled.get(cj) != want {
      return TestBuildCacheStateResult { selected: selected, c_hit: false, obj_hit: false, hit: false };
    }
    si = si + 1;
    cj = cj + 1;
  }
  let has_obj: bool = fs.exists(obj);
  let has_bin: bool = fs.exists(bin) || fs.exists(bin.concat(".exe"));
  return TestBuildCacheStateResult { selected: selected, c_hit: true, obj_hit: has_obj, hit: has_bin };
}

fn write_test_build_cache_with_tests(out: String, key: String, tests0: Vec[String]) -> Vec[String] {
  let tests: Vec[String] = tests0;
  let meta: String = out.concat(".test.cache.key");
  let formatted: FormatTestsResult = format_test_build_cache_tests_with_tests(tests);
  let tests_out: Vec[String] = formatted.tests;
  fs.mkdir_p(dir_name(meta));
  let _: bool = write_string_if_changed(meta, key.concat("\n"));
  let _: bool = write_string_if_changed(out.concat(".test.cache.tests"), formatted.text);
  return tests_out;
}

fn build_cache_output_copy_hit(out_path: String, key: String) -> bool {
  if key == "" { return false; }
  if !fs.exists(out_path) { return false; }
  let meta: String = out_path.concat(".build.copy.key");
  if !fs.exists(meta) { return false; }
  let cur: String = txt.trim_space(fs.read_to_string(meta));
  return cur == key;
}

fn build_cache_obj_path_for_key(key: String, ext: String) -> String {
  return path_join(path_join(path_join("target", "cache"), "pkg-obj-v1"), key).concat(ext);
}

fn build_cache_bin_for_key(key: String, target_os: String) -> String {
  let out: String = path_join(path_join(path_join("target", "cache"), "link-v1"), key);
  if target_os == "wasm" { return out.concat(".wasm"); }
  return out.concat(".bin");
}

