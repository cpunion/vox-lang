}

fn sort_strings_if_needed(xs0: Vec[String]) -> Vec[String] {
  let xs: Vec[String] = xs0;
  if xs.len() <= 1 { return xs; }
  let mut i: i32 = 1;
  while i < xs.len() {
    if xs.get(i - 1) > xs.get(i) {
      return sort_strings(xs);
    }
    i = i + 1;
  }
  return xs;
}

fn test_build_cache_meta_path(out: String) -> String {
  return out.concat(".test.cache.key");
}

fn test_build_cache_tests_path(out: String) -> String {
  return out.concat(".test.cache.tests");
}

fn test_build_cache_root_for_key(root: String, key: String) -> String {
  return path_join(path_join(path_join("target", "cache"), root), key);
}

fn test_build_cache_out_for_key(key: String) -> String {
  return test_build_cache_root_for_key("test-link-v1", key);
}

fn test_build_cache_cpath_for_key(key: String) -> String {
  return test_build_cache_root_for_key("test-pkg-obj-v1", key).concat(".c");
}

struct TestBuildNoCachePaths {
  out: String,
  cpath: String,
  bin: String,
}

fn test_build_no_cache_paths(out: String) -> TestBuildNoCachePaths {
  let no_cache_out: String = out.concat(".test.nocache");
  return TestBuildNoCachePaths {
    out: no_cache_out,
    cpath: no_cache_out.concat(".c"),
    bin: no_cache_out,
  };
}

struct TestBuildKeyKeep {
  keys: Vec[BuildCachePkgKey],
  test_key: String,
}

fn test_build_key_from_pkg_source_keys_keep(pkg_source_keys0: Vec[BuildCachePkgKey], mode: String) -> TestBuildKeyKeep {
  let pkg_source_keys: Vec[BuildCachePkgKey] = pkg_source_keys0;
  let mut test_h: u64 = 1469598103934665603 as u64;
  test_h = lock_hash_text(test_h, "test-build-cache-v5\n");
  test_h = lock_hash_text(test_h, if host_is_windows() { "windows\n" } else { "posix\n" });
  test_h = lock_hash_text(test_h, mode);
  test_h = lock_hash_text(test_h, "\n");
  let test_h0: u64 = build_cache_pkg_hash_for_mode_prefix("test-build\n".concat(mode));

  let mut i: i32 = 0;
  while i < pkg_source_keys.len() {
    let tpk: BuildCachePkgKey = build_cache_pkg_key_from_source_hash_prefix(pkg_source_keys.get(i), test_h0);
    test_h = lock_hash_text(test_h, "P\n");
    test_h = lock_hash_text(test_h, tpk.pkg);
    test_h = lock_hash_text(test_h, "\n");
    test_h = lock_hash_text(test_h, tpk.key);
    test_h = lock_hash_text(test_h, "\n");
    i = i + 1;
  }

  return TestBuildKeyKeep {
    keys: pkg_source_keys,
    test_key: test_h.to_string(),
  };
}

fn parse_test_build_cache_tests(text: String) -> Vec[String] {
  let lines: Vec[String] = txt.split_lines(text);
  let mut out: Vec[String] = Vec();
  let mut i: i32 = 0;
  while i < lines.len() {
    let s: String = txt.trim_space(lines.get(i));
    if s != "" { out.push(s); }
    i = i + 1;
  }
  return out;
}

struct FormatTestsResult {
  tests: Vec[String],
  text: String,
}

fn format_test_build_cache_tests_with_tests(tests0: Vec[String]) -> FormatTestsResult {
  let tests: Vec[String] = tests0;
  let mut tests_copy: Vec[String] = Vec();
  let mut ci: i32 = 0;
  while ci < tests.len() {
    tests_copy.push(tests.get(ci));
    ci = ci + 1;
  }
  let tests_sorted: Vec[String] = sort_strings_if_needed(tests_copy);
  let mut out: String = "";
  let mut i: i32 = 0;
  while i < tests_sorted.len() {
    out = out.concat(tests_sorted.get(i)).concat("\n");
    i = i + 1;
  }
  return FormatTestsResult { tests: tests, text: out };
}

struct ContainsAllResult {
  need: Vec[String],
  ok: bool,
}

fn test_build_cache_contains_all_sorted_hay_with_need(hay: Vec[String], need0: Vec[String]) -> ContainsAllResult {
  let need: Vec[String] = need0;
  let mut need_copy: Vec[String] = Vec();
  let mut ci: i32 = 0;
  while ci < need.len() {
    need_copy.push(need.get(ci));
    ci = ci + 1;
  }
  let need_sorted: Vec[String] = sort_strings_if_needed(need_copy);
  let mut i: i32 = 0; // sorted-need idx
  let mut j: i32 = 0; // hay idx
  while i < need_sorted.len() {
    let want: String = need_sorted.get(i);
    while j < hay.len() && hay.get(j) < want {
      j = j + 1;
    }
    if j >= hay.len() || hay.get(j) != want { return ContainsAllResult { need: need, ok: false }; }
    i = i + 1;
    j = j + 1;
  }
  return ContainsAllResult { need: need, ok: true };
}

struct TestBuildCacheStateResult {
  selected: Vec[String],
  c_hit: bool,
  hit: bool,
}

fn test_build_cache_state_with_tests(out: String, key: String, cpath: String, bin: String, selected0: Vec[String]) -> TestBuildCacheStateResult {
  let selected: Vec[String] = selected0;
  let mut compiled: Vec[String] = Vec();
  let meta: String = test_build_cache_meta_path(out);
  if fs.exists(meta) && fs.exists(cpath) {
    let cur: String = txt.trim_space(fs.read_to_string(meta));
    if cur == key {
      let tests_path: String = test_build_cache_tests_path(out);
      if fs.exists(tests_path) {
        compiled = parse_test_build_cache_tests(fs.read_to_string(tests_path));
      }
    }
  }
  if compiled.len() == 0 {
    return TestBuildCacheStateResult { selected: selected, c_hit: false, hit: false };
  }
  let contains: ContainsAllResult = test_build_cache_contains_all_sorted_hay_with_need(compiled, selected);
  if !contains.ok {
    return TestBuildCacheStateResult { selected: contains.need, c_hit: false, hit: false };
  }
  let has_bin: bool = fs.exists(bin) || fs.exists(bin.concat(".exe"));
  return TestBuildCacheStateResult { selected: contains.need, c_hit: true, hit: has_bin };
}

fn write_test_build_cache_with_tests(out: String, key: String, tests0: Vec[String]) -> Vec[String] {
  let tests: Vec[String] = tests0;
  let meta: String = test_build_cache_meta_path(out);
  let formatted: FormatTestsResult = format_test_build_cache_tests_with_tests(tests);
  let tests_out: Vec[String] = formatted.tests;
  fs.mkdir_p(dir_name(meta));
  let _: bool = write_string_if_changed(meta, key.concat("\n"));
  let _: bool = write_string_if_changed(test_build_cache_tests_path(out), formatted.text);
  return tests_out;
}

