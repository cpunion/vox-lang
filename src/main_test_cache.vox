}

fn build_sem_cache_hit(key: String) -> bool {
  let meta: String = path_join(path_join(path_join("target", "cache"), "pkg-sem-v1"), key).concat(".build.cache.key");
  if !fs.exists(meta) { return false; }
  let cur: String = txt.trim_space(fs.read_to_string(meta));
  return cur == key;
}

fn discover_tests_with_paths(paths0: Vec[String], use_cache: bool) -> DiscoverTestsResult {
  let paths: Vec[String] = paths0;
  let mut test_paths: Vec[String] = Vec();
  let mut pi: i32 = 0;
  while pi < paths.len() {
    let pth: String = paths.get(pi);
    if txt.has_prefix(pth, "tests/") || (txt.has_prefix(pth, "src/") && txt.has_suffix(pth, "_test.vox")) { test_paths.push(pth); }
    pi = pi + 1;
  }
  let mut h: u64 = 1469598103934665603 as u64;
  h = lock_hash_text(h, "discover-tests-cache-v1\n");
  let sorted_test_paths: Vec[String] = sort_strings_if_needed(test_paths);
  let mut test_files: Vec[ld.SourceFile] = Vec();
  let mut tj: i32 = 0;
  while tj < sorted_test_paths.len() {
    let pth: String = sorted_test_paths.get(tj);
    let text: String = fs.read_to_string(pth);
    test_files.push(ld.SourceFile { path: pth, text: text });
    h = lock_hash_text(h, "P\n");
    h = lock_hash_text(h, pth);
    h = lock_hash_text(h, "\n");
    h = lock_hash_text(h, text);
    h = lock_hash_text(h, "\n");
    tj = tj + 1;
  }
  let key: String = h.to_string();
  let key_path: String = "target/debug/.vox_test_discover.key";
  let list_path: String = "target/debug/.vox_test_discover.list";
  if use_cache && fs.exists(key_path) && fs.exists(list_path) {
    let cached_key: String = txt.trim_space(fs.read_to_string(key_path));
    if cached_key == key {
      return DiscoverTestsResult { paths: paths, tests: parse_test_build_cache_tests(fs.read_to_string(list_path)), cached_files: test_files, key: key };
    }
  }
  let mut tests: Vec[String] = Vec();
  let mut ti: i32 = 0;
  while ti < test_files.len() {
    let sf: ld.SourceFile = test_files.get(ti);
    let pth: String = sf.path;
    let src_text: String = sf.text;
    let r: p.ParseResult = p.parse_text_with_path(pth, src_text);
    if r.err != p.ParseError.None {
      panic(p.parse_error_to_string_with_source(pth, src_text, r.err));
    }
    let mp: String = ld.mod_path_from_file_path(pth);
    let mut fi: i32 = 0;
    while fi < r.prog.funcs.len() {
      let fd: ast.FuncDecl = r.prog.funcs.get(fi);
      if txt.has_prefix(fd.name, "test_") {
        if mp == "" || mp == "main" {
          tests.push(fd.name);
        } else {
          let mut s: String = mp;
          let mut si: i32 = 0;
          while si < s.len() {
            if s.byte_at(si) == 47 {
              s = s.slice(0, si).concat(".").concat(s.slice(si + 1, s.len()));
            }
            si = si + 1;
          }
          tests.push(s.concat("::").concat(fd.name));
        }
      }
      fi = fi + 1;
    }
    ti = ti + 1;
  }
  tests = sort_strings(tests);
  let mut tests_out: Vec[String] = tests;
  if use_cache {
    fs.mkdir_p("target/debug");
    let formatted: FormatTestsResult = format_test_build_cache_tests_with_tests(tests_out);
    let _: bool = write_string_if_changed(key_path, key.concat("\n"));
    let _: bool = write_string_if_changed(list_path, formatted.text);
    tests_out = formatted.tests;
  }
  return DiscoverTestsResult { paths: paths, tests: tests_out, cached_files: test_files, key: key };
}

fn discover_tests_cached_with_paths(paths0: Vec[String]) -> DiscoverTestsResult {
  return discover_tests_with_paths(paths0, true);
}

struct TestListOutputCacheReadResult {
  hit: bool,
  text: String,
}

fn test_list_output_cache_key(
  discover_key: String,
  selected_tests0: Vec[String],
  module_pat: String,
  run_pat: String,
  filter: String,
  jobs: i32,
  fail_fast: bool,
  rerun_failed: bool,
  rerun_failed_count: i32,
  json_out: bool,
) -> String {
  if discover_key == "" { return ""; }
  let selected_tests: Vec[String] = selected_tests0;
  let mut h: u64 = 1469598103934665603 as u64;
  h = lock_hash_text(h, "test-list-output-cache-v1\n");
  h = lock_hash_text(h, discover_key);
  h = lock_hash_text(h, "\n");
  h = lock_hash_text(h, if json_out { "json=1\n" } else { "json=0\n" });
  h = lock_hash_text(h, "module=");
  h = lock_hash_text(h, module_pat);
  h = lock_hash_text(h, "\n");
  h = lock_hash_text(h, "run=");
  h = lock_hash_text(h, run_pat);
  h = lock_hash_text(h, "\n");
  h = lock_hash_text(h, "filter=");
  h = lock_hash_text(h, filter);
  h = lock_hash_text(h, "\n");
  h = lock_hash_text(h, "jobs=");
  h = lock_hash_text(h, jobs.to_string());
  h = lock_hash_text(h, "\n");
  h = lock_hash_text(h, if fail_fast { "fail_fast=1\n" } else { "fail_fast=0\n" });
  h = lock_hash_text(h, if rerun_failed { "rerun_failed=1\n" } else { "rerun_failed=0\n" });
  h = lock_hash_text(h, "rerun_failed_count=");
  h = lock_hash_text(h, rerun_failed_count.to_string());
  h = lock_hash_text(h, "\n");
  let mut i: i32 = 0;
  while i < selected_tests.len() {
    h = lock_hash_text(h, "T\n");
    h = lock_hash_text(h, selected_tests.get(i));
    h = lock_hash_text(h, "\n");
    i = i + 1;
  }
  return h.to_string();
}

fn test_list_output_cache_path(key: String) -> String {
  return path_join(path_join(path_join("target", "cache"), "test-list-v1"), key).concat(".out");
}

fn test_list_output_cache_read(key: String) -> TestListOutputCacheReadResult {
  if key == "" {
    return TestListOutputCacheReadResult { hit: false, text: "" };
  }
  let path: String = test_list_output_cache_path(key);
  if !fs.exists(path) {
    return TestListOutputCacheReadResult { hit: false, text: "" };
  }
  return TestListOutputCacheReadResult { hit: true, text: fs.read_to_string(path) };
}

fn write_test_list_output_cache(key: String, text: String) -> () {
  if key == "" { return; }
  let path: String = test_list_output_cache_path(key);
  fs.mkdir_p(dir_name(path));
  let _: bool = write_string_if_changed(path, text);
}
