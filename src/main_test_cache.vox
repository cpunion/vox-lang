    cur_h = lock_hash_text(cur_h, "\n");
    cur_h = lock_hash_text(cur_h, f.text);
    cur_h = lock_hash_text(cur_h, "\n");
    oi = oi + 1;
  }
  if has_cur {
    out.push(BuildCachePkgKey { pkg: cur_pkg, key: cur_h.to_string() });
  }
  return BuildCachePkgSourceKeysKeepOrderResult { files: files, pkgs: pkgs, order: order, keys: out };
}

fn build_cache_pkg_source_keys_with_files(files0: Vec[ld.SourceFile]) -> BuildCachePkgSourceKeysResult {
  let kept: BuildCachePkgSourceKeysKeepOrderResult = build_cache_pkg_source_keys_keep_order_with_files(files0);
  return BuildCachePkgSourceKeysResult { files: kept.files, keys: kept.keys };
}

fn build_cache_hash_for_mode_prefix(mode: String) -> u64 {
  let mut h: u64 = 1469598103934665603 as u64;
  h = lock_hash_text(h, "build-cache-v3\n");
  h = lock_hash_text(h, if host_is_windows() { "windows\n" } else { "posix\n" });
  h = lock_hash_text(h, mode);
  h = lock_hash_text(h, "\n");
  return h;
}

fn build_cache_pkg_hash_for_mode_prefix(mode: String) -> u64 {
  let mut h: u64 = 1469598103934665603 as u64;
  h = lock_hash_text(h, "build-cache-pkg-v2\n");
  h = lock_hash_text(h, if host_is_windows() { "windows\n" } else { "posix\n" });
  h = lock_hash_text(h, mode);
  h = lock_hash_text(h, "\n");
  return h;
}

fn build_cache_pkg_key_from_source_hash_prefix(sk: BuildCachePkgKey, h0: u64) -> BuildCachePkgKey {
  let mut h: u64 = h0;
  h = lock_hash_text(h, sk.pkg);
  h = lock_hash_text(h, "\n");
  h = lock_hash_text(h, sk.key);
  h = lock_hash_text(h, "\n");
  return BuildCachePkgKey { pkg: sk.pkg, key: h.to_string() };
}

fn build_cache_sem_key_from_pkg_source_keys(pkg_source_keys0: Vec[BuildCachePkgKey], sem_mode: String) -> String {
  let keep: BuildCacheSemKeyKeep = build_cache_sem_key_from_pkg_source_keys_keep(pkg_source_keys0, sem_mode);
  return keep.sem_key;
}

fn build_cache_sem_key_from_pkg_source_keys_keep(pkg_source_keys0: Vec[BuildCachePkgKey], sem_mode: String) -> BuildCacheSemKeyKeep {
  let pkg_source_keys: Vec[BuildCachePkgKey] = pkg_source_keys0;
  let mut sem_h: u64 = build_cache_hash_for_mode_prefix(sem_mode);
  let sem_h0: u64 = build_cache_pkg_hash_for_mode_prefix(sem_mode);
  let mut i: i32 = 0;
  while i < pkg_source_keys.len() {
    let spk: BuildCachePkgKey = build_cache_pkg_key_from_source_hash_prefix(pkg_source_keys.get(i), sem_h0);
    sem_h = lock_hash_text(sem_h, "P\n");
    sem_h = lock_hash_text(sem_h, spk.pkg);
    sem_h = lock_hash_text(sem_h, "\n");
    sem_h = lock_hash_text(sem_h, spk.key);
    sem_h = lock_hash_text(sem_h, "\n");
    i = i + 1;
  }
  return BuildCacheSemKeyKeep {
    keys: pkg_source_keys,
    sem_key: sem_h.to_string(),
  };
}

fn build_cache_sem_dep_hashes_from_pkg_source_keys_keep(pkg_source_keys0: Vec[BuildCachePkgKey], sem_mode: String) -> BuildCacheSemDepHashesKeep {
  let pkg_source_keys: Vec[BuildCachePkgKey] = pkg_source_keys0;
  let sem_h0: u64 = build_cache_pkg_hash_for_mode_prefix(sem_mode);
  let mut deps: Vec[q.ParseLoadDepHash] = Vec();
  let mut i: i32 = 0;
  while i < pkg_source_keys.len() {
    let spk: BuildCachePkgKey = build_cache_pkg_key_from_source_hash_prefix(pkg_source_keys.get(i), sem_h0);
    deps.push(q.ParseLoadDepHash {
      pkg: spk.pkg,
      export_sig_hash: spk.key,
      type_sig_hash: spk.key,
      impl_sig_hash: spk.key,
    });
    i = i + 1;
  }
  return BuildCacheSemDepHashesKeep {
    keys: pkg_source_keys,
    dep_hashes: deps,
  };
}

fn build_cache_sem_key_dep_hashes_from_pkg_source_keys_keep(pkg_source_keys0: Vec[BuildCachePkgKey], sem_mode: String) -> BuildCacheSemKeyDepsKeep {
  let pkg_source_keys: Vec[BuildCachePkgKey] = pkg_source_keys0;
  let mut sem_h: u64 = build_cache_hash_for_mode_prefix(sem_mode);
  let sem_h0: u64 = build_cache_pkg_hash_for_mode_prefix(sem_mode);
  let mut deps: Vec[q.ParseLoadDepHash] = Vec();
  let mut i: i32 = 0;
  while i < pkg_source_keys.len() {
    let spk: BuildCachePkgKey = build_cache_pkg_key_from_source_hash_prefix(pkg_source_keys.get(i), sem_h0);
    sem_h = lock_hash_text(sem_h, "P\n");
    sem_h = lock_hash_text(sem_h, spk.pkg);
    sem_h = lock_hash_text(sem_h, "\n");
    sem_h = lock_hash_text(sem_h, spk.key);
    sem_h = lock_hash_text(sem_h, "\n");
    deps.push(q.ParseLoadDepHash {
      pkg: spk.pkg,
      export_sig_hash: spk.key,
      type_sig_hash: spk.key,
      impl_sig_hash: spk.key,
    });
    i = i + 1;
  }
  return BuildCacheSemKeyDepsKeep {
    keys: pkg_source_keys,
    sem_key: sem_h.to_string(),
    dep_hashes: deps,
  };
}

fn build_cache_sem_dep_hashes_equal(a: Vec[q.ParseLoadDepHash], b: Vec[q.ParseLoadDepHash]) -> bool {
  if a.len() != b.len() { return false; }
  let mut i: i32 = 0;
  while i < a.len() {
    let da: q.ParseLoadDepHash = a.get(i);
    let db: q.ParseLoadDepHash = b.get(i);
    if da.pkg != db.pkg { return false; }
    if da.export_sig_hash != db.export_sig_hash { return false; }
    if da.type_sig_hash != db.type_sig_hash { return false; }
    if da.impl_sig_hash != db.impl_sig_hash { return false; }
    i = i + 1;
  }
  return true;
}

fn build_cache_sem_dep_hash_before(a: q.ParseLoadDepHash, b: q.ParseLoadDepHash) -> bool {
  if a.pkg != b.pkg { return a.pkg < b.pkg; }
  if a.export_sig_hash != b.export_sig_hash { return a.export_sig_hash < b.export_sig_hash; }
  if a.type_sig_hash != b.type_sig_hash { return a.type_sig_hash < b.type_sig_hash; }
  return a.impl_sig_hash < b.impl_sig_hash;
}

fn build_cache_sem_dep_hashes_sorted_unique(deps: Vec[q.ParseLoadDepHash]) -> bool {
  if deps.len() <= 1 { return true; }
  let mut i: i32 = 1;
  while i < deps.len() {
    let prev: q.ParseLoadDepHash = deps.get(i - 1);
    let cur: q.ParseLoadDepHash = deps.get(i);
    if !build_cache_sem_dep_hash_before(prev, cur) {
      return false;
    }
    i = i + 1;
  }
  return true;
}

struct BuildSemCacheDepParseResult {
  ok: bool,
  dep: q.ParseLoadDepHash,
}

fn parse_build_sem_cache_dep_line(line: String) -> BuildSemCacheDepParseResult {
  let mut t0: i32 = -1;
  let mut t1: i32 = -1;
  let mut t2: i32 = -1;
  let mut i: i32 = 0;
  while i < line.len() {
    if line.byte_at(i) == 9 {
      if t0 < 0 {
        t0 = i;
      } else if t1 < 0 {
        t1 = i;
      } else if t2 < 0 {
        t2 = i;
      } else {
        return BuildSemCacheDepParseResult { ok: false, dep: q.ParseLoadDepHash { pkg: "", export_sig_hash: "", type_sig_hash: "", impl_sig_hash: "" } };
      }
    }
    i = i + 1;
  }
  if t0 <= 0 || t1 <= t0 + 1 || t2 <= t1 + 1 || t2 + 1 >= line.len() {
    return BuildSemCacheDepParseResult { ok: false, dep: q.ParseLoadDepHash { pkg: "", export_sig_hash: "", type_sig_hash: "", impl_sig_hash: "" } };
  }
  let dep: q.ParseLoadDepHash = q.ParseLoadDepHash {
    pkg: line.slice(0, t0),
    export_sig_hash: line.slice(t0 + 1, t1),
    type_sig_hash: line.slice(t1 + 1, t2),
    impl_sig_hash: line.slice(t2 + 1, line.len()),
  };
  return BuildSemCacheDepParseResult { ok: true, dep: dep };
}

struct BuildSemCacheReadResult {
  hit: bool,
  deps: Vec[q.ParseLoadDepHash],
}

fn build_sem_cache_read_with_deps(key: String) -> BuildSemCacheReadResult {
  let meta: String = path_join(path_join(path_join("target", "cache"), "pkg-sem-v1"), key).concat(".build.cache.key");
  if !fs.exists(meta) { return BuildSemCacheReadResult { hit: false, deps: Vec() }; }
  let cur: String = txt.trim_space(fs.read_to_string(meta));
  if cur != key { return BuildSemCacheReadResult { hit: false, deps: Vec() }; }
  let deps_path: String = path_join(path_join(path_join("target", "cache"), "pkg-sem-v1"), key).concat(".build.cache.deps");
  if !fs.exists(deps_path) { return BuildSemCacheReadResult { hit: false, deps: Vec() }; }
  let lines: Vec[String] = txt.split_lines(fs.read_to_string(deps_path));
  if lines.len() == 0 { return BuildSemCacheReadResult { hit: false, deps: Vec() }; }
  if txt.trim_space(lines.get(0)) != "v1" { return BuildSemCacheReadResult { hit: false, deps: Vec() }; }
  let mut deps: Vec[q.ParseLoadDepHash] = Vec();
  let mut i: i32 = 1;
  while i < lines.len() {
    let line: String = txt.trim_space(lines.get(i));
    if line != "" {
      let parsed: BuildSemCacheDepParseResult = parse_build_sem_cache_dep_line(line);
      if !parsed.ok { return BuildSemCacheReadResult { hit: false, deps: Vec() }; }
      deps.push(parsed.dep);
    }
    i = i + 1;
  }
  if !build_cache_sem_dep_hashes_sorted_unique(deps) {
    return BuildSemCacheReadResult { hit: false, deps: Vec() };
  }
  return BuildSemCacheReadResult { hit: true, deps: deps };
}

fn write_build_sem_cache_with_deps(key: String, deps0: Vec[q.ParseLoadDepHash]) -> () {
  let deps: Vec[q.ParseLoadDepHash] = deps0;
  let meta: String = path_join(path_join(path_join("target", "cache"), "pkg-sem-v1"), key).concat(".build.cache.key");
  fs.mkdir_p(dir_name(meta));
  let _: bool = write_string_if_changed(meta, key.concat("\n"));
  let deps_path: String = path_join(path_join(path_join("target", "cache"), "pkg-sem-v1"), key).concat(".build.cache.deps");
  let mut out: String = "v1\n";
  let mut i: i32 = 0;
  while i < deps.len() {
    let d: q.ParseLoadDepHash = deps.get(i);
    out = out
      .concat(d.pkg)
      .concat("\t")
      .concat(d.export_sig_hash)
      .concat("\t")
      .concat(d.type_sig_hash)
      .concat("\t")
      .concat(d.impl_sig_hash)
      .concat("\n");
    i = i + 1;
  }
  let _: bool = write_string_if_changed(deps_path, out);
}

fn build_sem_cache_hit_with_deps(key: String, deps: Vec[q.ParseLoadDepHash]) -> bool {
  if key == "" { return false; }
  let read: BuildSemCacheReadResult = build_sem_cache_read_with_deps(key);
  if !read.hit { return false; }
  return build_cache_sem_dep_hashes_equal(read.deps, deps);
}

struct BuildSemCacheHitDepsKeep {
  deps: Vec[q.ParseLoadDepHash],
  hit: bool,
}

fn build_sem_cache_hit_with_deps_keep(key: String, deps0: Vec[q.ParseLoadDepHash]) -> BuildSemCacheHitDepsKeep {
  let deps: Vec[q.ParseLoadDepHash] = deps0;
  if key == "" {
    return BuildSemCacheHitDepsKeep { deps: deps, hit: false };
  }
  let read: BuildSemCacheReadResult = build_sem_cache_read_with_deps(key);
  if !read.hit || read.deps.len() != deps.len() {
    return BuildSemCacheHitDepsKeep { deps: deps, hit: false };
  }
  let mut hit: bool = true;
  let mut i: i32 = 0;
  while i < deps.len() {
    let a: q.ParseLoadDepHash = read.deps.get(i);
    let b: q.ParseLoadDepHash = deps.get(i);
    if a.pkg != b.pkg || a.export_sig_hash != b.export_sig_hash || a.type_sig_hash != b.type_sig_hash || a.impl_sig_hash != b.impl_sig_hash {
      hit = false;
      i = deps.len();
    } else {
      i = i + 1;
    }
  }
  return BuildSemCacheHitDepsKeep { deps: deps, hit: hit };
}

fn build_cache_source_sig_from_pkg_source_keys(pkg_source_keys0: Vec[BuildCachePkgKey]) -> String {
  let pkg_source_keys: Vec[BuildCachePkgKey] = pkg_source_keys0;
  let mut h: u64 = 1469598103934665603 as u64;
  h = lock_hash_text(h, "build-cache-source-sig-v1\n");
  let mut i: i32 = 0;
  while i < pkg_source_keys.len() {
    let pk: BuildCachePkgKey = pkg_source_keys.get(i);
    h = lock_hash_text(h, "P\n");
    h = lock_hash_text(h, pk.pkg);
    h = lock_hash_text(h, "\n");
    h = lock_hash_text(h, pk.key);
    h = lock_hash_text(h, "\n");
    i = i + 1;
  }
  return h.to_string();
}

struct BuildSemCacheCRefResult {
  hit: bool,
  c_key: String,
  source_sig: String,
}

fn build_sem_cache_read_c_ref(key: String) -> BuildSemCacheCRefResult {
  let path: String = path_join(path_join(path_join("target", "cache"), "pkg-sem-v1"), key).concat(".build.cache.c-ref");
  if !fs.exists(path) {
    return BuildSemCacheCRefResult { hit: false, c_key: "", source_sig: "" };
  }
  let lines: Vec[String] = txt.split_lines(fs.read_to_string(path));
  if lines.len() < 3 { return BuildSemCacheCRefResult { hit: false, c_key: "", source_sig: "" }; }
  if txt.trim_space(lines.get(0)) != "v1" { return BuildSemCacheCRefResult { hit: false, c_key: "", source_sig: "" }; }
  let c_key: String = txt.trim_space(lines.get(1));
  let source_sig: String = txt.trim_space(lines.get(2));
  if c_key == "" || source_sig == "" {
    return BuildSemCacheCRefResult { hit: false, c_key: "", source_sig: "" };
  }
  return BuildSemCacheCRefResult { hit: true, c_key: c_key, source_sig: source_sig };
}

fn write_build_sem_cache_c_ref(key: String, c_key: String, source_sig: String) -> () {
  let path: String = path_join(path_join(path_join("target", "cache"), "pkg-sem-v1"), key).concat(".build.cache.c-ref");
  fs.mkdir_p(dir_name(path));
  let out: String = "v1\n".concat(c_key).concat("\n").concat(source_sig).concat("\n");
  let _: bool = write_string_if_changed(path, out);
}

fn build_cache_try_reuse_sem_cached_c_with_source_sig(sem_key: String, compile_key: String, source_sig: String, cache_cpath: String, trace_exec: bool) -> bool {
  if sem_key == "" || compile_key == "" || source_sig == "" { return false; }
  let ref0: BuildSemCacheCRefResult = build_sem_cache_read_c_ref(sem_key);
  if !ref0.hit || ref0.c_key == "" || ref0.source_sig == "" { return false; }
  if ref0.source_sig != source_sig { return false; }
  if ref0.c_key == compile_key { return false; }
  let sem_cached_cpath: String = build_cache_obj_path_for_key(ref0.c_key, ".c");
  if !fs.exists(sem_cached_cpath) { return false; }
  fs.mkdir_p(dir_name(cache_cpath));
  if !copy_file_host(sem_cached_cpath, cache_cpath, trace_exec) {
    fs.write_string(cache_cpath, fs.read_to_string(sem_cached_cpath));
  }
  return true;
}

fn test_build_cache_try_reuse_sem_cached_c_with_source_sig(
  sem_key: String,
  test_build_key: String,
  source_sig: String,
  cache_cpath: String,
  obj_ext: String,
  selected_tests: Vec[String],
  trace_exec: bool,
) -> bool {
  if sem_key == "" || test_build_key == "" || source_sig == "" { return false; }
  let ref0: BuildSemCacheCRefResult = build_sem_cache_read_c_ref(sem_key);
  if !ref0.hit || ref0.c_key == "" || ref0.source_sig == "" { return false; }
  if ref0.source_sig != source_sig { return false; }
  if ref0.c_key == test_build_key { return false; }
  let cached_out: String = path_join(path_join(path_join("target", "cache"), "test-link-v1"), ref0.c_key);
  let cached_cpath: String = path_join(path_join(path_join("target", "cache"), "test-pkg-obj-v1"), ref0.c_key).concat(".c");
  let cached_obj: String = path_join(path_join(path_join("target", "cache"), "test-pkg-obj-v1"), ref0.c_key).concat(obj_ext);
  let cached_bin: String = cached_out;
  let cached_state: TestBuildCacheStateResult =
    test_build_cache_state_with_tests(
      cached_out,
      ref0.c_key,
      cached_cpath,
      cached_obj,
      cached_bin,
      selected_tests,
    );
  if !cached_state.c_hit || !fs.exists(cached_cpath) { return false; }
  fs.mkdir_p(dir_name(cache_cpath));
  if !copy_file_host(cached_cpath, cache_cpath, trace_exec) {
    fs.write_string(cache_cpath, fs.read_to_string(cached_cpath));
  }
  return true;
}

fn build_cache_key_pair_from_pkg_source_keys_keep(
  pkg_source_keys0: Vec[BuildCachePkgKey],
  compile_mode: String,
  link_mode: String,
) -> BuildCacheKeyPairKeep {
  let pkg_source_keys: Vec[BuildCachePkgKey] = pkg_source_keys0;
  let mut compile_h: u64 = build_cache_hash_for_mode_prefix(compile_mode);
  let mut link_h: u64 = build_cache_hash_for_mode_prefix(link_mode);
  let compile_h0: u64 = build_cache_pkg_hash_for_mode_prefix(compile_mode);
  let link_h0: u64 = build_cache_pkg_hash_for_mode_prefix(link_mode);

  let mut i: i32 = 0;
  while i < pkg_source_keys.len() {
    let cpk: BuildCachePkgKey = build_cache_pkg_key_from_source_hash_prefix(pkg_source_keys.get(i), compile_h0);
    compile_h = lock_hash_text(compile_h, "P\n");
    compile_h = lock_hash_text(compile_h, cpk.pkg);
    compile_h = lock_hash_text(compile_h, "\n");
    compile_h = lock_hash_text(compile_h, cpk.key);
    compile_h = lock_hash_text(compile_h, "\n");

    let lpk: BuildCachePkgKey = build_cache_pkg_key_from_source_hash_prefix(pkg_source_keys.get(i), link_h0);
    link_h = lock_hash_text(link_h, "P\n");
    link_h = lock_hash_text(link_h, lpk.pkg);
    link_h = lock_hash_text(link_h, "\n");
    link_h = lock_hash_text(link_h, lpk.key);
    link_h = lock_hash_text(link_h, "\n");
    i = i + 1;
  }

  return BuildCacheKeyPairKeep {
    keys: pkg_source_keys,
      pair: BuildCacheKeyPair {
        compile_key: compile_h.to_string(),
        link_key: link_h.to_string(),
      },
  };
}

fn build_cache_key_pair_source_sig_from_pkg_source_keys_keep(
  pkg_source_keys0: Vec[BuildCachePkgKey],
  compile_mode: String,
  link_mode: String,
) -> BuildCacheKeyPairSourceSigKeep {
  let pkg_source_keys: Vec[BuildCachePkgKey] = pkg_source_keys0;
