fn source_file_order_by_pkg_path_with_files(files0: Vec[ld.SourceFile]) -> SourceFilePkgOrderResult {
  let files: Vec[ld.SourceFile] = files0;
  let mut pkgs: Vec[String] = Vec();
  let mut order: Vec[i32] = Vec();
  let mut i: i32 = 0;
  while i < files.len() {
    let path: String = files.get(i).path;
    let mut pkg: String = "main";
    if !txt.has_prefix(path, "src/") && !txt.has_prefix(path, "tests/") && !txt.has_prefix(path, "std/") && !txt.has_prefix(path, "examples/") && !txt.has_prefix(path, "target/") {
      let mut slash: i32 = 0;
      while slash < path.len() {
        if path.byte_at(slash) == 47 { break; } // '/'
        slash = slash + 1;
      }
      if slash > 0 && slash + 5 <= path.len() && path.slice(slash + 1, slash + 5) == "src/" {
        pkg = "pkg/".concat(path.slice(0, slash));
      } else {
        let mp: String = ld.mod_path_from_file_path(path);
        if txt.has_prefix(mp, "pkg/") {
          let mut pi: i32 = 4; // after "pkg/"
          while pi < mp.len() {
            if mp.byte_at(pi) == 47 { // '/'
              pkg = mp.slice(0, pi);
              break;
            }
            pi = pi + 1;
          }
          if pi >= mp.len() { pkg = mp; }
        }
      }
    }
    pkgs.push(pkg);
    order.push(i);
    i = i + 1;
  }

  let mut sorted: bool = true;
  i = 1;
  while i < order.len() {
    let prev_idx: i32 = order.get(i - 1);
    let cur_idx: i32 = order.get(i);
    let prev_pkg: String = pkgs.get(prev_idx);
    let cur_pkg: String = pkgs.get(cur_idx);
    let prev_path: String = files.get(prev_idx).path;
    let cur_path: String = files.get(cur_idx).path;
    if prev_pkg > cur_pkg || (prev_pkg == cur_pkg && prev_path > cur_path) {
      sorted = false;
      break;
    }
    i = i + 1;
  }
  if sorted {
    return SourceFilePkgOrderResult { files: files, pkgs: pkgs, order: order };
  }

  let mut gap: i32 = order.len() / 2;
  while gap > 0 {
    let mut oi: i32 = gap;
    while oi < order.len() {
      let keep: i32 = order.get(oi);
      let keep_pkg: String = pkgs.get(keep);
      let keep_path: String = files.get(keep).path;
      let mut j: i32 = oi;
      while j >= gap {
        let prev: i32 = order.get(j - gap);
        let prev_pkg: String = pkgs.get(prev);
        let prev_path: String = files.get(prev).path;
        if prev_pkg < keep_pkg || (prev_pkg == keep_pkg && prev_path <= keep_path) { break; }
        order.set(j, prev);
        j = j - gap;
      }
      order.set(j, keep);
      oi = oi + 1;
    }
    gap = gap / 2;
  }

  return SourceFilePkgOrderResult { files: files, pkgs: pkgs, order: order };
}

fn build_cache_pkg_sem_source_keys_with_files(files0: Vec[ld.SourceFile]) -> BuildCachePkgSemSourceKeysResult {
  let ordered: SourceFilePkgOrderResult = source_file_order_by_pkg_path_with_files(files0);
  let files: Vec[ld.SourceFile] = ordered.files;
  let pkgs: Vec[String] = ordered.pkgs;
  let order: Vec[i32] = ordered.order;

  let mut out: Vec[BuildCachePkgKey] = Vec();
  let mut sem_out: Vec[BuildCachePkgKey] = Vec();
  let mut has_cur: bool = false;
  let mut cur_pkg: String = "";
  let mut cur_h: u64 = 0 as u64;
  let mut cur_sem_h: u64 = 0 as u64;
  let mut cur_sem_diverged: bool = false;
  let mut oi: i32 = 0;
  while oi < order.len() {
    let idx: i32 = order.get(oi);
    let f: ld.SourceFile = files.get(idx);
    let pkg: String = pkgs.get(idx);
    if !has_cur || pkg != cur_pkg {
      if has_cur {
        out.push(BuildCachePkgKey { pkg: cur_pkg, key: cur_h.to_string() });
        sem_out.push(BuildCachePkgKey { pkg: cur_pkg, key: if cur_sem_diverged { cur_sem_h.to_string() } else { cur_h.to_string() } });
      }
      cur_pkg = pkg;
      cur_h = 1469598103934665603 as u64;
      cur_h = lock_hash_text(cur_h, "build-cache-pkg-src-v1\n");
      cur_h = lock_hash_text(cur_h, cur_pkg);
      cur_h = lock_hash_text(cur_h, "\n");
      cur_sem_h = cur_h;
      cur_sem_diverged = false;
      has_cur = true;
    }
    cur_h = lock_hash_text(cur_h, "F\n");
    cur_h = lock_hash_text(cur_h, f.path);
    cur_h = lock_hash_text(cur_h, "\n");
    cur_h = lock_hash_text(cur_h, f.text);
    cur_h = lock_hash_text(cur_h, "\n");
    let is_vox: bool = txt.has_suffix(f.path, ".vox");
    if !cur_sem_diverged {
      if is_vox {
        // Fast path: until a non-.vox file appears, sem hash equals full hash.
        cur_sem_h = cur_h;
      } else {
        cur_sem_diverged = true;
      }
    } else if is_vox {
      cur_sem_h = lock_hash_text(cur_sem_h, "F\n");
      cur_sem_h = lock_hash_text(cur_sem_h, f.path);
      cur_sem_h = lock_hash_text(cur_sem_h, "\n");
      cur_sem_h = lock_hash_text(cur_sem_h, f.text);
      cur_sem_h = lock_hash_text(cur_sem_h, "\n");
    }
    oi = oi + 1;
  }
  if has_cur {
    out.push(BuildCachePkgKey { pkg: cur_pkg, key: cur_h.to_string() });
    sem_out.push(BuildCachePkgKey { pkg: cur_pkg, key: if cur_sem_diverged { cur_sem_h.to_string() } else { cur_h.to_string() } });
  }
  return BuildCachePkgSemSourceKeysResult { files: files, keys: out, sem_keys: sem_out };
}

fn build_cache_pkg_sem_source_keys_only_from_order_with_files(files0: Vec[ld.SourceFile], pkgs: Vec[String], order: Vec[i32]) -> BuildCachePkgSemOnlySourceKeysResult {
  let files: Vec[ld.SourceFile] = files0;
  let mut sem_out: Vec[BuildCachePkgKey] = Vec();
  let mut has_cur: bool = false;
  let mut cur_pkg: String = "";
  let mut cur_sem_h: u64 = 0 as u64;
  let mut oi: i32 = 0;
  while oi < order.len() {
    let idx: i32 = order.get(oi);
    let f: ld.SourceFile = files.get(idx);
    let pkg: String = pkgs.get(idx);
    if !has_cur || pkg != cur_pkg {
      if has_cur {
        sem_out.push(BuildCachePkgKey { pkg: cur_pkg, key: cur_sem_h.to_string() });
      }
      cur_pkg = pkg;
      cur_sem_h = 1469598103934665603 as u64;
      cur_sem_h = lock_hash_text(cur_sem_h, "build-cache-pkg-src-v1\n");
      cur_sem_h = lock_hash_text(cur_sem_h, cur_pkg);
      cur_sem_h = lock_hash_text(cur_sem_h, "\n");
      has_cur = true;
    }
    if txt.has_suffix(f.path, ".vox") {
      cur_sem_h = lock_hash_text(cur_sem_h, "F\n");
      cur_sem_h = lock_hash_text(cur_sem_h, f.path);
      cur_sem_h = lock_hash_text(cur_sem_h, "\n");
      cur_sem_h = lock_hash_text(cur_sem_h, f.text);
      cur_sem_h = lock_hash_text(cur_sem_h, "\n");
    }
    oi = oi + 1;
  }
  if has_cur {
    sem_out.push(BuildCachePkgKey { pkg: cur_pkg, key: cur_sem_h.to_string() });
  }
  return BuildCachePkgSemOnlySourceKeysResult { files: files, sem_keys: sem_out };
}

fn build_cache_pkg_sem_source_keys_only_with_files(files0: Vec[ld.SourceFile]) -> BuildCachePkgSemOnlySourceKeysResult {
  let ordered: SourceFilePkgOrderResult = source_file_order_by_pkg_path_with_files(files0);
  return build_cache_pkg_sem_source_keys_only_from_order_with_files(ordered.files, ordered.pkgs, ordered.order);
}

fn build_cache_pkg_source_keys_keep_order_with_files(files0: Vec[ld.SourceFile]) -> BuildCachePkgSourceKeysKeepOrderResult {
  let ordered: SourceFilePkgOrderResult = source_file_order_by_pkg_path_with_files(files0);
  let files: Vec[ld.SourceFile] = ordered.files;
