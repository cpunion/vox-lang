import "std/testing" as t

fn rewrite_run_alias_for_test(args0: Vec[String]) -> Vec[String] {
  if args0.len() < 2 { return args0; }
  if !local_dev_repo_has_selfhost() { return args0; }
  if args0.get(0) != "run" { return args0; }
  if args0.get(1) != "fmt" { return args0; }
  let mut out: Vec[String] = Vec();
  out.push("fmt");
  let mut i: i32 = 2;
  while i < args0.len() {
    out.push(args0.get(i));
    i = i + 1;
  }
  return out;
}

fn test_run_alias_rewrite_fmt_smoke() -> () {
  let mut xs: Vec[String] = Vec();
  xs.push("run");
  xs.push("fmt");
  let ys: Vec[String] = rewrite_run_alias_for_test(xs);
  t.assert_eq(ys.len(), 1);
  t.assert_eq(ys.get(0), "fmt");
}

fn test_run_alias_rewrite_fmt_with_args_smoke() -> () {
  let mut xs: Vec[String] = Vec();
  xs.push("run");
  xs.push("fmt");
  xs.push("--check");
  xs.push("src");
  let ys: Vec[String] = rewrite_run_alias_for_test(xs);
  t.assert_eq(ys.len(), 3);
  t.assert_eq(ys.get(0), "fmt");
  t.assert_eq(ys.get(1), "--check");
  t.assert_eq(ys.get(2), "src");
}

fn test_run_alias_rewrite_non_fmt_kept_smoke() -> () {
  let mut xs: Vec[String] = Vec();
  xs.push("run");
  xs.push("target/debug/app");
  let ys: Vec[String] = rewrite_run_alias_for_test(xs);
  t.assert_eq(ys.len(), 2);
  t.assert_eq(ys.get(0), "run");
  t.assert_eq(ys.get(1), "target/debug/app");
}

fn test_local_dev_selfhost_non_whitelist_cmd_kept_smoke() -> () {
  let mut xs: Vec[String] = Vec();
  xs.push("build");
  let r: ToolchainRouteWithArgsResult = maybe_handle_local_dev_selfhost_with_args(xs, false);
  t.assert(!r.handled);
  t.assert_eq(r.code, 0);
  t.assert_eq(r.args.len(), 1);
  t.assert_eq(r.args.get(0), "build");
}
