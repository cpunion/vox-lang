import "std/testing" as t
import "vox/compile" as c
import "vox/loader" as ld
import "vox/codegen" as cg
import "vox/query" as q

fn test_compile_query_shadow_prepare_for_target_smoke() -> () {
  let mut files: Vec[ld.SourceFile] = Vec();
  files.push(ld.SourceFile { path: "src/main.vox", text: "fn main() -> i32 { return 0; }" });

  let mut deps: Vec[q.ParseLoadDepHash] = Vec();
  deps.push(q.ParseLoadDepHash { pkg: "std/io", export_sig_hash: "a", type_sig_hash: "a", impl_sig_hash: "a" });

  let mut switches: Vec[String] = Vec();
  switches.push("mode=build");

  let pr: c.CompileQueryShadowPrepareResult =
    c.compile_query_shadow_prepare_for_target_with_files(
      files,
      cg.EmitOptions { emit_driver_main: true, driver_main_kind: cg.DriverMainKind.User, emit_test_main: false, test_funcs: Vec(), c_sources: Vec() },
      64,
      "linux",
      "amd64",
      c.CompileQueryShadowOptions {
      enabled: true,
      trace_predicted_hit: true,
      mode: "build",
      diagnostics_mode: "diag-v0",
      compiler_version: "dev",
      compiler_channel: "dev",
      feature_switches: switches,
      dep_hashes: deps,
    },
    );
  let st: q.ParseLoadShadowState = pr.state;
  t.assert(st.key != "");
}

fn test_compile_query_shadow_prepare_disabled() -> () {
  let mut files: Vec[ld.SourceFile] = Vec();
  files.push(ld.SourceFile { path: "src/main.vox", text: "fn main() -> i32 { return 0; }" });
  let pr: c.CompileQueryShadowPrepareResult =
    c.compile_query_shadow_prepare_for_target_with_files(
      files,
      cg.EmitOptions { emit_driver_main: false, driver_main_kind: cg.DriverMainKind.User, emit_test_main: false, test_funcs: Vec(), c_sources: Vec() },
      64,
      "unknown",
      "unknown",
      c.compile_query_shadow_disabled(),
    );
  let st: q.ParseLoadShadowState = pr.state;
  t.assert_eq(st.key, "");
  t.assert(!st.predicted_hit);
}

fn test_compile_query_shadow_prepare_for_target_with_files_keeps_inputs() -> () {
  let mut files: Vec[ld.SourceFile] = Vec();
  files.push(ld.SourceFile { path: "src/main.vox", text: "fn main() -> i32 { return 0; }" });

  let mut deps: Vec[q.ParseLoadDepHash] = Vec();
  deps.push(q.ParseLoadDepHash { pkg: "std/io", export_sig_hash: "a", type_sig_hash: "a", impl_sig_hash: "a" });

  let mut switches: Vec[String] = Vec();
  switches.push("mode=build");

  let pr: c.CompileQueryShadowPrepareResult =
    c.compile_query_shadow_prepare_for_target_with_files(
      files,
      cg.EmitOptions { emit_driver_main: true, driver_main_kind: cg.DriverMainKind.User, emit_test_main: false, test_funcs: Vec(), c_sources: Vec() },
      64,
      "linux",
      "amd64",
      c.CompileQueryShadowOptions {
      enabled: true,
      trace_predicted_hit: true,
      mode: "build",
      diagnostics_mode: "diag-v0",
      compiler_version: "dev",
      compiler_channel: "dev",
      feature_switches: switches,
      dep_hashes: deps,
    },
    );
  t.assert(pr.files.len() == 1);
  t.assert_eq(pr.files.get(0).path, "src/main.vox");
  t.assert(pr.state.key != "");
}
