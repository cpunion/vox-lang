import "vox/ir" as ir

struct IdTy { id: i32, ty: String }

struct IdTySeq { id: i32, ty: String, seq: i32 }

fn idty_add(v0: Vec[IdTy], id: i32, ty: String) -> Vec[IdTy] {
  let mut v: Vec[IdTy] = v0;
  // IR ids are definition-unique in normal paths; keep append O(1) and let
  // the dense id table materialization handle any accidental duplicates.
  v.push(IdTy { id: id, ty: ty });
  return v;
}

fn idty_is_strictly_increasing_non_negative(v: Vec[IdTy]) -> bool {
  let mut i: i32 = 0;
  let mut prev: i32 = -1;
  while i < v.len() {
    let id: i32 = v.get(i).id;
    if id < 0 { return false; }
    if i > 0 && id <= prev { return false; }
    prev = id;
    i = i + 1;
  }
  return true;
}

fn idty_can_use_dense_last_wins(v: Vec[IdTy], max_id: i32) -> bool {
  if max_id < 0 { return false; }
  // Guard sparse/huge ids (e.g. synthetic large ids in tests) to avoid large
  // temporary vectors; fall back to sort-based path in those cases.
  if max_id > 262144 { return false; }
  let n: i32 = v.len();
  if n <= 0 { return false; }
  if max_id > n * 64 { return false; }
  return true;
}

fn idty_dense_last_wins_sorted(v0: Vec[IdTy], max_id: i32) -> Vec[IdTy] {
  let mut seen: Vec[bool] = Vec();
  let mut tys: Vec[String] = Vec();
  let mut i0: i32 = 0;
  while i0 <= max_id {
    seen.push(false);
    tys.push("");
    i0 = i0 + 1;
  }
  let mut i: i32 = 0;
  while i < v0.len() {
    let it: IdTy = v0.get(i);
    if it.id >= 0 && it.id <= max_id {
      seen.set(it.id, true);
      tys.set(it.id, it.ty);
    }
    i = i + 1;
  }
  let mut out: Vec[IdTy] = Vec();
  let mut id: i32 = 0;
  while id <= max_id {
    if seen.get(id) {
      out.push(IdTy { id: id, ty: tys.get(id) });
    }
    id = id + 1;
  }
  return out;
}

fn idty_unique_sorted_last_wins(v0: Vec[IdTy]) -> Vec[IdTy] {
  if v0.len() == 0 { return v0; }
  if idty_is_strictly_increasing_non_negative(v0) { return v0; }
  let mut max_id: i32 = -1;
  let mut mi: i32 = 0;
  while mi < v0.len() {
    let id: i32 = v0.get(mi).id;
    if id > max_id { max_id = id; }
    mi = mi + 1;
  }
  if idty_can_use_dense_last_wins(v0, max_id) {
    return idty_dense_last_wins_sorted(v0, max_id);
  }
  let mut ws: Vec[IdTySeq] = Vec();
  let mut i: i32 = 0;
  while i < v0.len() {
    let it: IdTy = v0.get(i);
    ws.push(IdTySeq { id: it.id, ty: it.ty, seq: i });
    i = i + 1;
  }

  let mut gap: i32 = ws.len() / 2;
  while gap > 0 {
    let mut wi: i32 = gap;
    while wi < ws.len() {
      let keep: IdTySeq = ws.get(wi);
      let mut j: i32 = wi;
      while j >= gap {
        let prev: IdTySeq = ws.get(j - gap);
        if prev.id < keep.id { break; }
        if prev.id == keep.id && prev.seq <= keep.seq { break; }
        ws.set(j, prev);
        j = j - gap;
      }
      ws.set(j, keep);
      wi = wi + 1;
    }
    gap = gap / 2;
  }

  let mut out: Vec[IdTy] = Vec();
  i = 0;
  while i < ws.len() {
    let mut keep: IdTySeq = ws.get(i);
    while i + 1 < ws.len() && ws.get(i + 1).id == keep.id {
      i = i + 1;
      keep = ws.get(i);
    }
    if keep.id >= 0 { out.push(IdTy { id: keep.id, ty: keep.ty }); }
    i = i + 1;
  }
  return out;
}

struct ValueNameTables {
  params: Vec[String],
  temps: Vec[String],
  slots: Vec[String],
}

struct TempIntConstTable {
  has: Vec[bool],
  vals: Vec[i64],
  not_signed_min: Vec[bool],
  non_negative: Vec[bool],
  slot_not_signed_min: Vec[bool],
  slot_non_negative: Vec[bool],
}

struct IntConstValue {
  ok: bool,
  n: i64,
}

fn build_indexed_names(prefix: String, max_id: i32) -> Vec[String] {
  let mut out: Vec[String] = Vec();
  let mut i: i32 = 0;
  while i <= max_id {
    out.push(prefix.concat(i.to_string()));
    i = i + 1;
  }
  return out;
}

fn build_value_name_tables(param_len: i32, max_temp: i32, max_slot: i32) -> ValueNameTables {
  let mut param_max: i32 = param_len - 1;
  if param_max < -1 { param_max = -1; }
  return ValueNameTables {
    params: build_indexed_names("p", param_max),
    temps: build_indexed_names("t", max_temp),
    slots: build_indexed_names("v", max_slot),
  };
}

fn temp_int_const_table_empty() -> TempIntConstTable {
  return TempIntConstTable {
    has: Vec(),
    vals: Vec(),
    not_signed_min: Vec(),
    non_negative: Vec(),
    slot_not_signed_min: Vec(),
    slot_non_negative: Vec(),
  };
}

fn build_temp_int_const_table(pool: ir.TyPool, target_ptr_bits: i32, f: ir.Func, max_temp: i32, max_slot: i32) -> TempIntConstTable {
  if max_temp < 0 { return temp_int_const_table_empty(); }
  let mut has: Vec[bool] = Vec();
  let mut vals: Vec[i64] = Vec();
  let mut not_signed_min: Vec[bool] = Vec();
  let mut non_negative: Vec[bool] = Vec();
  let mut i0: i32 = 0;
  while i0 <= max_temp {
    has.push(false);
    vals.push(0 as i64);
    not_signed_min.push(false);
    non_negative.push(false);
    i0 = i0 + 1;
  }
  let slot_w: i32 = if max_slot >= 0 { max_slot + 1 } else { 0 };
  let mut slot_seen_store_global: Vec[bool] = Vec();
  let mut slot_all_non_negative_global: Vec[bool] = Vec();
  let mut slot_all_not_signed_min_global: Vec[bool] = Vec();
  let mut gsi0: i32 = 0;
  while gsi0 < slot_w {
    slot_seen_store_global.push(false);
    slot_all_non_negative_global.push(true);
    slot_all_not_signed_min_global.push(true);
    gsi0 = gsi0 + 1;
  }
  let mut block_preds: Vec[Vec[i32]] = Vec();
  let mut bpi: i32 = 0;
  while bpi < f.blocks.len() {
    block_preds.push(Vec());
    bpi = bpi + 1;
  }
  bpi = 0;
  while bpi < f.blocks.len() {
    let b0: ir.Block = f.blocks.get(bpi);
    if b0.has_term {
      if match b0.term { ir.Term.Br(_dst) => true, _ => false } {
        let dst: String = match b0.term { ir.Term.Br(dst) => dst, _ => "" };
        let di: i32 = find_block_idx_by_name(f.blocks, dst);
        if di >= 0 && di < block_preds.len() {
          let mut ps: Vec[i32] = block_preds.get(di);
          ps.push(bpi);
          block_preds.set(di, ps);
        }
      } else if match b0.term { ir.Term.CondBr(_cond, _then_name, _else_name) => true, _ => false } {
        let then_name: String = match b0.term { ir.Term.CondBr(_cond, then_name, _else_name) => then_name, _ => "" };
        let else_name: String = match b0.term { ir.Term.CondBr(_cond, _then_name, else_name) => else_name, _ => "" };
        let d0: i32 = find_block_idx_by_name(f.blocks, then_name);
        if d0 >= 0 && d0 < block_preds.len() {
          let mut ps0: Vec[i32] = block_preds.get(d0);
          ps0.push(bpi);
          block_preds.set(d0, ps0);
        }
        let d1: i32 = find_block_idx_by_name(f.blocks, else_name);
        if d1 >= 0 && d1 < block_preds.len() {
          let mut ps1: Vec[i32] = block_preds.get(d1);
          ps1.push(bpi);
          block_preds.set(d1, ps1);
        }
      }
    }
    bpi = bpi + 1;
  }
  let mut block_slot_non_negative_out: Vec[bool] = Vec();
  let mut block_slot_not_signed_min_out: Vec[bool] = Vec();
  let mut boi: i32 = 0;
  while boi < f.blocks.len() {
    let mut si0: i32 = 0;
    while si0 < slot_w {
      block_slot_non_negative_out.push(false);
      block_slot_not_signed_min_out.push(false);
      si0 = si0 + 1;
    }
    boi = boi + 1;
  }
  let mut bi: i32 = 0;
  while bi < f.blocks.len() {
    let b: ir.Block = f.blocks.get(bi);
    let mut slot_has: Vec[bool] = Vec();
    let mut slot_vals: Vec[i64] = Vec();
    let mut slot_not_signed_min: Vec[bool] = Vec();
    let mut slot_non_negative: Vec[bool] = Vec();
    let mut si0: i32 = 0;
    while si0 <= max_slot {
      slot_has.push(false);
      slot_vals.push(0 as i64);
      slot_not_signed_min.push(false);
      slot_non_negative.push(false);
      si0 = si0 + 1;
    }
    if slot_w > 0 && bi < block_preds.len() {
      let ps: Vec[i32] = block_preds.get(bi);
      if ps.len() > 0 {
        let mut all_preds_known: bool = true;
        let mut pk: i32 = 0;
        while pk < ps.len() {
          let predk: i32 = ps.get(pk);
          if predk < 0 || predk >= bi {
            all_preds_known = false;
            break;
          }
          pk = pk + 1;
        }
        if all_preds_known {
          let mut si1: i32 = 0;
          while si1 < slot_w {
            let p0: i32 = ps.get(0);
            let pi0: i32 = p0 * slot_w + si1;
            let mut nn: bool = block_slot_non_negative_out.get(pi0);
            let mut nm: bool = block_slot_not_signed_min_out.get(pi0);
            let mut pj: i32 = 1;
            while pj < ps.len() {
              let predj: i32 = ps.get(pj);
              let pij: i32 = predj * slot_w + si1;
              nn = nn && block_slot_non_negative_out.get(pij);
              nm = nm && block_slot_not_signed_min_out.get(pij);
              pj = pj + 1;
            }
            slot_non_negative.set(si1, nn);
            slot_not_signed_min.set(si1, nm);
            si1 = si1 + 1;
          }
        }
      }
    }
    let mut ii: i32 = 0;
    while ii < b.instrs.len() {
      let ins: ir.Instr = b.instrs.get(ii);
      if match ins { ir.Instr.Const(_tid, _ty, ir.Value.Int(_n)) => true, _ => false } {
        let tid: i32 = match ins { ir.Instr.Const(tid, _ty, _v) => tid, _ => 0 };
        if tid >= 0 && tid <= max_temp {
          let ty: i32 = match ins { ir.Instr.Const(_tid, ty, _v) => ty, _ => 0 };
          let t: ir.Ty = ir.ty_pool_get(pool, ty);
          if is_int_scalar_kind(t.kind) {
            let n: i64 = match ins { ir.Instr.Const(_tid, _ty, ir.Value.Int(n)) => n, _ => 0 as i64 };
            has.set(tid, true);
            vals.set(tid, n);
            if n >= (0 as i64) {
              non_negative.set(tid, true);
            }
            if is_signed_int_kind(t.kind) {
              let minv: IntConstValue = int_min_const_for_signed_kind(t.kind);
              if minv.ok && n != minv.n {
                not_signed_min.set(tid, true);
              }
            }
          }
        }
      } else if match ins { ir.Instr.VecLen(_tid, _recv_slot) => true, _ => false } {
        let tid: i32 = match ins { ir.Instr.VecLen(tid, _recv_slot) => tid, _ => 0 };
        if tid >= 0 && tid <= max_temp {
          non_negative.set(tid, true);
          not_signed_min.set(tid, true);
        }
      } else if match ins { ir.Instr.IntCastChecked(_tid, _dst_ty, _src_ty, _v) => true, _ => false } {
        let tid: i32 = match ins { ir.Instr.IntCastChecked(tid, _dst_ty, _src_ty, _v) => tid, _ => 0 };
        if tid >= 0 && tid <= max_temp {
          let dst_ty: i32 = match ins { ir.Instr.IntCastChecked(_tid, dst_ty, _src_ty, _v) => dst_ty, _ => 0 };
          let src_ty: i32 = match ins { ir.Instr.IntCastChecked(_tid, _dst_ty, src_ty, _v) => src_ty, _ => 0 };
          let v: ir.Value = match ins { ir.Instr.IntCastChecked(_tid, _dst_ty, _src_ty, v) => v, _ => ir.v_int(0) };
          let dst_t: ir.Ty = ir.ty_pool_get(pool, dst_ty);
          let src_t: ir.Ty = ir.ty_pool_get(pool, src_ty);
          if is_int_scalar_kind(dst_t.kind) {
            let lit: IntConstValue = match v {
              ir.Value.Int(n) => IntConstValue { ok: true, n: n },
              ir.Value.Temp(vtid) =>
                if vtid >= 0 && vtid <= max_temp && has.get(vtid) {
                  IntConstValue { ok: true, n: vals.get(vtid) }
                } else {
                  IntConstValue { ok: false, n: 0 }
                },
              _ => IntConstValue { ok: false, n: 0 },
            };
            if lit.ok && int_literal_always_fits_dst_kind(dst_t.kind, lit.n, target_ptr_bits) {
              has.set(tid, true);
              vals.set(tid, lit.n);
              if lit.n >= (0 as i64) {
                non_negative.set(tid, true);
              }
              if is_signed_int_kind(dst_t.kind) {
                let minv: IntConstValue = int_min_const_for_signed_kind(dst_t.kind);
                if minv.ok && lit.n != minv.n {
                  not_signed_min.set(tid, true);
                }
              }
            } else {
              if is_unsigned_int_kind(dst_t.kind) {
                non_negative.set(tid, true);
              } else if is_unsigned_int_kind(src_t.kind) {
                non_negative.set(tid, true);
                not_signed_min.set(tid, true);
              } else if match v { ir.Value.Temp(vtid) => vtid >= 0 && vtid <= max_temp && non_negative.get(vtid), _ => false } {
                non_negative.set(tid, true);
              }
              if is_signed_int_kind(dst_t.kind) {
                let smax_bits: i32 = int_bits_max_for_target(src_t.kind, target_ptr_bits);
                let dmin_bits: i32 = int_bits_min_for_target(dst_t.kind, target_ptr_bits);
                if smax_bits > 0 && dmin_bits > 0 && smax_bits < dmin_bits {
                  not_signed_min.set(tid, true);
                }
              }
            }
          }
        }
      } else if match ins { ir.Instr.SlotDecl(_slot, _ty) => true, _ => false } {
        let slot: i32 = match ins { ir.Instr.SlotDecl(slot, _ty) => slot, _ => 0 };
        if slot >= 0 && slot < slot_has.len() {
          slot_has.set(slot, false);
          slot_vals.set(slot, 0 as i64);
          slot_not_signed_min.set(slot, false);
          slot_non_negative.set(slot, false);
          slot_seen_store_global.set(slot, false);
          slot_all_non_negative_global.set(slot, true);
          slot_all_not_signed_min_global.set(slot, true);
        }
      } else if match ins { ir.Instr.Store(_slot, _v) => true, _ => false } {
        let slot: i32 = match ins { ir.Instr.Store(slot, _v) => slot, _ => 0 };
        if slot >= 0 && slot < slot_has.len() {
          let v: ir.Value = match ins { ir.Instr.Store(_slot, v) => v, _ => ir.v_int(0) };
          let lit: IntConstValue = match v {
            ir.Value.Int(n) => IntConstValue { ok: true, n: n },
            ir.Value.Temp(vtid) =>
              if vtid >= 0 && vtid <= max_temp && has.get(vtid) {
                IntConstValue { ok: true, n: vals.get(vtid) }
              } else {
                IntConstValue { ok: false, n: 0 }
              },
            _ => IntConstValue { ok: false, n: 0 },
          };
          if lit.ok {
            slot_has.set(slot, true);
            slot_vals.set(slot, lit.n);
          } else {
            slot_has.set(slot, false);
            slot_vals.set(slot, 0 as i64);
          }
          let v_non_negative: bool = match v {
            ir.Value.Int(n) => n >= (0 as i64),
            ir.Value.Temp(vtid) => vtid >= 0 && vtid <= max_temp && non_negative.get(vtid),
            _ => false,
          };
          slot_non_negative.set(slot, v_non_negative);
          let v_not_signed_min: bool =
            if v_non_negative {
              true
            } else {
              match v {
                ir.Value.Int(n) => int_literal_not_any_signed_min(n),
                ir.Value.Temp(vtid) => vtid >= 0 && vtid <= max_temp && not_signed_min.get(vtid),
                _ => false,
              }
            };
          slot_not_signed_min.set(slot, v_not_signed_min);
          slot_seen_store_global.set(slot, true);
          if !v_non_negative {
            slot_all_non_negative_global.set(slot, false);
          }
          if !v_not_signed_min {
            slot_all_not_signed_min_global.set(slot, false);
          }
        }
      } else if match ins { ir.Instr.Load(_tid, _ty, _slot) => true, _ => false } {
        let tid: i32 = match ins { ir.Instr.Load(tid, _ty, _slot) => tid, _ => 0 };
        let ty: i32 = match ins { ir.Instr.Load(_tid, ty, _slot) => ty, _ => 0 };
        let slot: i32 = match ins { ir.Instr.Load(_tid, _ty, slot) => slot, _ => 0 };
        if tid >= 0 && tid <= max_temp && slot >= 0 && slot < slot_has.len() {
          let t: ir.Ty = ir.ty_pool_get(pool, ty);
          if is_int_scalar_kind(t.kind) {
            if slot_has.get(slot) && int_literal_always_fits_dst_kind(t.kind, slot_vals.get(slot), target_ptr_bits) {
              let n: i64 = slot_vals.get(slot);
              has.set(tid, true);
              vals.set(tid, n);
              if n >= (0 as i64) {
                non_negative.set(tid, true);
              }
              if is_signed_int_kind(t.kind) {
                let minv: IntConstValue = int_min_const_for_signed_kind(t.kind);
                if minv.ok && n != minv.n {
                  not_signed_min.set(tid, true);
                }
              }
            }
            if is_unsigned_int_kind(t.kind) {
              non_negative.set(tid, true);
              not_signed_min.set(tid, true);
            } else {
              let slot_non_negative_global: bool =
                slot_seen_store_global.get(slot) && slot_all_non_negative_global.get(slot);
              let slot_not_signed_min_global: bool =
                slot_seen_store_global.get(slot) && slot_all_not_signed_min_global.get(slot);
              if slot_non_negative.get(slot) || slot_non_negative_global {
                non_negative.set(tid, true);
                not_signed_min.set(tid, true);
              } else if slot_not_signed_min.get(slot) || slot_not_signed_min_global {
                not_signed_min.set(tid, true);
              }
            }
          }
        }
      } else if match ins { ir.Instr.Call(_has_dst, _tid, _ret_ty, _name, _args) => true, _ => false } {
        let has_dst: bool = match ins { ir.Instr.Call(has_dst, _tid, _ret_ty, _name, _args) => has_dst, _ => false };
        let tid: i32 = match ins { ir.Instr.Call(_has_dst, tid, _ret_ty, _name, _args) => tid, _ => 0 };
        let ret_ty: i32 = match ins { ir.Instr.Call(_has_dst, _tid, ret_ty, _name, _args) => ret_ty, _ => -1 };
        let name: String = match ins { ir.Instr.Call(_has_dst, _tid, _ret_ty, name, _args) => name, _ => "" };
        if has_dst && ret_ty >= 0 && tid >= 0 && tid <= max_temp {
          let t: ir.Ty = ir.ty_pool_get(pool, ret_ty);
          if is_int_scalar_kind(t.kind) && call_result_is_definitely_non_negative(name) {
            non_negative.set(tid, true);
            not_signed_min.set(tid, true);
          }
        }
      }
      ii = ii + 1;
    }
    if slot_w > 0 {
      let mut si2: i32 = 0;
      while si2 < slot_w {
        let oi: i32 = bi * slot_w + si2;
        block_slot_non_negative_out.set(oi, slot_non_negative.get(si2));
        block_slot_not_signed_min_out.set(oi, slot_not_signed_min.get(si2));
        si2 = si2 + 1;
      }
    }
    bi = bi + 1;
  }
  let mut slot_non_negative_global_final: Vec[bool] = Vec();
  let mut slot_not_signed_min_global_final: Vec[bool] = Vec();
  let mut gsi1: i32 = 0;
  while gsi1 < slot_w {
    slot_non_negative_global_final.push(slot_seen_store_global.get(gsi1) && slot_all_non_negative_global.get(gsi1));
    slot_not_signed_min_global_final.push(slot_seen_store_global.get(gsi1) && slot_all_not_signed_min_global.get(gsi1));
    gsi1 = gsi1 + 1;
  }
  return TempIntConstTable {
    has: has,
    vals: vals,
    not_signed_min: not_signed_min,
    non_negative: non_negative,
    slot_not_signed_min: slot_not_signed_min_global_final,
    slot_non_negative: slot_non_negative_global_final,
  };
}

fn int_const_value_from_operand(v: ir.Value, int_consts: TempIntConstTable) -> IntConstValue {
  return match v {
    ir.Value.Int(n) => IntConstValue { ok: true, n: n },
    ir.Value.Temp(tid) => {
      if tid >= 0 && tid < int_consts.has.len() && int_consts.has.get(tid) {
        IntConstValue { ok: true, n: int_consts.vals.get(tid) }
      } else {
        IntConstValue { ok: false, n: 0 }
      }
    },
    _ => IntConstValue { ok: false, n: 0 },
  };
}

fn int_min_const_for_signed_kind(kind: ir.TyKind) -> IntConstValue {
  return match kind {
    ir.TyKind.I8 => IntConstValue { ok: true, n: -128 as i64 },
    ir.TyKind.I16 => IntConstValue { ok: true, n: -32768 as i64 },
    ir.TyKind.I32 => IntConstValue { ok: true, n: ((-2147483647 as i64) - (1 as i64)) },
    ir.TyKind.I64 => IntConstValue { ok: true, n: ((-9223372036854775807 as i64) - (1 as i64)) },
    _ => IntConstValue { ok: false, n: 0 },
  };
}

fn int_literal_not_any_signed_min(n: i64) -> bool {
  return n != (-128 as i64)
    && n != (-32768 as i64)
    && n != ((-2147483647 as i64) - (1 as i64))
    && n != ((-9223372036854775807 as i64) - (1 as i64));
}

fn call_result_is_definitely_non_negative(name: String) -> bool {
  // std.prelude inherent `len` returns i32 length and is semantically non-negative.
  if name.starts_with("std.prelude::impl$inherent$len$") { return true; }
  if name.starts_with("std/prelude::impl$inherent$len$") { return true; }
  if name.starts_with("std::prelude::impl$inherent$len$") { return true; }
  return false;
}

fn find_block_idx_by_name(blocks: Vec[ir.Block], name: String) -> i32 {
  let mut i: i32 = 0;
  while i < blocks.len() {
    if blocks.get(i).name == name { return i; }
    i = i + 1;
  }
  return -1;
}

fn int_operand_is_definitely_not_signed_min(v: ir.Value, kind: ir.TyKind, int_consts: TempIntConstTable) -> bool {
  if !is_signed_int_kind(kind) { return false; }
  let minv: IntConstValue = int_min_const_for_signed_kind(kind);
  if !minv.ok { return false; }
  return match v {
    ir.Value.Int(n) => n != minv.n,
    ir.Value.Temp(tid) => tid >= 0 && tid < int_consts.not_signed_min.len() && int_consts.not_signed_min.get(tid),
    ir.Value.Slot(slot) => slot >= 0 && slot < int_consts.slot_not_signed_min.len() && int_consts.slot_not_signed_min.get(slot),
    _ => false,
  };
}

fn int_operand_is_definitely_non_negative(v: ir.Value, int_consts: TempIntConstTable) -> bool {
  return match v {
    ir.Value.Int(n) => n >= (0 as i64),
    ir.Value.Temp(tid) => tid >= 0 && tid < int_consts.non_negative.len() && int_consts.non_negative.get(tid),
    ir.Value.Slot(slot) => slot >= 0 && slot < int_consts.slot_non_negative.len() && int_consts.slot_non_negative.get(slot),
    _ => false,
  };
}

fn c_param_name_named(vn: ValueNameTables, i: i32) -> String {
  if i >= 0 && i < vn.params.len() { return vn.params.get(i); }
  return c_param_name(i);
}

fn c_temp_name_named(vn: ValueNameTables, id: i32) -> String {
  if id >= 0 && id < vn.temps.len() { return vn.temps.get(id); }
  return c_temp_name(id);
}

fn c_slot_name_named(vn: ValueNameTables, id: i32) -> String {
  if id >= 0 && id < vn.slots.len() { return vn.slots.get(id); }
  return c_slot_name(id);
}

fn c_value_named(v: ir.Value, vn: ValueNameTables) -> String {
  return match v {
    ir.Value.Param(i) => c_param_name_named(vn, i),
    ir.Value.Temp(i) => c_temp_name_named(vn, i),
    ir.Value.Slot(i) => c_slot_name_named(vn, i),
    ir.Value.Int(n) => n.to_string(),
    ir.Value.Float(text) => text,
    ir.Value.Bool(b) => if b { "true" } else { "false" },
    ir.Value.Str(s) => "\"".concat(s.escape_c()).concat("\""),
  };
}

fn c_binop(op: ir.BinOpKind) -> String {
  return match op {
    ir.BinOpKind.Add => "+",
    ir.BinOpKind.Sub => "-",
    ir.BinOpKind.Mul => "*",
    ir.BinOpKind.Div => "/",
    ir.BinOpKind.Mod => "%",
    ir.BinOpKind.BitAnd => "&",
    ir.BinOpKind.BitOr => "|",
    ir.BinOpKind.BitXor => "^",
    ir.BinOpKind.Shl => "<<",
    ir.BinOpKind.Shr => ">>",
  };
}

fn c_cmpop(op: ir.CmpKind) -> String {
  return match op {
    ir.CmpKind.Lt => "<",
    ir.CmpKind.Le => "<=",
    ir.CmpKind.Gt => ">",
    ir.CmpKind.Ge => ">=",
    ir.CmpKind.Eq => "==",
    ir.CmpKind.Ne => "!=",
  };
}

fn c_str_lit(s: String) -> String {
  return "\"".concat(s.escape_c()).concat("\"");
}

fn c_atomic_c_type(pool: ir.TyPool, elem_ty: i32) -> String {
  let t: ir.Ty = ir.ty_pool_get(pool, elem_ty);
  return match t.kind {
    ir.TyKind.I32 => "_Atomic int32_t",
    ir.TyKind.I64 => "_Atomic int64_t",
    ir.TyKind.ISize => "_Atomic intptr_t",
    _ => "_Atomic int64_t",
  };
}

fn c_atomic_val_c_type(pool: ir.TyPool, elem_ty: i32) -> String {
  let t: ir.Ty = ir.ty_pool_get(pool, elem_ty);
  return match t.kind {
    ir.TyKind.I32 => "int32_t",
    ir.TyKind.I64 => "int64_t",
    ir.TyKind.ISize => "intptr_t",
    _ => "int64_t",
  };
}

pub fn build_c_type_table(pool: ir.TyPool) -> Vec[String] {
  let mut out: Vec[String] = Vec();
  let mut i: i32 = 0;
  while i < pool.tys.len() {
    let t: ir.Ty = ir.ty_pool_get(pool, i);
    if t.kind == ir.TyKind.Param || t.kind == ir.TyKind.Ref || t.kind == ir.TyKind.Range || t.kind == ir.TyKind.Verified {
      // Keep wrappers/unresolved params lazy; precomputing them can recurse into
      // unresolved type params in generic contexts.
      out.push("");
    } else {
      out.push(c_type(pool, i));
    }
    i = i + 1;
  }
  return out;
}

fn c_type_from_table(c_types: Vec[String], pool: ir.TyPool, ty_idx: i32) -> String {
  if ty_idx >= 0 && ty_idx < c_types.len() {
    let ct: String = c_types.get(ty_idx);
    if ct != "" { return ct; }
  }
  return c_type(pool, ty_idx);
}

fn emit_instr_atomic_new_append(out0: Vec[String], pool: ir.TyPool, tid: i32, elem_ty: i32, val: ir.Value, vn: ValueNameTables) -> Vec[String] {
  let at: String = c_atomic_c_type(pool, elem_ty);
  let tmp: String = "_at_".concat(tid.to_string());
  let mut out: Vec[String] = out0;
  out.push("  ".concat(at).concat("* ").concat(tmp).concat(" = (").concat(at).concat("*)malloc(sizeof(").concat(at).concat("));"));
  out.push("  if (!".concat(tmp).concat(") { vox_host_panic(\"out of memory\"); }"));
  out.push("  atomic_init(".concat(tmp).concat(", ").concat(c_value_named(val, vn)).concat(");"));
  out.push("  ".concat(c_temp_name_named(vn, tid)).concat(" = (intptr_t)").concat(tmp).concat(";"));
  return out;
}

fn emit_instr_atomic_cas_append(out0: Vec[String], pool: ir.TyPool, tid: i32, elem_ty: i32, h: ir.Value, expected: ir.Value, desired: ir.Value, vn: ValueNameTables) -> Vec[String] {
  let at: String = c_atomic_c_type(pool, elem_ty);
  let vt: String = c_atomic_val_c_type(pool, elem_ty);
  let tmp: String = "_cas_".concat(tid.to_string());
  let mut out: Vec[String] = out0;
  out.push("  ".concat(vt).concat(" ").concat(tmp).concat(" = ").concat(c_value_named(expected, vn)).concat(";"));
  out.push("  ".concat(c_temp_name_named(vn, tid)).concat(" = atomic_compare_exchange_strong_explicit((").concat(at).concat("*)").concat(c_value_named(h, vn)).concat(", &").concat(tmp).concat(", ").concat(c_value_named(desired, vn)).concat(", memory_order_seq_cst, memory_order_seq_cst);"));
  return out;
}

fn is_int_scalar_kind(k: ir.TyKind) -> bool {
  return match k {
    ir.TyKind.I8 => true,
    ir.TyKind.U8 => true,
    ir.TyKind.I16 => true,
    ir.TyKind.U16 => true,
    ir.TyKind.I32 => true,
    ir.TyKind.U32 => true,
    ir.TyKind.I64 => true,
    ir.TyKind.U64 => true,
    ir.TyKind.ISize => true,
    ir.TyKind.USize => true,
    _ => false,
  };
}

fn is_signed_int_kind(k: ir.TyKind) -> bool {
  return match k { ir.TyKind.I8 => true, ir.TyKind.I16 => true, ir.TyKind.I32 => true, ir.TyKind.I64 => true, ir.TyKind.ISize => true, _ => false };
}

fn is_unsigned_int_kind(k: ir.TyKind) -> bool {
  return match k { ir.TyKind.U8 => true, ir.TyKind.U16 => true, ir.TyKind.U32 => true, ir.TyKind.U64 => true, ir.TyKind.USize => true, _ => false };
}

fn int_bits(k: ir.TyKind) -> i32 {
  return match k {
    ir.TyKind.I8 => 8,
    ir.TyKind.U8 => 8,
    ir.TyKind.I16 => 16,
    ir.TyKind.U16 => 16,
    ir.TyKind.I32 => 32,
    ir.TyKind.U32 => 32,
    ir.TyKind.I64 => 64,
    ir.TyKind.U64 => 64,
    ir.TyKind.ISize => 0,
    ir.TyKind.USize => 0,
    _ => 0,
  };
}

fn int_bits_expr(k: ir.TyKind) -> String {
  if k == ir.TyKind.ISize || k == ir.TyKind.USize {
    return "((int32_t)(sizeof(uintptr_t) * 8))";
  }
  let b: i32 = int_bits(k);
  return b.to_string();
}

fn int_sign_high_bit_expr(k: ir.TyKind) -> String {
  if k == ir.TyKind.ISize {
    return "(((uintptr_t)1) << (((int32_t)(sizeof(uintptr_t) * 8)) - 1))";
  }
  let b: i32 = int_bits(k);
  return "(((".concat(unsigned_peer_c_type(k)).concat(")1) << ").concat((b - 1).to_string()).concat(")");
}

fn int_bits_min(k: ir.TyKind) -> i32 {
  if k == ir.TyKind.ISize || k == ir.TyKind.USize { return 32; }
  return int_bits(k);
}

fn int_bits_max(k: ir.TyKind) -> i32 {
  if k == ir.TyKind.ISize || k == ir.TyKind.USize { return 64; }
  return int_bits(k);
}

fn ptr_bits_known(pbits: i32) -> bool {
  return pbits == 32 || pbits == 64;
}

fn int_bits_min_for_target(k: ir.TyKind, target_ptr_bits: i32) -> i32 {
  if k == ir.TyKind.ISize || k == ir.TyKind.USize {
    if ptr_bits_known(target_ptr_bits) { return target_ptr_bits; }
    return 32;
  }
  return int_bits_min(k);
}

fn int_bits_max_for_target(k: ir.TyKind, target_ptr_bits: i32) -> i32 {
  if k == ir.TyKind.ISize || k == ir.TyKind.USize {
    if ptr_bits_known(target_ptr_bits) { return target_ptr_bits; }
    return 64;
  }
  return int_bits_max(k);
}

fn int_cast_needs_runtime_check(dst: ir.TyKind, src: ir.TyKind, target_ptr_bits: i32) -> bool {
  if !is_int_scalar_kind(dst) || !is_int_scalar_kind(src) { return true; }
  if dst == src { return false; }
  let dmin: i32 = int_bits_min_for_target(dst, target_ptr_bits);
  let smax: i32 = int_bits_max_for_target(src, target_ptr_bits);
  if dmin == 0 || smax == 0 { return true; }

  let du: bool = is_unsigned_int_kind(dst);
  let su: bool = is_unsigned_int_kind(src);
  if du && !su { return true; } // signed -> unsigned always needs non-negative check
  if !du && su { return dmin <= smax; } // unsigned -> signed needs at least one extra sign bit
  return dmin < smax; // same signedness: destination must hold full source range
}

fn int_cast_signed_to_unsigned_needs_upper_check(dst: ir.TyKind, src: ir.TyKind, target_ptr_bits: i32) -> bool {
  if !is_unsigned_int_kind(dst) || !is_signed_int_kind(src) { return true; }
  // isize -> usize is width-equal by definition on every target.
  if src == ir.TyKind.ISize && dst == ir.TyKind.USize { return false; }
  let dmin: i32 = int_bits_min_for_target(dst, target_ptr_bits);
  let smax: i32 = int_bits_max_for_target(src, target_ptr_bits);
  if dmin == 0 || smax == 0 { return true; }
  // Signed src max is 2^(s-1)-1; any unsigned destination with at least s bits always fits it.
  return dmin < smax;
}

// Conservative literal-fit check used by codegen-only fast paths.
// For pointer-sized ints, require fit across all supported targets (32/64-bit).
fn int_literal_always_fits_dst_kind(dst: ir.TyKind, n: i64, target_ptr_bits: i32) -> bool {
  return match dst {
    ir.TyKind.I8 => n >= -128 && n <= 127,
    ir.TyKind.U8 => n >= 0 && n <= 255,
    ir.TyKind.I16 => n >= -32768 && n <= 32767,
    ir.TyKind.U16 => n >= 0 && n <= 65535,
    ir.TyKind.I32 => n >= -2147483648 && n <= 2147483647,
    ir.TyKind.U32 => n >= 0 && n <= 4294967295,
    ir.TyKind.I64 => true,
    ir.TyKind.U64 => n >= 0,
    ir.TyKind.ISize =>
      if ptr_bits_known(target_ptr_bits) && target_ptr_bits >= 64 {
        true
      } else {
        n >= -2147483648 && n <= 2147483647
      },
    ir.TyKind.USize =>
      if ptr_bits_known(target_ptr_bits) && target_ptr_bits >= 64 {
        n >= 0
      } else {
        n >= 0 && n <= 4294967295
      },
    _ => false,
  };
}

fn unsigned_peer_c_type(k: ir.TyKind) -> String {
  return match k {
    ir.TyKind.I8 => "uint8_t",
    ir.TyKind.U8 => "uint8_t",
    ir.TyKind.I16 => "uint16_t",
    ir.TyKind.U16 => "uint16_t",
    ir.TyKind.I32 => "uint32_t",
    ir.TyKind.U32 => "uint32_t",
    ir.TyKind.I64 => "uint64_t",
    ir.TyKind.U64 => "uint64_t",
    ir.TyKind.ISize => "uintptr_t",
    ir.TyKind.USize => "uintptr_t",
    _ => "uint64_t",
  };
}

fn signed_from_unsigned_bitcast_fn(k: ir.TyKind) -> String {
  return match k {
    ir.TyKind.I8 => "vox_bitcast_u8_i8",
    ir.TyKind.I16 => "vox_bitcast_u16_i16",
    ir.TyKind.I32 => "vox_bitcast_u32_i32",
    ir.TyKind.I64 => "vox_bitcast_u64_i64",
    ir.TyKind.ISize => "vox_bitcast_uptr_iptr",
    _ => "",
  };
}

fn signed_min_macro(k: ir.TyKind) -> String {
  return match k {
    ir.TyKind.I8 => "INT8_MIN",
    ir.TyKind.I16 => "INT16_MIN",
    ir.TyKind.I32 => "INT32_MIN",
    ir.TyKind.I64 => "INT64_MIN",
    ir.TyKind.ISize => "INTPTR_MIN",
    _ => "",
  };
}

fn signed_max_macro(k: ir.TyKind) -> String {
  return match k {
    ir.TyKind.I8 => "INT8_MAX",
    ir.TyKind.I16 => "INT16_MAX",
    ir.TyKind.I32 => "INT32_MAX",
    ir.TyKind.I64 => "INT64_MAX",
    ir.TyKind.ISize => "INTPTR_MAX",
    _ => "",
  };
}

struct LocalsResult { slots: Vec[IdTy], temps: Vec[IdTy], max_slot: i32, max_temp: i32 }

fn locals0() -> LocalsResult { return LocalsResult { slots: Vec(), temps: Vec(), max_slot: -1, max_temp: -1 }; }

fn temp_flag_get(flags: Vec[bool], tid: i32) -> bool {
  if tid < 0 || tid >= flags.len() { return false; }
  return flags.get(tid);
}

fn temp_flag_set(flags0: Vec[bool], tid: i32) -> Vec[bool] {
  if tid < 0 { return flags0; }
  let mut flags: Vec[bool] = flags0;
  while flags.len() <= tid { flags.push(false); }
  if !flags.get(tid) { flags.set(tid, true); }
  return flags;
}

fn slot_flag_get(flags: Vec[bool], sid: i32) -> bool {
  if sid < 0 || sid >= flags.len() { return false; }
  return flags.get(sid);
}

fn slot_flag_set(flags0: Vec[bool], sid: i32) -> Vec[bool] {
  if sid < 0 { return flags0; }
  let mut flags: Vec[bool] = flags0;
  while flags.len() <= sid { flags.push(false); }
  if !flags.get(sid) { flags.set(sid, true); }
  return flags;
}

fn mark_live_slot_value(flags0: Vec[bool], v: ir.Value) -> Vec[bool] {
  return match v {
    ir.Value.Slot(sid) => slot_flag_set(flags0, sid),
    _ => flags0,
  };
}

fn mark_live_slot_values(flags0: Vec[bool], vals: Vec[ir.Value]) -> Vec[bool] {
  let mut flags: Vec[bool] = flags0;
  let mut i: i32 = 0;
  while i < vals.len() {
    flags = mark_live_slot_value(flags, vals.get(i));
    i = i + 1;
  }
  return flags;
}

// Includes explicit slot reads (e.g. Load/Vec receiver slots) and
// slot-typed operands in values.
fn mark_live_slot_values_from_instr(flags0: Vec[bool], ins: ir.Instr) -> Vec[bool] {
  return match ins {
    ir.Instr.Const(_tid, _ty, v) => mark_live_slot_value(flags0, v),
    ir.Instr.BinOp(_tid, _op, _ty, a, b) => mark_live_slot_value(mark_live_slot_value(flags0, a), b),
    ir.Instr.Cmp(_tid, _op, _oty, a, b) => mark_live_slot_value(mark_live_slot_value(flags0, a), b),
    ir.Instr.And(_tid, a, b) => mark_live_slot_value(mark_live_slot_value(flags0, a), b),
    ir.Instr.Or(_tid, a, b) => mark_live_slot_value(mark_live_slot_value(flags0, a), b),
    ir.Instr.Not(_tid, a) => mark_live_slot_value(flags0, a),
    ir.Instr.IntCast(_tid, _dst_ty, _src_ty, v) => mark_live_slot_value(flags0, v),
    ir.Instr.IntCastChecked(_tid, _dst_ty, _src_ty, v) => mark_live_slot_value(flags0, v),
    ir.Instr.FloatCast(_tid, _dst_ty, _src_ty, v) => mark_live_slot_value(flags0, v),
    ir.Instr.RangeCheck(_ty, v, _lo, _hi) => mark_live_slot_value(flags0, v),
    ir.Instr.SlotDecl(_sid, _ty) => flags0,
    ir.Instr.Store(_sid, v) => mark_live_slot_value(flags0, v),
    ir.Instr.Load(_tid, _ty, sid) => slot_flag_set(flags0, sid),
    ir.Instr.GlobalLoad(_tid, _ty, _name) => flags0,
    ir.Instr.GlobalStore(_ty, _name, v) => mark_live_slot_value(flags0, v),
    ir.Instr.AddrOfSlot(_tid, _ty, sid) => slot_flag_set(flags0, sid),
    ir.Instr.AddrOfFieldChain(_tid, _ty, sid, _fields) => slot_flag_set(flags0, sid),
    ir.Instr.RefLoad(_tid, _ty, recv) => mark_live_slot_value(flags0, recv),
    ir.Instr.RefStore(_ty, recv, v) => mark_live_slot_value(mark_live_slot_value(flags0, recv), v),
    ir.Instr.PtrRead(_tid, _ty, ptr) => mark_live_slot_value(flags0, ptr),
    ir.Instr.PtrWrite(_ty, ptr, v) => mark_live_slot_value(mark_live_slot_value(flags0, ptr), v),
    ir.Instr.PtrOffset(_tid, ptr, off) => mark_live_slot_value(mark_live_slot_value(flags0, ptr), off),
    ir.Instr.StructInit(_tid, _ty, fields) => {
      let mut flags: Vec[bool] = flags0;
      let mut i: i32 = 0;
      while i < fields.len() {
        flags = mark_live_slot_value(flags, fields.get(i).val);
        i = i + 1;
      }
      flags
    },
    ir.Instr.FieldGet(_tid, _ty, recv, _field) => mark_live_slot_value(flags0, recv),
    ir.Instr.StoreField(sid, _field, v) => mark_live_slot_value(slot_flag_set(flags0, sid), v),
    ir.Instr.EnumInit(_tid, _ty, _variant, payload) => mark_live_slot_values(flags0, payload),
    ir.Instr.EnumTag(_tid, recv) => mark_live_slot_value(flags0, recv),
    ir.Instr.EnumPayload(_tid, _ty, recv, _variant, _idx) => mark_live_slot_value(flags0, recv),
    ir.Instr.VecNew(_tid, _vty, _elem) => flags0,
    ir.Instr.VecPush(recv_slot, _elem, v) => mark_live_slot_value(slot_flag_set(flags0, recv_slot), v),
    ir.Instr.VecInsert(recv_slot, _elem, idx, v) => mark_live_slot_value(mark_live_slot_value(slot_flag_set(flags0, recv_slot), idx), v),
    ir.Instr.VecSet(recv_slot, _elem, idx, v) => mark_live_slot_value(mark_live_slot_value(slot_flag_set(flags0, recv_slot), idx), v),
    ir.Instr.VecClear(recv_slot) => slot_flag_set(flags0, recv_slot),
    ir.Instr.VecExtend(recv_slot, other_slot) => slot_flag_set(slot_flag_set(flags0, recv_slot), other_slot),
    ir.Instr.VecPop(_tid, _elem, recv_slot) => slot_flag_set(flags0, recv_slot),
    ir.Instr.VecRemove(_tid, _elem, recv_slot, idx) => mark_live_slot_value(slot_flag_set(flags0, recv_slot), idx),
    ir.Instr.VecLen(_tid, recv_slot) => slot_flag_set(flags0, recv_slot),
    ir.Instr.VecGet(_tid, _elem, recv_slot, idx) => mark_live_slot_value(slot_flag_set(flags0, recv_slot), idx),
    ir.Instr.AtomicNew(_tid, _elem_ty, val) => mark_live_slot_value(flags0, val),
    ir.Instr.AtomicLoad(_tid, _elem_ty, h) => mark_live_slot_value(flags0, h),
    ir.Instr.AtomicStore(_elem_ty, h, val) => mark_live_slot_value(mark_live_slot_value(flags0, h), val),
    ir.Instr.AtomicFetchAdd(_tid, _elem_ty, h, delta) => mark_live_slot_value(mark_live_slot_value(flags0, h), delta),
    ir.Instr.AtomicSwap(_tid, _elem_ty, h, val) => mark_live_slot_value(mark_live_slot_value(flags0, h), val),
    ir.Instr.AtomicCAS(_tid, _elem_ty, h, expected, desired) => mark_live_slot_value(mark_live_slot_value(mark_live_slot_value(flags0, h), expected), desired),
    ir.Instr.AtomicDrop(_elem_ty, h) => mark_live_slot_value(flags0, h),
    ir.Instr.Call(_has_dst, _tid, _ret_ty, _name, args) => mark_live_slot_values(flags0, args),
  };
}

fn mark_live_slot_values_from_term(flags0: Vec[bool], t: ir.Term) -> Vec[bool] {
  return match t {
    ir.Term.Ret(has, v) => if has { mark_live_slot_value(flags0, v) } else { flags0 },
    ir.Term.Br(_target) => flags0,
    ir.Term.CondBr(cond, _then_block, _else_block) => mark_live_slot_value(flags0, cond),
    ir.Term.Panic(msg) => mark_live_slot_value(flags0, msg),
  };
}

struct SeedLivenessSummary {
  live_slots: Vec[bool],
  live_temps: Vec[bool],
  slot_candidates: Vec[i32],
  drop_temp_candidates: Vec[i32],
  needs_int_const_table: bool,
}

fn instr_needs_int_const_table(ins: ir.Instr) -> bool {
  return match ins {
    ir.Instr.IntCastChecked(_tid, _dst_ty, _src_ty, _v) => true,
    ir.Instr.BinOp(_tid, op, _ty, _a, _b) =>
      match op {
        ir.BinOpKind.Shl => true,
        ir.BinOpKind.Shr => true,
        ir.BinOpKind.Div => true,
        ir.BinOpKind.Mod => true,
        _ => false,
      },
    _ => false,
  };
}

fn collect_seed_liveness_summary(pool: ir.TyPool, f: ir.Func) -> SeedLivenessSummary {
  let mut live_slots: Vec[bool] = Vec();
  let mut live_temps: Vec[bool] = Vec();
  let mut slot_candidates: Vec[i32] = Vec();
  let mut drop_temp_candidates: Vec[i32] = Vec();
  let mut needs_int_const_table: bool = false;
  let mut bi: i32 = 0;
  while bi < f.blocks.len() {
    let b: ir.Block = f.blocks.get(bi);
    let mut ii: i32 = 0;
    while ii < b.instrs.len() {
      let ins: ir.Instr = b.instrs.get(ii);
      if !needs_int_const_table && instr_needs_int_const_table(ins) {
        needs_int_const_table = true;
      }
      live_slots = mark_live_slot_values_from_instr(live_slots, ins);
      live_temps = mark_live_from_instr_operands(live_temps, ins);
      live_temps = match ins {
        ir.Instr.SlotDecl(sid, _ty) => {
          slot_candidates.push(sid);
          live_temps
        },
        ir.Instr.Store(sid, _v) => {
          slot_candidates.push(sid);
          live_temps
        },
        _ => {
          let dst: i32 = instr_dst_temp_id(ins);
          if dst != -1 && instr_can_drop_when_dead(pool, ins) { drop_temp_candidates.push(dst); }
          live_temps
        },
      };
      ii = ii + 1;
    }
    if b.has_term {
      live_slots = mark_live_slot_values_from_term(live_slots, b.term);
      live_temps = mark_live_from_term(live_temps, b.term);
    }
    bi = bi + 1;
  }
  return SeedLivenessSummary {
    live_slots: live_slots,
    live_temps: live_temps,
    slot_candidates: slot_candidates,
    drop_temp_candidates: drop_temp_candidates,
    needs_int_const_table: needs_int_const_table,
  };
}

fn has_dead_candidates_from_seed(seed: SeedLivenessSummary) -> bool {
  let mut i: i32 = 0;
  while i < seed.slot_candidates.len() {
    if !slot_flag_get(seed.live_slots, seed.slot_candidates.get(i)) { return true; }
    i = i + 1;
  }
  i = 0;
  while i < seed.drop_temp_candidates.len() {
    if !temp_flag_get(seed.live_temps, seed.drop_temp_candidates.get(i)) { return true; }
    i = i + 1;
  }
  return false;
}

fn collect_live_slots_filtered(pool: ir.TyPool, f: ir.Func, live_temps: Vec[bool], live_slots0: Vec[bool]) -> Vec[bool] {
  let mut live: Vec[bool] = Vec();
  let mut bi: i32 = 0;
  while bi < f.blocks.len() {
    let b: ir.Block = f.blocks.get(bi);
    let mut ii: i32 = 0;
    while ii < b.instrs.len() {
      let ins: ir.Instr = b.instrs.get(ii);
      if !instr_is_dead_temp(pool, ins, live_temps) && !instr_is_dead_slot_instr(ins, live_slots0) {
        live = mark_live_slot_values_from_instr(live, ins);
      }
      ii = ii + 1;
    }
    if b.has_term { live = mark_live_slot_values_from_term(live, b.term); }
    bi = bi + 1;
  }
  return live;
}

fn instr_is_dead_slot_decl(ins: ir.Instr, live_slots: Vec[bool]) -> bool {
  return match ins {
    ir.Instr.SlotDecl(sid, _ty) => !slot_flag_get(live_slots, sid),
    _ => false,
  };
}

fn instr_is_dead_slot_store(ins: ir.Instr, live_slots: Vec[bool]) -> bool {
  return match ins {
    ir.Instr.Store(sid, _v) => !slot_flag_get(live_slots, sid),
    _ => false,
  };
}

fn instr_is_dead_slot_instr(ins: ir.Instr, live_slots: Vec[bool]) -> bool {
  return instr_is_dead_slot_decl(ins, live_slots) || instr_is_dead_slot_store(ins, live_slots);
}

fn mark_live_value(flags0: Vec[bool], v: ir.Value) -> Vec[bool] {
  return match v {
    ir.Value.Temp(tid) => temp_flag_set(flags0, tid),
    _ => flags0,
  };
}

fn mark_live_values(flags0: Vec[bool], vals: Vec[ir.Value]) -> Vec[bool] {
  let mut flags: Vec[bool] = flags0;
  let mut i: i32 = 0;
  while i < vals.len() {
    flags = mark_live_value(flags, vals.get(i));
    i = i + 1;
  }
  return flags;
}

fn instr_dst_temp_id(ins: ir.Instr) -> i32 {
  return match ins {
    ir.Instr.Const(tid, _ty, _v) => tid,
    ir.Instr.BinOp(tid, _op, _ty, _a, _b) => tid,
    ir.Instr.Cmp(tid, _op, _oty, _a, _b) => tid,
    ir.Instr.And(tid, _a, _b) => tid,
    ir.Instr.Or(tid, _a, _b) => tid,
    ir.Instr.Not(tid, _a) => tid,
    ir.Instr.IntCast(tid, _dst_ty, _src_ty, _v) => tid,
    ir.Instr.IntCastChecked(tid, _dst_ty, _src_ty, _v) => tid,
    ir.Instr.FloatCast(tid, _dst_ty, _src_ty, _v) => tid,
    ir.Instr.Load(tid, _ty, _sid) => tid,
    ir.Instr.GlobalLoad(tid, _ty, _name) => tid,
    ir.Instr.AddrOfSlot(tid, _ty, _sid) => tid,
    ir.Instr.AddrOfFieldChain(tid, _ty, _sid, _fields) => tid,
    ir.Instr.RefLoad(tid, _ty, _recv) => tid,
    ir.Instr.PtrRead(tid, _ty, _ptr) => tid,
    ir.Instr.PtrOffset(tid, _ptr, _off) => tid,
    ir.Instr.StructInit(tid, _ty, _fields) => tid,
    ir.Instr.FieldGet(tid, _ty, _recv, _field) => tid,
    ir.Instr.EnumInit(tid, _ty, _variant, _payload) => tid,
    ir.Instr.EnumTag(tid, _recv) => tid,
    ir.Instr.EnumPayload(tid, _ty, _recv, _variant, _idx) => tid,
    ir.Instr.VecNew(tid, _vty, _elem) => tid,
    ir.Instr.VecPop(tid, _elem, _recv_slot) => tid,
    ir.Instr.VecRemove(tid, _elem, _recv_slot, _idx) => tid,
    ir.Instr.VecLen(tid, _recv_slot) => tid,
    ir.Instr.VecGet(tid, _elem, _recv_slot, _idx) => tid,
    ir.Instr.AtomicNew(tid, _elem_ty, _val) => tid,
    ir.Instr.AtomicLoad(tid, _elem_ty, _h) => tid,
    ir.Instr.AtomicFetchAdd(tid, _elem_ty, _h, _delta) => tid,
    ir.Instr.AtomicSwap(tid, _elem_ty, _h, _val) => tid,
    ir.Instr.AtomicCAS(tid, _elem_ty, _h, _expected, _desired) => tid,
    ir.Instr.Call(has_dst, tid, _ret_ty, _name, _args) => if has_dst { tid } else { -1 },
    _ => -1,
  };
}

fn binop_can_panic(pool: ir.TyPool, op: ir.BinOpKind, ty: i32) -> bool {
  let t: ir.Ty = ir.ty_pool_get(pool, ty);
  if !is_int_scalar_kind(t.kind) { return false; }
  return match op {
    ir.BinOpKind.Div => true,
    ir.BinOpKind.Mod => true,
    ir.BinOpKind.Shl => true,
    ir.BinOpKind.Shr => true,
    _ => false,
  };
}

fn instr_can_drop_when_dead(pool: ir.TyPool, ins: ir.Instr) -> bool {
  return match ins {
    ir.Instr.Const(_tid, _ty, _v) => true,
    ir.Instr.BinOp(_tid, op, ty, _a, _b) => !binop_can_panic(pool, op, ty),
    ir.Instr.Cmp(_tid, _op, _oty, _a, _b) => true,
    ir.Instr.And(_tid, _a, _b) => true,
    ir.Instr.Or(_tid, _a, _b) => true,
    ir.Instr.Not(_tid, _a) => true,
    ir.Instr.IntCast(_tid, _dst_ty, _src_ty, _v) => true,
    ir.Instr.FloatCast(_tid, _dst_ty, _src_ty, _v) => true,
    ir.Instr.Load(_tid, _ty, _sid) => true,
    ir.Instr.GlobalLoad(_tid, _ty, _name) => true,
    ir.Instr.AddrOfSlot(_tid, _ty, _sid) => true,
    ir.Instr.AddrOfFieldChain(_tid, _ty, _sid, _fields) => true,
    ir.Instr.PtrOffset(_tid, _ptr, _off) => true,
    ir.Instr.StructInit(_tid, _ty, _fields) => true,
    ir.Instr.FieldGet(_tid, _ty, _recv, _field) => true,
    ir.Instr.EnumInit(_tid, _ty, _variant, _payload) => true,
    ir.Instr.EnumTag(_tid, _recv) => true,
    ir.Instr.EnumPayload(_tid, _ty, _recv, _variant, _idx) => true,
    ir.Instr.VecLen(_tid, _recv_slot) => true,
    _ => false,
  };
}

fn mark_live_from_instr_operands(flags0: Vec[bool], ins: ir.Instr) -> Vec[bool] {
  return match ins {
    ir.Instr.Const(_tid, _ty, _v) => flags0,
    ir.Instr.BinOp(_tid, _op, _ty, a, b) => mark_live_value(mark_live_value(flags0, a), b),
    ir.Instr.Cmp(_tid, _op, _oty, a, b) => mark_live_value(mark_live_value(flags0, a), b),
    ir.Instr.And(_tid, a, b) => mark_live_value(mark_live_value(flags0, a), b),
    ir.Instr.Or(_tid, a, b) => mark_live_value(mark_live_value(flags0, a), b),
    ir.Instr.Not(_tid, a) => mark_live_value(flags0, a),
    ir.Instr.IntCast(_tid, _dst_ty, _src_ty, v) => mark_live_value(flags0, v),
    ir.Instr.IntCastChecked(_tid, _dst_ty, _src_ty, v) => mark_live_value(flags0, v),
    ir.Instr.FloatCast(_tid, _dst_ty, _src_ty, v) => mark_live_value(flags0, v),
    ir.Instr.RangeCheck(_ty, v, _lo, _hi) => mark_live_value(flags0, v),
    ir.Instr.SlotDecl(_sid, _ty) => flags0,
    ir.Instr.Store(_sid, v) => mark_live_value(flags0, v),
    ir.Instr.Load(_tid, _ty, _sid) => flags0,
    ir.Instr.GlobalLoad(_tid, _ty, _name) => flags0,
    ir.Instr.GlobalStore(_ty, _name, v) => mark_live_value(flags0, v),
    ir.Instr.AddrOfSlot(_tid, _ty, _sid) => flags0,
    ir.Instr.AddrOfFieldChain(_tid, _ty, _sid, _fields) => flags0,
    ir.Instr.RefLoad(_tid, _ty, recv) => mark_live_value(flags0, recv),
    ir.Instr.RefStore(_ty, recv, v) => mark_live_value(mark_live_value(flags0, recv), v),
    ir.Instr.PtrRead(_tid, _ty, ptr) => mark_live_value(flags0, ptr),
    ir.Instr.PtrWrite(_ty, ptr, v) => mark_live_value(mark_live_value(flags0, ptr), v),
    ir.Instr.PtrOffset(_tid, ptr, off) => mark_live_value(mark_live_value(flags0, ptr), off),
    ir.Instr.StructInit(_tid, _ty, fields) => {
      let mut flags: Vec[bool] = flags0;
      let mut i: i32 = 0;
      while i < fields.len() {
        flags = mark_live_value(flags, fields.get(i).val);
        i = i + 1;
      }
      flags
    },
    ir.Instr.FieldGet(_tid, _ty, recv, _field) => mark_live_value(flags0, recv),
    ir.Instr.StoreField(_sid, _field, v) => mark_live_value(flags0, v),
    ir.Instr.EnumInit(_tid, _ty, _variant, payload) => mark_live_values(flags0, payload),
    ir.Instr.EnumTag(_tid, recv) => mark_live_value(flags0, recv),
    ir.Instr.EnumPayload(_tid, _ty, recv, _variant, _idx) => mark_live_value(flags0, recv),
    ir.Instr.VecNew(_tid, _vty, _elem) => flags0,
    ir.Instr.VecPush(_recv_slot, _elem, v) => mark_live_value(flags0, v),
    ir.Instr.VecInsert(_recv_slot, _elem, idx, v) => mark_live_value(mark_live_value(flags0, idx), v),
    ir.Instr.VecSet(_recv_slot, _elem, idx, v) => mark_live_value(mark_live_value(flags0, idx), v),
    ir.Instr.VecClear(_recv_slot) => flags0,
    ir.Instr.VecExtend(_recv_slot, _other_slot) => flags0,
    ir.Instr.VecPop(_tid, _elem, _recv_slot) => flags0,
    ir.Instr.VecRemove(_tid, _elem, _recv_slot, idx) => mark_live_value(flags0, idx),
    ir.Instr.VecLen(_tid, _recv_slot) => flags0,
    ir.Instr.VecGet(_tid, _elem, _recv_slot, idx) => mark_live_value(flags0, idx),
    ir.Instr.AtomicNew(_tid, _elem_ty, val) => mark_live_value(flags0, val),
    ir.Instr.AtomicLoad(_tid, _elem_ty, h) => mark_live_value(flags0, h),
    ir.Instr.AtomicStore(_elem_ty, h, val) => mark_live_value(mark_live_value(flags0, h), val),
    ir.Instr.AtomicFetchAdd(_tid, _elem_ty, h, delta) => mark_live_value(mark_live_value(flags0, h), delta),
    ir.Instr.AtomicSwap(_tid, _elem_ty, h, val) => mark_live_value(mark_live_value(flags0, h), val),
    ir.Instr.AtomicCAS(_tid, _elem_ty, h, expected, desired) => mark_live_value(mark_live_value(mark_live_value(flags0, h), expected), desired),
    ir.Instr.AtomicDrop(_elem_ty, h) => mark_live_value(flags0, h),
    ir.Instr.Call(_has_dst, _tid, _ret_ty, _name, args) => mark_live_values(flags0, args),
  };
}

fn mark_live_from_term(flags0: Vec[bool], t: ir.Term) -> Vec[bool] {
  return match t {
    ir.Term.Ret(has, v) => if has { mark_live_value(flags0, v) } else { flags0 },
    ir.Term.Br(_target) => flags0,
    ir.Term.CondBr(cond, _then_block, _else_block) => mark_live_value(flags0, cond),
    ir.Term.Panic(msg) => mark_live_value(flags0, msg),
  };
}

fn bool_flags_equal(a: Vec[bool], b: Vec[bool]) -> bool {
  if a.len() != b.len() { return false; }
  let mut i: i32 = 0;
  while i < a.len() {
    if a.get(i) != b.get(i) { return false; }
    i = i + 1;
  }
  return true;
}

struct ClosureInstrRef { next_same_dst: i32, block_idx: i32, instr_idx: i32 }

fn temp_ids_push_from_value(ids0: Vec[i32], v: ir.Value) -> Vec[i32] {
  return match v {
    ir.Value.Temp(tid) => {
      let mut ids: Vec[i32] = ids0;
      ids.push(tid);
      ids
    },
    _ => ids0,
  };
}

fn temp_ids_push_from_values(ids0: Vec[i32], vals: Vec[ir.Value]) -> Vec[i32] {
  let mut ids: Vec[i32] = ids0;
  let mut i: i32 = 0;
  while i < vals.len() {
    ids = temp_ids_push_from_value(ids, vals.get(i));
    i = i + 1;
  }
  return ids;
}

fn collect_operand_temp_ids_into(ins: ir.Instr, ids0: Vec[i32]) -> Vec[i32] {
  let mut ids: Vec[i32] = ids0;
  ids.clear();
  return match ins {
    ir.Instr.Const(_tid, _ty, _v) => ids,
    ir.Instr.BinOp(_tid, _op, _ty, a, b) => temp_ids_push_from_value(temp_ids_push_from_value(ids, a), b),
    ir.Instr.Cmp(_tid, _op, _oty, a, b) => temp_ids_push_from_value(temp_ids_push_from_value(ids, a), b),
    ir.Instr.And(_tid, a, b) => temp_ids_push_from_value(temp_ids_push_from_value(ids, a), b),
    ir.Instr.Or(_tid, a, b) => temp_ids_push_from_value(temp_ids_push_from_value(ids, a), b),
    ir.Instr.Not(_tid, a) => temp_ids_push_from_value(ids, a),
    ir.Instr.IntCast(_tid, _dst_ty, _src_ty, v) => temp_ids_push_from_value(ids, v),
    ir.Instr.IntCastChecked(_tid, _dst_ty, _src_ty, v) => temp_ids_push_from_value(ids, v),
    ir.Instr.FloatCast(_tid, _dst_ty, _src_ty, v) => temp_ids_push_from_value(ids, v),
    ir.Instr.RangeCheck(_ty, v, _lo, _hi) => temp_ids_push_from_value(ids, v),
    ir.Instr.SlotDecl(_sid, _ty) => ids,
    ir.Instr.Store(_sid, v) => temp_ids_push_from_value(ids, v),
    ir.Instr.Load(_tid, _ty, _sid) => ids,
    ir.Instr.GlobalLoad(_tid, _ty, _name) => ids,
    ir.Instr.GlobalStore(_ty, _name, v) => temp_ids_push_from_value(ids, v),
    ir.Instr.AddrOfSlot(_tid, _ty, _sid) => ids,
    ir.Instr.AddrOfFieldChain(_tid, _ty, _sid, _fields) => ids,
    ir.Instr.RefLoad(_tid, _ty, recv) => temp_ids_push_from_value(ids, recv),
    ir.Instr.RefStore(_ty, recv, v) => temp_ids_push_from_value(temp_ids_push_from_value(ids, recv), v),
    ir.Instr.PtrRead(_tid, _ty, ptr) => temp_ids_push_from_value(ids, ptr),
    ir.Instr.PtrWrite(_ty, ptr, v) => temp_ids_push_from_value(temp_ids_push_from_value(ids, ptr), v),
    ir.Instr.PtrOffset(_tid, ptr, off) => temp_ids_push_from_value(temp_ids_push_from_value(ids, ptr), off),
    ir.Instr.StructInit(_tid, _ty, fields) => {
      let mut ids1: Vec[i32] = ids;
      let mut i: i32 = 0;
      while i < fields.len() {
        ids1 = temp_ids_push_from_value(ids1, fields.get(i).val);
        i = i + 1;
      }
      ids1
    },
    ir.Instr.FieldGet(_tid, _ty, recv, _field) => temp_ids_push_from_value(ids, recv),
    ir.Instr.StoreField(_sid, _field, v) => temp_ids_push_from_value(ids, v),
    ir.Instr.EnumInit(_tid, _ty, _variant, payload) => temp_ids_push_from_values(ids, payload),
    ir.Instr.EnumTag(_tid, recv) => temp_ids_push_from_value(ids, recv),
    ir.Instr.EnumPayload(_tid, _ty, recv, _variant, _idx) => temp_ids_push_from_value(ids, recv),
    ir.Instr.VecNew(_tid, _vty, _elem) => ids,
    ir.Instr.VecPush(_recv_slot, _elem, v) => temp_ids_push_from_value(ids, v),
    ir.Instr.VecInsert(_recv_slot, _elem, idx, v) => temp_ids_push_from_value(temp_ids_push_from_value(ids, idx), v),
    ir.Instr.VecSet(_recv_slot, _elem, idx, v) => temp_ids_push_from_value(temp_ids_push_from_value(ids, idx), v),
    ir.Instr.VecClear(_recv_slot) => ids,
    ir.Instr.VecExtend(_recv_slot, _other_slot) => ids,
    ir.Instr.VecPop(_tid, _elem, _recv_slot) => ids,
    ir.Instr.VecRemove(_tid, _elem, _recv_slot, idx) => temp_ids_push_from_value(ids, idx),
    ir.Instr.VecLen(_tid, _recv_slot) => ids,
    ir.Instr.VecGet(_tid, _elem, _recv_slot, idx) => temp_ids_push_from_value(ids, idx),
    ir.Instr.AtomicNew(_tid, _elem_ty, val) => temp_ids_push_from_value(ids, val),
    ir.Instr.AtomicLoad(_tid, _elem_ty, h) => temp_ids_push_from_value(ids, h),
    ir.Instr.AtomicStore(_elem_ty, h, val) => temp_ids_push_from_value(temp_ids_push_from_value(ids, h), val),
    ir.Instr.AtomicFetchAdd(_tid, _elem_ty, h, delta) => temp_ids_push_from_value(temp_ids_push_from_value(ids, h), delta),
    ir.Instr.AtomicSwap(_tid, _elem_ty, h, val) => temp_ids_push_from_value(temp_ids_push_from_value(ids, h), val),
    ir.Instr.AtomicCAS(_tid, _elem_ty, h, expected, desired) => temp_ids_push_from_value(temp_ids_push_from_value(temp_ids_push_from_value(ids, h), expected), desired),
    ir.Instr.AtomicDrop(_elem_ty, h) => temp_ids_push_from_value(ids, h),
    ir.Instr.Call(_has_dst, _tid, _ret_ty, _name, args) => temp_ids_push_from_values(ids, args),
  };
}

fn collect_live_temps(pool: ir.TyPool, f: ir.Func, live_slots: Vec[bool]) -> Vec[bool] {
  // Seed from always-kept instruction operands and terminators.
  let mut live: Vec[bool] = Vec();
  let mut closure_instrs: Vec[ClosureInstrRef] = Vec();
  let mut closure_heads_by_dst: Vec[i32] = Vec();
  let mut bi: i32 = 0;
  while bi < f.blocks.len() {
    let b: ir.Block = f.blocks.get(bi);
    let mut ii: i32 = 0;
    while ii < b.instrs.len() {
      let ins: ir.Instr = b.instrs.get(ii);
      if !instr_is_dead_slot_instr(ins, live_slots) {
        let dst: i32 = instr_dst_temp_id(ins);
        if dst == -1 || !instr_can_drop_when_dead(pool, ins) {
          live = mark_live_from_instr_operands(live, ins);
        } else {
          while closure_heads_by_dst.len() <= dst { closure_heads_by_dst.push(-1); }
          let next_same_dst: i32 = closure_heads_by_dst.get(dst);
          let idx: i32 = closure_instrs.len();
          closure_instrs.push(ClosureInstrRef { next_same_dst: next_same_dst, block_idx: bi, instr_idx: ii });
          closure_heads_by_dst.set(dst, idx);
        }
      }
      ii = ii + 1;
    }
    if b.has_term { live = mark_live_from_term(live, b.term); }
    bi = bi + 1;
  }

  // Close over drop-safe temp defs using a destination-indexed worklist.
  let mut queue: Vec[i32] = Vec();
  let mut queued: Vec[bool] = Vec();
  let mut i0: i32 = 0;
  while i0 < live.len() {
    queued.push(false);
    i0 = i0 + 1;
  }
  let mut tid0: i32 = 0;
  while tid0 < live.len() {
    if live.get(tid0) {
      queue.push(tid0);
      queued.set(tid0, true);
    }
    tid0 = tid0 + 1;
  }
  let mut qi: i32 = 0;
  let mut deps_scratch: Vec[i32] = Vec();
  while qi < queue.len() {
    let tid: i32 = queue.get(qi);
    qi = qi + 1;
    if tid < 0 || tid >= closure_heads_by_dst.len() { continue; }
    let mut ci: i32 = closure_heads_by_dst.get(tid);
    while ci >= 0 {
      let c: ClosureInstrRef = closure_instrs.get(ci);
      let cins: ir.Instr = f.blocks.get(c.block_idx).instrs.get(c.instr_idx);
      deps_scratch = collect_operand_temp_ids_into(cins, deps_scratch);
      let mut di: i32 = 0;
      while di < deps_scratch.len() {
        let dep: i32 = deps_scratch.get(di);
        if dep >= 0 {
          while live.len() <= dep { live.push(false); }
          while queued.len() <= dep { queued.push(false); }
          if !live.get(dep) {
            live.set(dep, true);
            if !queued.get(dep) {
              queue.push(dep);
              queued.set(dep, true);
            }
          }
        }
        di = di + 1;
      }
      ci = c.next_same_dst;
    }
  }
  return live;
}

fn instr_is_dead_temp(pool: ir.TyPool, ins: ir.Instr, live_temps: Vec[bool]) -> bool {
  let dst: i32 = instr_dst_temp_id(ins);
  if dst == -1 { return false; }
  return !temp_flag_get(live_temps, dst) && instr_can_drop_when_dead(pool, ins);
}

fn collect_kept_instr_flags(pool: ir.TyPool, f: ir.Func, live_temps: Vec[bool], live_slots: Vec[bool]) -> Vec[bool] {
  let mut keep: Vec[bool] = Vec();
  let mut bi: i32 = 0;
  while bi < f.blocks.len() {
    let b: ir.Block = f.blocks.get(bi);
    let mut ii: i32 = 0;
    while ii < b.instrs.len() {
      let ins: ir.Instr = b.instrs.get(ii);
      keep.push(!instr_is_dead_temp(pool, ins, live_temps) && !instr_is_dead_slot_instr(ins, live_slots));
      ii = ii + 1;
    }
    bi = bi + 1;
  }
  return keep;
}

fn block_instr_offsets(f: ir.Func) -> Vec[i32] {
  let mut out: Vec[i32] = Vec();
  let mut off: i32 = 0;
  let mut bi: i32 = 0;
  while bi < f.blocks.len() {
    out.push(off);
    off = off + f.blocks.get(bi).instrs.len();
    bi = bi + 1;
  }
  return out;
}

fn call_dst_is_read(has_dst: bool, tid: i32, read_temps: Vec[bool]) -> bool {
  if !has_dst { return false; }
  return temp_flag_get(read_temps, tid);
}

fn temp_is_read(tid: i32, read_temps: Vec[bool]) -> bool {
  return temp_flag_get(read_temps, tid);
}

fn locals_add_slot(l0: LocalsResult, sid: i32, ty: String) -> LocalsResult {
  let mut l: LocalsResult = l0;
  l.slots = idty_add(l.slots, sid, ty);
  if sid > l.max_slot { l.max_slot = sid; }
  return l;
}

fn locals_add_temp(l0: LocalsResult, tid: i32, ty: String) -> LocalsResult {
  let mut l: LocalsResult = l0;
  l.temps = idty_add(l.temps, tid, ty);
  if tid > l.max_temp { l.max_temp = tid; }
  return l;
}

fn locals_add_call(c_types: Vec[String], pool: ir.TyPool, l0: LocalsResult, has_dst: bool, tid: i32, ret_ty: i32) -> LocalsResult {
  if !has_dst { return l0; }
  return locals_add_temp(l0, tid, c_type_from_table(c_types, pool, ret_ty));
}

fn locals_add_instr(c_types: Vec[String], pool: ir.TyPool, l0: LocalsResult, ins: ir.Instr) -> LocalsResult {
  return match ins {
    ir.Instr.SlotDecl(sid, ty) => locals_add_slot(l0, sid, c_type_from_table(c_types, pool, ty)),
    ir.Instr.Const(tid, ty, _v) => locals_add_temp(l0, tid, c_type_from_table(c_types, pool, ty)),
    ir.Instr.BinOp(tid, _op, ty, _a, _b) => locals_add_temp(l0, tid, c_type_from_table(c_types, pool, ty)),
    ir.Instr.Cmp(tid, _op, _oty, _a, _b) => locals_add_temp(l0, tid, "bool"),
    ir.Instr.And(tid, _a, _b) => locals_add_temp(l0, tid, "bool"),
    ir.Instr.Or(tid, _a, _b) => locals_add_temp(l0, tid, "bool"),
    ir.Instr.Not(tid, _a) => locals_add_temp(l0, tid, "bool"),
    ir.Instr.IntCast(tid, dst_ty, _src_ty, _v) => locals_add_temp(l0, tid, c_type_from_table(c_types, pool, dst_ty)),
    ir.Instr.IntCastChecked(tid, dst_ty, _src_ty, _v) => locals_add_temp(l0, tid, c_type_from_table(c_types, pool, dst_ty)),
    ir.Instr.FloatCast(tid, dst_ty, _src_ty, _v) => locals_add_temp(l0, tid, c_type_from_table(c_types, pool, dst_ty)),
    ir.Instr.Load(tid, ty, _sid) => locals_add_temp(l0, tid, c_type_from_table(c_types, pool, ty)),
    ir.Instr.GlobalLoad(tid, ty, _name) => locals_add_temp(l0, tid, c_type_from_table(c_types, pool, ty)),
    ir.Instr.GlobalStore(_ty, _name, _v) => l0,
    ir.Instr.AddrOfSlot(tid, ty, _sid) => locals_add_temp(l0, tid, c_type_from_table(c_types, pool, ty)),
    ir.Instr.AddrOfFieldChain(tid, ty, _sid, _fs) => locals_add_temp(l0, tid, c_type_from_table(c_types, pool, ty)),
    ir.Instr.RefLoad(tid, ty, _recv) => locals_add_temp(l0, tid, c_type_from_table(c_types, pool, ty)),
    ir.Instr.PtrRead(tid, ty, _ptr) => locals_add_temp(l0, tid, c_type_from_table(c_types, pool, ty)),
    ir.Instr.PtrWrite(_ty, _ptr, _v) => l0,
    ir.Instr.PtrOffset(tid, _ptr, _off) => locals_add_temp(l0, tid, "void*"),
    ir.Instr.StructInit(tid, ty, _fs) => locals_add_temp(l0, tid, c_type_from_table(c_types, pool, ty)),
    ir.Instr.FieldGet(tid, ty, _r, _f) => locals_add_temp(l0, tid, c_type_from_table(c_types, pool, ty)),
    ir.Instr.EnumInit(tid, ty, _v, _ps) => locals_add_temp(l0, tid, c_type_from_table(c_types, pool, ty)),
    ir.Instr.EnumTag(tid, _r) => locals_add_temp(l0, tid, "int32_t"),
    ir.Instr.EnumPayload(tid, ty, _r, _v, _i) => locals_add_temp(l0, tid, c_type_from_table(c_types, pool, ty)),
    ir.Instr.VecNew(tid, ty, _elem) => locals_add_temp(l0, tid, c_type_from_table(c_types, pool, ty)),
    ir.Instr.VecInsert(_sid, _elem, _idx, _v) => l0,
    ir.Instr.VecSet(_sid, _elem, _idx, _v) => l0,
    ir.Instr.VecClear(_sid) => l0,
    ir.Instr.VecExtend(_sid, _other_sid) => l0,
    ir.Instr.VecPop(tid, ty, _sid) => locals_add_temp(l0, tid, c_type_from_table(c_types, pool, ty)),
    ir.Instr.VecRemove(tid, ty, _sid, _idx) => locals_add_temp(l0, tid, c_type_from_table(c_types, pool, ty)),
    ir.Instr.VecLen(tid, _sid) => locals_add_temp(l0, tid, "int32_t"),
    ir.Instr.VecGet(tid, ty, _sid, _idx) => locals_add_temp(l0, tid, c_type_from_table(c_types, pool, ty)),
    ir.Instr.AtomicNew(tid, _elem_ty, _val) => locals_add_temp(l0, tid, "intptr_t"),
    ir.Instr.AtomicLoad(tid, elem_ty, _h) => locals_add_temp(l0, tid, c_type_from_table(c_types, pool, elem_ty)),
    ir.Instr.AtomicStore(_elem_ty, _h, _val) => l0,
    ir.Instr.AtomicFetchAdd(tid, elem_ty, _h, _delta) => locals_add_temp(l0, tid, c_type_from_table(c_types, pool, elem_ty)),
    ir.Instr.AtomicSwap(tid, elem_ty, _h, _val) => locals_add_temp(l0, tid, c_type_from_table(c_types, pool, elem_ty)),
    ir.Instr.AtomicCAS(tid, _ety, _h, _expected, _desired) => locals_add_temp(l0, tid, "bool"),
    ir.Instr.AtomicDrop(_ety, _h) => l0,
    ir.Instr.Call(has_dst, tid, ret_ty, _name, _args) => locals_add_call(c_types, pool, l0, has_dst, tid, ret_ty),
    _ => l0,
  };
}

fn collect_locals(c_types: Vec[String], pool: ir.TyPool, f: ir.Func, keep_instrs: Vec[bool], block_offsets: Vec[i32], read_temps: Vec[bool]) -> LocalsResult {
  let mut l: LocalsResult = locals0();
  let mut bi: i32 = 0;
  while bi < f.blocks.len() {
    let b: ir.Block = f.blocks.get(bi);
    let mut ii: i32 = 0;
    while ii < b.instrs.len() {
      let ins: ir.Instr = b.instrs.get(ii);
      let idx: i32 = block_offsets.get(bi) + ii;
      let keep: bool = if idx >= 0 && idx < keep_instrs.len() { keep_instrs.get(idx) } else { true };
      if keep {
        l = match ins {
          ir.Instr.Call(has_dst, tid, ret_ty, _name, _args) =>
            locals_add_call(c_types, pool, l, call_dst_is_read(has_dst, tid, read_temps), tid, ret_ty),
          ir.Instr.VecPop(tid, ty, _sid) =>
            if temp_is_read(tid, read_temps) { locals_add_temp(l, tid, c_type_from_table(c_types, pool, ty)) } else { l },
          ir.Instr.VecRemove(tid, ty, _sid, _idx) =>
            if temp_is_read(tid, read_temps) { locals_add_temp(l, tid, c_type_from_table(c_types, pool, ty)) } else { l },
          ir.Instr.VecGet(tid, ty, _sid, _idx) =>
            if temp_is_read(tid, read_temps) { locals_add_temp(l, tid, c_type_from_table(c_types, pool, ty)) } else { l },
          _ => locals_add_instr(c_types, pool, l, ins),
        };
      }
      ii = ii + 1;
    }
    bi = bi + 1;
  }
  return l;
}

fn collect_locals_keep_all(c_types: Vec[String], pool: ir.TyPool, f: ir.Func, read_temps: Vec[bool]) -> LocalsResult {
  let mut l: LocalsResult = locals0();
  let mut bi: i32 = 0;
  while bi < f.blocks.len() {
    let b: ir.Block = f.blocks.get(bi);
    let mut ii: i32 = 0;
    while ii < b.instrs.len() {
      let ins: ir.Instr = b.instrs.get(ii);
      l = match ins {
        ir.Instr.Call(has_dst, tid, ret_ty, _name, _args) =>
          locals_add_call(c_types, pool, l, call_dst_is_read(has_dst, tid, read_temps), tid, ret_ty),
        ir.Instr.VecPop(tid, ty, _sid) =>
          if temp_is_read(tid, read_temps) { locals_add_temp(l, tid, c_type_from_table(c_types, pool, ty)) } else { l },
        ir.Instr.VecRemove(tid, ty, _sid, _idx) =>
          if temp_is_read(tid, read_temps) { locals_add_temp(l, tid, c_type_from_table(c_types, pool, ty)) } else { l },
        ir.Instr.VecGet(tid, ty, _sid, _idx) =>
          if temp_is_read(tid, read_temps) { locals_add_temp(l, tid, c_type_from_table(c_types, pool, ty)) } else { l },
        _ => locals_add_instr(c_types, pool, l, ins),
      };
      ii = ii + 1;
    }
    bi = bi + 1;
  }
  return l;
}

fn push_line(out0: Vec[String], line: String) -> Vec[String] {
  let mut out: Vec[String] = out0;
  out.push(line);
  return out;
}

fn c_decl_line(ty: String, name: String) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push("  ");
  parts.push(ty);
  parts.push(" ");
  parts.push(name);
  parts.push(";");
  return parts.join("");
}

fn c_label_line(name: String) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push(c_label_name(name));
  parts.push(":");
  return parts.join("");
}

fn c_assign_line(lhs: String, rhs: String) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push("  ");
  parts.push(lhs);
  parts.push(" = ");
  parts.push(rhs);
  parts.push(";");
  return parts.join("");
}

fn c_assign_cast_line(lhs: String, cast_ty: String, rhs: String) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push("  ");
  parts.push(lhs);
  parts.push(" = (");
  parts.push(cast_ty);
  parts.push(")");
  parts.push(rhs);
  parts.push(";");
  return parts.join("");
}

fn c_store_line(lhs: String, rhs: String) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push("  ");
  parts.push(lhs);
  parts.push(" = ");
  parts.push(rhs);
  parts.push(";");
  return parts.join("");
}

fn c_field_store_line(base: String, field: String, rhs: String) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push("  ");
  parts.push(base);
  parts.push(".");
  parts.push(c_ident(field));
  parts.push(" = ");
  parts.push(rhs);
  parts.push(";");
  return parts.join("");
}

fn c_addr_of_expr(target: String) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push("&");
  parts.push(target);
  return parts.join("");
}

fn c_deref_expr(expr: String) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push("(*");
  parts.push(expr);
  parts.push(")");
  return parts.join("");
}

fn c_ptr_read_expr(ty: String, ptr_expr: String) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push("*(");
  parts.push(ty);
  parts.push("*)");
  parts.push(ptr_expr);
  return parts.join("");
}

fn c_ptr_write_line(ty: String, ptr_expr: String, rhs: String) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push("  *((");
  parts.push(ty);
  parts.push("*)");
  parts.push(ptr_expr);
  parts.push(") = ");
  parts.push(rhs);
  parts.push(";");
  return parts.join("");
}

fn c_ptr_offset_expr(ptr_expr: String, off_expr: String) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push("(void*)((char*)");
  parts.push(ptr_expr);
  parts.push(" + ");
  parts.push(off_expr);
  parts.push(")");
  return parts.join("");
}

fn c_field_access_expr(base: String, field: String) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push(base);
  parts.push(".");
  parts.push(c_ident(field));
  return parts.join("");
}

fn c_enum_payload_expr(base: String, variant: String, idx: i32) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push(base);
  parts.push(".payload.");
  parts.push(c_ident(variant));
  parts.push("._");
  parts.push(idx.to_string());
  return parts.join("");
}

fn c_atomic_call_expr(fn_name: String, atomic_ty: String, handle_expr: String, arg_exprs: Vec[String]) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push(fn_name);
  parts.push("((");
  parts.push(atomic_ty);
  parts.push("*)");
  parts.push(handle_expr);
  let mut i: i32 = 0;
  while i < arg_exprs.len() {
    parts.push(", ");
    parts.push(arg_exprs.get(i));
    i = i + 1;
  }
  parts.push(", memory_order_seq_cst)");
  return parts.join("");
}

fn c_call_stmt_line(fn_name: String, arg_exprs: Vec[String]) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push("  ");
  parts.push(fn_name);
  parts.push("(");
  let mut i: i32 = 0;
  while i < arg_exprs.len() {
    if i != 0 { parts.push(", "); }
    parts.push(arg_exprs.get(i));
    i = i + 1;
  }
  parts.push(");");
  return parts.join("");
}

fn c_guard_float_cast_unsigned_line(v_text: String, dst_max: String, msg: String) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push("  if (!isfinite((double)");
  parts.push(v_text);
  parts.push(") || (double)");
  parts.push(v_text);
  parts.push(" < 0.0 || (long double)");
  parts.push(v_text);
  parts.push(" > (long double)");
  parts.push(dst_max);
  parts.push(") { vox_host_panic(");
  parts.push(c_str_lit(msg));
  parts.push("); }");
  return parts.join("");
}

fn c_guard_float_cast_signed_line(v_text: String, dst_min: String, dst_max: String, msg: String) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push("  if (!isfinite((double)");
  parts.push(v_text);
  parts.push(") || (long double)");
  parts.push(v_text);
  parts.push(" < (long double)");
  parts.push(dst_min);
  parts.push(" || (long double)");
  parts.push(v_text);
  parts.push(" > (long double)");
  parts.push(dst_max);
  parts.push(") { vox_host_panic(");
  parts.push(c_str_lit(msg));
  parts.push("); }");
  return parts.join("");
}

fn c_guard_signed_cast_bounds_line(v_text: String, dst_min: String, dst_max: String, msg: String) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push("  if (((int64_t)");
  parts.push(v_text);
  parts.push(" < (int64_t)");
  parts.push(dst_min);
  parts.push(") || ((int64_t)");
  parts.push(v_text);
  parts.push(" > (int64_t)");
  parts.push(dst_max);
  parts.push(")) { vox_host_panic(");
  parts.push(c_str_lit(msg));
  parts.push("); }");
  return parts.join("");
}

fn c_guard_negative_line(v_text: String, msg: String) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push("  if (");
  parts.push(v_text);
  parts.push(" < 0) { vox_host_panic(");
  parts.push(c_str_lit(msg));
  parts.push("); }");
  return parts.join("");
}

fn c_guard_cast_call_line(fn_name: String, cast_ty: String, v_text: String, msg: String) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push("  if (");
  parts.push(fn_name);
  parts.push("((");
  parts.push(cast_ty);
  parts.push(")");
  parts.push(v_text);
  parts.push(")) { vox_host_panic(");
  parts.push(c_str_lit(msg));
  parts.push("); }");
  return parts.join("");
}

fn c_guard_u64_gt_line(v_text: String, dst_max: String, msg: String) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push("  if ((uint64_t)");
  parts.push(v_text);
  parts.push(" > (uint64_t)");
  parts.push(dst_max);
  parts.push(") { vox_host_panic(");
  parts.push(c_str_lit(msg));
  parts.push("); }");
  return parts.join("");
}

fn c_guard_negative_or_u64_gt_line(v_text: String, dst_max: String, msg: String) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push("  if (");
  parts.push(v_text);
  parts.push(" < 0 || (uint64_t)");
  parts.push(v_text);
  parts.push(" > (uint64_t)");
  parts.push(dst_max);
  parts.push(") { vox_host_panic(");
  parts.push(c_str_lit(msg));
  parts.push("); }");
  return parts.join("");
}

fn c_unsigned_wrapped_binop_expr(uty: String, a_text: String, op_text: String, b_text: String) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push("((");
  parts.push(uty);
  parts.push(")((((");
  parts.push(uty);
  parts.push(")");
  parts.push(a_text);
  parts.push(") ");
  parts.push(op_text);
  parts.push(" ((");
  parts.push(uty);
  parts.push(")");
  parts.push(b_text);
  parts.push("))))");
  return parts.join("");
}

fn c_signed_wrapped_binop_expr(bitcast_fn: String, uty: String, a_text: String, op_text: String, b_text: String) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push(bitcast_fn);
  parts.push(c_unsigned_wrapped_binop_expr(uty, a_text, op_text, b_text));
  return parts.join("");
}

fn emit_instr_cmp_line(pool: ir.TyPool, tid: i32, op: ir.CmpKind, oty: i32, a: ir.Value, b: ir.Value, vn: ValueNameTables) -> String {
  let t: ir.Ty = ir.ty_pool_get(pool, oty);
  if t.kind == ir.TyKind.Range || t.kind == ir.TyKind.Verified || t.kind == ir.TyKind.Ref {
    return emit_instr_cmp_line(pool, tid, op, t.elem, a, b, vn);
  }
  if t.kind == ir.TyKind.String {
    let cmpop: String = c_cmpop(op);
    return "  ".concat(c_temp_name_named(vn, tid)).concat(" = (strcmp(").concat(c_value_named(a, vn)).concat(", ").concat(c_value_named(b, vn)).concat(") ").concat(cmpop).concat(" 0);");
  }
  if t.kind == ir.TyKind.Enum {
    if op != ir.CmpKind.Eq && op != ir.CmpKind.Ne { panic("unsupported enum comparison"); }
    let cal: String = c_enum_eq_fn_name(ty_qname(t)).concat("(").concat(c_value_named(a, vn)).concat(", ").concat(c_value_named(b, vn)).concat(")");
    if op == ir.CmpKind.Eq {
      return "  ".concat(c_temp_name_named(vn, tid)).concat(" = ").concat(cal).concat(";");
    }
    return "  ".concat(c_temp_name_named(vn, tid)).concat(" = (!").concat(cal).concat(");");
  }
  if t.kind == ir.TyKind.Struct {
    if op != ir.CmpKind.Eq && op != ir.CmpKind.Ne { panic("unsupported struct comparison"); }
    let cal: String = c_struct_eq_fn_name(ty_qname(t)).concat("(").concat(c_value_named(a, vn)).concat(", ").concat(c_value_named(b, vn)).concat(")");
    if op == ir.CmpKind.Eq {
      return "  ".concat(c_temp_name_named(vn, tid)).concat(" = ").concat(cal).concat(";");
    }
    return "  ".concat(c_temp_name_named(vn, tid)).concat(" = (!").concat(cal).concat(");");
  }
  return "  ".concat(c_temp_name_named(vn, tid)).concat(" = (").concat(c_value_named(a, vn)).concat(" ").concat(c_cmpop(op)).concat(" ").concat(c_value_named(b, vn)).concat(");");
}

fn c_field_chain(fields: Vec[String]) -> String {
  let mut out: String = "";
  let mut i: i32 = 0;
  while i < fields.len() {
    out = out.concat(".").concat(c_ident(fields.get(i)));
    i = i + 1;
  }
  return out;
}

fn emit_instr_int_cast_checked_append(
  out0: Vec[String],
  c_types: Vec[String],
  pool: ir.TyPool,
  target_ptr_bits: i32,
  tid: i32,
  dst_ty: i32,
  src_ty: i32,
  v: ir.Value,
  int_consts: TempIntConstTable,
  vn: ValueNameTables,
) -> Vec[String] {
  let dst: ir.Ty = ir.ty_pool_get(pool, dst_ty);
  let src: ir.Ty = ir.ty_pool_get(pool, src_ty);
  let v_text: String = c_value_named(v, vn);

  let dst_is_unsigned: bool = is_unsigned_int_kind(dst.kind);
  let src_is_unsigned: bool = is_unsigned_int_kind(src.kind);
  let src_is_float: bool = src.kind == ir.TyKind.F32 || src.kind == ir.TyKind.F64;
  let src_int_lit: IntConstValue = int_const_value_from_operand(v, int_consts);
  let src_non_negative: bool = int_operand_is_definitely_non_negative(v, int_consts);

  let mut out: Vec[String] = out0;
  if !src_is_float && src_int_lit.ok && int_literal_always_fits_dst_kind(dst.kind, src_int_lit.n, target_ptr_bits) {
    out.push(c_assign_cast_line(c_temp_name_named(vn, tid), c_type_from_table(c_types, pool, dst_ty), v_text));
    return out;
  }
  if !src_is_float && !int_cast_needs_runtime_check(dst.kind, src.kind, target_ptr_bits) {
    out.push(c_assign_cast_line(c_temp_name_named(vn, tid), c_type_from_table(c_types, pool, dst_ty), v_text));
    return out;
  }

  let src_name: String = match src.kind {
    ir.TyKind.I8 => "i8",
    ir.TyKind.U8 => "u8",
    ir.TyKind.I16 => "i16",
    ir.TyKind.U16 => "u16",
    ir.TyKind.I32 => "i32",
    ir.TyKind.U32 => "u32",
    ir.TyKind.I64 => "i64",
    ir.TyKind.U64 => "u64",
    ir.TyKind.ISize => "isize",
    ir.TyKind.USize => "usize",
    _ => "?",
  };
  let dst_name: String = match dst.kind {
    ir.TyKind.I8 => "i8",
    ir.TyKind.U8 => "u8",
    ir.TyKind.I16 => "i16",
    ir.TyKind.U16 => "u16",
    ir.TyKind.I32 => "i32",
    ir.TyKind.U32 => "u32",
    ir.TyKind.I64 => "i64",
    ir.TyKind.U64 => "u64",
    ir.TyKind.ISize => "isize",
    ir.TyKind.USize => "usize",
    _ => "?",
  };
  let msg: String = src_name.concat(" to ").concat(dst_name).concat(" overflow");

  let dst_max: String =
    match dst.kind {
      ir.TyKind.I8 => "INT8_MAX",
      ir.TyKind.U8 => "UINT8_MAX",
      ir.TyKind.I16 => "INT16_MAX",
      ir.TyKind.U16 => "UINT16_MAX",
      ir.TyKind.I32 => "INT32_MAX",
      ir.TyKind.U32 => "UINT32_MAX",
      ir.TyKind.I64 => "INT64_MAX",
      ir.TyKind.U64 => "UINT64_MAX",
      ir.TyKind.ISize => "INTPTR_MAX",
      ir.TyKind.USize => "UINTPTR_MAX",
      _ => "",
    };
  if dst_max.len() == 0 { panic("int_cast_checked dst must be int"); }
  let dst_min: String =
    match dst.kind {
      ir.TyKind.I8 => "INT8_MIN",
      ir.TyKind.I16 => "INT16_MIN",
      ir.TyKind.I32 => "INT32_MIN",
      ir.TyKind.I64 => "INT64_MIN",
      ir.TyKind.ISize => "INTPTR_MIN",
      _ => "0",
    };

  if src_is_float {
    if dst_is_unsigned {
      out.push(c_guard_float_cast_unsigned_line(v_text, dst_max, msg));
    } else {
      out.push(c_guard_float_cast_signed_line(v_text, dst_min, dst_max, msg));
    }
  } else {
    if dst_is_unsigned {
      if src_is_unsigned {
        if dst.kind == ir.TyKind.U64 {
        } else if dst.kind == ir.TyKind.USize && src.kind == ir.TyKind.U64 {
          out.push(c_guard_cast_call_line("vox_u64_exceeds_uintptr_max", "uint64_t", v_text, msg));
        } else if dst.kind == ir.TyKind.U32 && src.kind == ir.TyKind.USize {
          out.push(c_guard_cast_call_line("vox_uptr_exceeds_u32_max", "uintptr_t", v_text, msg));
        } else {
          out.push(c_guard_u64_gt_line(v_text, dst_max, msg));
        }
      } else {
        if dst.kind == ir.TyKind.U64 {
          if !src_non_negative {
            out.push(c_guard_negative_line(v_text, msg));
          }
        } else if dst.kind == ir.TyKind.U32 && src.kind == ir.TyKind.ISize {
          if !src_non_negative {
            out.push(c_guard_negative_line(v_text, msg));
          }
          out.push(c_guard_cast_call_line("vox_iptr_exceeds_u32_max", "intptr_t", v_text, msg));
        } else if int_cast_signed_to_unsigned_needs_upper_check(dst.kind, src.kind, target_ptr_bits) {
          if dst.kind == ir.TyKind.USize && src.kind == ir.TyKind.I64 {
            if !src_non_negative {
              out.push(c_guard_negative_line(v_text, msg));
            }
            out.push(c_guard_cast_call_line("vox_u64_exceeds_uintptr_max", "uint64_t", v_text, msg));
          } else {
            if src_non_negative {
              out.push(c_guard_u64_gt_line(v_text, dst_max, msg));
            } else {
              out.push(c_guard_negative_or_u64_gt_line(v_text, dst_max, msg));
            }
          }
        } else {
          if !src_non_negative {
            out.push(c_guard_negative_line(v_text, msg));
          }
        }
      }
    } else {
      if src_is_unsigned {
        if dst.kind == ir.TyKind.ISize && src.kind == ir.TyKind.U32 {
          out.push(c_guard_cast_call_line("vox_u32_exceeds_intptr_max", "uint32_t", v_text, msg));
        } else if dst.kind == ir.TyKind.I64 && src.kind == ir.TyKind.USize {
          out.push(c_guard_cast_call_line("vox_uptr_exceeds_i64_max", "uintptr_t", v_text, msg));
        } else {
          out.push(c_guard_u64_gt_line(v_text, dst_max, msg));
        }
      } else {
        if dst.kind == ir.TyKind.ISize && src.kind == ir.TyKind.I64 {
          out.push(c_guard_cast_call_line("vox_i64_outside_intptr_range", "int64_t", v_text, msg));
        } else {
          out.push(c_guard_signed_cast_bounds_line(v_text, dst_min, dst_max, msg));
        }
      }
    }
  }
  out.push(c_assign_cast_line(c_temp_name_named(vn, tid), c_type_from_table(c_types, pool, dst_ty), v_text));
  return out;
}

fn emit_instr_struct_init_line(c_types: Vec[String], pool: ir.TyPool, tid: i32, ty: i32, fs: Vec[ir.StructInitField], vn: ValueNameTables) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push("  ");
  parts.push(c_temp_name_named(vn, tid));
  parts.push(" = (");
  parts.push(c_type_from_table(c_types, pool, ty));
  parts.push("){");
  let mut i: i32 = 0;
  while i < fs.len() {
    let f: ir.StructInitField = fs.get(i);
    if i != 0 { parts.push(", "); }
    parts.push(".");
    parts.push(c_ident(f.name));
    parts.push(" = ");
    parts.push(c_value_named(f.val, vn));
    i = i + 1;
  }
  parts.push("};");
  return parts.join("");
}

fn emit_instr_enum_init_line(c_types: Vec[String], pool: ir.TyPool, p: ir.Program, enum_order: Vec[i32], tid: i32, ty: i32, variant: String, payload: Vec[ir.Value], vn: ValueNameTables) -> String {
  let enum_name: String = ty_qname(ir.ty_pool_get(pool, ty));
  let en_idx: i32 = find_enum_decl_index_ordered(p, enum_order, enum_name);
  if en_idx < 0 { panic("unknown enum in codegen"); }
  let en: ir.EnumDecl = p.enums.get(en_idx);
  let tag: i32 = enum_variant_tag(en, variant);
  let mut parts: Vec[String] = Vec();
  parts.push("  ");
  parts.push(c_temp_name_named(vn, tid));
  parts.push(" = (");
  parts.push(c_type_from_table(c_types, pool, ty));
  parts.push("){.tag = ");
  parts.push(tag.to_string());
  if enum_has_payload(en) {
    parts.push(", .payload.");
    parts.push(c_ident(variant));
    parts.push(" = {");
    if payload.len() != 0 {
      let mut pi: i32 = 0;
      while pi < payload.len() {
        if pi != 0 { parts.push(", "); }
        parts.push("._");
        parts.push(pi.to_string());
        parts.push(" = ");
        parts.push(c_value_named(payload.get(pi), vn));
        pi = pi + 1;
      }
    } else {
      parts.push("._ = 0");
    }
    parts.push("}");
  }
  parts.push("};");
  return parts.join("");
}

fn emit_instr_binop_int_append(
  out0: Vec[String],
  c_types: Vec[String],
  pool: ir.TyPool,
  tid: i32,
  op: ir.BinOpKind,
  ty: i32,
  a: ir.Value,
  b: ir.Value,
  int_consts: TempIntConstTable,
  vn: ValueNameTables,
) -> Vec[String] {
  let t: ir.Ty = ir.ty_pool_get(pool, ty);
  if !is_int_scalar_kind(t.kind) { panic("binop int helper expects int type"); }
  let dst_cty: String = c_type_from_table(c_types, pool, ty);
  let a_text: String = c_value_named(a, vn);
  let b_text: String = c_value_named(b, vn);
  let a_int_lit_v: IntConstValue = int_const_value_from_operand(a, int_consts);
  let b_int_lit_v: IntConstValue = int_const_value_from_operand(b, int_consts);
  let a_is_int_lit: bool = a_int_lit_v.ok;
  let b_is_int_lit: bool = b_int_lit_v.ok;
  let a_int_lit: i64 = if a_is_int_lit { a_int_lit_v.n } else { 0 as i64 };
  let b_int_lit: i64 = if b_is_int_lit { b_int_lit_v.n } else { 0 as i64 };

  let is_mul: bool = match op { ir.BinOpKind.Mul => true, _ => false };
  let is_add: bool = match op { ir.BinOpKind.Add => true, _ => false };
  let is_sub: bool = match op { ir.BinOpKind.Sub => true, _ => false };
  let is_bit: bool = match op { ir.BinOpKind.BitAnd => true, ir.BinOpKind.BitOr => true, ir.BinOpKind.BitXor => true, _ => false };
  let mut out: Vec[String] = out0;
  if is_add || is_sub || is_mul || is_bit {
    let op_text: String = c_binop(op);
    if !is_signed_int_kind(t.kind) {
      let uty: String = unsigned_peer_c_type(t.kind);
      let uexpr: String = c_unsigned_wrapped_binop_expr(uty, a_text, op_text, b_text);
      out.push(c_assign_cast_line(c_temp_name_named(vn, tid), dst_cty, uexpr));
      return out;
    }
    let uty: String = unsigned_peer_c_type(t.kind);
    let bitcast_fn: String = signed_from_unsigned_bitcast_fn(t.kind);
    if bitcast_fn == "" { panic("missing signed bitcast helper"); }
    let expr: String = c_signed_wrapped_binop_expr(bitcast_fn, uty, a_text, op_text, b_text);
    out.push(c_assign_line(c_temp_name_named(vn, tid), expr));
    return out;
  }

  let is_shl: bool = match op { ir.BinOpKind.Shl => true, _ => false };
  let is_shr: bool = match op { ir.BinOpKind.Shr => true, _ => false };
  if is_shl || is_shr {
    let bits_expr: String = int_bits_expr(t.kind);
    let bits_const: i32 = int_bits(t.kind);
    let uty: String = unsigned_peer_c_type(t.kind);
    let bitcast_fn: String = signed_from_unsigned_bitcast_fn(t.kind);
    out.push("  {");
    out.push("    ".concat(uty).concat(" ua = (").concat(uty).concat(")").concat(a_text).concat(";"));
    if is_signed_int_kind(t.kind) {
      if b_is_int_lit && bits_const > 0 {
        if b_int_lit < 0 || b_int_lit >= (bits_const as i64) {
          out.push("    vox_host_panic(\"shift count out of range\");");
          out.push("    uint64_t n = 0;");
        } else {
          out.push("    uint64_t n = (uint64_t)".concat(b_int_lit.to_string()).concat(";"));
        }
      } else {
        out.push("    int64_t sh = (int64_t)".concat(b_text).concat(";"));
        out.push("    if (sh < 0 || sh >= (int64_t)".concat(bits_expr).concat(") { vox_host_panic(\"shift count out of range\"); }"));
        out.push("    uint64_t n = (uint64_t)sh;");
      }
    } else {
      if b_is_int_lit && bits_const > 0 {
        if b_int_lit < 0 || b_int_lit >= (bits_const as i64) {
          out.push("    vox_host_panic(\"shift count out of range\");");
          out.push("    uint64_t n = 0;");
        } else {
          out.push("    uint64_t n = (uint64_t)".concat(b_int_lit.to_string()).concat(";"));
        }
      } else {
        out.push("    uint64_t n = (uint64_t)".concat(b_text).concat(";"));
        out.push("    if (n >= (uint64_t)".concat(bits_expr).concat(") { vox_host_panic(\"shift count out of range\"); }"));
      }
    }
    if is_shl {
      out.push("    ".concat(uty).concat(" ur = (").concat(uty).concat(")(ua << n);"));
    } else if is_signed_int_kind(t.kind) {
      out.push("    ".concat(uty).concat(" ur;"));
      out.push("    if (n == 0) {");
      out.push("      ur = ua;");
      let lsign: String = "    } else if ((ua & ".concat(int_sign_high_bit_expr(t.kind)).concat(") != 0) {");
      out.push(lsign);
      out.push("      ".concat(uty).concat(" m = ~(((").concat(uty).concat(")~(").concat(uty).concat(")0) >> n);"));
      out.push("      ur = (".concat(uty).concat(")((ua >> n) | m);"));
      out.push("    } else {");
      out.push("      ur = (".concat(uty).concat(")(ua >> n);"));
      out.push("    }");
    } else {
      out.push("    ".concat(uty).concat(" ur = (").concat(uty).concat(")(ua >> n);"));
    }
    if is_signed_int_kind(t.kind) {
      if bitcast_fn == "" { panic("missing signed bitcast helper"); }
      out.push("    ".concat(c_temp_name_named(vn, tid)).concat(" = ").concat(bitcast_fn).concat("(ur);"));
    } else {
      out.push("    ".concat(c_temp_name_named(vn, tid)).concat(" = (").concat(dst_cty).concat(")ur;"));
    }
    out.push("  }");
    return out;
  }

  let is_div: bool = match op { ir.BinOpKind.Div => true, _ => false };
  let is_mod: bool = match op { ir.BinOpKind.Mod => true, _ => false };
  if is_div || is_mod {
    if b_is_int_lit {
      if b_int_lit == 0 {
        out.push("  vox_host_panic(\"division by zero\");");
      }
    } else {
      out.push("  if (".concat(b_text).concat(" == (").concat(dst_cty).concat(")0) { vox_host_panic(\"division by zero\"); }"));
    }
    if is_signed_int_kind(t.kind) {
      let minm: String = signed_min_macro(t.kind);
      let maxm: String = signed_max_macro(t.kind);
      if minm.len() == 0 || maxm.len() == 0 { panic("missing signed min/max macro"); }
      if b_is_int_lit {
        if b_int_lit == -1 {
          if int_operand_is_definitely_not_signed_min(a, t.kind, int_consts) {
          } else if a_is_int_lit {
            let a_min: IntConstValue = int_min_const_for_signed_kind(t.kind);
            if !a_min.ok {
              out.push("  if (".concat(a_text).concat(" == ").concat(minm).concat(") { vox_host_panic(\"division overflow\"); }"));
            } else if a_int_lit == a_min.n {
              out.push("  vox_host_panic(\"division overflow\");");
            } else {
              out.push("  if (".concat(a_text).concat(" == ").concat(minm).concat(") { vox_host_panic(\"division overflow\"); }"));
            }
          } else {
            out.push("  if (".concat(a_text).concat(" == ").concat(minm).concat(") { vox_host_panic(\"division overflow\"); }"));
          }
        }
      } else {
        out.push("  if (".concat(a_text).concat(" == ").concat(minm).concat(" && ").concat(b_text).concat(" == (").concat(dst_cty).concat(")-1) { vox_host_panic(\"division overflow\"); }"));
      }
    }
    out.push("  ".concat(c_temp_name_named(vn, tid)).concat(" = (").concat(dst_cty).concat(")(").concat(a_text).concat(" ").concat(c_binop(op)).concat(" ").concat(b_text).concat(");"));
    return out;
  }

  panic("unknown binop");
}

fn emit_instr_vec_new_append(out0: Vec[String], c_types: Vec[String], pool: ir.TyPool, tid: i32, elem: i32, vn: ValueNameTables) -> Vec[String] {
  let mut out: Vec[String] = out0;
  out.push("  {");
  out.push("    vox_vec_data* h = vox_vec_data_new((int32_t)sizeof(".concat(c_type_from_table(c_types, pool, elem)).concat("));"));
  out.push("    ".concat(c_temp_name_named(vn, tid)).concat(" = (vox_vec){ .h = h, .len = 0 };"));
  out.push("  }");
  return out;
}

fn emit_vec_grow_if_needed_append(out0: Vec[String], vname: String, need_expr: String) -> Vec[String] {
  return push_line(out0, "    vox_vec_grow_to(".concat(vname).concat(", ").concat(need_expr).concat(");"));
}

fn vec_elem_store_line(c_types: Vec[String], pool: ir.TyPool, elem: i32, dst_ptr_expr: String, src_expr: String) -> String {
  let ety: String = c_type_from_table(c_types, pool, elem);
  return "    *((".concat(ety).concat("*)(").concat(dst_ptr_expr).concat(")) = ").concat(src_expr).concat(";");
}

fn vec_elem_load_line(c_types: Vec[String], pool: ir.TyPool, tid: i32, elem: i32, src_ptr_expr: String, vn: ValueNameTables) -> String {
  let ety: String = c_type_from_table(c_types, pool, elem);
  return "    ".concat(c_temp_name_named(vn, tid)).concat(" = *((").concat(ety).concat("*)(").concat(src_ptr_expr).concat("));");
}

fn emit_instr_vec_push_append(out0: Vec[String], c_types: Vec[String], pool: ir.TyPool, recv_slot: i32, elem: i32, v: ir.Value, vn: ValueNameTables) -> Vec[String] {
  let mut out: Vec[String] = out0;
  out.push("  {");
  out.push("    vox_vec* vox_v = &".concat(c_slot_name_named(vn, recv_slot)).concat(";"));
  out.push("    vox_vec_require_handle(vox_v, \"vec push invalid args\");");
  out = emit_vec_grow_if_needed_append(out, "vox_v", "(int64_t)vox_v->len + 1");
  out.push(vec_elem_store_line(c_types, pool, elem, "vox_v->h->data + (size_t)vox_v->len * (size_t)vox_v->h->elem_size", c_value_named(v, vn)));
  out.push("    vox_v->len++;");
  out.push("  }");
  return out;
}

fn emit_instr_vec_insert_append(out0: Vec[String], c_types: Vec[String], pool: ir.TyPool, recv_slot: i32, elem: i32, idx: ir.Value, v: ir.Value, vn: ValueNameTables) -> Vec[String] {
  let mut out: Vec[String] = out0;
  out.push("  {");
  out.push("    vox_vec* vox_v = &".concat(c_slot_name_named(vn, recv_slot)).concat(";"));
  out.push("    vox_vec_require_handle(vox_v, \"vec insert invalid args\");");
  out.push("    int32_t vox_idx = vox_vec_checked_insert_index(vox_v, (int32_t)".concat(c_value_named(idx, vn)).concat(", \"vec insert index out of bounds\");"));
  out = emit_vec_grow_if_needed_append(out, "vox_v", "(int64_t)vox_v->len + 1");
  out.push("    uint8_t* vox_ptr = vox_v->h->data + (size_t)vox_idx * (size_t)vox_v->h->elem_size;");
  out.push("    int32_t vox_tail = vox_v->len - vox_idx;");
  out.push("    if (vox_tail > 0) {");
  out.push("      memmove(vox_ptr + (size_t)vox_v->h->elem_size, vox_ptr, (size_t)vox_tail * (size_t)vox_v->h->elem_size);");
  out.push("    }");
  out.push(vec_elem_store_line(c_types, pool, elem, "vox_ptr", c_value_named(v, vn)));
  out.push("    vox_v->len++;");
  out.push("  }");
  return out;
}

fn emit_instr_vec_set_append(out0: Vec[String], c_types: Vec[String], pool: ir.TyPool, recv_slot: i32, elem: i32, idx: ir.Value, v: ir.Value, vn: ValueNameTables) -> Vec[String] {
  let mut out: Vec[String] = out0;
  out.push("  {");
  out.push("    vox_vec* vox_v = &".concat(c_slot_name_named(vn, recv_slot)).concat(";"));
  out.push("    vox_vec_require_handle(vox_v, \"vec set invalid args\");");
  out.push("    int32_t vox_idx = vox_vec_checked_index(vox_v, (int32_t)".concat(c_value_named(idx, vn)).concat(", \"vec set index out of bounds\");"));
  out.push(vec_elem_store_line(c_types, pool, elem, "vox_v->h->data + (size_t)vox_idx * (size_t)vox_v->h->elem_size", c_value_named(v, vn)));
  out.push("  }");
  return out;
}

fn emit_instr_vec_clear_append(out0: Vec[String], recv_slot: i32, vn: ValueNameTables) -> Vec[String] {
  let mut out: Vec[String] = out0;
  out.push("  {");
  out.push("    vox_vec* vox_v = &".concat(c_slot_name_named(vn, recv_slot)).concat(";"));
  out.push("    if (vox_v) { vox_v->len = 0; }");
  out.push("  }");
  return out;
}

fn emit_instr_vec_extend_append(out0: Vec[String], recv_slot: i32, other_slot: i32, vn: ValueNameTables) -> Vec[String] {
  let mut out: Vec[String] = out0;
  out.push("  {");
  out.push("    vox_vec* vox_v = &".concat(c_slot_name_named(vn, recv_slot)).concat(";"));
  out.push("    const vox_vec* vox_other = &".concat(c_slot_name_named(vn, other_slot)).concat(";"));
  out.push("    if (!vox_v || !vox_v->h || !vox_other || !vox_other->h) {");
  out.push("      /* no-op */");
  out.push("    } else if (vox_other->len > 0) {");
  out.push("      int64_t vox_need64 = (int64_t)vox_v->len + (int64_t)vox_other->len;");
  out.push("      if (vox_need64 > INT32_MAX) { vox_host_panic(\"vec too large\"); }");
  out.push("      int32_t vox_need = (int32_t)vox_need64;");
  out = emit_vec_grow_if_needed_append(out, "vox_v", "vox_need64");
  out.push("      memcpy(vox_v->h->data + (size_t)vox_v->len * (size_t)vox_v->h->elem_size, vox_other->h->data, (size_t)vox_other->len * (size_t)vox_other->h->elem_size);");
  out.push("      vox_v->len = vox_need;");
  out.push("    }");
  out.push("  }");
  return out;
}

fn emit_instr_vec_pop_append(out0: Vec[String], c_types: Vec[String], pool: ir.TyPool, tid: i32, elem: i32, recv_slot: i32, load_dst: bool, vn: ValueNameTables) -> Vec[String] {
  let mut out: Vec[String] = out0;
  out.push("  {");
  out.push("    vox_vec* vox_v = &".concat(c_slot_name_named(vn, recv_slot)).concat(";"));
  out.push("    vox_vec_require_handle(vox_v, \"vec pop invalid args\");");
  out.push("    if (vox_v->len <= 0) { vox_host_panic(\"vec pop on empty vector\"); }");
  out.push("    int32_t vox_idx = vox_v->len - 1;");
  if load_dst {
    out.push(vec_elem_load_line(c_types, pool, tid, elem, "vox_v->h->data + (size_t)vox_idx * (size_t)vox_v->h->elem_size", vn));
  }
  out.push("    vox_v->len = vox_idx;");
  out.push("  }");
  return out;
}

fn emit_instr_vec_remove_append(out0: Vec[String], c_types: Vec[String], pool: ir.TyPool, tid: i32, elem: i32, recv_slot: i32, idx: ir.Value, load_dst: bool, vn: ValueNameTables) -> Vec[String] {
  let mut out: Vec[String] = out0;
  out.push("  {");
  out.push("    vox_vec* vox_v = &".concat(c_slot_name_named(vn, recv_slot)).concat(";"));
  out.push("    vox_vec_require_handle(vox_v, \"vec remove invalid args\");");
  out.push("    int32_t vox_idx = vox_vec_checked_index(vox_v, (int32_t)".concat(c_value_named(idx, vn)).concat(", \"vec remove index out of bounds\");"));
  out.push("    uint8_t* vox_ptr = vox_v->h->data + (size_t)vox_idx * (size_t)vox_v->h->elem_size;");
  if load_dst {
    out.push(vec_elem_load_line(c_types, pool, tid, elem, "vox_ptr", vn));
  }
  out.push("    int32_t vox_tail = vox_v->len - vox_idx - 1;");
  out.push("    if (vox_tail > 0) {");
  out.push("      memmove(vox_ptr, vox_ptr + (size_t)vox_v->h->elem_size, (size_t)vox_tail * (size_t)vox_v->h->elem_size);");
  out.push("    }");
  out.push("    vox_v->len = vox_v->len - 1;");
  out.push("  }");
  return out;
}

fn emit_instr_vec_len_line(tid: i32, recv_slot: i32, vn: ValueNameTables) -> String {
  return "  ".concat(c_temp_name_named(vn, tid)).concat(" = ").concat(c_slot_name_named(vn, recv_slot)).concat(".len;");
}

fn emit_instr_vec_get_append(out0: Vec[String], c_types: Vec[String], pool: ir.TyPool, tid: i32, elem: i32, recv_slot: i32, idx: ir.Value, load_dst: bool, vn: ValueNameTables) -> Vec[String] {
  let mut out: Vec[String] = out0;
  out.push("  {");
  out.push("    const vox_vec* vox_v = &".concat(c_slot_name_named(vn, recv_slot)).concat(";"));
  out.push("    vox_vec_require_handle(vox_v, \"vec get invalid args\");");
  out.push("    int32_t vox_idx = vox_vec_checked_index(vox_v, (int32_t)".concat(c_value_named(idx, vn)).concat(", \"vec index out of bounds\");"));
  if load_dst {
    out.push(vec_elem_load_line(c_types, pool, tid, elem, "vox_v->h->data + (size_t)vox_idx * (size_t)vox_v->h->elem_size", vn));
  }
  out.push("  }");
  return out;
}

pub fn ffi_import_order(imports: Vec[ir.FfiImportDecl]) -> Vec[i32] {
  let mut order: Vec[i32] = Vec();
  let mut i: i32 = 0;
  while i < imports.len() {
    order.push(i);
    i = i + 1;
  }
  let mut sorted: bool = true;
  let mut si: i32 = 1;
  while si < imports.len() {
    if imports.get(si - 1).func > imports.get(si).func {
      sorted = false;
      break;
    }
    si = si + 1;
  }
  if sorted { return order; }

  let mut gap: i32 = order.len() / 2;
  while gap > 0 {
    let mut oi: i32 = gap;
    while oi < order.len() {
      let keep: i32 = order.get(oi);
      let keep_name: String = imports.get(keep).func;
      let mut j: i32 = oi;
      while j >= gap {
        let prev: i32 = order.get(j - gap);
        if imports.get(prev).func <= keep_name { break; }
        order.set(j, prev);
        j = j - gap;
      }
      order.set(j, keep);
      oi = oi + 1;
    }
    gap = gap / 2;
  }
  return order;
}

pub struct CallNameEntry { pub name: String, pub sym: String }

fn call_name_lower_bound(entries: Vec[CallNameEntry], name: String) -> i32 {
  let mut lo: i32 = 0;
  let mut hi: i32 = entries.len();
  while lo < hi {
    let mid: i32 = lo + ((hi - lo) / 2);
    let cur: String = entries.get(mid).name;
    if cur < name {
      lo = mid + 1;
    } else {
      hi = mid;
    }
  }
  return lo;
}

fn call_name_put(entries0: Vec[CallNameEntry], name: String, sym: String) -> Vec[CallNameEntry] {
  let mut entries: Vec[CallNameEntry] = entries0;
  let lo: i32 = call_name_lower_bound(entries, name);
  if lo < entries.len() && entries.get(lo).name == name {
    entries.set(lo, CallNameEntry { name: name, sym: sym });
    return entries;
  }
  entries.insert(lo, CallNameEntry { name: name, sym: sym });
  return entries;
}

pub fn build_call_name_entries(p: ir.Program, funcs: Vec[ir.Func], ffi_order: Vec[i32]) -> Vec[CallNameEntry] {
  let mut entries: Vec[CallNameEntry] = Vec();
  // Internal function symbols are always `c_fn_name(name)`, so only keep
  // the cases that actually override that fallback.
  let mut ii: i32 = 0;
  while ii < ffi_order.len() {
    let im: ir.FfiImportDecl = p.ffi_imports.get(ffi_order.get(ii));
    if im.target != "c" && im.target != "wasm" {
      panic("c backend does not support ffi_import target in calls: ".concat(im.target));
    }
    let sym: String = if im.target == "wasm" { c_ffi_import_name(im.func) } else { im.symbol };
    // FFI import names override internal function names on collisions.
    entries = call_name_put(entries, im.func, sym);
    ii = ii + 1;
  }
  return entries;
}

fn call_name_lookup(entries: Vec[CallNameEntry], name: String) -> String {
  let lo: i32 = call_name_lower_bound(entries, name);
  if lo < entries.len() && entries.get(lo).name == name {
    return entries.get(lo).sym;
  }
  return c_fn_name(name);
}

struct CallNameLookupCachedResult {
  sym: String,
  cache: Vec[CallNameEntry],
}

fn call_name_lookup_cached(global_entries: Vec[CallNameEntry], cache0: Vec[CallNameEntry], name: String) -> CallNameLookupCachedResult {
  if cache0.len() > 0 {
    let last: CallNameEntry = cache0.get(cache0.len() - 1);
    if last.name == name {
      return CallNameLookupCachedResult { sym: last.sym, cache: cache0 };
    }
    // Keep sorted cache append-only on monotonic lookups to avoid binary-search
    // insert shifts in the hot call emission path.
    if last.name < name {
      let sym1: String = call_name_lookup(global_entries, name);
      let mut cache1: Vec[CallNameEntry] = cache0;
      cache1.push(CallNameEntry { name: name, sym: sym1 });
      return CallNameLookupCachedResult { sym: sym1, cache: cache1 };
    }
  }
  let mut cache: Vec[CallNameEntry] = cache0;
  let lo: i32 = call_name_lower_bound(cache, name);
  if lo < cache.len() && cache.get(lo).name == name {
    return CallNameLookupCachedResult { sym: cache.get(lo).sym, cache: cache };
  }
  let sym: String = call_name_lookup(global_entries, name);
  cache.insert(lo, CallNameEntry { name: name, sym: sym });
  return CallNameLookupCachedResult { sym: sym, cache: cache };
}

fn emit_instr_call_line_with_sym(has_dst: bool, tid: i32, ret_ty: i32, sym: String, args: Vec[ir.Value], read_temps: Vec[bool], vn: ValueNameTables) -> String {
  let mut parts: Vec[String] = Vec();
  parts.push("  ");
  if call_dst_is_read(has_dst, tid, read_temps) && ret_ty != -1 {
    parts.push(c_temp_name_named(vn, tid));
    parts.push(" = ");
  }
  parts.push(sym);
  parts.push("(");
  let mut i: i32 = 0;
  while i < args.len() {
    if i != 0 { parts.push(", "); }
    parts.push(c_value_named(args.get(i), vn));
    i = i + 1;
  }
  parts.push(");");
  return parts.join("");
}

struct EmitInstrCallCachedLineResult {
  line: String,
  cache: Vec[CallNameEntry],
}

fn emit_instr_call_cached_line(
  call_names: Vec[CallNameEntry],
  cache0: Vec[CallNameEntry],
  has_dst: bool,
  tid: i32,
  ret_ty: i32,
  name: String,
  args: Vec[ir.Value],
  read_temps: Vec[bool],
  vn: ValueNameTables,
) -> EmitInstrCallCachedLineResult {
  if name == "panic" {
    if args.len() != 1 { panic("panic expects 1 arg"); }
    return EmitInstrCallCachedLineResult {
      line: "  vox_host_panic(".concat(c_value_named(args.get(0), vn)).concat(");"),
      cache: cache0,
    };
  }
  let cr: CallNameLookupCachedResult = call_name_lookup_cached(call_names, cache0, name);
  return EmitInstrCallCachedLineResult {
    line: emit_instr_call_line_with_sym(has_dst, tid, ret_ty, cr.sym, args, read_temps, vn),
    cache: cr.cache,
  };
}

fn emit_instr_append(
  out0: Vec[String],
  c_types: Vec[String],
  pool: ir.TyPool,
  target_ptr_bits: i32,
  p: ir.Program,
  call_names: Vec[CallNameEntry],
  enum_order: Vec[i32],
  ins: ir.Instr,
  read_temps: Vec[bool],
  int_consts: TempIntConstTable,
  vn: ValueNameTables,
) -> Vec[String] {
  let mut out: Vec[String] = out0;
  return match ins {
    ir.Instr.SlotDecl(_sid, _ty) => out,

    ir.Instr.Const(tid, _ty, v) => { out.push(c_assign_line(c_temp_name_named(vn, tid), c_value_named(v, vn))); out },
    ir.Instr.BinOp(tid, op, ty, a, b) => {
      let bt: ir.Ty = ir.ty_pool_get(pool, ty);
      if is_int_scalar_kind(bt.kind) {
        emit_instr_binop_int_append(out, c_types, pool, tid, op, ty, a, b, int_consts, vn)
      } else if op == ir.BinOpKind.Mod && bt.kind == ir.TyKind.F32 {
        out.push("  ".concat(c_temp_name_named(vn, tid)).concat(" = fmodf(").concat(c_value_named(a, vn)).concat(", ").concat(c_value_named(b, vn)).concat(");"));
        out
      } else if op == ir.BinOpKind.Mod && bt.kind == ir.TyKind.F64 {
        out.push("  ".concat(c_temp_name_named(vn, tid)).concat(" = fmod(").concat(c_value_named(a, vn)).concat(", ").concat(c_value_named(b, vn)).concat(");"));
        out
      } else {
        out.push("  ".concat(c_temp_name_named(vn, tid)).concat(" = ").concat(c_value_named(a, vn)).concat(" ").concat(c_binop(op)).concat(" ").concat(c_value_named(b, vn)).concat(";"));
        out
      }
    },
    ir.Instr.Cmp(tid, op, oty, a, b) => push_line(out, emit_instr_cmp_line(pool, tid, op, oty, a, b, vn)),
    ir.Instr.And(tid, a, b) => { out.push(c_assign_line(c_temp_name_named(vn, tid), "(".concat(c_value_named(a, vn)).concat(" && ").concat(c_value_named(b, vn)).concat(")"))); out },
    ir.Instr.Or(tid, a, b) => { out.push(c_assign_line(c_temp_name_named(vn, tid), "(".concat(c_value_named(a, vn)).concat(" || ").concat(c_value_named(b, vn)).concat(")"))); out },
    ir.Instr.Not(tid, a) => { out.push(c_assign_line(c_temp_name_named(vn, tid), "(!".concat(c_value_named(a, vn)).concat(")"))); out },

    ir.Instr.IntCast(tid, dst_ty, _src_ty, v) => {
      out.push(c_assign_cast_line(c_temp_name_named(vn, tid), c_type_from_table(c_types, pool, dst_ty), c_value_named(v, vn)));
      out
    },
    ir.Instr.IntCastChecked(tid, dst_ty, src_ty, v) =>
      emit_instr_int_cast_checked_append(out, c_types, pool, target_ptr_bits, tid, dst_ty, src_ty, v, int_consts, vn),
    ir.Instr.FloatCast(tid, dst_ty, _src_ty, v) => {
      out.push(c_assign_cast_line(c_temp_name_named(vn, tid), c_type_from_table(c_types, pool, dst_ty), c_value_named(v, vn)));
      out
    },
    ir.Instr.RangeCheck(ty, v, lo, hi) => {
      out.push(
        "  if (".concat(c_value_named(v, vn)).concat(" < (").concat(c_type_from_table(c_types, pool, ty)).concat(")").concat(lo.to_string())
          .concat(" || ").concat(c_value_named(v, vn)).concat(" > (").concat(c_type_from_table(c_types, pool, ty)).concat(")").concat(hi.to_string())
          .concat(") { vox_host_panic(\"range check failed\"); }"),
      );
      out
    },

    ir.Instr.Store(sid, v) => { out.push(c_store_line(c_slot_name_named(vn, sid), c_value_named(v, vn))); out },
    ir.Instr.Load(tid, _ty, sid) => { out.push(c_assign_line(c_temp_name_named(vn, tid), c_slot_name_named(vn, sid))); out },
    ir.Instr.GlobalLoad(tid, _ty, name) => { out.push(c_assign_line(c_temp_name_named(vn, tid), c_static_name(name))); out },
    ir.Instr.GlobalStore(_ty, name, v) => { out.push(c_store_line(c_static_name(name), c_value_named(v, vn))); out },
    ir.Instr.AddrOfSlot(tid, _ty, sid) => { out.push(c_assign_line(c_temp_name_named(vn, tid), c_addr_of_expr(c_slot_name_named(vn, sid)))); out },
    ir.Instr.AddrOfFieldChain(tid, _ty, sid, fields) => { out.push(c_assign_line(c_temp_name_named(vn, tid), c_addr_of_expr(c_slot_name_named(vn, sid).concat(c_field_chain(fields))))); out },
    ir.Instr.RefLoad(tid, _ty, recv) => { out.push(c_assign_line(c_temp_name_named(vn, tid), c_deref_expr(c_value_named(recv, vn)))); out },
    ir.Instr.RefStore(_ty, recv, v) => { out.push(c_store_line(c_deref_expr(c_value_named(recv, vn)), c_value_named(v, vn))); out },

    ir.Instr.PtrRead(tid, ty, ptr) => { out.push(c_assign_line(c_temp_name_named(vn, tid), c_ptr_read_expr(c_type_from_table(c_types, pool, ty), c_value_named(ptr, vn)))); out },
    ir.Instr.PtrWrite(ty, ptr, v) => { out.push(c_ptr_write_line(c_type_from_table(c_types, pool, ty), c_value_named(ptr, vn), c_value_named(v, vn))); out },
    ir.Instr.PtrOffset(tid, ptr, off) => { out.push(c_assign_line(c_temp_name_named(vn, tid), c_ptr_offset_expr(c_value_named(ptr, vn), c_value_named(off, vn)))); out },

    ir.Instr.StructInit(tid, ty, fs) => push_line(out, emit_instr_struct_init_line(c_types, pool, tid, ty, fs, vn)),
    ir.Instr.FieldGet(tid, _ty, recv, field) => { out.push(c_assign_line(c_temp_name_named(vn, tid), c_field_access_expr(c_value_named(recv, vn), field))); out },
    ir.Instr.StoreField(sid, field, v) => { out.push(c_field_store_line(c_slot_name_named(vn, sid), field, c_value_named(v, vn))); out },

    ir.Instr.EnumInit(tid, ty, variant, payload) => push_line(out, emit_instr_enum_init_line(c_types, pool, p, enum_order, tid, ty, variant, payload, vn)),
    ir.Instr.EnumTag(tid, recv) => { out.push(c_assign_line(c_temp_name_named(vn, tid), c_field_access_expr(c_value_named(recv, vn), "tag"))); out },
    ir.Instr.EnumPayload(tid, _ty, recv, variant, idx) => { out.push(c_assign_line(c_temp_name_named(vn, tid), c_enum_payload_expr(c_value_named(recv, vn), variant, idx))); out },

    ir.Instr.VecNew(tid, _vty, elem) => emit_instr_vec_new_append(out, c_types, pool, tid, elem, vn),
    ir.Instr.VecPush(recv_slot, elem, v) => emit_instr_vec_push_append(out, c_types, pool, recv_slot, elem, v, vn),
    ir.Instr.VecInsert(recv_slot, elem, idx, v) => emit_instr_vec_insert_append(out, c_types, pool, recv_slot, elem, idx, v, vn),
    ir.Instr.VecSet(recv_slot, elem, idx, v) => emit_instr_vec_set_append(out, c_types, pool, recv_slot, elem, idx, v, vn),
    ir.Instr.VecClear(recv_slot) => emit_instr_vec_clear_append(out, recv_slot, vn),
    ir.Instr.VecExtend(recv_slot, other_slot) => emit_instr_vec_extend_append(out, recv_slot, other_slot, vn),
    ir.Instr.VecPop(tid, elem, recv_slot) => emit_instr_vec_pop_append(out, c_types, pool, tid, elem, recv_slot, temp_is_read(tid, read_temps), vn),
    ir.Instr.VecRemove(tid, elem, recv_slot, idx) => emit_instr_vec_remove_append(out, c_types, pool, tid, elem, recv_slot, idx, temp_is_read(tid, read_temps), vn),
    ir.Instr.VecLen(tid, recv_slot) => push_line(out, emit_instr_vec_len_line(tid, recv_slot, vn)),
    ir.Instr.VecGet(tid, elem, recv_slot, idx) => emit_instr_vec_get_append(out, c_types, pool, tid, elem, recv_slot, idx, temp_is_read(tid, read_temps), vn),

    ir.Instr.AtomicNew(tid, elem_ty, val) => emit_instr_atomic_new_append(out, pool, tid, elem_ty, val, vn),
    ir.Instr.AtomicLoad(tid, elem_ty, h) => { out.push(c_assign_line(c_temp_name_named(vn, tid), c_atomic_call_expr("atomic_load_explicit", c_atomic_c_type(pool, elem_ty), c_value_named(h, vn), Vec()))); out },
    ir.Instr.AtomicStore(elem_ty, h, val) => {
      let mut xs: Vec[String] = Vec();
      xs.push("(".concat(c_atomic_c_type(pool, elem_ty)).concat("*)").concat(c_value_named(h, vn)));
      xs.push(c_value_named(val, vn));
      xs.push("memory_order_seq_cst");
      out.push(c_call_stmt_line("atomic_store_explicit", xs));
      out
    },
    ir.Instr.AtomicFetchAdd(tid, elem_ty, h, delta) => { let mut xs: Vec[String] = Vec(); xs.push(c_value_named(delta, vn)); out.push(c_assign_line(c_temp_name_named(vn, tid), c_atomic_call_expr("atomic_fetch_add_explicit", c_atomic_c_type(pool, elem_ty), c_value_named(h, vn), xs))); out },
    ir.Instr.AtomicSwap(tid, elem_ty, h, val) => { let mut xs: Vec[String] = Vec(); xs.push(c_value_named(val, vn)); out.push(c_assign_line(c_temp_name_named(vn, tid), c_atomic_call_expr("atomic_exchange_explicit", c_atomic_c_type(pool, elem_ty), c_value_named(h, vn), xs))); out },
    ir.Instr.AtomicCAS(tid, elem_ty, h, expected, desired) => emit_instr_atomic_cas_append(out, pool, tid, elem_ty, h, expected, desired, vn),
    ir.Instr.AtomicDrop(_elem_ty, h) => {
      let mut xs: Vec[String] = Vec();
      xs.push("(void*)".concat(c_value_named(h, vn)));
      out.push(c_call_stmt_line("free", xs));
      out
    },

    ir.Instr.Call(has_dst, tid, ret_ty, name, args) => {
      let cr: EmitInstrCallCachedLineResult = emit_instr_call_cached_line(call_names, Vec(), has_dst, tid, ret_ty, name, args, read_temps, vn);
      out.push(cr.line);
      out
    },
  };
}

fn emit_term_ret_append(out0: Vec[String], has: bool, v: ir.Value, vn: ValueNameTables) -> Vec[String] {
  let mut out: Vec[String] = out0;
  if has {
    out.push("  return ".concat(c_value_named(v, vn)).concat(";"));
  } else {
    out.push("  return;");
  }
  return out;
}

fn emit_term_br_append(out0: Vec[String], target: String, fallthrough: String) -> Vec[String] {
  let mut out: Vec[String] = out0;
  if target != fallthrough {
    out.push("  goto ".concat(c_label_name(target)).concat(";"));
  }
  return out;
}

fn emit_term_cond_br_append(out0: Vec[String], cond: ir.Value, t: String, e: String, fallthrough: String, vn: ValueNameTables) -> Vec[String] {
  let mut out: Vec[String] = out0;
  if t == e {
    if t != fallthrough {
      out.push("  goto ".concat(c_label_name(t)).concat(";"));
    }
    return out;
  }
  if t == fallthrough && e == fallthrough { return out; }
  if t == fallthrough {
    out.push("  if (!(".concat(c_value_named(cond, vn)).concat(")) goto ").concat(c_label_name(e)).concat(";"));
    return out;
  }
  if e == fallthrough {
    out.push("  if (".concat(c_value_named(cond, vn)).concat(") goto ").concat(c_label_name(t)).concat(";"));
    return out;
  }
  out.push("  if (".concat(c_value_named(cond, vn)).concat(") goto ").concat(c_label_name(t)).concat("; else goto ").concat(c_label_name(e)).concat(";"));
  return out;
}

fn emit_term_panic_append(out0: Vec[String], msg: ir.Value, vn: ValueNameTables) -> Vec[String] {
  let mut out: Vec[String] = out0;
  out.push("  vox_host_panic(".concat(c_value_named(msg, vn)).concat(");"));
  return out;
}

fn emit_term_append(out0: Vec[String], t: ir.Term, fallthrough: String, vn: ValueNameTables) -> Vec[String] {
  return match t {
    ir.Term.Ret(has, v) => emit_term_ret_append(out0, has, v, vn),
    ir.Term.Br(target) => emit_term_br_append(out0, target, fallthrough),
    ir.Term.CondBr(cond, t, e) => emit_term_cond_br_append(out0, cond, t, e, fallthrough, vn),
    ir.Term.Panic(msg) => emit_term_panic_append(out0, msg, vn),
  };
}

fn block_name_order(blocks: Vec[ir.Block]) -> Vec[i32] {
  let mut order: Vec[i32] = Vec();
  let mut i: i32 = 0;
  while i < blocks.len() {
    order.push(i);
    i = i + 1;
  }
  let mut sorted: bool = true;
  let mut si: i32 = 1;
  while si < blocks.len() {
    if blocks.get(si - 1).name > blocks.get(si).name {
      sorted = false;
      break;
    }
    si = si + 1;
  }
  if sorted { return order; }

  let mut gap: i32 = order.len() / 2;
  while gap > 0 {
    let mut oi: i32 = gap;
    while oi < order.len() {
      let keep: i32 = order.get(oi);
      let keep_name: String = blocks.get(keep).name;
      let mut j: i32 = oi;
      while j >= gap {
        let prev: i32 = order.get(j - gap);
        if blocks.get(prev).name <= keep_name { break; }
        order.set(j, prev);
        j = j - gap;
      }
      order.set(j, keep);
      oi = oi + 1;
    }
    gap = gap / 2;
  }
  return order;
}

fn block_index_by_name_ordered(blocks: Vec[ir.Block], order: Vec[i32], name: String) -> i32 {
  let mut lo: i32 = 0;
  let mut hi: i32 = order.len() - 1;
  while lo <= hi {
    let mid: i32 = lo + ((hi - lo) / 2);
    let idx: i32 = order.get(mid);
    let cur: String = blocks.get(idx).name;
    if cur == name { return idx; }
    if cur < name {
      lo = mid + 1;
    } else {
      hi = mid - 1;
    }
  }
  return -1;
}

fn block_trivial_br_target_index(blocks: Vec[ir.Block], order: Vec[i32], bi: i32) -> i32 {
  if bi < 0 || bi >= blocks.len() { return -1; }
  let b: ir.Block = blocks.get(bi);
  if b.instrs.len() != 0 { return -1; }
  if !b.has_term { return -1; }
  let target: String = match b.term {
    ir.Term.Br(t) => t,
    _ => "",
  };
  if target == "" { return -1; }
  return block_index_by_name_ordered(blocks, order, target);
}

fn build_trivial_br_redirects(blocks: Vec[ir.Block], order: Vec[i32]) -> Vec[i32] {
  let unknown: i32 = -2;
  let mut out: Vec[i32] = Vec();
  let mut seen_mark: Vec[i32] = Vec();
  let mut seen_pos: Vec[i32] = Vec();
  let mut i: i32 = 0;
  while i < blocks.len() {
    out.push(unknown);
    seen_mark.push(0);
    seen_pos.push(-1);
    i = i + 1;
  }

  let mut run_id: i32 = 1;
  i = 0;
  while i < blocks.len() {
    if out.get(i) != unknown {
      i = i + 1;
      continue;
    }
    let mut path: Vec[i32] = Vec();
    let mut cur: i32 = i;
    let mut final_redirect: i32 = i;

    while true {
      if cur < 0 || cur >= blocks.len() {
        break;
      }
      let known: i32 = out.get(cur);
      if known != unknown {
        final_redirect = known;
        break;
      }
      if seen_mark.get(cur) == run_id {
        // Cycle of trivial branch-only blocks: keep the cycle representative stable.
        let pos: i32 = seen_pos.get(cur);
        final_redirect = if pos >= 0 && pos < path.len() { path.get(pos) } else { cur };
        break;
      }

      seen_mark.set(cur, run_id);
      seen_pos.set(cur, path.len());
      path.push(cur);

      let tgt: i32 = block_trivial_br_target_index(blocks, order, cur);
      if tgt < 0 || tgt >= blocks.len() || tgt == cur {
        final_redirect = cur;
        break;
      }
      cur = tgt;
    }

    let mut pi: i32 = 0;
    while pi < path.len() {
      out.set(path.get(pi), final_redirect);
      pi = pi + 1;
    }
    run_id = run_id + 1;
    i = i + 1;
  }
  return out;
}

struct BlockJumpTables { next_a: Vec[i32], next_b: Vec[i32] }

fn build_block_jump_tables(blocks: Vec[ir.Block], order: Vec[i32], redirects: Vec[i32]) -> BlockJumpTables {
  let mut next_a: Vec[i32] = Vec();
  let mut next_b: Vec[i32] = Vec();
  let mut i: i32 = 0;
  while i < blocks.len() {
    next_a.push(-1);
    next_b.push(-1);
    i = i + 1;
  }
  let mut bi: i32 = 0;
  while bi < blocks.len() {
    let b: ir.Block = blocks.get(bi);
    if b.has_term {
      let edge_a: String = match b.term {
        ir.Term.Br(target) => target,
        ir.Term.CondBr(_cond, t, _e) => t,
        _ => "",
      };
      if edge_a != "" {
        let idx_a0: i32 = block_index_by_name_ordered(blocks, order, edge_a);
        let idx_a: i32 = if idx_a0 >= 0 && idx_a0 < redirects.len() { redirects.get(idx_a0) } else { idx_a0 };
        next_a.set(bi, idx_a);
      }
      let edge_b: String = match b.term {
        ir.Term.CondBr(_cond, _t, e) => e,
        _ => "",
      };
      if edge_b != "" {
        let idx_b0: i32 = block_index_by_name_ordered(blocks, order, edge_b);
        let idx_b: i32 = if idx_b0 >= 0 && idx_b0 < redirects.len() { redirects.get(idx_b0) } else { idx_b0 };
        next_b.set(bi, idx_b);
      }
    }
    bi = bi + 1;
  }
  return BlockJumpTables { next_a: next_a, next_b: next_b };
}

fn collect_reachable_block_indices(blocks: Vec[ir.Block], jumps: BlockJumpTables, entry_idx: i32) -> Vec[i32] {
  if blocks.len() == 0 { return Vec(); }

  let mut queue: Vec[i32] = Vec();
  let mut visited: Vec[bool] = Vec();
  let mut queued: Vec[bool] = Vec();
  let mut i0: i32 = 0;
  while i0 < blocks.len() {
    visited.push(false);
    queued.push(false);
    i0 = i0 + 1;
  }
  let entry: i32 = if entry_idx >= 0 && entry_idx < blocks.len() { entry_idx } else { 0 };
  queue.push(entry);
  queued.set(entry, true);

  let mut qi: i32 = 0;
  while qi < queue.len() {
    let bi: i32 = queue.get(qi);
    qi = qi + 1;
    if bi < 0 { continue; }
    if bi >= blocks.len() { continue; }
    if visited.get(bi) { continue; }
    visited.set(bi, true);
    let b: ir.Block = blocks.get(bi);
    if !b.has_term { continue; }
    let next_a: i32 = jumps.next_a.get(bi);
    if next_a >= 0 && !queued.get(next_a) {
      queue.push(next_a);
      queued.set(next_a, true);
    }
    let next_b: i32 = jumps.next_b.get(bi);
    if next_b >= 0 && !queued.get(next_b) {
      queue.push(next_b);
      queued.set(next_b, true);
    }
  }

  let mut out: Vec[i32] = Vec();
  let mut i: i32 = 0;
  while i < blocks.len() {
    if visited.get(i) { out.push(i); }
    i = i + 1;
  }
  return out;
}

fn collect_jump_target_flags(blocks: Vec[ir.Block], jumps: BlockJumpTables, reachable: Vec[i32]) -> Vec[bool] {
  let mut flags: Vec[bool] = Vec();
  let mut i0: i32 = 0;
  while i0 < reachable.len() {
    flags.push(false);
    i0 = i0 + 1;
  }
  if reachable.len() == 0 { return flags; }

  let mut reachable_pos: Vec[i32] = Vec();
  let mut pi0: i32 = 0;
  while pi0 < blocks.len() {
    reachable_pos.push(-1);
    pi0 = pi0 + 1;
  }
  let mut ri0: i32 = 0;
  while ri0 < reachable.len() {
    let bi0: i32 = reachable.get(ri0);
    if bi0 >= 0 && bi0 < blocks.len() {
      reachable_pos.set(bi0, ri0);
    }
    ri0 = ri0 + 1;
  }

  let mut ri: i32 = 0;
  while ri < reachable.len() {
    let bi: i32 = reachable.get(ri);
    if bi < 0 || bi >= blocks.len() {
      ri = ri + 1;
      continue;
    }
    let b: ir.Block = blocks.get(bi);
    let fallthrough_idx: i32 = if ri + 1 < reachable.len() { reachable.get(ri + 1) } else { -1 };
    if b.has_term {
      let idx_a0: i32 = jumps.next_a.get(bi);
      let idx_b0: i32 = jumps.next_b.get(bi);
      let target_a_idx: i32 = match b.term {
        ir.Term.Br(_target) => idx_a0,
        ir.Term.CondBr(_cond, _t, _e) => if idx_a0 == fallthrough_idx { idx_b0 } else { idx_a0 },
        _ => -1,
      };
      if target_a_idx >= 0 && target_a_idx != fallthrough_idx {
        let pos_a: i32 = reachable_pos.get(target_a_idx);
        if pos_a >= 0 { flags.set(pos_a, true); }
      }
      let target_b_idx: i32 = match b.term {
        ir.Term.CondBr(_cond, _t, _e) =>
          if idx_a0 == fallthrough_idx || idx_b0 == fallthrough_idx { -1 } else { idx_b0 },
        _ => -1,
      };
      if target_b_idx >= 0 {
        let pos_b: i32 = reachable_pos.get(target_b_idx);
        if pos_b >= 0 { flags.set(pos_b, true); }
      }
    }
    ri = ri + 1;
  }
  return flags;
}

pub fn enum_decl_order(enums: Vec[ir.EnumDecl]) -> Vec[i32] {
  let mut order: Vec[i32] = Vec();
  let mut i: i32 = 0;
  while i < enums.len() {
    order.push(i);
    i = i + 1;
  }
  let mut sorted: bool = true;
  let mut si: i32 = 1;
  while si < enums.len() {
    if enums.get(si - 1).name > enums.get(si).name {
      sorted = false;
      break;
    }
    si = si + 1;
  }
  if sorted { return order; }

  let mut gap: i32 = order.len() / 2;
  while gap > 0 {
    let mut oi: i32 = gap;
    while oi < order.len() {
      let keep: i32 = order.get(oi);
      let keep_name: String = enums.get(keep).name;
      let mut j: i32 = oi;
      while j >= gap {
        let prev: i32 = order.get(j - gap);
        if enums.get(prev).name <= keep_name { break; }
        order.set(j, prev);
        j = j - gap;
      }
      order.set(j, keep);
      oi = oi + 1;
    }
    gap = gap / 2;
  }
  return order;
}

fn find_enum_decl_index_ordered(p: ir.Program, order: Vec[i32], name: String) -> i32 {
  let mut lo: i32 = 0;
  let mut hi: i32 = order.len() - 1;
  while lo <= hi {
    let mid: i32 = lo + ((hi - lo) / 2);
    let idx: i32 = order.get(mid);
    let cur: String = p.enums.get(idx).name;
    if cur == name { return idx; }
    if cur < name {
      lo = mid + 1;
    } else {
      hi = mid - 1;
    }
  }
  return -1;
}

fn enum_variant_tag(en: ir.EnumDecl, variant: String) -> i32 {
  let mut i: i32 = 0;
  while i < en.variants.len() {
    if en.variants.get(i).name == variant { return i; }
    i = i + 1;
  }
  panic("unknown enum variant in codegen");
  return -1;
}

fn param_flag_get(flags: Vec[bool], pid: i32) -> bool {
  if pid < 0 || pid >= flags.len() { return false; }
  return flags.get(pid);
}

fn param_flag_set(flags0: Vec[bool], pid: i32) -> Vec[bool] {
  if pid < 0 { return flags0; }
  let mut flags: Vec[bool] = flags0;
  while flags.len() <= pid { flags.push(false); }
  if !flags.get(pid) { flags.set(pid, true); }
  return flags;
}

fn mark_used_param_value(flags0: Vec[bool], v: ir.Value) -> Vec[bool] {
  return match v {
    ir.Value.Param(pid) => param_flag_set(flags0, pid),
    _ => flags0,
  };
}

fn mark_used_param_values(flags0: Vec[bool], vals: Vec[ir.Value]) -> Vec[bool] {
  let mut flags: Vec[bool] = flags0;
  let mut i: i32 = 0;
  while i < vals.len() {
    flags = mark_used_param_value(flags, vals.get(i));
    i = i + 1;
  }
  return flags;
}

fn mark_used_params_from_instr(flags0: Vec[bool], ins: ir.Instr) -> Vec[bool] {
  return match ins {
    ir.Instr.Const(_tid, _ty, v) => mark_used_param_value(flags0, v),
    ir.Instr.BinOp(_tid, _op, _ty, a, b) => mark_used_param_value(mark_used_param_value(flags0, a), b),
    ir.Instr.Cmp(_tid, _op, _oty, a, b) => mark_used_param_value(mark_used_param_value(flags0, a), b),
    ir.Instr.And(_tid, a, b) => mark_used_param_value(mark_used_param_value(flags0, a), b),
    ir.Instr.Or(_tid, a, b) => mark_used_param_value(mark_used_param_value(flags0, a), b),
    ir.Instr.Not(_tid, a) => mark_used_param_value(flags0, a),
    ir.Instr.IntCast(_tid, _dst_ty, _src_ty, v) => mark_used_param_value(flags0, v),
    ir.Instr.IntCastChecked(_tid, _dst_ty, _src_ty, v) => mark_used_param_value(flags0, v),
    ir.Instr.FloatCast(_tid, _dst_ty, _src_ty, v) => mark_used_param_value(flags0, v),
    ir.Instr.RangeCheck(_ty, v, _lo, _hi) => mark_used_param_value(flags0, v),
    ir.Instr.SlotDecl(_sid, _ty) => flags0,
    ir.Instr.Store(_sid, v) => mark_used_param_value(flags0, v),
    ir.Instr.Load(_tid, _ty, _sid) => flags0,
    ir.Instr.GlobalLoad(_tid, _ty, _name) => flags0,
    ir.Instr.GlobalStore(_ty, _name, v) => mark_used_param_value(flags0, v),
    ir.Instr.AddrOfSlot(_tid, _ty, _sid) => flags0,
    ir.Instr.AddrOfFieldChain(_tid, _ty, _sid, _fields) => flags0,
    ir.Instr.RefLoad(_tid, _ty, recv) => mark_used_param_value(flags0, recv),
    ir.Instr.RefStore(_ty, recv, v) => mark_used_param_value(mark_used_param_value(flags0, recv), v),
    ir.Instr.PtrRead(_tid, _ty, ptr) => mark_used_param_value(flags0, ptr),
    ir.Instr.PtrWrite(_ty, ptr, v) => mark_used_param_value(mark_used_param_value(flags0, ptr), v),
    ir.Instr.PtrOffset(_tid, ptr, off) => mark_used_param_value(mark_used_param_value(flags0, ptr), off),
    ir.Instr.StructInit(_tid, _ty, fields) => {
      let mut flags: Vec[bool] = flags0;
      let mut i: i32 = 0;
      while i < fields.len() {
        flags = mark_used_param_value(flags, fields.get(i).val);
        i = i + 1;
      }
      flags
    },
    ir.Instr.FieldGet(_tid, _ty, recv, _field) => mark_used_param_value(flags0, recv),
    ir.Instr.StoreField(_sid, _field, v) => mark_used_param_value(flags0, v),
    ir.Instr.EnumInit(_tid, _ty, _variant, payload) => mark_used_param_values(flags0, payload),
    ir.Instr.EnumTag(_tid, recv) => mark_used_param_value(flags0, recv),
    ir.Instr.EnumPayload(_tid, _ty, recv, _variant, _idx) => mark_used_param_value(flags0, recv),
    ir.Instr.VecNew(_tid, _vty, _elem) => flags0,
    ir.Instr.VecPush(_recv_slot, _elem, v) => mark_used_param_value(flags0, v),
    ir.Instr.VecInsert(_recv_slot, _elem, idx, v) => mark_used_param_value(mark_used_param_value(flags0, idx), v),
    ir.Instr.VecSet(_recv_slot, _elem, idx, v) => mark_used_param_value(mark_used_param_value(flags0, idx), v),
    ir.Instr.VecClear(_recv_slot) => flags0,
    ir.Instr.VecExtend(_recv_slot, _other_slot) => flags0,
    ir.Instr.VecPop(_tid, _elem, _recv_slot) => flags0,
    ir.Instr.VecRemove(_tid, _elem, _recv_slot, idx) => mark_used_param_value(flags0, idx),
    ir.Instr.VecLen(_tid, _recv_slot) => flags0,
    ir.Instr.VecGet(_tid, _elem, _recv_slot, idx) => mark_used_param_value(flags0, idx),
    ir.Instr.AtomicNew(_tid, _elem_ty, val) => mark_used_param_value(flags0, val),
    ir.Instr.AtomicLoad(_tid, _elem_ty, h) => mark_used_param_value(flags0, h),
    ir.Instr.AtomicStore(_elem_ty, h, val) => mark_used_param_value(mark_used_param_value(flags0, h), val),
    ir.Instr.AtomicFetchAdd(_tid, _elem_ty, h, delta) => mark_used_param_value(mark_used_param_value(flags0, h), delta),
    ir.Instr.AtomicSwap(_tid, _elem_ty, h, val) => mark_used_param_value(mark_used_param_value(flags0, h), val),
    ir.Instr.AtomicCAS(_tid, _elem_ty, h, expected, desired) => mark_used_param_value(mark_used_param_value(mark_used_param_value(flags0, h), expected), desired),
    ir.Instr.AtomicDrop(_elem_ty, h) => mark_used_param_value(flags0, h),
    ir.Instr.Call(_has_dst, _tid, _ret_ty, _name, args) => mark_used_param_values(flags0, args),
  };
}

fn mark_used_params_from_term(flags0: Vec[bool], t: ir.Term) -> Vec[bool] {
  return match t {
    ir.Term.Ret(has, v) => if has { mark_used_param_value(flags0, v) } else { flags0 },
    ir.Term.Br(_target) => flags0,
    ir.Term.CondBr(cond, _then_block, _else_block) => mark_used_param_value(flags0, cond),
    ir.Term.Panic(msg) => mark_used_param_value(flags0, msg),
  };
}

pub fn emit_func_append(out0: Vec[String], c_types: Vec[String], pool: ir.TyPool, p: ir.Program, f: ir.Func, call_names: Vec[CallNameEntry], enum_order: Vec[i32]) -> Vec[String] {
  return emit_func_append_with_call_cache(out0, c_types, pool, 0, p, f, call_names, enum_order, Vec()).out;
}

pub struct EmitFuncAppendWithCallCacheResult {
  pub out: Vec[String],
  pub call_cache: Vec[CallNameEntry],
}

pub fn emit_func_append_with_call_cache(
  out0: Vec[String],
  c_types: Vec[String],
  pool: ir.TyPool,
  target_ptr_bits: i32,
  p: ir.Program,
  f: ir.Func,
  call_names: Vec[CallNameEntry],
  enum_order: Vec[i32],
  call_cache0: Vec[CallNameEntry],
) -> EmitFuncAppendWithCallCacheResult {
  let seed: SeedLivenessSummary = collect_seed_liveness_summary(pool, f);
  let seed_slots: Vec[bool] = seed.live_slots;
  let seed_temps: Vec[bool] = seed.live_temps;
  let has_dead_candidates: bool = has_dead_candidates_from_seed(seed);
  let mut live_slots: Vec[bool] = seed_slots;
  let mut live_temps: Vec[bool] = seed_temps;
  if has_dead_candidates {
    let live_temps0: Vec[bool] = collect_live_temps(pool, f, seed_slots);
    live_slots = collect_live_slots_filtered(pool, f, live_temps0, seed_slots);
    live_temps = if bool_flags_equal(live_slots, seed_slots) { live_temps0 } else { collect_live_temps(pool, f, live_slots) };
  }
  // `live_temps` is already derived from read-use closure on kept instructions;
  // reuse it directly to avoid an extra full-function scan.
  let read_temps: Vec[bool] = live_temps;
  let keep_all: bool = !has_dead_candidates;
  let block_offsets: Vec[i32] = if keep_all {
    Vec()
  } else {
    block_instr_offsets(f)
  };
  let keep_instrs: Vec[bool] = if keep_all {
    Vec()
  } else {
    collect_kept_instr_flags(pool, f, live_temps, live_slots)
  };
  let locals: LocalsResult = if keep_all {
    collect_locals_keep_all(c_types, pool, f, read_temps)
  } else {
    collect_locals(c_types, pool, f, keep_instrs, block_offsets, read_temps)
  };
  let int_consts: TempIntConstTable =
    if seed.needs_int_const_table {
      build_temp_int_const_table(pool, target_ptr_bits, f, locals.max_temp, locals.max_slot)
    } else {
      temp_int_const_table_empty()
    };
  let slot_locals: Vec[IdTy] = idty_unique_sorted_last_wins(locals.slots);
  let temp_locals: Vec[IdTy] = idty_unique_sorted_last_wins(locals.temps);
  let block_order: Vec[i32] = block_name_order(f.blocks);
  let block_redirects: Vec[i32] = build_trivial_br_redirects(f.blocks, block_order);
  let block_jumps: BlockJumpTables = build_block_jump_tables(f.blocks, block_order, block_redirects);
  let entry_idx: i32 = if block_redirects.len() > 0 { block_redirects.get(0) } else { 0 };
  let block_indices: Vec[i32] = collect_reachable_block_indices(f.blocks, block_jumps, entry_idx);
  let jump_target_flags: Vec[bool] = collect_jump_target_flags(f.blocks, block_jumps, block_indices);
  let vn: ValueNameTables = build_value_name_tables(f.params.len(), locals.max_temp, locals.max_slot);
  let mut out: Vec[String] = out0;

  // Signature
  let is_main: bool = f.name == "main";
  let mut sig_parts: Vec[String] = Vec();
  sig_parts.push("static ");
  sig_parts.push(c_ret_type(pool, f.ret));
  sig_parts.push(" ");
  sig_parts.push(c_fn_name(f.name));
  sig_parts.push("(");
  if is_main {
    sig_parts.push("int32_t vox_p_argc, intptr_t vox_p_argv");
    if f.params.len() != 0 { sig_parts.push(", "); }
  }
  let mut i: i32 = 0;
  while i < f.params.len() {
    if i != 0 { sig_parts.push(", "); }
    let pa: ir.Param = f.params.get(i);
    sig_parts.push(c_type_from_table(c_types, pool, pa.ty));
    sig_parts.push(" ");
    sig_parts.push(c_param_name_named(vn, i));
    i = i + 1;
  }
  sig_parts.push(") {");
  out.push(sig_parts.join(""));
  let param_suppress_insert_at: i32 = out.len();
  let mut used_params: Vec[bool] = Vec();

  // Slots
  let mut si: i32 = 0;
  while si < slot_locals.len() {
    let it: IdTy = slot_locals.get(si);
    out.push(c_decl_line(it.ty, c_slot_name_named(vn, it.id)));
    si = si + 1;
  }

  // Temps
  let mut ti0: i32 = 0;
  while ti0 < temp_locals.len() {
    let it: IdTy = temp_locals.get(ti0);
    out.push(c_decl_line(it.ty, c_temp_name_named(vn, it.id)));
    ti0 = ti0 + 1;
  }
  if slot_locals.len() != 0 || temp_locals.len() != 0 { out.push(""); }

  // Blocks
  let mut call_cache: Vec[CallNameEntry] = call_cache0;
  let mut ri: i32 = 0;
  while ri < block_indices.len() {
    let bi: i32 = block_indices.get(ri);
    let b: ir.Block = f.blocks.get(bi);
    // Emit labels only for real jump targets.
    let emit_label: bool = jump_target_flags.get(ri);
    if emit_label { out.push(c_label_line(b.name)); }
    let mut ii: i32 = 0;
    while ii < b.instrs.len() {
      let ins: ir.Instr = b.instrs.get(ii);
      let keep: bool = if keep_all {
        true
      } else {
        let idx: i32 = block_offsets.get(bi) + ii;
        if idx >= 0 && idx < keep_instrs.len() { keep_instrs.get(idx) } else { true }
      };
      if keep {
        used_params = mark_used_params_from_instr(used_params, ins);
        out =
          match ins {
            ir.Instr.Call(has_dst, tid, ret_ty, name, args) => {
              let cr: EmitInstrCallCachedLineResult = emit_instr_call_cached_line(call_names, call_cache, has_dst, tid, ret_ty, name, args, read_temps, vn);
              call_cache = cr.cache;
              out.push(cr.line);
              out
            },
            _ => emit_instr_append(out, c_types, pool, target_ptr_bits, p, call_names, enum_order, ins, read_temps, int_consts, vn),
          };
      }
      ii = ii + 1;
    }
    if !b.has_term { panic("block missing terminator"); }
    used_params = mark_used_params_from_term(used_params, b.term);
    let fallthrough: String = if ri + 1 < block_indices.len() { f.blocks.get(block_indices.get(ri + 1)).name } else { "" };
    let idx_a0: i32 = block_jumps.next_a.get(bi);
    let idx_b0: i32 = block_jumps.next_b.get(bi);
    let target_a: String = if idx_a0 >= 0 && idx_a0 < f.blocks.len() {
      f.blocks.get(idx_a0).name
    } else {
      match b.term { ir.Term.Br(t) => t, ir.Term.CondBr(_cond, t, _e) => t, _ => "" }
    };
    let target_b: String = if idx_b0 >= 0 && idx_b0 < f.blocks.len() {
      f.blocks.get(idx_b0).name
    } else {
      match b.term { ir.Term.CondBr(_cond, _t, e) => e, _ => "" }
    };
    let term_resolved: ir.Term = match b.term {
      ir.Term.Br(_target) => ir.Term.Br(target_a),
      ir.Term.CondBr(cond, _t, _e) => ir.Term.CondBr(cond, target_a, target_b),
      _ => b.term,
    };
    out = emit_term_append(out, term_resolved, fallthrough, vn);
    out.push("");
    ri = ri + 1;
  }
  let mut suppress_lines: Vec[String] = Vec();
  if is_main {
    suppress_lines.push("  (void)vox_p_argc;");
    suppress_lines.push("  (void)vox_p_argv;");
  }
  let mut pi: i32 = 0;
  while pi < f.params.len() {
    if !param_flag_get(used_params, pi) {
      suppress_lines.push("  (void)".concat(c_param_name_named(vn, pi)).concat(";"));
    }
    pi = pi + 1;
  }
  if suppress_lines.len() != 0 {
    let mut li: i32 = 0;
    while li < suppress_lines.len() {
      out.insert(param_suppress_insert_at + li, suppress_lines.get(li));
      li = li + 1;
    }
    out.insert(param_suppress_insert_at + suppress_lines.len(), "");
  }

  out.push("}");
  return EmitFuncAppendWithCallCacheResult {
    out: out,
    call_cache: call_cache,
  };
}

pub fn emit_func(c_types: Vec[String], pool: ir.TyPool, p: ir.Program, f: ir.Func, call_names: Vec[CallNameEntry], enum_order: Vec[i32]) -> Vec[String] {
  return emit_func_append(Vec(), c_types, pool, p, f, call_names, enum_order);
}
