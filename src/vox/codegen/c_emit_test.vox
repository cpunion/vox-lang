fn test_codegen_int_div_emits_div0_check() -> () {
  let c: String = compile_to_c("fn main() -> i32 { let a: i32 = 1; let b: i32 = 0; return a / b; }");
  t.assert(contains(c, "division by zero"));
}

fn emit_div_i32_c(a: ir.Value, b: ir.Value) -> String {
  let mut pool: ir.TyPool = ir.ty_pool();
  let r_i32: ir.AddTyResult = ir.ty_pool_add(pool, ir.ty_i32());
  pool = r_i32.pool;
  let ty_i32: i32 = r_i32.idx;
  let mut p0: ir.Program = ir.program(pool);
  let mut instrs: Vec[ir.Instr] = Vec();
  instrs.push(ir.Instr.BinOp(0, ir.BinOpKind.Div, ty_i32, a, b));
  let mut blocks: Vec[ir.Block] = Vec();
  blocks.push(ir.Block { name: "entry", instrs: instrs, has_term: true, term: ir.Term.Ret(true, ir.v_temp(0)) });
  p0.funcs.push(ir.Func { name: "main", params: Vec(), ret: ty_i32, blocks: blocks });
  return cg.emit_c(p0, cg.EmitOptions {
    emit_driver_main: false,
    driver_main_kind: cg.DriverMainKind.User,
    emit_test_main: false,
    test_funcs: Vec(),
    c_sources: Vec(),
  });
}

fn emit_shift_i32_c(op: ir.BinOpKind, a: ir.Value, b: ir.Value) -> String {
  let mut pool: ir.TyPool = ir.ty_pool();
  let r_i32: ir.AddTyResult = ir.ty_pool_add(pool, ir.ty_i32());
  pool = r_i32.pool;
  let ty_i32: i32 = r_i32.idx;
  let mut p0: ir.Program = ir.program(pool);
  let mut instrs: Vec[ir.Instr] = Vec();
  instrs.push(ir.Instr.BinOp(0, op, ty_i32, a, b));
  let mut blocks: Vec[ir.Block] = Vec();
  blocks.push(ir.Block { name: "entry", instrs: instrs, has_term: true, term: ir.Term.Ret(true, ir.v_temp(0)) });
  p0.funcs.push(ir.Func { name: "main", params: Vec(), ret: ty_i32, blocks: blocks });
  return cg.emit_c(p0, cg.EmitOptions {
    emit_driver_main: false,
    driver_main_kind: cg.DriverMainKind.User,
    emit_test_main: false,
    test_funcs: Vec(),
    c_sources: Vec(),
  });
}

fn test_codegen_int_div_const_nonzero_skips_div0_check() -> () {
  let c: String = emit_div_i32_c(ir.v_int(42), ir.v_int(2));
  t.assert(!contains(c, "division by zero"));
}

fn test_codegen_int_div_const_non_minus_one_skips_overflow_check() -> () {
  let c: String = emit_div_i32_c(ir.v_int(42), ir.v_int(2));
  t.assert(!contains(c, "division overflow"));
}

fn test_codegen_int_div_const_minus_one_keeps_overflow_check() -> () {
  let c: String = emit_div_i32_c(ir.v_int(42), ir.v_int(-1));
  t.assert(contains(c, "division overflow"));
  t.assert(!contains(c, "division by zero"));
}

fn test_codegen_int_mod_emits_div0_check_unsigned() -> () {
  let src: String = "fn main() -> i32 { let a: u32 = 1; let b: u32 = 0; let c: u32 = a % b; return c as i32; }";
  let c: String = compile_to_c(src);
  t.assert(contains(c, "division by zero"));
}

fn test_codegen_shift_const_in_range_skips_shift_guard() -> () {
  let c: String = emit_shift_i32_c(ir.BinOpKind.Shl, ir.v_int(1), ir.v_int(4));
  t.assert(!contains(c, "shift count out of range"));
}

fn test_codegen_shift_const_out_of_range_keeps_shift_guard() -> () {
  let c: String = emit_shift_i32_c(ir.BinOpKind.Shl, ir.v_int(1), ir.v_int(32));
  t.assert(contains(c, "shift count out of range"));
}

fn test_codegen_int_add_avoids_signed_overflow_ub() -> () {
  let c: String = compile_to_c("fn main() -> i32 { let a: i32 = 1; let b: i32 = 2; return a + b; }");
  // Signed overflow is UB in C; backend must route through unsigned wrap + bitcast helper.
  t.assert(contains(c, "vox_bitcast_u32_i32("));
}

fn test_codegen_u32_add_uses_native_width_unsigned_ops() -> () {
  let c: String = compile_to_c("fn main() -> u32 { let a: u32 = 1; let b: u32 = 2; return a + b; }");
  t.assert(contains(c, "= (uint32_t)((uint32_t)(((("));
  t.assert(!contains(c, "= (uint32_t)((uint64_t)"));
}

fn test_codegen_bit_ops_and_shift_checks() -> () {
  let src: String = "fn main() -> i32 {\n  let a: i32 = 6 & 3;\n  let b: i32 = 1 << 4;\n  let c: i32 = b >> 2;\n  let _d: i32 = 1 << 32;\n  return (a | c) ^ 1;\n}";
  let c: String = compile_to_c(src);
  t.assert(contains(c, " & "));
  t.assert(contains(c, " | "));
  t.assert(contains(c, " ^ "));
  t.assert(contains(c, "<<"));
  t.assert(contains(c, ">>"));
  t.assert(contains(c, "shift count out of range"));
}

fn test_codegen_runtime_allocator_surface_smoke() -> () {
  let c: String = compile_to_c("fn main() -> i32 { return 0; }");
  t.assert(contains(c, "extern void* realloc(void*, size_t);"));
  t.assert(contains(c, "extern void* malloc(size_t);"));
  t.assert(contains(c, "extern void free(void*);"));
}

fn test_codegen_ref_str_cmp_uses_strcmp() -> () {
  let src: String = "fn eq(a: &str, b: &str) -> bool { return a == b; }\nfn main() -> i32 { return if eq(\"x\", \"x\") { 1 } else { 0 }; }";
  let c: String = compile_to_c(src);
  t.assert(contains(c, "strcmp("));
}

fn test_codegen_driver_main_ref_static_str_return_smoke() -> () {
  let c: String = compile_to_c("fn main() -> &'static str { return \"vox\"; }");
  t.assert(contains(c, "const char* v = vox_fn_mmain((int32_t)argc, (intptr_t)argv);"));
}
