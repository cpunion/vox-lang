}

fn test_codegen_event_loop_uses_runtime_helpers() -> () {
  let src: String = """
    @ffi_import("c", "vox_impl_el_init")
    fn el_init() -> ();
    @ffi_import("c", "vox_impl_el_poller_wake")
    fn el_wake() -> ();
    @ffi_import("c", "vox_impl_el_poller_wait")
    fn el_wait(timeout_ms: i32) -> ();
    fn f() -> () {
      el_init();
      el_wake();
      el_wait(100);
      return;
    }
  """;
  let r: p.ParseResult = p.parse_text(src);
  t.assert(r.err == p.ParseError.None);
  let mut w: tc.World = tc.world();
  w = add_string_prelude(w);
  w = tc.world_add(w, "std/async", r.prog);
  let gr: irgen.GenResult = irgen.generate_world(w);
  t.assert_with(gr.ok, gr.err);
  let c: String = cg.emit_c(gr.prog, cg.EmitOptions {
    emit_driver_main: false,
    driver_main_kind: cg.DriverMainKind.User,
    emit_test_main: false,
    test_funcs: Vec(),
    c_sources: Vec(),
  });
  // FFI imports should stay direct (no codegen-injected helper bodies).
  t.assert_with(contains(c, "extern void vox_impl_el_init("), "expected extern decl for vox_impl_el_init");
  t.assert_with(contains(c, "extern void vox_impl_el_poller_wake("), "expected extern decl for vox_impl_el_poller_wake");
  t.assert_with(contains(c, "extern void vox_impl_el_poller_wait("), "expected extern decl for vox_impl_el_poller_wait");
  t.assert_with(contains(c, "vox_impl_el_init();"), "expected direct call to vox_impl_el_init");
  t.assert_with(contains(c, "vox_impl_el_poller_wake();"), "expected direct call to vox_impl_el_poller_wake");
  t.assert_with(contains(c, "vox_impl_el_poller_wait("), "expected direct call to vox_impl_el_poller_wait");
  t.assert_with(!contains(c, "void vox_impl_el_init(void) {"), "expected no injected event-loop init helper body");
  t.assert_with(!contains(c, "void vox_impl_el_poller_wake(void) {"), "expected no injected event-loop wake helper body");
  t.assert_with(!contains(c, "void vox_impl_el_poller_wait(int32_t timeout_ms) {"), "expected no injected event-loop wait helper body");
  t.assert_with(!contains(c, "vox_wake_slots["), "expected old wake slots to be removed");
  t.assert_with(!contains(c, "vox_impl_wake_notify("), "expected old wake notify helper removed");
  t.assert_with(!contains(c, "vox_impl_wake_wait("), "expected old wake wait helper removed");
}

fn test_codegen_runtime_core_does_not_emit_rt_atomic_helpers() -> () {
  let src: String = """
    fn main() -> i32 {
      return 0;
    }
  """;
  let c: String = compile_to_c(src);
  t.assert_with(!contains(c, "int32_t rt_atomic_i32_load(void* p)"), "expected no rt_atomic_i32_load helper in runtime core");
  t.assert_with(!contains(c, "void rt_atomic_i32_store(void* p, int32_t v)"), "expected no rt_atomic_i32_store helper in runtime core");
  t.assert_with(!contains(c, "int64_t rt_atomic_i64_load(void* p)"), "expected no rt_atomic_i64_load helper in runtime core");
  t.assert_with(!contains(c, "void rt_atomic_i64_store(void* p, int64_t v)"), "expected no rt_atomic_i64_store helper in runtime core");
}

fn test_codegen_sync_drop_intrinsics_use_runtime_helpers() -> () {
  let src: String = """
    @ffi_import("c", "vox_impl_atomic_i32_new")
    fn rt_atomic_i32_new(v: i32) -> isize;
    @ffi_import("c", "vox_impl_atomic_i32_load")
    fn rt_atomic_i32_load(h: isize) -> i32;
    @ffi_import("c", "vox_impl_atomic_i32_store")
    fn rt_atomic_i32_store(h: isize, v: i32) -> ();
    @ffi_import("c", "vox_impl_atomic_i32_drop")
    fn rt_atomic_i32_drop(h: isize) -> ();
    @ffi_import("c", "vox_impl_atomic_i64_new")
    fn rt_atomic_i64_new(v: i64) -> isize;
    @ffi_import("c", "vox_impl_atomic_i64_load")
    fn rt_atomic_i64_load(h: isize) -> i64;
    @ffi_import("c", "vox_impl_atomic_i64_store")
    fn rt_atomic_i64_store(h: isize, v: i64) -> ();
    @ffi_import("c", "vox_impl_atomic_i64_drop")
    fn rt_atomic_i64_drop(h: isize) -> ();
    fn main() -> i32 {
      let m: isize = rt_atomic_i32_new(1);
      let v: i32 = rt_atomic_i32_load(m);
      rt_atomic_i32_store(m, v + 1);
      rt_atomic_i32_drop(m);
      rt_atomic_i32_drop(m);
      let a: isize = rt_atomic_i64_new(2 as i64);
      let x: i64 = rt_atomic_i64_load(a);
      rt_atomic_i64_store(a, x + (1 as i64));
      rt_atomic_i64_drop(a);
      rt_atomic_i64_drop(a);
      return 0;
    }
  """;
  let r: p.ParseResult = p.parse_text(src);
  t.assert(r.err == p.ParseError.None);
  let mut w: tc.World = tc.world();
  w = add_string_prelude(w);
  w = tc.world_add(w, "std/sync", r.prog);
  let gr: irgen.GenResult = irgen.generate_world(w);
  t.assert_with(gr.ok, gr.err);
  t.assert(gr.ok);
  let c: String = cg.emit_c(gr.prog, cg.EmitOptions { emit_driver_main: false, driver_main_kind: cg.DriverMainKind.User, emit_test_main: false, test_funcs: Vec(), c_sources: Vec() });
  t.assert_with(contains(c, "extern intptr_t vox_impl_atomic_i32_new("), "expected i32 atomic extern new");
  t.assert_with(contains(c, "extern int32_t vox_impl_atomic_i32_load("), "expected i32 atomic extern load");
  t.assert_with(contains(c, "extern void vox_impl_atomic_i32_store("), "expected i32 atomic extern store");
  t.assert_with(contains(c, "extern void vox_impl_atomic_i32_drop("), "expected i32 atomic extern drop");
  t.assert_with(contains(c, "extern intptr_t vox_impl_atomic_i64_new("), "expected i64 atomic extern new");
  t.assert_with(contains(c, "extern int64_t vox_impl_atomic_i64_load("), "expected i64 atomic extern load");
  t.assert_with(contains(c, "extern void vox_impl_atomic_i64_store("), "expected i64 atomic extern store");
  t.assert_with(contains(c, "extern void vox_impl_atomic_i64_drop("), "expected i64 atomic extern drop");
  t.assert_with(!contains(c, "vox_sync_handle_add("), "expected no injected sync handle add helper");
  t.assert_with(!contains(c, "vox_sync_handle_live("), "expected no injected sync handle live helper");
  t.assert_with(!contains(c, "vox_sync_handle_remove("), "expected no injected sync handle remove helper");
  t.assert_with(contains(c, "vox_impl_atomic_i32_drop("), "expected i32 atomic drop calls");
  t.assert_with(contains(c, "vox_impl_atomic_i64_drop("), "expected i64 atomic drop calls");
}

fn test_codegen_vec_is_empty_uses_runtime_len() -> () {
  let src: String = """
    fn main() -> i32 {
      let mut v: Vec[i32] = Vec();
      if v.is_empty() { v.push(1); }
      return if !v.is_empty() && v.len() == 1 { 1 } else { 0 };
    }
  """;
  let c: String = compile_to_c(src);
  t.assert(contains(c, "vox_v->len++;"));
  t.assert(contains(c, ".len;"));
}

fn test_codegen_vec_clear_is_inlined() -> () {
  let src: String = """
    fn main() -> i32 {
      let mut v: Vec[i32] = Vec();
      v.push(1);
      v.clear();
      return v.len();
    }
  """;
  let c: String = compile_to_c(src);
  t.assert(contains(c, "vox_v->len = 0;"));
}

fn test_codegen_vec_extend_is_inlined() -> () {
  let src: String = """
    fn main() -> i32 {
      let mut a: Vec[i32] = Vec();
      a.push(1);
      let mut b: Vec[i32] = Vec();
      b.push(2);
      a.extend(b);
      return a.len();
    }
  """;
  let c: String = compile_to_c(src);
  t.assert(!contains(c, "vec extend elem_size mismatch"));
  t.assert(contains(c, "memcpy(vox_v->h->data + (size_t)vox_v->len * (size_t)vox_v->h->elem_size, vox_other->h->data"));
}

