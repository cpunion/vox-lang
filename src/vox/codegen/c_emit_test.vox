fn test_codegen_int_cast_checked_uses_ptr_bounds_for_isize_usize() -> () {
  let src: String = """
    fn main() -> i32 {
      let a: i64 = 7;
      let b: isize = a as isize;
      let c: usize = b as usize;
      return c as i32;
    }
  """;
  let c: String = compile_to_c(src);
  t.assert(contains(c, "INTPTR_MAX"));
  t.assert(contains(c, "INTPTR_MIN"));
  t.assert(contains(c, "isize to usize overflow"));
}

fn test_codegen_int_cast_checked_i32_to_usize_avoids_redundant_upper_check() -> () {
  let src: String = """
    fn main() -> i32 {
      let a: i32 = 7;
      let b: usize = a as usize;
      return b as i32;
    }
  """;
  let c: String = compile_to_c(src);
  t.assert(contains(c, "< 0) { vox_host_panic(\"i32 to usize overflow\"); }"));
  t.assert(!contains(c, " > (uint64_t)UINTPTR_MAX) { vox_host_panic(\"i32 to usize overflow\"); }"));
}

fn test_codegen_int_cast_checked_isize_to_usize_avoids_redundant_upper_check() -> () {
  let src: String = """
    fn id(x: isize) -> usize { return x as usize; }
    fn main() -> i32 {
      let a: isize = 7;
      let b: usize = id(a);
      return b as i32;
    }
  """;
  let c: String = compile_to_c(src);
  t.assert(contains(c, "< 0) { vox_host_panic(\"isize to usize overflow\"); }"));
  t.assert(!contains(c, " > (uint64_t)UINTPTR_MAX) { vox_host_panic(\"isize to usize overflow\"); }"));
}

