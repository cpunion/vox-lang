  p0.funcs.push(ir.Func { name: "foo", params: Vec(), ret: ty_i32, blocks: foo_blocks });

  let mut bar_blocks: Vec[ir.Block] = Vec();
  bar_blocks.push(ir.Block { name: "entry", instrs: Vec(), has_term: true, term: ir.Term.Ret(true, ir.v_int(2)) });
  p0.funcs.push(ir.Func { name: "bar", params: Vec(), ret: ty_i32, blocks: bar_blocks });

  let c: String = cg.emit_c(p0, cg.EmitOptions {
    emit_driver_main: false,
    driver_main_kind: cg.DriverMainKind.User,
    emit_test_main: false,
    test_funcs: Vec(),
    c_sources: Vec(),
  });
  t.assert(contains(c, "vox_fn_mfoo("));
  t.assert(contains(c, "vox_fn_mbar("));
}

fn test_codegen_fallthrough_br_omits_goto_and_label() -> () {
  let mut pool: ir.TyPool = ir.ty_pool();
  let r_i32: ir.AddTyResult = ir.ty_pool_add(pool, ir.ty_i32());
  pool = r_i32.pool;
  let ty_i32: i32 = r_i32.idx;
  let mut p0: ir.Program = ir.program(pool);
  let mut blocks: Vec[ir.Block] = Vec();
  blocks.push(ir.Block { name: "entry", instrs: Vec(), has_term: true, term: ir.Term.Br("next") });
  blocks.push(ir.Block { name: "next", instrs: Vec(), has_term: true, term: ir.Term.Ret(true, ir.v_int(0)) });
  p0.funcs.push(ir.Func { name: "main", params: Vec(), ret: ty_i32, blocks: blocks });
  let c: String = cg.emit_c(p0, cg.EmitOptions {
    emit_driver_main: false,
    driver_main_kind: cg.DriverMainKind.User,
    emit_test_main: false,
    test_funcs: Vec(),
    c_sources: Vec(),
  });
  t.assert(!contains(c, "goto vox_blk_next;"));
  t.assert(!contains(c, "vox_blk_next:"));
}

fn test_codegen_non_fallthrough_br_keeps_goto_and_label() -> () {
  let mut pool: ir.TyPool = ir.ty_pool();
  let r_i32: ir.AddTyResult = ir.ty_pool_add(pool, ir.ty_i32());
  pool = r_i32.pool;
  let ty_i32: i32 = r_i32.idx;
  let mut p0: ir.Program = ir.program(pool);
  let mut blocks: Vec[ir.Block] = Vec();
  blocks.push(ir.Block { name: "entry", instrs: Vec(), has_term: true, term: ir.Term.Br("end") });
  blocks.push(ir.Block { name: "mid", instrs: Vec(), has_term: true, term: ir.Term.Ret(true, ir.v_int(1)) });
  blocks.push(ir.Block { name: "end", instrs: Vec(), has_term: true, term: ir.Term.Ret(true, ir.v_int(0)) });
  p0.funcs.push(ir.Func { name: "main", params: Vec(), ret: ty_i32, blocks: blocks });
  let c: String = cg.emit_c(p0, cg.EmitOptions {
    emit_driver_main: false,
    driver_main_kind: cg.DriverMainKind.User,
    emit_test_main: false,
    test_funcs: Vec(),
    c_sources: Vec(),
  });
  // Unreachable middle block is pruned from layout; entry -> end becomes fallthrough.
  t.assert_with(!contains(c, "goto vox_blk_end;"), "expected no goto after reachable-block pruning");
  t.assert_with(!contains(c, "vox_blk_end:"), "expected no label when end is pure fallthrough");
}

fn test_codegen_fallthrough_condbr_uses_single_branch_goto() -> () {
  let mut pool: ir.TyPool = ir.ty_pool();
  let r_i32: ir.AddTyResult = ir.ty_pool_add(pool, ir.ty_i32());
  pool = r_i32.pool;
  let ty_i32: i32 = r_i32.idx;
  let r_bool: ir.AddTyResult = ir.ty_pool_add(pool, ir.ty_bool());
  pool = r_bool.pool;
  let ty_bool: i32 = r_bool.idx;
  let mut p0: ir.Program = ir.program(pool);
  let mut blocks: Vec[ir.Block] = Vec();
  blocks.push(ir.Block {
    name: "entry",
    instrs: Vec(),
    has_term: true,
    term: ir.Term.CondBr(ir.v_param(0), "next", "alt"),
  });
  blocks.push(ir.Block { name: "next", instrs: Vec(), has_term: true, term: ir.Term.Ret(true, ir.v_int(0)) });
  blocks.push(ir.Block { name: "alt", instrs: Vec(), has_term: true, term: ir.Term.Ret(true, ir.v_int(1)) });
  let mut params: Vec[ir.Param] = Vec();
  params.push(ir.Param { name: "flag", ty: ty_bool });
  p0.funcs.push(ir.Func { name: "main", params: params, ret: ty_i32, blocks: blocks });
  let c: String = cg.emit_c(p0, cg.EmitOptions {
    emit_driver_main: false,
    driver_main_kind: cg.DriverMainKind.User,
    emit_test_main: false,
    test_funcs: Vec(),
    c_sources: Vec(),
  });
  t.assert(contains(c, "if (!(p0)) goto vox_blk_alt;"));
  t.assert(!contains(c, "else goto"));
  t.assert(!contains(c, "vox_blk_next:"));
}

fn test_codegen_condbr_same_target_simplifies_to_single_goto() -> () {
  let mut pool: ir.TyPool = ir.ty_pool();
  let r_i32: ir.AddTyResult = ir.ty_pool_add(pool, ir.ty_i32());
  pool = r_i32.pool;
  let ty_i32: i32 = r_i32.idx;
  let r_bool: ir.AddTyResult = ir.ty_pool_add(pool, ir.ty_bool());
  pool = r_bool.pool;
  let ty_bool: i32 = r_bool.idx;
  let mut p0: ir.Program = ir.program(pool);
  let mut blocks: Vec[ir.Block] = Vec();
  blocks.push(ir.Block {
    name: "entry",
    instrs: Vec(),
    has_term: true,
    term: ir.Term.CondBr(ir.v_param(0), "done", "done"),
  });
  blocks.push(ir.Block { name: "mid", instrs: Vec(), has_term: true, term: ir.Term.Ret(true, ir.v_int(1)) });
  blocks.push(ir.Block { name: "done", instrs: Vec(), has_term: true, term: ir.Term.Ret(true, ir.v_int(0)) });
  let mut params: Vec[ir.Param] = Vec();
  params.push(ir.Param { name: "flag", ty: ty_bool });
  p0.funcs.push(ir.Func { name: "main", params: params, ret: ty_i32, blocks: blocks });
  let c: String = cg.emit_c(p0, cg.EmitOptions {
    emit_driver_main: false,
    driver_main_kind: cg.DriverMainKind.User,
    emit_test_main: false,
    test_funcs: Vec(),
    c_sources: Vec(),
  });
  t.assert_with(!contains(c, "goto vox_blk_done;"), "expected same-target condbr to fold to fallthrough when target is next block");
  t.assert_with(!contains(c, "if (p0) goto vox_blk_done; else goto vox_blk_done;"), "expected no redundant if/else for same-target condbr");
  t.assert_with(!contains(c, "vox_blk_done:"), "expected no done label when there is no jump to it");
}

fn test_codegen_trivial_br_chain_is_redirected_from_entry() -> () {
  let mut pool: ir.TyPool = ir.ty_pool();
  let r_i32: ir.AddTyResult = ir.ty_pool_add(pool, ir.ty_i32());
  pool = r_i32.pool;
  let ty_i32: i32 = r_i32.idx;
  let mut p0: ir.Program = ir.program(pool);
  let mut blocks: Vec[ir.Block] = Vec();
  blocks.push(ir.Block { name: "entry", instrs: Vec(), has_term: true, term: ir.Term.Br("hop") });
  blocks.push(ir.Block { name: "hop", instrs: Vec(), has_term: true, term: ir.Term.Br("done") });
  blocks.push(ir.Block { name: "done", instrs: Vec(), has_term: true, term: ir.Term.Ret(true, ir.v_int(0)) });
  p0.funcs.push(ir.Func { name: "main", params: Vec(), ret: ty_i32, blocks: blocks });
  let c: String = cg.emit_c(p0, cg.EmitOptions {
    emit_driver_main: false,
    driver_main_kind: cg.DriverMainKind.User,
    emit_test_main: false,
    test_funcs: Vec(),
    c_sources: Vec(),
  });
  t.assert(!contains(c, "goto vox_blk_hop;"));
  t.assert(!contains(c, "goto vox_blk_done;"));
  t.assert(!contains(c, "vox_blk_hop:"));
  t.assert(!contains(c, "vox_blk_done:"));
}

fn test_codegen_condbr_redirects_through_trivial_bridge_blocks() -> () {
  let mut pool: ir.TyPool = ir.ty_pool();
  let r_i32: ir.AddTyResult = ir.ty_pool_add(pool, ir.ty_i32());
  pool = r_i32.pool;
  let ty_i32: i32 = r_i32.idx;
  let r_bool: ir.AddTyResult = ir.ty_pool_add(pool, ir.ty_bool());
  pool = r_bool.pool;
  let ty_bool: i32 = r_bool.idx;
  let mut p0: ir.Program = ir.program(pool);
  let mut blocks: Vec[ir.Block] = Vec();
  blocks.push(ir.Block {
    name: "entry",
    instrs: Vec(),
    has_term: true,
    term: ir.Term.CondBr(ir.v_param(0), "then_bridge", "else_bridge"),
  });
  blocks.push(ir.Block { name: "then_bridge", instrs: Vec(), has_term: true, term: ir.Term.Br("then_done") });
  blocks.push(ir.Block { name: "else_bridge", instrs: Vec(), has_term: true, term: ir.Term.Br("else_done") });
  blocks.push(ir.Block { name: "then_done", instrs: Vec(), has_term: true, term: ir.Term.Ret(true, ir.v_int(1)) });
  blocks.push(ir.Block { name: "else_done", instrs: Vec(), has_term: true, term: ir.Term.Ret(true, ir.v_int(0)) });
  let mut params: Vec[ir.Param] = Vec();
  params.push(ir.Param { name: "flag", ty: ty_bool });
  p0.funcs.push(ir.Func { name: "main", params: params, ret: ty_i32, blocks: blocks });
  let c: String = cg.emit_c(p0, cg.EmitOptions {
    emit_driver_main: false,
    driver_main_kind: cg.DriverMainKind.User,
    emit_test_main: false,
    test_funcs: Vec(),
    c_sources: Vec(),
  });
  t.assert(contains(c, "if (!(p0)) goto vox_blk_else_done;"));
  t.assert(!contains(c, "goto vox_blk_then_bridge;"));
  t.assert(!contains(c, "goto vox_blk_else_bridge;"));
  t.assert(!contains(c, "vox_blk_then_bridge:"));
  t.assert(!contains(c, "vox_blk_else_bridge:"));
}

fn test_codegen_trivial_br_cycle_does_not_oscillate_redirects() -> () {
  let mut pool: ir.TyPool = ir.ty_pool();
  let r_i32: ir.AddTyResult = ir.ty_pool_add(pool, ir.ty_i32());
  pool = r_i32.pool;
  let ty_i32: i32 = r_i32.idx;
  let mut p0: ir.Program = ir.program(pool);
  let mut blocks: Vec[ir.Block] = Vec();
  blocks.push(ir.Block { name: "entry", instrs: Vec(), has_term: true, term: ir.Term.Br("a") });
  blocks.push(ir.Block { name: "a", instrs: Vec(), has_term: true, term: ir.Term.Br("b") });
  blocks.push(ir.Block { name: "b", instrs: Vec(), has_term: true, term: ir.Term.Br("a") });
  p0.funcs.push(ir.Func { name: "main", params: Vec(), ret: ty_i32, blocks: blocks });
  let c: String = cg.emit_c(p0, cg.EmitOptions {
    emit_driver_main: false,
    driver_main_kind: cg.DriverMainKind.User,
    emit_test_main: false,
    test_funcs: Vec(),
    c_sources: Vec(),
  });
  t.assert_with(contains(c, "vox_fn_mmain("), "codegen should complete for trivial-branch cycles");
  t.assert_with(contains(c, "vox_blk_a:"), "cycle entry label should remain in emitted C");
  t.assert_with(contains(c, "goto vox_blk_a;"), "cycle back-edge goto should remain in emitted C");
}

fn test_codegen_drops_dead_pure_temps() -> () {
  let mut pool: ir.TyPool = ir.ty_pool();
  let r_i32: ir.AddTyResult = ir.ty_pool_add(pool, ir.ty_i32());
  pool = r_i32.pool;
  let ty_i32: i32 = r_i32.idx;

  let mut p0: ir.Program = ir.program(pool);
  let mut instrs: Vec[ir.Instr] = Vec();
  // Dead const can be dropped.
  instrs.push(ir.Instr.Const(987654, ty_i32, ir.v_int(1)));
  // Dead pure arithmetic can be dropped.
  instrs.push(ir.Instr.BinOp(987656, ir.BinOpKind.Add, ty_i32, ir.v_int(1), ir.v_int(2)));
  // Shift can panic on invalid counts; keep it even if result is unused.
  instrs.push(ir.Instr.BinOp(987655, ir.BinOpKind.Shl, ty_i32, ir.v_int(1), ir.v_int(2)));
  let mut blocks: Vec[ir.Block] = Vec();
  blocks.push(ir.Block { name: "entry", instrs: instrs, has_term: true, term: ir.Term.Ret(true, ir.v_int(0)) });
  p0.funcs.push(ir.Func { name: "main", params: Vec(), ret: ty_i32, blocks: blocks });

  let c: String = cg.emit_c(p0, cg.EmitOptions {
    emit_driver_main: false,
    driver_main_kind: cg.DriverMainKind.User,
    emit_test_main: false,
    test_funcs: Vec(),
    c_sources: Vec(),
  });
  t.assert(!contains(c, "t987654"));
  t.assert(!contains(c, "t987656"));
  t.assert(contains(c, "int32_t t987655;"));
  t.assert(contains(c, "shift count out of range"));
}

fn test_codegen_keeps_dead_call_without_storing_result() -> () {
  let mut pool: ir.TyPool = ir.ty_pool();
  let r_i32: ir.AddTyResult = ir.ty_pool_add(pool, ir.ty_i32());
  pool = r_i32.pool;
  let ty_i32: i32 = r_i32.idx;

  let mut p0: ir.Program = ir.program(pool);
  let mut instrs: Vec[ir.Instr] = Vec();
  // Call may have side effects; keep the call even when result temp is dead.
  instrs.push(ir.Instr.Call(true, 777, ty_i32, "foo", Vec()));
  let mut blocks: Vec[ir.Block] = Vec();
  blocks.push(ir.Block { name: "entry", instrs: instrs, has_term: true, term: ir.Term.Ret(true, ir.v_int(0)) });
  p0.funcs.push(ir.Func { name: "main", params: Vec(), ret: ty_i32, blocks: blocks });

  let c: String = cg.emit_c(p0, cg.EmitOptions {
    emit_driver_main: false,
    driver_main_kind: cg.DriverMainKind.User,
    emit_test_main: false,
    test_funcs: Vec(),
    c_sources: Vec(),
  });
  t.assert(contains(c, "vox_fn_mfoo();"));
  t.assert(!contains(c, "t777 = vox_fn_mfoo();"));
  t.assert(!contains(c, "t777;"));
}

fn test_codegen_frontend_ignored_call_result_omits_assignment() -> () {
  let c: String = compile_to_c("""
    fn side() -> i32 { return 1; }
    fn main() -> i32 {
      let _ignored: i32 = side();
      return 0;
    }
  """);
  t.assert(contains(c, "vox_fn_mside();"));
  t.assert(!contains(c, " = vox_fn_mside();"));
}

fn test_codegen_drops_dead_load_chain_temps() -> () {
  let mut pool: ir.TyPool = ir.ty_pool();
  let r_i32: ir.AddTyResult = ir.ty_pool_add(pool, ir.ty_i32());
  pool = r_i32.pool;
  let ty_i32: i32 = r_i32.idx;

  let mut p0: ir.Program = ir.program(pool);
  let mut instrs: Vec[ir.Instr] = Vec();
  instrs.push(ir.Instr.SlotDecl(0, ty_i32));
  instrs.push(ir.Instr.Store(0, ir.v_int(7)));
  // Entire chain is dead and pure, should be removed.
  instrs.push(ir.Instr.Load(88, ty_i32, 0));
  instrs.push(ir.Instr.IntCast(89, ty_i32, ty_i32, ir.v_temp(88)));
  let mut blocks: Vec[ir.Block] = Vec();
  blocks.push(ir.Block { name: "entry", instrs: instrs, has_term: true, term: ir.Term.Ret(true, ir.v_int(0)) });
  p0.funcs.push(ir.Func { name: "main", params: Vec(), ret: ty_i32, blocks: blocks });

  let c: String = cg.emit_c(p0, cg.EmitOptions {
    emit_driver_main: false,
    driver_main_kind: cg.DriverMainKind.User,
    emit_test_main: false,
    test_funcs: Vec(),
    c_sources: Vec(),
  });
  t.assert(!contains(c, "t88"));
  t.assert(!contains(c, "t89"));
}

fn test_codegen_drops_dead_slot_store_and_feeding_temp() -> () {
  let mut pool: ir.TyPool = ir.ty_pool();
  let r_i32: ir.AddTyResult = ir.ty_pool_add(pool, ir.ty_i32());
  pool = r_i32.pool;
  let ty_i32: i32 = r_i32.idx;

  let mut p0: ir.Program = ir.program(pool);
  let mut instrs: Vec[ir.Instr] = Vec();
  instrs.push(ir.Instr.SlotDecl(0, ty_i32));
  instrs.push(ir.Instr.Const(91, ty_i32, ir.v_int(7)));
  // Dead slot store should be removed, and t91 should not be kept alive by it.
  instrs.push(ir.Instr.Store(0, ir.v_temp(91)));
  let mut blocks: Vec[ir.Block] = Vec();
  blocks.push(ir.Block { name: "entry", instrs: instrs, has_term: true, term: ir.Term.Ret(true, ir.v_int(0)) });
  p0.funcs.push(ir.Func { name: "main", params: Vec(), ret: ty_i32, blocks: blocks });

  let c: String = cg.emit_c(p0, cg.EmitOptions {
    emit_driver_main: false,
    driver_main_kind: cg.DriverMainKind.User,
    emit_test_main: false,
    test_funcs: Vec(),
    c_sources: Vec(),
  });
  t.assert(!contains(c, "v0"));
  t.assert(!contains(c, "t91"));
}

