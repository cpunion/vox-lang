fn test_codegen_vec_i32_push_set_insert_use_typed_store() -> () {
  let src: String = """
    fn main() -> i32 {
      let mut v: Vec[i32] = Vec();
      v.push(1);
      v.insert(0, 2);
      v.set(0, 3);
      return v.get(0);
    }
  """;
  let c: String = compile_to_c(src);
  t.assert(contains(c, "*((int32_t*)(vox_v->h->data + (size_t)vox_v->len * (size_t)vox_v->h->elem_size)) = "));
  t.assert(contains(c, "*((int32_t*)(vox_ptr)) = "));
  t.assert(contains(c, "*((int32_t*)(vox_v->h->data + (size_t)vox_idx * (size_t)vox_v->h->elem_size)) = "));
  t.assert(!contains(c, "memcpy(vox_v->h->data + (size_t)vox_v->len * (size_t)vox_v->h->elem_size, &"));
  t.assert(!contains(c, "memcpy(vox_ptr, &"));
}

fn test_codegen_vec_i32_get_pop_remove_use_typed_load() -> () {
  let src: String = """
    fn main() -> i32 {
      let mut v: Vec[i32] = Vec();
      v.push(1);
      v.push(2);
      let a: i32 = v.get(0);
      let b: i32 = v.pop();
      let c: i32 = v.remove(0);
      return a + b + c;
    }
  """;
