import "std/testing" as t
import "vox/typecheck" as tc

fn test_parse_i32_dec_rejects_too_large_literal() -> () {
  let pr: tc.ParseI32DecResult = tc.parse_i32_dec("2147483648");
  t.assert(!pr.ok);
}

fn test_parse_i32_dec_accepts_i32_max() -> () {
  let pr: tc.ParseI32DecResult = tc.parse_i32_dec("2147483647");
  t.assert(pr.ok);
  t.assert_eq(pr.val, 2147483647);
}
