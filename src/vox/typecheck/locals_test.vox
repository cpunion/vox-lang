import "std/testing" as t
import "vox/typecheck" as tc

fn test_locals_lookup_ignores_hidden_entries_after_non_prune_exit_smoke() -> () {
  let mut l: tc.Locals = tc.locals_new();
  l = tc.locals_decl(l, "x", 10, false);
  l = tc.locals_enter(l);
  l = tc.locals_decl(l, "x", 20, false);
  l = tc.locals_exit(l);

  let vr: tc.LookupVarResult = tc.locals_lookup(l, "x");
  t.assert(vr.found);
  t.assert_eq(vr.ty, 10);
}

fn test_locals_lookup_const_ignores_hidden_entries_after_non_prune_exit_smoke() -> () {
  let mut l: tc.Locals = tc.locals_new();
  l = tc.locals_decl_const(l, "k", 11);
  l = tc.locals_enter(l);
  l = tc.locals_decl_const(l, "k", 22);
  l = tc.locals_exit(l);

  let cr: tc.LookupConstResult = tc.locals_lookup_const(l, "k");
  t.assert(cr.found);
  t.assert_eq(cr.ty, 11);
}

fn test_locals_set_moved_targets_visible_binding_after_non_prune_exit_smoke() -> () {
  let mut l: tc.Locals = tc.locals_new();
  l = tc.locals_decl(l, "x", 10, true);
  l = tc.locals_enter(l);
  l = tc.locals_decl(l, "x", 20, true);
  l = tc.locals_exit(l);
  l = tc.locals_mark_moved(l, "x");

  let vr: tc.LookupVarResult = tc.locals_lookup(l, "x");
  t.assert(vr.found);
  t.assert_eq(vr.ty, 10);
  t.assert(vr.moved);
}
