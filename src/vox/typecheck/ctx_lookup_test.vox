import "std/testing" as t
import "vox/typecheck" as tc

fn ctx_lookup_test_empty_func_sig(c: tc.Ctx) -> tc.FuncSig {
  return tc.FuncSig {
    params: Vec(),
    param_borrow_kinds: Vec(),
    ret: c.ty_i32,
    has_variadic: false,
    is_ffi_variadic: false,
    variadic_elem: c.ty_bad,
    vis: 0,
    is_pub: false,
    type_params: Vec(),
    type_param_packs: Vec(),
    const_params: Vec(),
    type_param_bounds: Vec(),
    effects: Vec(),
    resource_reads: Vec(),
    resource_writes: Vec(),
    const_where_bounds: Vec(),
  };
}

fn ctx_lookup_test_async_sig(c: tc.Ctx, mod_path: String, name: String) -> tc.AsyncFnSig {
  return tc.AsyncFnSig {
    mod_path: mod_path,
    name: name,
    output_ty: c.ty_unit,
    frame_name: name.concat("__frame"),
    frame_ty: c.ty_bad,
    poll_lowered: name.concat("__poll"),
  };
}

fn ctx_lookup_test_const_sig(c: tc.Ctx, mod_path: String, name: String) -> tc.ConstSig {
  return tc.ConstSig {
    mod_path: mod_path,
    name: name,
    vis: 0,
    is_pub: true,
    ty: c.ty_i32,
    kind: tc.const_kind_int(),
    iv: 7,
    bv: false,
    sv: "",
  };
}

fn ctx_lookup_test_static_sig(c: tc.Ctx, mod_path: String, name: String) -> tc.StaticSig {
  return tc.StaticSig {
    mod_path: mod_path,
    name: name,
    vis: 0,
    is_pub: true,
    ty: c.ty_i32,
    init_kind: tc.const_kind_int(),
    init_iv: 9,
    init_bv: false,
    init_sv: "",
  };
}

fn ctx_lookup_test_impl_sig(
  mod_path: String,
  is_inherent: bool,
  is_negative: bool,
  trait_mod_path: String,
  trait_name: String,
  for_ty: i32,
) -> tc.ImplSig {
  return tc.ImplSig {
    mod_path: mod_path,
    decl_idx: -1,
    is_inherent: is_inherent,
    is_negative: is_negative,
    trait_mod_path: trait_mod_path,
    trait_name: trait_name,
    for_ty: for_ty,
    head_type_params: Vec(),
    head_type_param_bounds: Vec(),
    head_const_where_bounds: Vec(),
    assoc_types: Vec(),
    methods: Vec(),
  };
}

fn test_ctx_lookup_index_keeps_first_duplicate_func_entry() -> () {
  let mut c: tc.Ctx = tc.new_ctx();
  let sig: tc.FuncSig = ctx_lookup_test_empty_func_sig(c);
  c.funcs.push(tc.FuncSym { mod_path: "main", name: "dup", sig: sig, deprecated_message: "" });
  c.funcs.push(tc.FuncSym { mod_path: "main", name: "dup", sig: sig, deprecated_message: "" });
  c = tc.ctx_rebuild_sym_lookup_indexes(c);

  t.assert_eq(c.func_lookup_index.len(), 1);
  let e: tc.SymLookupIndexEntry = c.func_lookup_index.get(0);
  t.assert_eq(e.mod_path, "");
  t.assert_eq(e.name, "dup");
  t.assert_eq(e.idx, 0);
}

fn test_ctx_lookup_index_sorts_by_mod_then_name() -> () {
  let mut c: tc.Ctx = tc.new_ctx();
  let sig: tc.FuncSig = ctx_lookup_test_empty_func_sig(c);
  c.funcs.push(tc.FuncSym { mod_path: "zmod", name: "b", sig: sig, deprecated_message: "" });
  c.funcs.push(tc.FuncSym { mod_path: "main", name: "z", sig: sig, deprecated_message: "" });
  c.funcs.push(tc.FuncSym { mod_path: "amod", name: "a", sig: sig, deprecated_message: "" });
  c.funcs.push(tc.FuncSym { mod_path: "amod", name: "b", sig: sig, deprecated_message: "" });
  c = tc.ctx_rebuild_sym_lookup_indexes(c);

  t.assert_eq(c.func_lookup_index.len(), 4);
  let e0: tc.SymLookupIndexEntry = c.func_lookup_index.get(0);
  let e1: tc.SymLookupIndexEntry = c.func_lookup_index.get(1);
  let e2: tc.SymLookupIndexEntry = c.func_lookup_index.get(2);
  let e3: tc.SymLookupIndexEntry = c.func_lookup_index.get(3);
  t.assert_eq(e0.mod_path, "");
  t.assert_eq(e0.name, "z");
  t.assert_eq(e0.idx, 1);
  t.assert_eq(e1.mod_path, "amod");
  t.assert_eq(e1.name, "a");
  t.assert_eq(e1.idx, 2);
  t.assert_eq(e2.mod_path, "amod");
  t.assert_eq(e2.name, "b");
  t.assert_eq(e2.idx, 3);
  t.assert_eq(e3.mod_path, "zmod");
  t.assert_eq(e3.name, "b");
  t.assert_eq(e3.idx, 0);
}

fn test_ctx_lookup_index_keeps_first_duplicate_async_fn_entry() -> () {
  let mut c: tc.Ctx = tc.new_ctx();
  c.async_fns.push(ctx_lookup_test_async_sig(c, "main", "dup_async"));
  c.async_fns.push(ctx_lookup_test_async_sig(c, "main", "dup_async"));
  c = tc.ctx_rebuild_sym_lookup_indexes(c);

  t.assert_eq(c.async_fn_lookup_index.len(), 1);
  let e: tc.SymLookupIndexEntry = c.async_fn_lookup_index.get(0);
  t.assert_eq(e.mod_path, "");
  t.assert_eq(e.name, "dup_async");
  t.assert_eq(e.idx, 0);
}

fn test_find_async_fn_lookup_index_root_mod_equivalence() -> () {
  let mut c: tc.Ctx = tc.new_ctx();
  c.async_fns.push(ctx_lookup_test_async_sig(c, "main", "entry_async"));
  c = tc.ctx_rebuild_sym_lookup_indexes(c);

  let r_main: tc.FindAsyncFnResult = tc.find_async_fn(c, "main", "entry_async");
  let r_root: tc.FindAsyncFnResult = tc.find_async_fn(c, "", "entry_async");
  t.assert(r_main.found);
  t.assert(r_root.found);
  t.assert_eq(r_main.sig.name, "entry_async");
  t.assert_eq(r_root.sig.name, "entry_async");
}

