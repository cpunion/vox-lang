fn test_ctx_impl_trait_lookup_index_sorts_and_keeps_duplicate_trait_entries() -> () {
  let mut c: tc.Ctx = tc.new_ctx();
  c.impls.push(ctx_lookup_test_impl_sig("main", true, false, "", "", c.ty_i32));
  c.impls.push(ctx_lookup_test_impl_sig("main", false, false, "zmod", "T", c.ty_i32));
  c.impls.push(ctx_lookup_test_impl_sig("main", false, false, "amod", "A", c.ty_i64));
  c.impls.push(ctx_lookup_test_impl_sig("main", false, true, "amod", "A", c.ty_u32));
  c = tc.ctx_rebuild_sym_lookup_indexes(c);

  t.assert_eq(c.impl_trait_lookup_index.len(), 3);
  let e0: tc.SymLookupIndexEntry = c.impl_trait_lookup_index.get(0);
  let e1: tc.SymLookupIndexEntry = c.impl_trait_lookup_index.get(1);
  let e2: tc.SymLookupIndexEntry = c.impl_trait_lookup_index.get(2);

  t.assert_eq(e0.mod_path, "amod");
  t.assert_eq(e0.name, "A");
  t.assert_eq(e0.idx, 2);
  t.assert_eq(e1.mod_path, "amod");
  t.assert_eq(e1.name, "A");
  t.assert_eq(e1.idx, 3);
  t.assert_eq(e2.mod_path, "zmod");
  t.assert_eq(e2.name, "T");
  t.assert_eq(e2.idx, 1);
}
