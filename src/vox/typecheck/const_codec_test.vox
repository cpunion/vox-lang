import "std/testing" as t
import "vox/typecheck" as tc

fn test_const_enum_unpack_rejects_large_count() -> () {
  let dec: tc.ConstEnumPayloadDecode = tc.const_enum_unpack("Variant#2147483648");
  t.assert(!dec.ok);
}

fn test_const_enum_unpack_rejects_large_kind_or_ty() -> () {
  let dk: tc.ConstEnumPayloadDecode = tc.const_enum_unpack("Variant#1#2147483648|1|0|0|");
  t.assert(!dk.ok);
  let dt: tc.ConstEnumPayloadDecode = tc.const_enum_unpack("Variant#1#1|2147483648|0|0|");
  t.assert(!dt.ok);
}

fn test_const_struct_unpack_rejects_large_count() -> () {
  let dec: tc.ConstStructDecode = tc.const_struct_unpack("2147483648");
  t.assert(!dec.ok);
}

fn test_const_struct_unpack_rejects_large_kind_or_ty() -> () {
  let dk: tc.ConstStructDecode = tc.const_struct_unpack("1#2147483648|1|0|0|");
  t.assert(!dk.ok);
  let dt: tc.ConstStructDecode = tc.const_struct_unpack("1#1|2147483648|0|0|");
  t.assert(!dt.ok);
}
