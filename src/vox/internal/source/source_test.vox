import "std/string" as s
import "std/testing" as t
import "vox/internal/source" as srcw

fn test_walk_vox_files_smoke() -> () {
  let xs: Vec[String] = srcw.walk_vox_files(".");
  t.assert_with(xs.len() > 0, "expected non-empty source set");
  let mut found: bool = false;
  let mut found_syntax_adt: bool = false;
  let mut found_bad_short: bool = false;
  let mut found_bad_non_vox: bool = false;
  let mut found_bad_non_src_tests: bool = false;
  let mut i: i32 = 0;
  while i < xs.len() {
    let p: String = xs.get(i);
    if s.ends_with(s.view_all(p), "src/main.vox") {
      found = true;
    }
    if s.ends_with(s.view_all(p), "tests/syntax/src/adt_test.vox") { found_syntax_adt = true; }
    // Guard only the exact shortened path, not valid nested suffixes like
    // tests/syntax/src/adt_test.vox.
    if p == "src/adt_test.vox" { found_bad_short = true; }
    if !s.ends_with(s.view_all(p), ".vox") { found_bad_non_vox = true; }
    let is_src: bool = s.starts_with(s.view_all(p), "src/");
    let is_tests: bool = s.starts_with(s.view_all(p), "tests/");
    if !is_src && !is_tests { found_bad_non_src_tests = true; }
    i = i + 1;
  }
  t.assert_with(found, "expected src/main.vox in source set");
  t.assert_with(found_syntax_adt, "expected tests/syntax/src/adt_test.vox in source set");
  t.assert_with(!found_bad_short, "unexpected shortened tests path src/adt_test.vox");
  t.assert_with(!found_bad_non_vox, "unexpected non-.vox path in source set");
  t.assert_with(!found_bad_non_src_tests, "unexpected non src/tests path in source set");
}

fn test_walk_src_vox_files_excludes_tests_smoke() -> () {
  let xs: Vec[String] = srcw.walk_src_vox_files(".");
  t.assert_with(xs.len() > 0, "expected non-empty src source set");
  let mut found_main: bool = false;
  let mut found_test_path: bool = false;
  let mut i: i32 = 0;
  while i < xs.len() {
    let p: String = xs.get(i);
    if s.ends_with(s.view_all(p), "src/main.vox") {
      found_main = true;
    }
    if s.starts_with(s.view_all(p), "tests/") {
      found_test_path = true;
    }
    i = i + 1;
  }
  t.assert_with(found_main, "expected src/main.vox in src source set");
  t.assert_with(!found_test_path, "unexpected tests/** entry in src-only source set");
}

fn test_walk_src_non_test_vox_files_excludes_src_test_files_smoke() -> () {
  let xs: Vec[String] = srcw.walk_src_non_test_vox_files(".");
  t.assert_with(xs.len() > 0, "expected non-empty src source set");
  let mut found_main: bool = false;
  let mut found_src_test_file: bool = false;
  let mut i: i32 = 0;
  while i < xs.len() {
    let p: String = xs.get(i);
    if s.ends_with(s.view_all(p), "src/main.vox") {
      found_main = true;
    }
    if s.ends_with(s.view_all(p), "_test.vox") {
      found_src_test_file = true;
    }
    i = i + 1;
  }
  t.assert_with(found_main, "expected src/main.vox in src non-test source set");
  t.assert_with(!found_src_test_file, "unexpected src/*_test.vox entry in src non-test source set");
}

fn test_walk_c_files_src_only_smoke() -> () {
  let xs: Vec[String] = srcw.walk_c_files(".");
  t.assert_with(xs.len() > 0, "expected non-empty src c source set");
  let mut found_preamble: bool = false;
  let mut found_bad_non_c: bool = false;
  let mut found_bad_non_src: bool = false;
  let mut i: i32 = 0;
  while i < xs.len() {
    let p: String = xs.get(i);
    if s.ends_with(s.view_all(p), "_preamble.c") { found_preamble = true; }
    if !s.ends_with(s.view_all(p), ".c") { found_bad_non_c = true; }
    if !s.starts_with(s.view_all(p), "src/") { found_bad_non_src = true; }
    i = i + 1;
  }
  t.assert_with(found_preamble, "expected src bootstrap preamble c source");
  t.assert_with(!found_bad_non_c, "unexpected non-.c path in c source set");
  t.assert_with(!found_bad_non_src, "unexpected non-src path in c source set");
}
