fn test_build_cache_pkg_sem_source_keys_only_keep_order_preserves_order_smoke() -> () {
  let ordered: SourceFilePkgOrderResult = source_file_order_by_pkg_path_with_files(build_cache_test_files_main_and_dep());
  let kept: BuildCachePkgSemOnlySourceKeysKeepOrderResult =
    build_cache_pkg_sem_source_keys_only_keep_order_with_files(ordered.files, ordered.pkgs, ordered.order);
  let ordered_again: SourceFilePkgOrderResult = source_file_order_by_pkg_path_with_files(build_cache_test_files_main_and_dep());
  t.assert_eq(kept.pkgs.len(), ordered_again.pkgs.len());
  t.assert_eq(kept.order.len(), ordered_again.order.len());
  let mut i: i32 = 0;
  while i < kept.pkgs.len() {
    t.assert_eq(kept.pkgs.get(i), ordered_again.pkgs.get(i));
    i = i + 1;
  }
  i = 0;
  while i < kept.order.len() {
    t.assert_eq(kept.order.get(i), ordered_again.order.get(i));
    i = i + 1;
  }
}

