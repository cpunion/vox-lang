}

fn test_test_build_cache_try_reuse_sem_cached_c_with_source_sig_hit_smoke() -> () {
  let sem_key: String = build_cache_test_unused_key("sem-reuse-test-hit-sem");
  let cached_key: String = build_cache_test_unused_key_for_test_cache("sem-reuse-test-hit-cached");
  let out_key: String = build_cache_test_unused_key_for_test_cache("sem-reuse-test-hit-out");
  t.assert(cached_key != out_key);
  let cached_cpath: String = path_join(path_join(path_join("target", "cache"), "test-pkg-obj-v1"), cached_key).concat(".c");
  fs.mkdir_p(dir_name(cached_cpath));
  fs.write_string(cached_cpath, "/*test sem cached c hit*/");
  let cached_out: String = path_join(path_join(path_join("target", "cache"), "test-link-v1"), cached_key);
  let mut compiled: Vec[String] = Vec();
  compiled.push("root.test_a");
  compiled.push("root.test_b");
  compiled = write_test_build_cache_with_tests(cached_out, cached_key, compiled);
  t.assert_eq(compiled.len(), 2);
  write_build_sem_cache_c_ref(sem_key, cached_key, "source-sig-test-hit");
  let out_cpath: String = path_join(path_join(path_join("target", "cache"), "test-pkg-obj-v1"), out_key).concat(".c");
  let mut selected: Vec[String] = Vec();
  selected.push("root.test_a");
  t.assert(
    test_build_cache_try_reuse_sem_cached_c_with_source_sig(
      sem_key,
      out_key,
      "source-sig-test-hit",
      out_cpath,
      ".o",
      selected,
      false,
    ),
  );
  t.assert(fs.exists(out_cpath));
  t.assert_eq(fs.read_to_string(out_cpath), "/*test sem cached c hit*/");
}

fn test_test_build_cache_try_reuse_sem_cached_c_with_source_sig_selected_miss_smoke() -> () {
  let sem_key: String = build_cache_test_unused_key("sem-reuse-test-miss-sem");
  let cached_key: String = build_cache_test_unused_key_for_test_cache("sem-reuse-test-miss-cached");
  let out_key: String = build_cache_test_unused_key_for_test_cache("sem-reuse-test-miss-out");
