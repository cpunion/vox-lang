fn test_build_cache_key_triple_keep_preserves_keys_and_derivation_smoke() -> () {
  let compile_mode: String = "cmd=build\ntarget=linux-amd64";
  let link_mode: String = "cmd=build\ntarget=linux-amd64\nartifact=static";
  let sem_mode: String = "sem\ncmd=build\ntarget=linux-amd64";
  let kept: BuildCacheTestKeyTripleKeep =
    build_cache_test_key_triple_from_pkg_source_keys_keep(
      build_cache_pkg_source_keys_with_files(build_cache_test_files_main_and_dep()).keys,
      compile_mode,
      link_mode,
      sem_mode,
    );
  t.assert_eq(kept.keys.len(), 2);
  t.assert_eq(kept.keys.get(0).pkg, "main");
  t.assert_eq(kept.keys.get(1).pkg, "pkg/dep");
  let compile_direct: String = build_cache_test_key_from_pkg_source_keys(build_cache_pkg_source_keys_with_files(build_cache_test_files_main_and_dep()).keys, compile_mode);
  let link_direct: String = build_cache_test_key_from_pkg_source_keys(build_cache_pkg_source_keys_with_files(build_cache_test_files_main_and_dep()).keys, link_mode);
  let sem_direct: String = build_cache_test_key_from_pkg_source_keys(build_cache_pkg_source_keys_with_files(build_cache_test_files_main_and_dep()).keys, sem_mode);
  t.assert_eq(kept.triple.compile_key, compile_direct);
  t.assert_eq(kept.triple.link_key, link_direct);
  t.assert_eq(kept.triple.sem_key, sem_direct);
}

fn test_build_cache_sem_key_dep_hashes_keep_matches_direct_smoke() -> () {
  let sem_mode: String = "sem\ncmd=build\ntarget=linux-amd64";
  let split: BuildCachePkgSemSourceKeysResult = build_cache_pkg_sem_source_keys_with_files(build_cache_test_files_main_and_dep());
  let kept: BuildCacheSemKeyDepsKeep = build_cache_sem_key_dep_hashes_from_pkg_source_keys_keep(split.sem_keys, sem_mode);
  let sem_direct: String = build_cache_test_sem_key_from_files(build_cache_test_files_main_and_dep(), "sem\ncmd=build\ntarget=linux-amd64");
  t.assert_eq(kept.sem_key, sem_direct);
  t.assert_eq(kept.dep_hashes.len(), kept.keys.len());
  let h0: u64 = build_cache_pkg_hash_for_mode_prefix("sem\ncmd=build\ntarget=linux-amd64");
  let mut i: i32 = 0;
  while i < kept.keys.len() {
    let pk: BuildCachePkgKey = build_cache_pkg_key_from_source_hash_prefix(kept.keys.get(i), h0);
    let d: q.ParseLoadDepHash = kept.dep_hashes.get(i);
    t.assert_eq(d.pkg, pk.pkg);
    t.assert_eq(d.export_sig_hash, pk.key);
    t.assert_eq(d.type_sig_hash, pk.key);
    t.assert_eq(d.impl_sig_hash, pk.key);
    i = i + 1;
  }
}

