  t.assert(source_sig0 != source_sig1);
}

fn test_build_cache_key_pair_from_sem_keys_tracks_c_source_changes_via_mode_smoke() -> () {
  let split0: BuildCachePkgSemSourceKeysResult =
    build_cache_pkg_sem_source_keys_with_files(
      build_cache_test_files_with_mixed_sources("fn main() -> i32 { return 1; }", "int helper() { return 1; }"),
    );
  let split1: BuildCachePkgSemSourceKeysResult =
    build_cache_pkg_sem_source_keys_with_files(
      build_cache_test_files_with_mixed_sources("fn main() -> i32 { return 1; }", "int helper() { return 2; }"),
    );
  t.assert_eq(pkg_key_for_pkg(split0.sem_keys, "main"), pkg_key_for_pkg(split1.sem_keys, "main"));
  let mut c0: Vec[String] = Vec();
  c0.push("int helper() { return 1; }");
  let mut c1: Vec[String] = Vec();
  c1.push("int helper() { return 2; }");
  let c_sig0: String = build_cache_c_sources_sig_from_texts(c0);
  let c_sig1: String = build_cache_c_sources_sig_from_texts(c1);
  let compile_mode0: String = "cmd=build\ntarget=linux-amd64\nc_sources_sig=".concat(c_sig0);
  let compile_mode1: String = "cmd=build\ntarget=linux-amd64\nc_sources_sig=".concat(c_sig1);
  let link_mode0: String = "cmd=build-link\ntarget=linux-amd64\nc_sources_sig=".concat(c_sig0);
  let link_mode1: String = "cmd=build-link\ntarget=linux-amd64\nc_sources_sig=".concat(c_sig1);
  let kept0: BuildCacheKeyPairSourceSigKeep =
    build_cache_key_pair_source_sig_from_pkg_source_keys_keep(split0.sem_keys, compile_mode0, link_mode0);
  let kept1: BuildCacheKeyPairSourceSigKeep =
    build_cache_key_pair_source_sig_from_pkg_source_keys_keep(split1.sem_keys, compile_mode1, link_mode1);
  t.assert(kept0.pair.compile_key != kept1.pair.compile_key);
  t.assert(kept0.pair.link_key != kept1.pair.link_key);
}

