fn test_build_sem_cache_hit_backfills_missing_meta_from_deps_smoke() -> () {
  let seed_key: String = build_cache_test_unused_key("key-sem-hit-backfill-meta-seed");
  let key: String = build_cache_test_unused_key("key-sem-hit-backfill-meta");
  write_build_sem_cache_with_deps(seed_key, build_cache_test_sem_deps_main_dep());
  let seed_deps_path: String = path_join(path_join(path_join("target", "cache"), "pkg-sem-v1"), seed_key).concat(".build.cache.deps");
  let deps_path: String = path_join(path_join(path_join("target", "cache"), "pkg-sem-v1"), key).concat(".build.cache.deps");
  fs.mkdir_p(dir_name(deps_path));
  fs.write_string(deps_path, fs.read_to_string(seed_deps_path));
  let meta: String = path_join(path_join(path_join("target", "cache"), "pkg-sem-v1"), key).concat(".build.cache.key");
  t.assert(!fs.exists(meta));
  t.assert(build_sem_cache_hit(key));
  t.assert(fs.exists(meta));
  t.assert_eq(fs.read_to_string(meta), key.concat("\n"));
}

