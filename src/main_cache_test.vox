fn test_build_cache_hit_roundtrip_smoke() -> () {
  let key: String = "key-1";
  let cpath: String = build_cache_obj_path_for_key(key, ".c");
  let bin: String = build_cache_bin_for_key(key, "linux");
  let obj: String = build_cache_obj_path_for_key(key, ".o");
  fs.mkdir_p("target/debug");
  fs.mkdir_p(dir_name(cpath));
  fs.mkdir_p(dir_name(bin));
  fs.mkdir_p(dir_name(obj));
  fs.write_string(cpath, "/*c*/");
  fs.write_string(bin, "bin");
  fs.write_string(obj, "obj");
  let obj_meta: String = path_join(path_join(path_join("target", "cache"), "pkg-obj-v1"), key).concat(".build.cache.key");
  fs.mkdir_p(dir_name(obj_meta));
  let _: bool = write_string_if_changed(obj_meta, key.concat("\n"));
  let sem_meta: String = path_join(path_join(path_join("target", "cache"), "pkg-sem-v1"), key).concat(".build.cache.key");
  fs.mkdir_p(dir_name(sem_meta));
  let _: bool = write_string_if_changed(sem_meta, key.concat("\n"));
  let link_meta: String = path_join(path_join(path_join("target", "cache"), "link-v1"), key).concat(".build.cache.key");
  fs.mkdir_p(dir_name(link_meta));
  let _: bool = write_string_if_changed(link_meta, key.concat("\n"));
  t.assert(build_link_cache_hit(key, bin));
  t.assert(build_cache_c_hit(key, cpath));
  t.assert(build_cache_test_obj_hit(key, cpath, obj));
  t.assert(build_sem_cache_hit(key));
  t.assert(!build_link_cache_hit("key-2", bin));
  t.assert(!build_cache_c_hit("key-2", cpath));
  t.assert(!build_cache_test_obj_hit("key-2", cpath, obj));
  t.assert(!build_sem_cache_hit("key-2"));
}

fn test_build_sem_cache_read_with_deps_roundtrip_smoke() -> () {
  let key: String = build_cache_test_unused_key("sem-read-roundtrip");
  let deps_write: Vec[q.ParseLoadDepHash] = build_cache_test_sem_deps_main_dep();
  write_build_sem_cache_with_deps(key, deps_write);
  let read: BuildSemCacheReadResult = build_sem_cache_read_with_deps(key);
  let deps_expected: Vec[q.ParseLoadDepHash] = build_cache_test_sem_deps_main_dep();
  t.assert(read.hit);
  t.assert(build_cache_sem_dep_hashes_equal(read.deps, deps_expected));
}

fn test_build_sem_cache_hit_with_deps_keep_preserves_deps_smoke() -> () {
  let key: String = build_cache_test_unused_key("sem-hit-keep");
  write_build_sem_cache_with_deps(key, build_cache_test_sem_deps_main_dep());
  let keep_hit: BuildSemCacheHitDepsKeep = build_sem_cache_hit_with_deps_keep(key, build_cache_test_sem_deps_main_dep());
  t.assert(keep_hit.hit);
  t.assert(build_cache_sem_dep_hashes_equal(keep_hit.deps, build_cache_test_sem_deps_main_dep()));

  let mut miss_deps: Vec[q.ParseLoadDepHash] = build_cache_test_sem_deps_main_dep();
  miss_deps.set(0, q.ParseLoadDepHash { pkg: "main", export_sig_hash: "999", type_sig_hash: "999", impl_sig_hash: "999" });
  let keep_miss: BuildSemCacheHitDepsKeep = build_sem_cache_hit_with_deps_keep(key, miss_deps);
  t.assert(!keep_miss.hit);
}

fn test_build_sem_cache_read_with_deps_requires_deps_file_smoke() -> () {
