fn test_build_cache_hit_roundtrip_smoke() -> () {
  let key: String = "key-1";
  let cpath: String = build_cache_cpath_for_key(key);
  let bin: String = build_cache_bin_for_key(key, "linux");
  let obj: String = build_cache_obj_path_for_key(key, ".o");
  fs.mkdir_p("target/debug");
  fs.mkdir_p(dir_name(cpath));
  fs.mkdir_p(dir_name(bin));
  fs.mkdir_p(dir_name(obj));
  fs.write_string(cpath, "/*c*/");
  fs.write_string(bin, "bin");
  fs.write_string(obj, "obj");
  write_build_obj_cache(key);
  write_build_sem_cache(key);
  write_build_cache(key);
  t.assert(build_link_cache_hit(key, bin));
  t.assert(build_cache_c_hit(key, cpath));
  t.assert(build_cache_test_obj_hit(key, cpath, obj));
  t.assert(build_sem_cache_hit(key));
  t.assert(!build_link_cache_hit("key-2", bin));
  t.assert(!build_cache_c_hit("key-2", cpath));
  t.assert(!build_cache_test_obj_hit("key-2", cpath, obj));
  t.assert(!build_sem_cache_hit("key-2"));
}

fn test_build_cache_c_hit_without_obj_smoke() -> () {
  let key: String = build_cache_test_unused_key("key-c-hit-no-obj");
  let cpath: String = build_cache_cpath_for_key(key);
  let obj: String = build_cache_obj_path_for_key(key, ".o");
  fs.mkdir_p(dir_name(cpath));
  fs.write_string(cpath, "/*c*/");
  write_build_obj_cache(key);
  t.assert(build_cache_c_hit(key, cpath));
  t.assert(!build_cache_test_obj_hit(key, cpath, obj));
}

fn test_build_link_cache_hit_does_not_require_cpath_smoke() -> () {
  let key: String = build_cache_test_unused_key("key-link-no-cpath");
  let cpath: String = build_cache_cpath_for_key(key);
  let bin: String = build_cache_bin_for_key(key, "linux");
  fs.mkdir_p("target/debug");
  fs.mkdir_p(dir_name(bin));
  t.assert(!fs.exists(cpath));
  fs.write_string(bin, "bin");
  write_build_cache(key);
  t.assert(build_link_cache_hit(key, bin));
}

fn test_build_cache_paths_use_split_link_and_obj_roots() -> () {
  let key: String = "k";
  t.assert(text_contains(build_cache_cpath_for_key(key), "pkg-obj-v1"));
  t.assert(text_contains(build_cache_obj_path_for_key(key, ".o"), "pkg-obj-v1"));
  t.assert(text_contains(build_cache_obj_meta_path_for_key(key), "pkg-obj-v1"));
  t.assert(text_contains(build_cache_sem_meta_path_for_key(key), "pkg-sem-v1"));
  t.assert(text_contains(build_cache_bin_for_key(key, "linux"), "link-v1"));
  t.assert(text_contains(path_join(path_join(path_join("target", "cache"), "link-v1"), key).concat(".build.cache.key"), "link-v1"));
}

fn test_build_cache_output_copy_key_roundtrip_smoke() -> () {
  let out_path: String = build_cache_test_unused_output_copy_path("key-copy-meta-roundtrip");
