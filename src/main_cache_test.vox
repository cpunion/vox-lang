  let mut compiled: Vec[String] = Vec();
  compiled.push("root.test_a");
  compiled = write_test_build_cache_with_tests(cached_out, cached_key, compiled);
  t.assert_eq(compiled.len(), 1);
  write_build_sem_cache_c_ref(sem_key, cached_key, "source-sig-test-miss");
  let out_cpath: String = path_join(path_join(path_join("target", "cache"), "test-pkg-obj-v1"), out_key).concat(".c");
  let mut selected: Vec[String] = Vec();
