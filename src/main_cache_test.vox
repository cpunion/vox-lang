  let split1: BuildCachePkgSemSourceKeysResult = build_cache_pkg_sem_source_keys_with_files(build_cache_test_files_main_and_dep());
  let combined: BuildCacheSemKeyDepsKeep = build_cache_sem_key_dep_hashes_from_pkg_source_keys_keep(split1.sem_keys, sem_mode);
  t.assert_eq(sem_key_keep.sem_key, combined.sem_key);
  t.assert(build_cache_sem_dep_hashes_equal(sem_dep_keep.dep_hashes, combined.dep_hashes));
}

fn test_build_cache_sem_key_dep_hashes_only_from_order_with_files_matches_split_smoke() -> () {
  let sem_mode: String = "sem\ncmd=build\ntarget=linux-amd64";
  let ordered: SourceFilePkgOrderResult = source_file_order_by_pkg_path_with_files(build_cache_test_files_main_and_dep());
  let kept: BuildCacheSemKeyDepHashesOnlyResult =
    build_cache_sem_key_dep_hashes_only_from_order_with_files(ordered.files, ordered.pkgs, ordered.order, sem_mode);
  let split: BuildCachePkgSemSourceKeysResult = build_cache_pkg_sem_source_keys_with_files(build_cache_test_files_main_and_dep());
  let direct: BuildCacheSemKeyDepsKeep = build_cache_sem_key_dep_hashes_from_pkg_source_keys_keep(split.sem_keys, sem_mode);
  t.assert_eq(kept.sem_key, direct.sem_key);
  t.assert(build_cache_sem_dep_hashes_equal(kept.dep_hashes, direct.dep_hashes));
  t.assert_eq(kept.sem_keys.len(), direct.keys.len());
  let mut i: i32 = 0;
  while i < kept.sem_keys.len() {
    let a: BuildCachePkgKey = kept.sem_keys.get(i);
    let b: BuildCachePkgKey = direct.keys.get(i);
    t.assert_eq(a.pkg, b.pkg);
    t.assert_eq(a.key, b.key);
    i = i + 1;
  }
}

