fn test_build_cache_pkg_sem_source_keys_split_matches_direct_derivation_smoke() -> () {
  let sem_mode: String = "sem\ncmd=build\ntarget=linux-amd64";
  let split: BuildCachePkgSemSourceKeysResult = build_cache_pkg_sem_source_keys_with_files(build_cache_test_files_with_mixed_sources("fn main() -> i32 { return 1; }", "int helper() { return 2; }"));
  let direct: BuildCachePkgSourceKeysResult = build_cache_pkg_source_keys_with_files(build_cache_test_files_with_mixed_sources("fn main() -> i32 { return 1; }", "int helper() { return 2; }"));
  t.assert_eq(split.keys.len(), direct.keys.len());
  t.assert_eq(pkg_key_for_pkg(split.keys, "main"), pkg_key_for_pkg(direct.keys, "main"));

  let sem_from_split: String = build_cache_sem_key_from_pkg_source_keys(split.sem_keys, sem_mode);
  let sem_direct: String = build_cache_test_sem_key_from_files(build_cache_test_files_with_mixed_sources("fn main() -> i32 { return 1; }", "int helper() { return 2; }"), sem_mode);
  t.assert_eq(sem_from_split, sem_direct);
}

