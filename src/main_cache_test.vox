fn test_test_list_output_cache_key_changes_with_options_smoke() -> () {
  let k0: String = test_list_output_cache_key("discover-k", cache_test_selected_tests_basic(), "", "", "", 8, false, false, 0, false);
  let k1: String = test_list_output_cache_key("discover-k", cache_test_selected_tests_basic(), "", "", "", 8, false, false, 0, true);
  let k2: String = test_list_output_cache_key("discover-k", cache_test_selected_tests_basic(), "*mod*", "", "", 8, false, false, 0, false);
  let k3: String = test_list_output_cache_key("discover-k", cache_test_selected_tests_basic(), "", "", "", 8, false, true, 3, false);
  t.assert(k0 != "");
  t.assert(k0 != k1);
  t.assert(k0 != k2);
  t.assert(k0 != k3);
}

fn test_test_list_output_cache_read_write_smoke() -> () {
  let mut key: String = "";
  let mut i: i32 = 0;
  while i < 1024 {
    let cand: String = "test-list-output-cache-smoke-".concat(i.to_string());
    if !fs.exists(test_list_output_cache_path(cand)) {
      key = cand;
      i = 1024;
    } else {
      i = i + 1;
    }
  }
  t.assert(key != "");
  let out_text: String = "{\"ok\":true}\n";
  write_test_list_output_cache(key, out_text);
  let read_hit: TestListOutputCacheReadResult = test_list_output_cache_read(key);
  t.assert(read_hit.hit);
  t.assert_eq(read_hit.text, out_text);
  let read_miss: TestListOutputCacheReadResult = test_list_output_cache_read(key.concat("-missing"));
  t.assert(!read_miss.hit);
  t.assert(text_contains(test_list_output_cache_path(key), "test-list-v1"));
}

fn test_hidden_source_path_smoke() -> () {
  t.assert(is_hidden_source_path(".tmp.c"));
  t.assert(is_hidden_source_path("src/.tmp.c"));
  t.assert(is_hidden_source_path("src/std/.cache/rt.c"));
  t.assert(!is_hidden_source_path("src/./main.c"));
  t.assert(!is_hidden_source_path("src/foo/../bar.c"));
  t.assert(!is_hidden_source_path("src/std/runtime/rt.c"));
}

