fn test_test_build_cache_contains_all_sorted_hay_with_need_smoke() -> () {
  let mut hay_hit: Vec[String] = Vec();
  hay_hit.push("root.test_a");
  hay_hit.push("root.test_b");
  hay_hit.push("root.test_c");
  let mut need_hit: Vec[String] = Vec();
  need_hit.push("root.test_b");
  need_hit.push("root.test_a");
  let mut need_hit_copy: Vec[String] = Vec();
  let mut hit_ci: i32 = 0;
  while hit_ci < need_hit.len() {
    need_hit_copy.push(need_hit.get(hit_ci));
    hit_ci = hit_ci + 1;
  }
  let need_hit_sorted: Vec[String] = sort_strings_if_needed(need_hit_copy);
  let mut hit_ok: bool = true;
  let mut hit_i: i32 = 0; // sorted-need idx
  let mut hit_j: i32 = 0; // hay idx
  while hit_i < need_hit_sorted.len() {
    let want: String = need_hit_sorted.get(hit_i);
    while hit_j < hay_hit.len() && hay_hit.get(hit_j) < want {
      hit_j = hit_j + 1;
    }
    if hit_j >= hay_hit.len() || hay_hit.get(hit_j) != want {
      hit_ok = false;
      hit_i = need_hit_sorted.len();
      hit_j = hay_hit.len();
    } else {
      hit_i = hit_i + 1;
      hit_j = hit_j + 1;
    }
  }
  t.assert(hit_ok);

  let mut hay_miss: Vec[String] = Vec();
  hay_miss.push("root.test_a");
  hay_miss.push("root.test_b");
  hay_miss.push("root.test_c");
  let mut need_miss: Vec[String] = Vec();
  need_miss.push("root.test_d");
  let mut need_miss_copy: Vec[String] = Vec();
  let mut miss_ci: i32 = 0;
  while miss_ci < need_miss.len() {
    need_miss_copy.push(need_miss.get(miss_ci));
    miss_ci = miss_ci + 1;
  }
  let need_miss_sorted: Vec[String] = sort_strings_if_needed(need_miss_copy);
  let mut miss_ok: bool = true;
  let mut miss_i: i32 = 0; // sorted-need idx
  let mut miss_j: i32 = 0; // hay idx
  while miss_i < need_miss_sorted.len() {
    let want: String = need_miss_sorted.get(miss_i);
    while miss_j < hay_miss.len() && hay_miss.get(miss_j) < want {
      miss_j = miss_j + 1;
    }
    if miss_j >= hay_miss.len() || hay_miss.get(miss_j) != want {
      miss_ok = false;
      miss_i = need_miss_sorted.len();
      miss_j = hay_miss.len();
    } else {
      miss_i = miss_i + 1;
      miss_j = miss_j + 1;
    }
  }
  t.assert(!miss_ok);
}

fn test_test_mode_sem_key_matches_single_derivation_smoke() -> () {
  let mode: String = "cmd=test\ntarget=linux-amd64";
  let sem_mode: String = "sem\n".concat(mode);
  let kept: BuildCacheTestKeyTripleKeep =
    build_cache_test_key_triple_from_pkg_source_keys_keep(
      build_cache_pkg_source_keys_with_files(build_cache_test_files_main_and_dep()).keys,
      mode,
      mode,
      sem_mode,
    );
  let sem_direct: String = build_cache_test_key_from_pkg_source_keys(build_cache_pkg_source_keys_with_files(build_cache_test_files_main_and_dep()).keys, sem_mode);
  t.assert_eq(kept.triple.sem_key, sem_direct);
}

fn test_test_build_sem_keys_keep_matches_direct_derivation_smoke() -> () {
  let mode: String = "cmd=test\ntarget=linux-amd64";
  let sem_mode: String = "sem\n".concat(mode);
  let test_kept: TestBuildKeyKeep = test_build_key_from_pkg_source_keys_keep(build_cache_pkg_source_keys_with_files(build_cache_test_files_main_and_dep()).keys, mode);
  let sem_kept: BuildCacheTestKeyTripleKeep =
    build_cache_test_key_triple_from_pkg_source_keys_keep(
      build_cache_pkg_source_keys_with_files(build_cache_test_files_main_and_dep()).keys,
      mode,
      mode,
      sem_mode,
    );
  let test_direct: String = cache_test_build_test_key_from_pkg_source_keys(build_cache_pkg_source_keys_with_files(build_cache_test_files_main_and_dep()).keys, mode);
  let sem_direct: String = build_cache_test_key_from_pkg_source_keys(build_cache_pkg_source_keys_with_files(build_cache_test_files_main_and_dep()).keys, sem_mode);
  t.assert_eq(test_kept.test_key, test_direct);
  t.assert_eq(sem_kept.triple.sem_key, sem_direct);
  t.assert_eq(test_kept.keys.len(), 2);
  t.assert_eq(sem_kept.keys.len(), 2);
}

fn test_test_build_key_keep_matches_direct_derivation_smoke() -> () {
  let mode: String = "cmd=test\ntarget=linux-amd64";
