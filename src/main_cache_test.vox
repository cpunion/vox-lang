fn test_test_build_cache_contains_all_sorted_hay_with_need_smoke() -> () {
  let mut hay_hit: Vec[String] = Vec();
  hay_hit.push("root.test_a");
  hay_hit.push("root.test_b");
  hay_hit.push("root.test_c");
  let mut need_hit: Vec[String] = Vec();
  need_hit.push("root.test_b");
  need_hit.push("root.test_a");
  let hit: ContainsAllResult = test_build_cache_contains_all_sorted_hay_with_need(hay_hit, need_hit);
  t.assert(hit.ok);
  t.assert_eq(hit.need.len(), 2);
  t.assert_eq(hit.need.get(0), "root.test_b");
  t.assert_eq(hit.need.get(1), "root.test_a");

  let mut hay_miss: Vec[String] = Vec();
  hay_miss.push("root.test_a");
  hay_miss.push("root.test_b");
  hay_miss.push("root.test_c");
  let mut need_miss: Vec[String] = Vec();
  need_miss.push("root.test_d");
  let miss: ContainsAllResult = test_build_cache_contains_all_sorted_hay_with_need(hay_miss, need_miss);
  t.assert(!miss.ok);
  t.assert_eq(miss.need.len(), 1);
  t.assert_eq(miss.need.get(0), "root.test_d");
}

