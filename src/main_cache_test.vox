fn test_build_cache_pkg_sem_source_keys_split_matches_direct_derivation_smoke() -> () {
  let sem_mode: String = "sem\ncmd=build\ntarget=linux-amd64";
  let split: BuildCachePkgSemSourceKeysResult = build_cache_pkg_sem_source_keys_with_files(build_cache_test_files_with_mixed_sources("fn main() -> i32 { return 1; }", "int helper() { return 2; }"));
  let direct: BuildCachePkgSourceKeysResult = build_cache_pkg_source_keys_with_files(build_cache_test_files_with_mixed_sources("fn main() -> i32 { return 1; }", "int helper() { return 2; }"));
  t.assert_eq(split.keys.len(), direct.keys.len());
  t.assert_eq(pkg_key_for_pkg(split.keys, "main"), pkg_key_for_pkg(direct.keys, "main"));

  let sem_from_split: String = build_cache_sem_key_from_pkg_source_keys(split.sem_keys, sem_mode);
  let sem_direct: String = build_cache_test_sem_key_from_files(build_cache_test_files_with_mixed_sources("fn main() -> i32 { return 1; }", "int helper() { return 2; }"), sem_mode);
  t.assert_eq(sem_from_split, sem_direct);
}

fn test_test_build_cache_hit_subset_smoke() -> () {
  let key: String = "test-key-1";
  let out: String = test_build_cache_out_for_key(key);
  let cpath: String = test_build_cache_cpath_for_key(key);
  let bin: String = out;
  fs.mkdir_p(dir_name(cpath));
  fs.mkdir_p(dir_name(bin));
  fs.write_string(cpath, "/*c*/");
  fs.write_string(bin, "bin");
  let mut compiled: Vec[String] = Vec();
  compiled.push("root.test_a");
  compiled.push("root.test_b");
  compiled = write_test_build_cache_with_tests(out, key, compiled);

  let mut need_a: Vec[String] = Vec();
  need_a.push("root.test_a");
  t.assert(test_build_cache_state_with_tests(out, key, cpath, bin, need_a).hit);

  let mut need_c: Vec[String] = Vec();
  need_c.push("root.test_c");
  t.assert(!test_build_cache_state_with_tests(out, key, cpath, bin, need_c).hit);
}

fn test_test_build_cache_state_c_hit_without_bin_smoke() -> () {
  let mut key: String = "test-key-c-hit-no-bin";
  let mut i: i32 = 0;
  while i < 2048 {
    let cand: String = "test-key-c-hit-no-bin-".concat(i.to_string());
    if !fs.exists(test_build_cache_cpath_for_key(cand)) && !fs.exists(test_build_cache_out_for_key(cand)) {
      key = cand;
      i = 2048;
    } else {
      i = i + 1;
    }
  }
  let out: String = test_build_cache_out_for_key(key);
  let cpath: String = test_build_cache_cpath_for_key(key);
  let bin: String = out;
  fs.mkdir_p(dir_name(cpath));
  fs.write_string(cpath, "/*c*/");
  let mut compiled: Vec[String] = Vec();
  compiled.push("root.test_a");
  compiled = write_test_build_cache_with_tests(out, key, compiled);
  t.assert(!fs.exists(bin));

  let mut need_a: Vec[String] = Vec();
  need_a.push("root.test_a");
  let st: TestBuildCacheStateResult = test_build_cache_state_with_tests(out, key, cpath, bin, need_a);
  t.assert(st.c_hit);
  t.assert(!st.hit);
  t.assert_eq(st.selected.len(), 1);
}

fn test_test_build_cache_paths_use_split_link_and_obj_roots() -> () {
  let key: String = "k";
