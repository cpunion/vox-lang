fn test_test_build_cache_hit_subset_smoke() -> () {
  let key: String = "test-key-1";
  let out: String = path_join(path_join(path_join("target", "cache"), "test-link-v1"), key);
  let cpath: String = path_join(path_join(path_join("target", "cache"), "test-pkg-obj-v1"), key).concat(".c");
  let obj: String = path_join(path_join(path_join("target", "cache"), "test-pkg-obj-v1"), key).concat(".o");
  let bin: String = out;
  fs.mkdir_p(dir_name(cpath));
  fs.mkdir_p(dir_name(bin));
  fs.write_string(cpath, "/*c*/");
  fs.write_string(obj, "obj");
  fs.write_string(bin, "bin");
  let mut compiled: Vec[String] = Vec();
  compiled.push("root.test_a");
  compiled.push("root.test_b");
  compiled = write_test_build_cache_with_tests(out, key, compiled);

  let mut need_a: Vec[String] = Vec();
  need_a.push("root.test_a");
  let hit_a: TestBuildCacheStateResult = test_build_cache_state_with_tests(out, key, cpath, obj, bin, need_a);
  t.assert(hit_a.c_hit);
  t.assert(hit_a.obj_hit);
  t.assert(hit_a.hit);

  let mut need_c: Vec[String] = Vec();
  need_c.push("root.test_c");
  t.assert(!test_build_cache_state_with_tests(out, key, cpath, obj, bin, need_c).hit);
}

fn test_test_build_cache_state_backfills_missing_meta_smoke() -> () {
  let key: String = build_cache_test_unused_key_for_test_cache("test-state-backfill-meta");
  let out: String = path_join(path_join(path_join("target", "cache"), "test-link-v1"), key);
  let cpath: String = path_join(path_join(path_join("target", "cache"), "test-pkg-obj-v1"), key).concat(".c");
  let obj: String = path_join(path_join(path_join("target", "cache"), "test-pkg-obj-v1"), key).concat(".o");
  let bin: String = out;
  fs.mkdir_p(dir_name(cpath));
  fs.mkdir_p(dir_name(bin));
  fs.write_string(cpath, "/*c*/");
  fs.write_string(obj, "obj");
  fs.write_string(bin, "bin");
  let mut compiled: Vec[String] = Vec();
  compiled.push("root.test_a");
  let formatted: FormatTestsResult = format_test_build_cache_tests_with_tests(compiled);
  compiled = formatted.tests;
  fs.write_string(out.concat(".test.cache.tests"), formatted.text);
  t.assert_eq(compiled.len(), 1);
  let meta: String = out.concat(".test.cache.key");
  t.assert(!fs.exists(meta));
  let mut need_a: Vec[String] = Vec();
  need_a.push("root.test_a");
  let st: TestBuildCacheStateResult = test_build_cache_state_with_tests(out, key, cpath, obj, bin, need_a);
  t.assert(st.c_hit);
  t.assert(st.obj_hit);
  t.assert(st.hit);
  t.assert(fs.exists(meta));
  t.assert_eq(fs.read_to_string(meta), key.concat("\n"));
}

fn test_test_build_cache_state_c_hit_without_bin_smoke() -> () {
  let mut key: String = "test-key-c-hit-no-bin";
  let mut i: i32 = 0;
  while i < 2048 {
    let cand: String = "test-key-c-hit-no-bin-".concat(i.to_string());
    if !fs.exists(path_join(path_join(path_join("target", "cache"), "test-pkg-obj-v1"), cand).concat(".c")) && !fs.exists(path_join(path_join(path_join("target", "cache"), "test-pkg-obj-v1"), cand).concat(".o")) && !fs.exists(path_join(path_join(path_join("target", "cache"), "test-pkg-obj-v1"), cand).concat(".obj")) && !fs.exists(path_join(path_join(path_join("target", "cache"), "test-link-v1"), cand)) {
      key = cand;
      i = 2048;
    } else {
      i = i + 1;
    }
  }
  let out: String = path_join(path_join(path_join("target", "cache"), "test-link-v1"), key);
  let cpath: String = path_join(path_join(path_join("target", "cache"), "test-pkg-obj-v1"), key).concat(".c");
  let obj: String = path_join(path_join(path_join("target", "cache"), "test-pkg-obj-v1"), key).concat(".o");
  let bin: String = out;
  fs.mkdir_p(dir_name(cpath));
  fs.write_string(cpath, "/*c*/");
  fs.write_string(obj, "obj");
  let mut compiled: Vec[String] = Vec();
  compiled.push("root.test_a");
  compiled = write_test_build_cache_with_tests(out, key, compiled);
  t.assert(!fs.exists(bin));

  let mut need_a: Vec[String] = Vec();
  need_a.push("root.test_a");
  let st: TestBuildCacheStateResult = test_build_cache_state_with_tests(out, key, cpath, obj, bin, need_a);
  t.assert(st.c_hit);
  t.assert(st.obj_hit);
  t.assert(!st.hit);
  t.assert_eq(st.selected.len(), 1);
}

fn test_test_build_cache_paths_use_split_link_and_obj_roots() -> () {
  let key: String = "k";
  t.assert(text_contains(path_join(path_join(path_join("target", "cache"), "test-link-v1"), key), "test-link-v1"));
  t.assert(text_contains(path_join(path_join(path_join("target", "cache"), "test-pkg-obj-v1"), key).concat(".c"), "test-pkg-obj-v1"));
  t.assert(text_contains(path_join(path_join(path_join("target", "cache"), "test-pkg-obj-v1"), key).concat(".o"), "test-pkg-obj-v1"));
}

fn test_test_build_cache_state_c_hit_without_obj_and_bin_smoke() -> () {
  let key: String = build_cache_test_unused_key_for_test_cache("test-key-c-hit-no-obj-no-bin");
  let out: String = path_join(path_join(path_join("target", "cache"), "test-link-v1"), key);
  let cpath: String = path_join(path_join(path_join("target", "cache"), "test-pkg-obj-v1"), key).concat(".c");
  let obj: String = path_join(path_join(path_join("target", "cache"), "test-pkg-obj-v1"), key).concat(".o");
  let bin: String = out;
  fs.mkdir_p(dir_name(cpath));
  fs.write_string(cpath, "/*c*/");
  let mut compiled: Vec[String] = Vec();
  compiled.push("root.test_a");
  compiled = write_test_build_cache_with_tests(out, key, compiled);
  let mut need: Vec[String] = Vec();
  need.push("root.test_a");
  let st: TestBuildCacheStateResult = test_build_cache_state_with_tests(out, key, cpath, obj, bin, need);
  t.assert(st.c_hit);
  t.assert(!st.obj_hit);
  t.assert(!st.hit);
}

fn test_test_build_no_cache_paths_smoke() -> () {
  let out: String = "target/debug/demo";
  let selected0: Vec[String] = cache_test_selected_tests_basic();
  let selected1: Vec[String] = cache_test_selected_tests_basic();
  let no_cache_out0: String = test_nocache_out_path(out, selected0, "", "", "", false, 0);
  let no_cache_out1: String = test_nocache_out_path(out, selected1, "", "", "", false, 0);
  t.assert(txt.has_prefix(no_cache_out0, "target/debug/demo.test.nocache."));
  t.assert(txt.has_prefix(no_cache_out1, "target/debug/demo.test.nocache."));
  t.assert(no_cache_out0 != no_cache_out1);
  t.assert(txt.has_suffix(no_cache_out0.concat(".c"), ".c"));
}

fn test_test_nocache_output_key_changes_with_selection_smoke() -> () {
  let k0: String = test_nocache_output_key(cache_test_selected_tests_basic(), "", "", "", false, 0);
  let k1: String = test_nocache_output_key(cache_test_selected_tests_basic(), "", "*focus*", "", false, 0);
  let k2: String = test_nocache_output_key(cache_test_selected_tests_basic(), "", "", "needle", false, 0);
  let k3: String = test_nocache_output_key(cache_test_selected_tests_basic(), "", "", "", true, 3);
  t.assert(k0 != "");
  t.assert(k0 != k1);
  t.assert(k0 != k2);
  t.assert(k0 != k3);
}

fn test_failed_tests_path_isolated_by_out_smoke() -> () {
  let p0: String = failed_tests_path("target/debug/demo-a");
  let p1: String = failed_tests_path("target/debug/demo-b");
  let p2: String = failed_tests_path("target/debug/demo-a");
  t.assert(txt.has_prefix(p0, "target/debug/.vox_last_failed_tests."));
  t.assert(txt.has_suffix(p0, ".json"));
  t.assert(p0 != p1);
  t.assert_eq(p0, p2);
}

fn test_write_failed_tests_isolated_by_out_smoke() -> () {
  let out0: String = "target/debug/demo-failed-a";
  let out1: String = "target/debug/demo-failed-b";
  let p0: String = failed_tests_path(out0);
  let p1: String = failed_tests_path(out1);
  let mut failed0: Vec[String] = Vec();
  failed0.push("root.test_a");
  failed0.push("root.test_b");
  let mut failed1: Vec[String] = Vec();
  failed1.push("root.test_c");
  let canon0: Vec[String] = write_failed_tests(out0, failed0);
  let canon1: Vec[String] = write_failed_tests(out1, failed1);
  t.assert_eq(canon0.len(), 2);
  t.assert_eq(canon1.len(), 1);
  t.assert(fs.exists(p0));
  t.assert(fs.exists(p1));
  let text0: String = fs.read_to_string(p0);
  let text1: String = fs.read_to_string(p1);
  t.assert(index_of_from(text0, "\"root.test_a\"", 0) >= 0);
  t.assert(index_of_from(text0, "\"root.test_b\"", 0) >= 0);
  t.assert(index_of_from(text0, "\"root.test_c\"", 0) < 0);
  t.assert(index_of_from(text1, "\"root.test_c\"", 0) >= 0);
  t.assert(index_of_from(text1, "\"root.test_a\"", 0) < 0);
}
