fn test_build_cache_try_reuse_sem_cached_c_with_source_sig_hit_smoke() -> () {
  let sem_key: String = build_cache_test_unused_key("sem-reuse-build-hit-sem");
  let cached_key: String = build_cache_test_unused_key("sem-reuse-build-hit-cached");
  let out_key: String = build_cache_test_unused_key("sem-reuse-build-hit-out");
  t.assert(cached_key != out_key);
  let cached_cpath: String = build_cache_obj_path_for_key(cached_key, ".c");
  fs.mkdir_p(dir_name(cached_cpath));
  fs.write_string(cached_cpath, "/*sem cached c hit*/");
  let source_sig: String = "source-sig-build-hit";
  write_build_sem_cache_c_ref(sem_key, cached_key, source_sig);
  let out_cpath: String = build_cache_obj_path_for_key(out_key, ".c");
  t.assert(!fs.exists(out_cpath));
  t.assert(build_cache_try_reuse_sem_cached_c_with_source_sig(sem_key, out_key, source_sig, out_cpath, false));
  t.assert(fs.exists(out_cpath));
  t.assert_eq(fs.read_to_string(out_cpath), "/*sem cached c hit*/");
}

fn test_build_cache_try_reuse_sem_cached_c_with_source_sig_mismatch_smoke() -> () {
