fn test_build_cache_source_sig_with_c_sig_tracks_c_changes_smoke() -> () {
  let fs0: Vec[ld.SourceFile] = build_cache_test_files_with_mixed_sources("fn main() -> i32 { return 1; }", "int helper() { return 1; }");
  let fs1: Vec[ld.SourceFile] = build_cache_test_files_with_mixed_sources("fn main() -> i32 { return 1; }", "int helper() { return 2; }");
