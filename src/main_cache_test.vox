fn build_cache_test_files_ab() -> Vec[ld.SourceFile] {
  let mut xs: Vec[ld.SourceFile] = Vec();
  xs.push(ld.SourceFile { path: "src/b.vox", text: "fn b() -> i32 { return 2; }" });
  xs.push(ld.SourceFile { path: "src/a.vox", text: "fn a() -> i32 { return 1; }" });
  return xs;
}

fn build_cache_test_files_main_and_dep() -> Vec[ld.SourceFile] {
  let mut xs: Vec[ld.SourceFile] = Vec();
  xs.push(ld.SourceFile { path: "src/a.vox", text: "fn a() -> i32 { return 1; }" });
  xs.push(ld.SourceFile { path: "dep/src/lib.vox", text: "fn dep() -> i32 { return 7; }" });
  return xs;
}

fn build_cache_test_files_with_mixed_sources(vox_text: String, c_text: String) -> Vec[ld.SourceFile] {
  let mut xs: Vec[ld.SourceFile] = Vec();
  xs.push(ld.SourceFile { path: "src/main.vox", text: vox_text });
  xs.push(ld.SourceFile { path: "src/runtime/helper.c", text: c_text });
  return xs;
}

fn build_cache_test_files_with_mixed_sources_c_first(vox_text: String, c_text: String) -> Vec[ld.SourceFile] {
  let mut xs: Vec[ld.SourceFile] = Vec();
  xs.push(ld.SourceFile { path: "src/00_helper.c", text: c_text });
  xs.push(ld.SourceFile { path: "src/main.vox", text: vox_text });
  return xs;
}

fn build_cache_test_sem_deps_main_dep() -> Vec[q.ParseLoadDepHash] {
  let mut out: Vec[q.ParseLoadDepHash] = Vec();
  out.push(q.ParseLoadDepHash { pkg: "main", export_sig_hash: "101", type_sig_hash: "101", impl_sig_hash: "101" });
  out.push(q.ParseLoadDepHash { pkg: "pkg/dep", export_sig_hash: "202", type_sig_hash: "202", impl_sig_hash: "202" });
  return out;
}

fn pkg_key_for_pkg(xs: Vec[BuildCachePkgKey], pkg: String) -> String {
  let mut i: i32 = 0;
  while i < xs.len() {
    let x: BuildCachePkgKey = xs.get(i);
    if x.pkg == pkg { return x.key; }
    i = i + 1;
  }
  return "";
}

fn build_cache_test_pkg_keys_with_mode(files0: Vec[ld.SourceFile], mode: String) -> Vec[BuildCachePkgKey] {
  let h0: u64 = build_cache_pkg_hash_for_mode_prefix(mode);
  let pkg_source_keys: Vec[BuildCachePkgKey] = build_cache_pkg_source_keys_with_files(files0).keys;
  let mut out: Vec[BuildCachePkgKey] = Vec();
  let mut i: i32 = 0;
  while i < pkg_source_keys.len() {
    out.push(build_cache_pkg_key_from_source_hash_prefix(pkg_source_keys.get(i), h0));
    i = i + 1;
  }
  return out;
}

fn build_cache_test_obj_hit(key: String, cpath: String, obj: String) -> bool {
  return build_cache_c_hit(key, cpath) && fs.exists(obj);
}

fn build_cache_test_key_from_pkg_source_keys(pkg_source_keys0: Vec[BuildCachePkgKey], mode: String) -> String {
  let mut h: u64 = build_cache_hash_for_mode_prefix(mode);
  let h0: u64 = build_cache_pkg_hash_for_mode_prefix(mode);
  let mut i: i32 = 0;
  while i < pkg_source_keys0.len() {
    let pk: BuildCachePkgKey = build_cache_pkg_key_from_source_hash_prefix(pkg_source_keys0.get(i), h0);
    h = lock_hash_text(h, "P\n");
    h = lock_hash_text(h, pk.pkg);
    h = lock_hash_text(h, "\n");
    h = lock_hash_text(h, pk.key);
    h = lock_hash_text(h, "\n");
    i = i + 1;
  }
  return h.to_string();
}

fn cache_test_build_test_key_from_pkg_source_keys(pkg_source_keys0: Vec[BuildCachePkgKey], mode: String) -> String {
  let mut h: u64 = 1469598103934665603 as u64;
  h = lock_hash_text(h, "test-build-cache-v5\n");
  h = lock_hash_text(h, if host_is_windows() { "windows\n" } else { "posix\n" });
  h = lock_hash_text(h, mode);
  h = lock_hash_text(h, "\n");
  let h0: u64 = build_cache_pkg_hash_for_mode_prefix("test-build\n".concat(mode));
  let mut i: i32 = 0;
  while i < pkg_source_keys0.len() {
    let pk: BuildCachePkgKey = build_cache_pkg_key_from_source_hash_prefix(pkg_source_keys0.get(i), h0);
    h = lock_hash_text(h, "P\n");
    h = lock_hash_text(h, pk.pkg);
    h = lock_hash_text(h, "\n");
    h = lock_hash_text(h, pk.key);
    h = lock_hash_text(h, "\n");
    i = i + 1;
  }
  return h.to_string();
}

fn build_cache_test_sem_key_from_files(files0: Vec[ld.SourceFile], sem_mode: String) -> String {
  let split: BuildCachePkgSemSourceKeysResult = build_cache_pkg_sem_source_keys_with_files(files0);
  return build_cache_sem_key_from_pkg_source_keys(split.sem_keys, sem_mode);
}

struct BuildCacheTestKeyTriple {
  compile_key: String,
  link_key: String,
  sem_key: String,
}

struct BuildCacheTestKeyTripleKeep {
  keys: Vec[BuildCachePkgKey],
  triple: BuildCacheTestKeyTriple,
}

fn build_cache_test_key_triple_from_pkg_source_keys_keep(
  pkg_source_keys0: Vec[BuildCachePkgKey],
  compile_mode: String,
  link_mode: String,
  sem_mode: String,
) -> BuildCacheTestKeyTripleKeep {
  let pkg_source_keys: Vec[BuildCachePkgKey] = pkg_source_keys0;
  let mut compile_h: u64 = build_cache_hash_for_mode_prefix(compile_mode);
  let mut link_h: u64 = build_cache_hash_for_mode_prefix(link_mode);
  let mut sem_h: u64 = build_cache_hash_for_mode_prefix(sem_mode);
  let compile_h0: u64 = build_cache_pkg_hash_for_mode_prefix(compile_mode);
  let link_h0: u64 = build_cache_pkg_hash_for_mode_prefix(link_mode);
  let sem_h0: u64 = build_cache_pkg_hash_for_mode_prefix(sem_mode);

  let mut i: i32 = 0;
  while i < pkg_source_keys.len() {
    let cpk: BuildCachePkgKey = build_cache_pkg_key_from_source_hash_prefix(pkg_source_keys.get(i), compile_h0);
    compile_h = lock_hash_text(compile_h, "P\n");
    compile_h = lock_hash_text(compile_h, cpk.pkg);
    compile_h = lock_hash_text(compile_h, "\n");
    compile_h = lock_hash_text(compile_h, cpk.key);
    compile_h = lock_hash_text(compile_h, "\n");

    let lpk: BuildCachePkgKey = build_cache_pkg_key_from_source_hash_prefix(pkg_source_keys.get(i), link_h0);
    link_h = lock_hash_text(link_h, "P\n");
    link_h = lock_hash_text(link_h, lpk.pkg);
    link_h = lock_hash_text(link_h, "\n");
    link_h = lock_hash_text(link_h, lpk.key);
    link_h = lock_hash_text(link_h, "\n");

    let spk: BuildCachePkgKey = build_cache_pkg_key_from_source_hash_prefix(pkg_source_keys.get(i), sem_h0);
    sem_h = lock_hash_text(sem_h, "P\n");
    sem_h = lock_hash_text(sem_h, spk.pkg);
    sem_h = lock_hash_text(sem_h, "\n");
    sem_h = lock_hash_text(sem_h, spk.key);
    sem_h = lock_hash_text(sem_h, "\n");
    i = i + 1;
  }

  return BuildCacheTestKeyTripleKeep {
    keys: pkg_source_keys,
    triple: BuildCacheTestKeyTriple {
      compile_key: compile_h.to_string(),
      link_key: link_h.to_string(),
      sem_key: sem_h.to_string(),
    },
  };
}

fn build_cache_test_unused_key(prefix: String) -> String {
  let mut i: i32 = 0;
  while i < 2048 {
    let key: String = prefix.concat("-").concat(i.to_string());
    if !fs.exists(build_cache_obj_path_for_key(key, ".c")) {
      return key;
    }
    i = i + 1;
  }
  panic("build_cache_test_unused_key: no unused key for prefix '".concat(prefix).concat("' after 2048 attempts"));
}

fn build_cache_test_unused_output_copy_path(prefix: String) -> String {
  let mut i: i32 = 0;
  while i < 2048 {
    let out_path: String = build_cache_obj_path_for_key(prefix.concat("-").concat(i.to_string()), ".out.c");
    if !fs.exists(out_path) && !fs.exists(out_path.concat(".build.copy.key")) {
      return out_path;
    }
    i = i + 1;
  }
  panic("build_cache_test_unused_output_copy_path: no unused path for prefix '".concat(prefix).concat("' after 2048 attempts"));
}

fn build_cache_test_unused_key_for_test_cache(prefix: String) -> String {
  let mut i: i32 = 0;
  while i < 2048 {
    let key: String = prefix.concat("-").concat(i.to_string());
    let cpath: String = path_join(path_join(path_join("target", "cache"), "test-pkg-obj-v1"), key).concat(".c");
    let obj_o: String = path_join(path_join(path_join("target", "cache"), "test-pkg-obj-v1"), key).concat(".o");
    let obj_obj: String = path_join(path_join(path_join("target", "cache"), "test-pkg-obj-v1"), key).concat(".obj");
    let out: String = path_join(path_join(path_join("target", "cache"), "test-link-v1"), key);
    if !fs.exists(cpath) && !fs.exists(obj_o) && !fs.exists(obj_obj) && !fs.exists(out) && !fs.exists(out.concat(".exe")) {
      return key;
    }
    i = i + 1;
  }
  panic("build_cache_test_unused_key_for_test_cache: no unused key for prefix '".concat(prefix).concat("' after 2048 attempts"));
}

fn test_build_cache_enabled_from_env_smoke() -> () {
  t.assert(build_cache_enabled_from_env(""));
  t.assert(build_cache_enabled_from_env("0"));
  t.assert(build_cache_enabled_from_env("false"));
  t.assert(!build_cache_enabled_from_env("1"));
  t.assert(!build_cache_enabled_from_env("true"));
  t.assert(!build_cache_enabled_from_env("on"));
}

fn test_build_cache_pkg_from_source_path_smoke() -> () {
  let mut main_files: Vec[ld.SourceFile] = Vec();
  main_files.push(ld.SourceFile { path: "src/main.vox", text: "" });
  let main_order: SourceFilePkgOrderResult = source_file_order_by_pkg_path_with_files(main_files);
  t.assert_eq(main_order.pkgs.len(), 1);
  t.assert_eq(main_order.pkgs.get(0), "main");

  let mut dep_files: Vec[ld.SourceFile] = Vec();
  dep_files.push(ld.SourceFile { path: "dep/src/lib.vox", text: "" });
  let dep_order: SourceFilePkgOrderResult = source_file_order_by_pkg_path_with_files(dep_files);
  t.assert_eq(dep_order.pkgs.len(), 1);
  t.assert_eq(dep_order.pkgs.get(0), "pkg/dep");

  let mut foo_files: Vec[ld.SourceFile] = Vec();
  foo_files.push(ld.SourceFile { path: "foo/src/lib.vox", text: "" });
  let foo_order: SourceFilePkgOrderResult = source_file_order_by_pkg_path_with_files(foo_files);
  t.assert_eq(foo_order.pkgs.len(), 1);
  t.assert_eq(foo_order.pkgs.get(0), "pkg/foo");
}

fn test_should_skip_query_shadow_prepare_smoke() -> () {
  t.assert(!should_skip_query_shadow_prepare(false, false, false));
  t.assert(!should_skip_query_shadow_prepare(false, true, false));
  t.assert(!should_skip_query_shadow_prepare(true, false, false));
  t.assert(!should_skip_query_shadow_prepare(true, true, true));
  t.assert(should_skip_query_shadow_prepare(true, true, false));
}

fn test_should_use_sem_cache_smoke() -> () {
  t.assert(!should_use_sem_cache(false, false));
  t.assert(!should_use_sem_cache(false, true));
  t.assert(should_use_sem_cache(true, false));
  t.assert(should_use_sem_cache(true, true));
}

fn test_sort_strings_if_needed_smoke() -> () {
  let mut sorted: Vec[String] = Vec();
  sorted.push("a");
  sorted.push("b");
  sorted.push("c");
  let sorted_out: Vec[String] = sort_strings_if_needed(sorted);
  t.assert_eq(sorted_out.len(), 3);
  t.assert_eq(sorted_out.get(0), "a");
  t.assert_eq(sorted_out.get(1), "b");
  t.assert_eq(sorted_out.get(2), "c");

  let mut unsorted: Vec[String] = Vec();
  unsorted.push("b");
  unsorted.push("a");
  unsorted.push("c");
  let unsorted_out: Vec[String] = sort_strings_if_needed(unsorted);
  t.assert_eq(unsorted_out.len(), 3);
  t.assert_eq(unsorted_out.get(0), "a");
  t.assert_eq(unsorted_out.get(1), "b");
  t.assert_eq(unsorted_out.get(2), "c");
}

