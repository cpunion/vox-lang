fn test_load_files_with_cached_reuses_discovery_text_smoke() -> () {
  let mut paths: Vec[String] = Vec();
  paths.push("target/tmp/nonexistent_discovery_cache_test.vox");
  let mut cached: Vec[ld.SourceFile] = Vec();
  cached.push(ld.SourceFile { path: "target/tmp/nonexistent_discovery_cache_test.vox", text: "fn test_cached() -> () {}\n" });
  let loaded: Vec[ld.SourceFile] = load_files_with_cached(paths, cached);
  t.assert_eq(loaded.len(), 1);
  t.assert_eq(loaded.get(0).path, "target/tmp/nonexistent_discovery_cache_test.vox");
  t.assert_eq(loaded.get(0).text, "fn test_cached() -> () {}\n");
}

fn test_load_files_with_cached_handles_unsorted_cache_and_disk_fallback_smoke() -> () {
  fs.mkdir_p("target/tmp");
  fs.write_string("target/tmp/load_files_with_cached_disk_fallback.vox", "fn test_disk_fallback() -> () {}\n");

  let mut paths: Vec[String] = Vec();
  paths.push("target/tmp/nonexistent_cached_b.vox");
  paths.push("target/tmp/load_files_with_cached_disk_fallback.vox");
  paths.push("target/tmp/nonexistent_cached_a.vox");

  let mut cached: Vec[ld.SourceFile] = Vec();
  cached.push(ld.SourceFile { path: "target/tmp/nonexistent_cached_b.vox", text: "fn test_cached_b() -> () {}\n" });
  cached.push(ld.SourceFile { path: "target/tmp/nonexistent_cached_a.vox", text: "fn test_cached_a() -> () {}\n" });

  let loaded: Vec[ld.SourceFile] = load_files_with_cached(paths, cached);
  t.assert_eq(loaded.len(), 3);
  t.assert_eq(loaded.get(0).text, "fn test_cached_b() -> () {}\n");
  t.assert_eq(loaded.get(1).text, "fn test_disk_fallback() -> () {}\n");
  t.assert_eq(loaded.get(2).text, "fn test_cached_a() -> () {}\n");
}

fn test_source_file_path_index_order_keeps_sorted_input_smoke() -> () {
  let mut cached: Vec[ld.SourceFile] = Vec();
  cached.push(ld.SourceFile { path: "src/a_test.vox", text: "fn test_a() -> () {}\n" });
  cached.push(ld.SourceFile { path: "src/b_test.vox", text: "fn test_b() -> () {}\n" });
  cached.push(ld.SourceFile { path: "src/c_test.vox", text: "fn test_c() -> () {}\n" });
  let ordered: SourceFilePathIndexOrderResult = source_file_path_index_order(cached);
  t.assert(ordered.sorted);
  t.assert_eq(ordered.order.len(), 3);
  t.assert_eq(ordered.order.get(0), 0);
  t.assert_eq(ordered.order.get(1), 1);
  t.assert_eq(ordered.order.get(2), 2);
}

fn test_source_file_path_index_order_marks_unsorted_input_smoke() -> () {
  let mut cached: Vec[ld.SourceFile] = Vec();
  cached.push(ld.SourceFile { path: "src/b_test.vox", text: "fn test_b() -> () {}\n" });
  cached.push(ld.SourceFile { path: "src/a_test.vox", text: "fn test_a() -> () {}\n" });
  let ordered: SourceFilePathIndexOrderResult = source_file_path_index_order(cached);
  t.assert(!ordered.sorted);
}

fn test_source_file_order_by_pkg_path_with_files_keeps_sorted_input_smoke() -> () {
  let mut files: Vec[ld.SourceFile] = Vec();
  files.push(ld.SourceFile { path: "pkg/a/src/a.vox", text: "fn a() -> i32 { return 1; }\n" });
  files.push(ld.SourceFile { path: "pkg/a/src/b.vox", text: "fn b() -> i32 { return 2; }\n" });
  files.push(ld.SourceFile { path: "pkg/b/src/a.vox", text: "fn c() -> i32 { return 3; }\n" });
  let ordered: SourceFilePkgOrderResult = source_file_order_by_pkg_path_with_files(files);
  t.assert_eq(ordered.order.len(), 3);
  t.assert_eq(ordered.order.get(0), 0);
  t.assert_eq(ordered.order.get(1), 1);
  t.assert_eq(ordered.order.get(2), 2);
}

fn test_source_file_order_by_pkg_path_with_files_sorts_unsorted_input_smoke() -> () {
  let mut files: Vec[ld.SourceFile] = Vec();
  files.push(ld.SourceFile { path: "pkg/a/src/b.vox", text: "fn b() -> i32 { return 2; }\n" });
  files.push(ld.SourceFile { path: "pkg/a/src/a.vox", text: "fn a() -> i32 { return 1; }\n" });
  let ordered: SourceFilePkgOrderResult = source_file_order_by_pkg_path_with_files(files);
  t.assert_eq(ordered.order.len(), 2);
  t.assert_eq(ordered.order.get(0), 1);
  t.assert_eq(ordered.order.get(1), 0);
}

fn test_discover_tests_from_cached_test_files_smoke() -> () {
  let mut paths: Vec[String] = Vec();
  paths.push("target/tmp/nonexistent_discovery_cached_parse_test.vox");
  let mut cached: Vec[ld.SourceFile] = Vec();
  cached.push(
    ld.SourceFile {
      path: "target/tmp/nonexistent_discovery_cached_parse_test.vox",
      text: "fn helper() -> () {}\nfn test_cached_discovery() -> () {}\n",
    },
  );
  let discovered: DiscoverTestsResult = discover_tests_from_cached_test_files(paths, cached);
  t.assert_eq(discovered.tests.len(), 1);
  t.assert(text_contains(discovered.tests.get(0), "test_cached_discovery"));
  t.assert_eq(discovered.cached_files.len(), 1);
  t.assert_eq(discovered.cached_files.get(0).path, "target/tmp/nonexistent_discovery_cached_parse_test.vox");
}

fn test_discover_tests_cached_with_paths_cache_hit_keeps_cached_files_smoke() -> () {
  fs.mkdir_p("tests/tmp");
  fs.write_string("tests/tmp/discover_cache_hit_keep_files_test.vox", "fn test_cached_hit_keeps_files() -> () {}\n");

  let mut key_paths: Vec[String] = Vec();
  key_paths.push("tests/tmp/discover_cache_hit_keep_files_test.vox");
  let key: String = cache_test_discover_tests_key_from_paths(key_paths);

  fs.mkdir_p("target/debug");
  fs.write_string("target/debug/.vox_test_discover.key", key.concat("\n"));
  fs.write_string("target/debug/.vox_test_discover.list", "main::test_cached_hit_keeps_files\n");

  let mut paths: Vec[String] = Vec();
  paths.push("tests/tmp/discover_cache_hit_keep_files_test.vox");
  let discovered: DiscoverTestsResult = discover_tests_cached_with_paths(paths);
  t.assert_eq(discovered.tests.len(), 1);
  t.assert_eq(discovered.cached_files.len(), 1);
  t.assert_eq(discovered.cached_files.get(0).path, "tests/tmp/discover_cache_hit_keep_files_test.vox");
  t.assert_eq(discovered.cached_files.get(0).text, "fn test_cached_hit_keeps_files() -> () {}\n");
}

fn test_hidden_source_path_smoke() -> () {
  t.assert(is_hidden_source_path(".tmp.c"));
  t.assert(is_hidden_source_path("src/.tmp.c"));
  t.assert(is_hidden_source_path("src/std/.cache/rt.c"));
  t.assert(!is_hidden_source_path("src/./main.c"));
  t.assert(!is_hidden_source_path("src/foo/../bar.c"));
  t.assert(!is_hidden_source_path("src/std/runtime/rt.c"));
}

fn test_filter_pkg_c_sources_skips_hidden_smoke() -> () {
  let mut xs: Vec[String] = Vec();
  xs.push("src/std/runtime/rt.c");
  xs.push("src/.tmp.c");
  xs.push("src/std/.cache/rt.c");
  xs.push("tests/helper.c");
  let ys: Vec[String] = filter_pkg_c_sources(xs);
  t.assert_eq(ys.len(), 1);
  t.assert_eq(ys.get(0), "src/std/runtime/rt.c");
}

fn test_build_cache_key_is_order_stable() -> () {
  let k0: String = build_cache_test_key_from_pkg_source_keys(build_cache_pkg_source_keys_with_files(build_cache_test_files_ab()).keys, "cmd=build");
  let k1: String = build_cache_test_key_from_pkg_source_keys(build_cache_pkg_source_keys_with_files(build_cache_test_files_ba()).keys, "cmd=build");
  t.assert_eq(k0, k1);
}

fn test_build_cache_key_changes_with_mode() -> () {
  let k0: String = build_cache_test_key_from_pkg_source_keys(build_cache_pkg_source_keys_with_files(build_cache_test_files_ab()).keys, "cmd=build\ntarget=darwin-arm64");
  let k1: String = build_cache_test_key_from_pkg_source_keys(build_cache_pkg_source_keys_with_files(build_cache_test_files_ab()).keys, "cmd=build\ntarget=linux-amd64");
  t.assert(k0 != k1);
}

