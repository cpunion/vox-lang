import "std/testing" as t

fn test_main_legacy_runtime_text_truthy_smoke() -> () {
  t.assert(text_truthy("1"));
  t.assert(text_truthy(" true "));
  t.assert(text_truthy("YES"));
  t.assert(text_truthy("On"));
  t.assert(!text_truthy(""));
  t.assert(!text_truthy("0"));
  t.assert(!text_truthy("false"));
  t.assert(!text_truthy("no"));
  t.assert(!text_truthy("off"));
}

fn test_main_is_legacy_runtime_c_source_path_smoke() -> () {
  t.assert(is_legacy_runtime_c_source_path("src/vox/bootstrap/legacy_runtime/_preamble.c"));
  t.assert(is_legacy_runtime_c_source_path("src/vox/bootstrap/legacy_runtime/rt_core.c"));
  t.assert(is_legacy_runtime_c_source_path("src/vox/bootstrap/legacy_runtime/rt_atomic.c"));
  t.assert(!is_legacy_runtime_c_source_path("src/vox/bootstrap/legacy_runtime/rt_str.c"));
  t.assert(!is_legacy_runtime_c_source_path("src/std/sys/sys_linux.vox"));
}

fn test_main_filter_pkg_c_sources_without_legacy_runtime_smoke() -> () {
  let mut xs: Vec[String] = Vec();
  xs.push("src/a.c");
  xs.push("src/vox/bootstrap/legacy_runtime/_preamble.c");
  xs.push("src/.hidden/drop.c");
  xs.push("tools/x.c");
  xs.push("src/vox/bootstrap/legacy_runtime/rt_core.c");
  xs.push("src/vox/bootstrap/legacy_runtime/rt_atomic.c");
  xs.push("src/z.c");

  let ys: Vec[String] = filter_pkg_c_sources_with_legacy(xs, false);
  t.assert_eq(ys.len(), 2);
  t.assert_eq(ys.get(0), "src/a.c");
  t.assert_eq(ys.get(1), "src/z.c");
}

fn test_main_filter_pkg_c_sources_with_legacy_runtime_smoke() -> () {
  let mut xs: Vec[String] = Vec();
  xs.push("src/a.c");
  xs.push("src/vox/bootstrap/legacy_runtime/_preamble.c");
  xs.push("src/.hidden/drop.c");
  xs.push("tools/x.c");
  xs.push("src/vox/bootstrap/legacy_runtime/rt_core.c");
  xs.push("src/vox/bootstrap/legacy_runtime/rt_atomic.c");
  xs.push("src/z.c");

  let ys: Vec[String] = filter_pkg_c_sources_with_legacy(xs, true);
  t.assert_eq(ys.len(), 5);
  t.assert_eq(ys.get(0), "src/a.c");
  t.assert_eq(ys.get(1), "src/vox/bootstrap/legacy_runtime/_preamble.c");
  t.assert_eq(ys.get(2), "src/vox/bootstrap/legacy_runtime/rt_core.c");
  t.assert_eq(ys.get(3), "src/vox/bootstrap/legacy_runtime/rt_atomic.c");
  t.assert_eq(ys.get(4), "src/z.c");
}
