import "std/testing" as t

fn test_build_module_queues_preserves_first_seen_module_order_smoke() -> () {
  let mut tests: Vec[String] = Vec();
  tests.push("beta::test_b1");
  tests.push("alpha::test_a1");
  tests.push("beta::test_b2");
  tests.push("gamma::test_g1");
  let queues: Vec[ModuleQueue] = build_module_queues(tests);

  t.assert_eq(queues.len(), 3);
  t.assert_eq(queues.get(0).module, "beta");
  t.assert_eq(queues.get(1).module, "alpha");
  t.assert_eq(queues.get(2).module, "gamma");

  t.assert_eq(queues.get(0).tests.len(), 2);
  t.assert_eq(queues.get(0).tests.get(0), "beta::test_b1");
  t.assert_eq(queues.get(0).tests.get(1), "beta::test_b2");
  t.assert_eq(queues.get(1).tests.len(), 1);
  t.assert_eq(queues.get(1).tests.get(0), "alpha::test_a1");
}

fn test_build_module_queues_groups_root_module_tests_smoke() -> () {
  let mut tests: Vec[String] = Vec();
  tests.push("test_root_a");
  tests.push("alpha::test_a1");
  tests.push("test_root_b");
  let queues: Vec[ModuleQueue] = build_module_queues(tests);

  t.assert_eq(queues.len(), 2);
  t.assert_eq(queues.get(0).module, "(root)");
  t.assert_eq(queues.get(1).module, "alpha");
  t.assert_eq(queues.get(0).tests.len(), 2);
  t.assert_eq(queues.get(0).tests.get(0), "test_root_a");
  t.assert_eq(queues.get(0).tests.get(1), "test_root_b");
}
